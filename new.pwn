	TextDrawSetShadow(SBox, 0);
	TextDrawSetOutline(SBox, 0);
	TextDrawFont(SBox, 3);

	//PAINTBALL
	BlueTeam = TextDrawCreate(510.000000, 141.000000, "TEAM BLUE:");
	TextDrawBackgroundColor(BlueTeam, 255);
	TextDrawFont(BlueTeam, 1);
	TextDrawLetterSize(BlueTeam, 0.300000, 1.000000);
