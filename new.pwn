CMD:getgun(playerid, params[])
{
	switch(PlayerInfo[playerid][pMember])
	{
	case 19:
		{
			if(GetVehicleModel(GetPlayerVehicleID(playerid)) != 470) return   SendClientMessage(playerid,COLOR_GREY,"Вы не в Хаммере!");
			if(armmatbi <= 0) return SendClientMessage(playerid,COLOR_GRAD1,"На складе нет оружия!");
			if(PlayerInfo[playerid][pGun51Time] > 0) return 	SendClientMessage(playerid,COLOR_GRAD1,"Брать оружие можно раз в 5 минут");
			GivePlayerWeapon(playerid, 30, 100);
			SetPlayerArmour(playerid, 100);
			SetPlayerHealth(playerid,100);
			armmatbi -= 500;
			PlayerInfo[playerid][pGun51Time] = 60;
			SetPlayerChatBubble(playerid,"взял оружие из багажника",COLOR_YELLOW,30.0,10000);
			SendClientMessage(playerid, COLOR_ISPOLZUY,"Вы достали из багажника: AK-47 (100), Бронижелет, Сухой паёк");
			return true;
		}
	case 3:
		{
			if(GetVehicleModel(GetPlayerVehicleID(playerid)) != 470) return   SendClientMessage(playerid,COLOR_GREY,"Вы не в Хаммере!");
			if(armmatsf <= 0) return SendClientMessage(playerid,COLOR_GRAD1,"На складе нет оружия!");
			if(PlayerInfo[playerid][pGun51Time] > 0) return 	SendClientMessage(playerid,COLOR_GRAD1,"Брать оружие можно раз в 5 минут");
			GivePlayerWeapon(playerid, 31, 100);
			SetPlayerArmour(playerid, 100);
			SetPlayerHealth(playerid,100);
			armmatsf -= 500;
			PlayerInfo[playerid][pGunaviaTime] = 60;
			SetPlayerChatBubble(playerid,"взял оружие из багажника",COLOR_YELLOW,30.0,10000);
