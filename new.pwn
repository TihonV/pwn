								HomeInfo[h][hVcol2] = 0;
								HomeInfo[h][hVehSost] = 0;
								HomeInfo[h][hMats] = 0;
								HomeInfo[h][hStyle] = 0;
								HomeInfo[h][hSost] = 0;
