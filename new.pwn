publics: LoadSBizz()
{
	static rows, fields;
	cache_get_data(rows, fields);
	new temp[64],string2[360],i=0;
	if(rows)
	{
		for(new he = 0;he < rows; he++)
		{
			cache_get_row(he, 0, temp), SBusiness[he][sID] = strval(temp);
			cache_get_row(he, 1, temp), SBusiness[he][sOwned] = strval(temp);
			cache_get_row(he, 2, temp), strmid(SBusiness[he][sOwner], temp, 0, strlen(temp), 255);
			cache_get_row(he, 3, temp), strmid(SBusiness[he][sMessage], temp, 0, strlen(temp), 255);
			cache_get_row(he, 4, temp), SBusiness[he][sEntranceX] = floatstr(temp);
			cache_get_row(he, 5, temp), SBusiness[he][sEntranceY] = floatstr(temp);
			cache_get_row(he, 6, temp), SBusiness[he][sEntranceZ] = floatstr(temp);
			cache_get_row(he, 7, temp), SBusiness[he][sBuyPrice] = strval(temp);
			cache_get_row(he, 8, temp), SBusiness[he][sLocked] = strval(temp);
			cache_get_row(he, 9, temp), SBusiness[he][sPrice] = strval(temp);
			cache_get_row(he, 10, temp), SBusiness[he][sBenz] = strval(temp);
			cache_get_row(he, 11, temp), SBusiness[he][sPriceBenz] = strval(temp);
			cache_get_row(he, 11, temp), SBusiness[he][sTill] = strval(temp);
			i++;
			if(SBusiness[he][sOwned] == 0)
			{
				SBusiness[he][sBuyPrice] = 1000000;
				SBusiness[he][sOwned] = 0;
				SBusiness[he][sLocked] = 1;
				SBusiness[he][sPrice] = 2500;
				SBusiness[he][sBenz] = 2500;
				SBusiness[he][sPriceBenz] = 2500;
				SBusiness[he][sTill] = 100000;
				format(string2, sizeof(string2), "[id %d]\n\nАЗС Штата\n''%s''\nпродается\n\nцена %d вирт\n\n[введите /buyfuel для покупки]",SBusiness[he][sID],SBusiness[he][sMessage],SBusiness[he][sBuyPrice]);
			}
			else
			{
				if(SBusiness[he][sLocked] == 0) format(string2, sizeof(string2), "{FFFF00}%s\n{FFFFFF}Владелец: {32CD32}%s\nБензин: %d/10000\nСтоимость: %d вирт.\n\n{FFFFFF}[{32CD32}Заправка работает{FFFFFF}]",SBusiness[he][sMessage],SBusiness[he][sOwner],SBusiness[he][sBenz],SBusiness[he][sPriceBenz]);
				else format(string2, sizeof(string2), "{FFFF00}%s\n{FFFFFF}Владелец: {32CD32}%s\nБензин: %d/10000\nСтоимость: %d вирт.\n\n{FFFFFF}[{FF0000}Заправка не работает{FFFFFF}]",SBusiness[he][sMessage],SBusiness[he][sOwner],SBusiness[he][sBenz],SBusiness[he][sPriceBenz]);
			}
			SBusiness[he][sLabel] = Create3DTextLabel(string2,COLOR_YELLOW,SBusiness[he][sEntranceX], SBusiness[he][sEntranceY], SBusiness[he][sEntranceZ],20.0,0,1);
			SBusiness[he][sIcon] = CreateDynamicMapIcon(SBusiness[he][sEntranceX], SBusiness[he][sEntranceY], SBusiness[he][sEntranceZ], 42, COLOR_WHITE, 0, -1, -1, 50.0);
		}
		printf("[ %d ] Заправки успешно загружены.",i);
	}
	else printf("[ERROR] Заправки не загружены.");
	return true;
}

stock SaveSBizz(houseid)
{
	new update[600],string[64];
	update = "UPDATE `"TABLE_SBIZZ"` SET ";
	acc_int_strcat(update, sizeof(update), "sOwned", SBusiness[houseid][sOwned]);
	acc_str_strcat(update, sizeof(update), "sMessage", SBusiness[houseid][sMessage]);
	acc_int_strcat(update, sizeof(update), "sBuyPrice", SBusiness[houseid][sBuyPrice]);
	acc_int_strcat(update, sizeof(update), "sLocked", SBusiness[houseid][sLocked]);
	acc_int_strcat(update, sizeof(update), "sPrice", SBusiness[houseid][sPrice]);
	acc_int_strcat(update, sizeof(update), "sBenz", SBusiness[houseid][sBenz]);
	acc_int_strcat(update, sizeof(update), "sPriceBenz", SBusiness[houseid][sPriceBenz]);
	acc_int_strcat(update, sizeof(update), "sTill", SBusiness[houseid][sTill]);
	strdel(update, strlen(update)-1, strlen(update));
	format(string,sizeof(string)," WHERE `sID` = '%d'",houseid);
	strcat(update, string);
	mysql_function_query(dbHandle, update, false, "", "");
}

stock SaveAll()
{
	for(new sb = 0; sb < sizeof(SBusiness); sb++) SaveSBizz(sb);
	for(new b = 0; b < sizeof(Business); b++) SaveBizz(b);
	return true;
}

stock SaveHousee()
{
	for(new h = 0; h < sizeof(HomeInfo); h++) SaveHouse(h);
	return true;
}
stock SellBizz(playerid)
{
	if(PlayerInfo[playerid][pPbiskey] != 255)
	{
		new bouse = PlayerInfo[playerid][pPbiskey];
		Business[bouse][bLocked] = 1;
		Business[bouse][bOwned] = 0;
		Business[bouse][bProducts] = 0;
		strmid(Business[bouse][bOwner], "The State", 0, strlen("The State"), 255);
		strmid(Business[bouse][bExtortion], "No-one", 0, strlen("No-one"), 255);
		SendClientMessage(playerid, COLOR_YELLOW2, "Бизнес успешно продан");
		SendMes(playerid,COLOR_WHITE,"- Прибыль с продажи бизнеса: %d вирт", Business[bouse][bTill]);
		SendMes(playerid,COLOR_WHITE,"- Новый счёт в банке: %d вирт", PlayerInfo[playerid][pBank]);
		SendClientMessage(playerid, COLOR_YELLOW2, "Бизнес успешно продан");
		PlayerInfo[playerid][pBank] +=Business[bouse][bTill] / 2;
		PlayerInfo[playerid][pBank] +=Business[bouse][b2Till];
		Business[bouse][bTill] = 0;
		Business[bouse][b2Till] = 0;
		format(stringer, sizeof(stringer), "{00FF32}Цена:{FEFEFE} %d\n{F5FF00}Бизнес продаётся\nДля покупки нажмите 'L.ALT'",Business[bouse][bBuyPrice]);
		Update3DTextLabelText(Business[bouse][bLabel], COLOR_YELLOW, stringer);
		SaveBizz(bouse);
		PlayerInfo[playerid][pPbiskey] = 255;
	}
	return true;
}

public OnGameModeInit()
{
