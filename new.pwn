						else if(HomeInfo[h][hValue] <= 500000 && HomeInfo[h][hValue] > 300000) { HomeInfo[h][hKlass] = 1; }
						else if(HomeInfo[h][hValue] <= 2000000 && HomeInfo[h][hValue] > 500000) { HomeInfo[h][hKlass] = 2; }
						else if(HomeInfo[h][hValue] <= 3000000 && HomeInfo[h][hValue] > 2000000) { HomeInfo[h][hKlass] = 3; }
						else if(HomeInfo[h][hValue] < 5000000 && HomeInfo[h][hValue] > 3000000) { HomeInfo[h][hKlass] = 4; }
