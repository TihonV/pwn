CMD:asetpos(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] == 12)
	{
		if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /asetpos [дом]");
		new Float: lwx, Float:lwy, Float:lwz;
		GetPlayerPos(playerid, lwx, lwy, lwz);
		HomeInfo[params[0]][hEntrancex] = lwx;
		HomeInfo[params[0]][hEntrancey]= lwy;
		HomeInfo[params[0]][hEntrancez] = lwz;
		mysql_format(dbHandle, QUERY, sizeof(QUERY), "UPDATE `"TABLE_HOUSE"` SET `hEntrancex` = '%f', `hEntrancey` = '%f', `hEntrancez` = '%f' WHERE hID = '%i'",lwx,lwy,lwz,params[0]);
		mysql_function_query(dbHandle, QUERY, false, "", "");
		BuyHouse(params[0]);
	}
	return true;
}
CMD:gmx(playerid, params[])
{
 	if(PlayerInfo[playerid][pAdmin] == 12)
