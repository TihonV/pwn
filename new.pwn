stock GetPlayer2DZone(playerid, zone[], len)
{
	new Float:x, Float:y, Float:z;
	GetPlayerPos(playerid, x, y, z);
	for(new i = 0; i != sizeof(gSAZones); i++ )
	{
		if(x >= gSAZones[i][SAZONE_AREA][0] && x <= gSAZones[i][SAZONE_AREA][3] && y >= gSAZones[i][SAZONE_AREA][1] && y <= gSAZones[i][SAZONE_AREA][4])
		{
			return format(zone, len, gSAZones[i][SAZONE_NAME], 0);
		}
	}
	return false;
}
public OnPlayerCommandPerformed(playerid, cmdtext[], success)
{
	if(FloodCheck(playerid, 0, 2, "Не флудите!") ) return false;
	if(success == -1)
	{
		SendMes(playerid, COLOR_GREY, "Ошибка: %s - данной команды не существует", cmdtext);
		SendClientMessage(playerid, COLOR_GREY, "Используйте '/mm' для просмотра команд!");
		return true;
	}
	return true;
}

public KickTimer(playerid) return GKick(playerid);

stock GKick(playerid, time = 50)
{
	if(GetPVarInt(playerid, "Kick") == -1) Kick(playerid);
	else if(!GetPVarInt(playerid, "Kick")) SetPVarInt(playerid, "Kick", SetTimerEx("KickTimer", time, 0, "d", playerid));
	else
	{
		KillTimer(GetPVarInt(playerid, "Kick"));
		SetPVarInt(playerid, "Kick", -1);
		GKick(playerid);
	}
	return 1;
}

forward GzCheck(i,napad,vlad);
public GzCheck(i,napad,vlad)
{
	PlayerForeach(m)
	{
		if(m == -1) continue;
		if(PlayerInfo[m][ppkz] == true && !IsAGang(m)) EndCapt(m);
		if(PlayerInfo[m][pMember] == napad || PlayerInfo[m][pMember] == vlad)
		{
			if(PlayerInfo[m][ppkz] == false)
			{
				GangZoneFlashForPlayer(m,GZInfo[i][gID],GetGangColor(napad));
				PlayerTextDrawShow(m, Capture[m][0]); // box
				PlayerTextDrawShow(m, Capture[m][1]); // box
				PlayerTextDrawShow(m, Capture[m][2]); // box
				PlayerTextDrawShow(m, Capture[m][3]); // time
				format(GZInfo[i][strcpt],30,"Capture Time: %s",TimeConverter(GZInfo[i][gTime]));
				PlayerTextDrawSetString(m,Capture[m][3],GZInfo[i][strcpt]);
				format(GZInfo[i][strcpt],30,"~w~%s ~r~0",GFrac(vlad));
				PlayerTextDrawSetString(m,Capture[m][5],GZInfo[i][strcpt]);
				PlayerTextDrawShow(m, Capture[m][5]);
				format(GZInfo[i][strcpt],30,"~w~%s ~r~0",GFrac(napad));
				PlayerTextDrawSetString(m,Capture[m][4],GZInfo[i][strcpt]);
				PlayerTextDrawShow(m, Capture[m][4]);
				PlayerInfo[m][ppkz] = true;
			}
			else
			{
				format(GZInfo[i][strcpt],30,"Capture Time: %s",TimeConverter(GZInfo[i][gTime]));
				PlayerTextDrawSetString(m,Capture[m][3],GZInfo[i][strcpt]);
				format(GZInfo[i][strcpt],30,"~w~%s ~r~%d",GFrac(vlad),CountOnZone[vlad]);
				PlayerTextDrawSetString(m,Capture[m][5],GZInfo[i][strcpt]);
				format(GZInfo[i][strcpt],30,"~w~%s ~r~%d",GFrac(napad),CountOnZone[napad]);
				PlayerTextDrawSetString(m,Capture[m][4],GZInfo[i][strcpt]);
			}
		}
	}
	if(GZInfo[i][gTime] > 0) GZInfo[i][gTime] -= 1;
	if(GZInfo[i][gTime] <= 0)
	{
		if(GZInfo[i][ZoneOnBattle] == 1)
		{
			new strlolka[112];
			if(CountOnZone[vlad] == CountOnZone[napad] || CountOnZone[vlad] > CountOnZone[napad]) format(strlolka,112,"%s захватили территорию у банды %s в районе %s",GFrac(vlad),GFrac(napad),GZInfo[i][GZName]);
			else
			{
				format(strlolka,112,"%s захватили территорию у банды %s в районе %s",GFrac(napad),GFrac(vlad),GZInfo[i][GZName]);
				GZInfo[i][gFrakVlad] = GZInfo[i][gNapad];
			}
			SendBand(napad,vlad,COLOR_ORANGE,strlolka);
			GZInfo[i][ZoneOnBattle] = 2;
		}
		if(GZInfo[i][ZoneOnBattle] == 2)
		{
			PlayerForeach(m)
			{
				if(m == -1) continue;
				if(PlayerInfo[m][pMember] == napad || PlayerInfo[m][pMember] == vlad) EndCapt(m);
			}
			CountOnZone[napad] = 0;
			CountOnZone[vlad] = 0;
			GZInfo[i][ZoneOnBattle] = 0;
			FracV(napad,vlad,0);
			GangZoneStopFlashForAll(GZInfo[i][gID]);
			GangZoneHideForAll(GZInfo[i][gID]);
			GangZoneShowForAll(GZInfo[i][gID],GetGangZoneColor(i));
			SaveGZ(i);
			KillTimer(GZInfo[i][gzTimer]);
			return true;
		}
	}
	return true;
}
stock EndCapt(m)
{
	PlayerTextDrawHide(m, Capture[m][0]);
	PlayerTextDrawHide(m, Capture[m][1]);
	PlayerTextDrawHide(m, Capture[m][2]);
	PlayerTextDrawHide(m, Capture[m][3]);
	PlayerTextDrawHide(m, Capture[m][4]);
	PlayerTextDrawHide(m, Capture[m][5]);
	for(new num; num < 10; num++) SendDeathMessageToPlayer(m,6000,5005, 255);
	PlayerInfo[m][ppkz] = false;
	return true;
}
stock SendDead(ids,whoids,killerid,playerid,reason)
{
	PlayerForeach(m)
	{
		if(m == -1) continue;
		if(PlayerInfo[m][pMember] == ids || PlayerInfo[m][pMember] == whoids) SendDeathMessageToPlayer(m, killerid, playerid, reason);
	}
	return true;
}
stock FracCD(one,two,item)
{
	FrakCD[one] = item;
	FrakCD[two] = item;
	FracV(one,two,1);
	return true;
}
stock FracV(one,two,item)
{
	FracVoina[one] = item;
	FracVoina[two] = item;
	return true;
}

stock SendBand(one,two,color,str[])
{
	PlayerForeach(x)
	{
		if(x == -1) continue;
		if(PlayerInfo[x][pMember] == one || PlayerInfo[x][pMember] == two)
		SendClientMessage(x,color,str);
	}
	return true;
}
stock GFrac(frac)
{
	new namegang[20];
	switch(frac)
	{
	case 15: namegang = "Grove Street";
	case 17: namegang = "Varios Los Aztecas";
	case 12: namegang = "East Side Ballas";
	case 18: namegang = "The Rifa Gang";
	case 13: namegang = "Los Santos Vagos";
	}
	return namegang;
}
stock TimeConverter(seconds)//Конвертер секунды в минуты и секунды
{
	new str[6];//объявляем символьную переменную
	new minutes = floatround(seconds/60);//кол. целых минут
	seconds -= minutes*60;  //остаток
	format(str, sizeof(str), "%02d:%02d", minutes, seconds);//преобразовываем
	return str;//возвращаем строку символов
}
stock FloodCheck(playerid,cmdid,time,message[])
{
	if(AntiFlood[playerid][cmdid] > 0)
	{
		SendClientMessage(playerid, -1, message);
		return true;
	}
	AntiFlood[playerid][cmdid] = time;
	return false;
}
stock FreezePlayerForTime(playerid,time){
	TogglePlayerControllable(playerid,false);
	return SetTimerEx( "FreezeUnfreezeTimer", time, 0, "i", playerid );
}

publics: FreezeUnfreezeTimer( playerid ) {
	return TogglePlayerControllable( playerid, true );
}
public ChainSaw(playerid)
{
	new string[32];
	SetPVarInt(playerid,"Saw",0);
	ClearAnimations(playerid);
	new rand = random(sizeof(RandomSaw));
	SetPlayerCheckpoint(playerid, RandomSaw[rand][0], RandomSaw[rand][1], RandomSaw[rand][2], 2.0);
	SetPVarInt(playerid,"Saw_",rand);
	SetPVarInt(playerid,"JobMoney",GetPVarInt(playerid,"JobMoney")+100);
	format(string,32,"~g~+100$~n~~b~TOTAL:~w~ %i$",GetPVarInt(playerid,"JobMoney"));
	GameTextForPlayer(playerid,string, 5000, 1);
	SendClientMessage(playerid,COLOR_WHITE,"Вы успешно спилили дерево, продолжайте свою работу!");
	return true;
}
public Bench(playerid)
{
	new breaking = random(GetPVarInt(playerid,"breaking"));
	ClearAnimations(playerid);
	DestroyObject(PlantObject[playerid]);
	PlantObject[playerid] = -1;
	if(breaking == 1) return GameTextForPlayer(playerid,"~r~Breaking",3000,1), ApplyAnimation(playerid,"CASINO","Roulette_lose",4.0,1,1,1,0,3000,0);
	breaking = random(12);
	if(breaking == 2)
	{
		SetPVarInt(playerid,"breaking",GetPVarInt(playerid,"breaking")+1);
		SendMes(playerid,COLOR_GREEN,"Ваш навык увеличен! Шансы создать бракованый продукт 1 из %i",GetPVarInt(playerid,"breaking"));
	}
	SetPlayerSpecialAction(playerid, SPECIAL_ACTION_CARRY);
	SetPlayerCheckpoint(playerid,2564.6721,-1292.9766,1044.1250,2.0);
	SetPVarInt(playerid,"CHECKPOINTID",5);
	SendClientMessage(playerid,COLOR_WHITE,"Вы собрали продукт, отнесите его на склад");
	SetPlayerAttachedObject(playerid, 2 , 2358, 1,0.11,0.36,0.0,0.0,90.0);
	return true;
}
stock IsAWorkbench(playerid)
{
	if(IsPlayerInRangeOfPoint(playerid, 0.2, 2558.5752,-1295.8500,1044.1250) ||
			IsPlayerInRangeOfPoint(playerid, 0.2, 2556.2285,-1295.8503,1044.1250) ||
			IsPlayerInRangeOfPoint(playerid, 0.2, 2553.9480,-1295.8500,1044.1250) ||
			IsPlayerInRangeOfPoint(playerid, 0.2, 2544.5281,-1295.8500,1044.1250) ||
			IsPlayerInRangeOfPoint(playerid, 0.2, 2542.1721,-1295.8497,1044.1250) ||
			IsPlayerInRangeOfPoint(playerid, 0.2, 2542.0186,-1291.0048,1044.1250) ||
			IsPlayerInRangeOfPoint(playerid, 0.2, 2544.3474,-1291.0057,1044.1250) ||
			IsPlayerInRangeOfPoint(playerid, 0.2, 2553.7336,-1291.0054,1044.1250) ||
			IsPlayerInRangeOfPoint(playerid, 0.2, 2556.0935,-1291.0056,1044.1250) ||
			IsPlayerInRangeOfPoint(playerid, 0.2, 2558.4849,-1291.0046,1044.1250)) return true;
	else return false;
}
stock GameModeExitFunc()
{
	SaveAccounts();
	KillTimer(othtimer);
	KillTimer(narkotimer);
	return true;
}
forward Secund();
public Secund()
{
	PlayerForeach(i)
	{
		if(GetPVarInt(i,"AntiDM") > 0)
		{
			new anim = GetPlayerAnimationIndex(i);
			if(anim != 471) ApplyAnimation(i, "FAT", "IDLE_tired",4.0,1,0,0,0,0,1);
			SetPVarInt(i,"AntiDM",GetPVarInt(i,"AntiDM")-1);
			if(GetPVarInt(i,"AntiDM") == 0) ClearAnimations(i);
		}
		if(IsAWorkbench(i) && GetPVarInt(i,"Metall") == 1 && GetPVarInt(i,"JobPlayer") == 3)
		{
			new Float:x,Float:y,Float:z,Float:a;
			GetPlayerPos(i,x,y,z);
			if(IsPlayerAttachedObjectSlotUsed(i,2)) RemovePlayerAttachedObject(i,2);
			DeletePVar(i,"Metall");
			SetTimerEx("Bench", 10000, false, "i", i);
			GetPlayerFacingAngle(i,a);
			ClearAnimations(i);
			if(floatround(a) > 130 && floatround(a) < 300) PlantObject[i] = CreateDynamicObject(1356,x,y-0.85,1044.20703125,0.00000000,0.00000000,0.00000000);
			else PlantObject[i] = CreateDynamicObject(1356,x,y+0.85,1044.20703125,0.00000000,0.00000000,0.00000000);
			ApplyAnimation(i,"CAR_CHAT","CAR_Sc4_BL",4.0,1,1,1,0,11000,0);
		}
	}
	return true;
}
stock BadFloat(Float:x)
{
	if(x >= 10.0 || x <= -10.0)
	return true;

	return false;
}
stock CheckBunnyHop(playerid) {
	if(GetTickCount() - GetPVarInt(playerid, "UnBannyHop") < 4000) {
		if(PlayerSpeed(playerid) >= 18 && PlayerSpeed(playerid) < 50) ApplyAnimation(playerid,"FAT","IDLE_tired",4.0,0,0,0,0,0 );
	}
	SetPVarInt(playerid, "UnBannyHop", GetTickCount());
}
stock PlayerSpeed(playerid)
{
	new Float:X, Float:Y, Float:Z;
	if(!IsPlayerInAnyVehicle(playerid)) GetPlayerVelocity(playerid,X,Y,Z);
	return floatround( floatsqroot( X * X + Y * Y + Z * Z ) * 170.0 );
}
stock SendMes(playerid, color, fstringg[], {Float, _}:...)
{
	static const
	STATIC_ARGS = 3;
	new
	n = (numargs() - STATIC_ARGS) * BYTES_PER_CELL;
	if(n)
	{
		new
		message[128],
		arg_start,
		arg_end;
		#emit CONST.alt        fstringg
		#emit LCTRL          5
		#emit ADD
		#emit STOR.S.pri        arg_start

		#emit LOAD.S.alt        n
		#emit ADD
		#emit STOR.S.pri        arg_end
		do
		{
			#emit LOAD.I
			#emit PUSH.pri
			arg_end -= BYTES_PER_CELL;
			#emit LOAD.S.pri      arg_end
		}
		while (arg_end > arg_start);

		#emit PUSH.S          fstringg
		#emit PUSH.C          128
		#emit PUSH.ADR         message

		n += BYTES_PER_CELL * 3;
		#emit PUSH.S          n
		#emit SYSREQ.C         format

		n += BYTES_PER_CELL;
		#emit LCTRL          4
		#emit LOAD.S.alt        n
		#emit ADD
		#emit SCTRL          4
		return SendClientMessage(playerid, color, message);
	}
	else return SendClientMessage(playerid, color, fstringg);
}
publics: DiceOff()
{
	PlayerForeach(i)
	{
		if(i == -1) continue;
		if(GetPVarInt(i, "OpustitRuki") == 1)
		{
			SetPVarInt(i, "OpustitRuki", 0);
			if(IsPlayerAttachedObjectSlotUsed(i,1)) RemovePlayerAttachedObject(i,1);
			ClearAnimations(i);
		}
	}
}
stock AntiCheat(i)
{
	if(gPlayerLogged[i] == 0 || IsPlayerNPC(i) || !IsPlayerConnected(i)) return true;
	new tttgtg;
	new str[300];
	tttgtg = GetPlayerAmmo(SpecAd[i]);
	new Float:hppp;
	new Float:aermor;
	new Float:health;
	GetPlayerArmour(SpecAd[i],aermor);
	GetPlayerHealth(SpecAd[i],hppp);
	GetVehicleHealth(GetPlayerVehicleID(SpecAd[i]),health);
	new fps = 40 + random(60);
	if(PlayerInfo[i][pAdmin] >= 1)
	{
		if(IsPlayerInAnyVehicle(SpecAd[i]))
		{
			new playersip[20];
			GetPlayerIp(SpecAd[i],playersip,sizeof(playersip));
			format(str, sizeof(str),"~g~%s %i~n~~n~~w~Number: %i~n~IP: %s~n~~n~Ping: %i~n~~r~Speed: ~w~%i~n~~g~Armour: ~w~%.0f~n~~g~Health: ~w~%.0f~n~Warns: %i~n~~b~Ammo: ~w~%i~n~~n~~g~$ ~w~Cash: ~g~%i~n~~g~$ ~w~Bank: ~g~%i~n~~n~~r~Scan FPS: %i~n~Car HP: %.0f",PlayerInfo[SpecAd[i]][pName],
			SpecAd[i],PlayerInfo[SpecAd[i]][pPnumber],playersip,GetPlayerPing(SpecAd[i]),SpeedVehicle(SpecAd[i]),aermor,hppp,PlayerInfo[SpecAd[i]][pWarns],tttgtg,PlayerInfo[SpecAd[i]][pCash],PlayerInfo[SpecAd[i]][pBank],fps,health);
			PlayerTextDrawSetString(i,FULLRECON[i],str);
		}
		if(!IsPlayerInAnyVehicle(SpecAd[i]))
		{
			new playersip[20];
			GetPlayerIp(SpecAd[i],playersip,sizeof(playersip));
			format(str, sizeof(str),"~g~%s %i~n~~n~~w~Number: %i~n~IP: %s~n~~n~Ping: %i~n~~r~Speed: ~w~%i~n~~g~Armour: ~w~%.0f~n~~g~Health: ~w~%.0f~n~Warns: %i~n~~b~Ammo: ~w~%i~n~~n~~g~$ ~w~Cash: ~g~%i~n~~g~$ ~w~Bank: ~g~%i~n~~n~~r~Scan FPS: %i",PlayerInfo[SpecAd[i]][pName],SpecAd[i],PlayerInfo[SpecAd[i]][pPnumber],playersip,GetPlayerPing(SpecAd[i]),SpeedVehicle(SpecAd[i]),aermor,
			hppp,PlayerInfo[SpecAd[i]][pWarns],tttgtg,PlayerInfo[SpecAd[i]][pCash],PlayerInfo[SpecAd[i]][pBank],fps);
			PlayerTextDrawSetString(i,FULLRECON[i],str);
		}
	}
	return true;
}
stock notallowed(weaponid)
{
	switch(weaponid)
	{
	case 25..27, 16..18, 34..37, 39..40, 43..200: return false;
	default: return true;
	}
	return true;
}
