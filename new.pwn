stock IsAbleToGiveSkin(playerid)
{
	new fractionid = PlayerInfo[playerid][pMember];
	new rank = PlayerInfo[playerid][pRank];
	switch(fractionid)
	{
	case 1,10,21,3,19: if(rank >= 14) return 1;
	case 2,4,26,25,24,6,14,15,18,17,12,11,5,13: if(rank >= 9) return 1;
	case 7: if(rank >= 5) return 1;
	case 16: if(rank >= 12) return 1;
	case 23: if(rank >= 11) return 1;
	case 27: if(rank >= 4) return 1;
	}
	return 0;
}
stock IsAbleToUninvite(playerid)
{
	new fractionid = PlayerInfo[playerid][pMember];
	new rank = PlayerInfo[playerid][pRank];
	switch(fractionid)
	{
	case 1,10,21,3,19: if(rank >= 13) return 1;
	case 2,4,26,25,24,6,14,15,18,17,12,11,5,13: if(rank >= 8) return 1;
	case 7: if(rank >= 4) return 1;
	case 16: if(rank >= 11) return 1;
	case 23: if(rank >= 10) return 1;
	case 27: if(rank >= 3) return 1;
	}
	return 0;
}
stock CanUninvitePlayer(playerid,playerid2)
{
	if(PlayerInfo[playerid][pLeader] >= 1) return true;
	new rank = PlayerInfo[playerid][pRank];
	if(PlayerInfo[playerid][pMember] > 0 && PlayerInfo[playerid2][pMember] > 0 &&
			rank < PlayerInfo[playerid2][pRank]) return false;
	switch(PlayerInfo[playerid][pMember])
	{
	case 1,10,21,3,19: if(rank >= 13) return 1;
	case 2,4,26,25,24,6,14,15,18,17,12,11,5,13: if(rank >= 8) return 1;
	case 7: if(rank >= 4) return 1;
	case 16: if(rank >= 11) return 1;
	case 23: if(rank >= 10) return 1;
	case 27: if(rank >= 3) return 1;
	}
	return false;
}
stock GetSRVMoney(playerid) return PlayerInfo[playerid][pCash];
stock Delgun(playerid) return ResetPlayerWeapons(playerid);
stock GetMoney()
{
	PlayerForeach(i)
	{
		if(IsPlayerConnected(i))
		{
			new money = GetPlayerMoney(i);
			if(PlayerInfo[i][pCash] < money) ResetPlayerMoney(i),GivePlayerMoney(i, PlayerInfo[i][pCash]);
			else if(PlayerInfo[i][pCash] > money) ResetPlayerMoney(i),GivePlayerMoney(i, PlayerInfo[i][pCash]);
		}
	}
	return true;
}
UnLockCar(carid)
{
	gCarLock[carid] = 0;
	GetVehicleParamsEx(carid,engine,lights,alarm,doors,bonnet,boot,objective);
	SetVehicleParamsEx(carid,engine,lights,alarm,VEHICLE_PARAMS_OFF,bonnet,boot,objective);
	PlayerForeach(i) SetVehicleParamsForPlayer(carid,i,0,0);
}
stock Menu()
{
	BuyClothes = CreateMenu ( "Shop", 1, 10.0, 130.0, 100.0, 80.0);
	AddMenuItem(BuyClothes, 0, "Next >>");
	AddMenuItem(BuyClothes, 0, "<< Back");
	AddMenuItem(BuyClothes, 0, "Select");
	AddMenuItem(BuyClothes, 0, "Exit");

	ChoseSkin = CreateMenu("Clothing", 1, 50.0, 160.0, 90.0);
	AddMenuItem(ChoseSkin,0,"<>~y~ Next");
	AddMenuItem(ChoseSkin,0,"<>~g~ Select");

	bomj[0] = CreateMenu("Clothing", 1, 50.0, 160.0, 90.0);
	AddMenuItem(bomj[0] ,0,"<>~y~ Next");
	AddMenuItem(bomj[0] ,0,"<>~g~ Select");

	bomj[1] = CreateMenu("Clothing", 1, 50.0, 160.0, 90.0);
	AddMenuItem(bomj[1] ,0,"<>~y~ Next");
	AddMenuItem(bomj[1] ,0,"<>~g~ Select");

	Admin = CreateMenu("Recon", 1, 0.0, 110.0, 80.0);
	AddMenuItem(Admin,0,"Next Player");
	AddMenuItem(Admin,0,"Old Player");
	AddMenuItem(Admin,0,"Update");
	AddMenuItem(Admin,0,"Slap");
	AddMenuItem(Admin,0,"Stats");
	AddMenuItem(Admin,0,"GetIP");
	AddMenuItem(Admin,0,"GMTest");
	AddMenuItem(Admin,0,"OFF");
	return true;
}
stock SpeedVehicle(vehicleid)
{
	new Float:ST[4];
	GetVehicleVelocity(vehicleid,ST[0],ST[1],ST[2]);
	ST[3] = floatsqroot(floatpower(floatabs(ST[0]), 2.0) + floatpower(floatabs(ST[1]), 2.0) + floatpower(floatabs(ST[2]), 2.0)) * 213.3;
	return floatround(ST[3]);
}
public OnVehicleDamageStatusUpdate(vehicleid, playerid)
{
	new house = PlayerInfo[playerid][pPhousekey]; new Float: carhp;
	GetVehicleHealth(vehicleid, carhp);
	PlayerForeach(i)
	{
		if(GetPlayerVehicleID(playerid) == caridhouse[i])
		{
			if(carhp > 700 && carhp < 1000) { HomeInfo[house][hVehSost] -= 0,PlayerInfo[playerid][pProz] -= 0; return true; }
			else if(carhp > 500 && carhp < 700) { HomeInfo[house][hVehSost] -= 1,PlayerInfo[playerid][pProz] -= 1; return true; }
			else if(carhp > 200 && carhp < 500) { if(PlayerInfo[playerid][pProz] > 0) HomeInfo[house][hVehSost] -= 2; PlayerInfo[playerid][pProz] -= 2; return true; }
		}
	}
	return true;
}
publics: TeleportTimer(playerid)
{
	SetPlayerPos(playerid, TeleportDest[playerid][0],TeleportDest[playerid][1],TeleportDest[playerid][2]);
	SetPlayerInterior(playerid, TeleportDestNoFloat[playerid][0]);
	SetPlayerVirtualWorld(playerid, TeleportDestNoFloat[playerid][1]);
	return true;
}
stock StopSpectate(playerid)
{
	SetPVarInt(playerid,"PlayerSpec",0);
	TogglePlayerSpectating(playerid, 0);
	gSpectateID[playerid] = INVALID_PLAYER_ID;
	gSpectateType[playerid] = ADMIN_SPEC_TYPE_NONE;
	PlayerTextDrawHide(playerid, FULLRECON[playerid]);
	GameTextForPlayer(playerid, "~n~~n~~n~~n~~n~~n~~n~~n~~w~Recon Stop",1000,3);
	teleporttimers = SetTimerEx("TeleportTimer", 100, false, "i", playerid);
	HideMenuForPlayer(Admin,playerid);
	KillTimer(teleporttimers);
	return true;
}
stock GetWeaponSlot(weaponid)
{
	new slot;
	switch(weaponid)
	{
	case 0,1: slot = 0;
	case 2..9: slot = 1;
	case 22..24: slot = 2;
	case 25..27: slot = 3;
	case 28,29,32: slot = 4;
	case 30,31: slot = 5;
	case 33,34: slot = 6;
	case 35..38: slot = 7;
	case 16..18,39: slot = 8;
	case 41..43: slot = 9;
	case 10..15: slot = 10;
	case 44..46: slot = 11;
	case 40: slot = 12;
	default: slot = -1;
	}
	return slot;
}
public OnPlayerWeaponShot(playerid, weaponid, hittype, hitid, Float:fX, Float:fY, Float:fZ)
{
	if( hittype == BULLET_HIT_TYPE_PLAYER && (BadFloat(fX) || BadFloat(fY) || BadFloat(fZ)) )
	{
		Kick(playerid);
		return 0;
	}
	return true;
}
stock MainMenuPl(playerid)
{
	ShowPlayerDialog(playerid, 9623, DIALOG_STYLE_LIST, "{FF8300}Меню персонажа", "[0] Статистика персонажа\n[1] Команда сервера\n[2] Поддержка\n[3] Настройки\n[4] Доступ к игре\n[5] Справочник\n[6] Донат", "Далее", "Скрыть");
	return true;
}
stock AnRepairVehicle(vehicleid) return RepairVehicle(vehicleid);
stock SearchingHit(playerid)
{
	new d,string[256];
	format(string, sizeof(string), "{FFFF00}Выберите и введите номер жертвы\n\n{FFFFFF}"),strcat(string, string);
	PlayerForeach(i)
	{
		if(IsPlayerConnected(i))
		{
			if(PlayerInfo[i][pHeadValue] > 0 && ContractInfo[i][cHitman] == INVALID_PLAYER_ID)
			{
				d++;
				if(d > 0 && d < 5) format(stringer, sizeof(stringer), "[{32CD32}%d{FFFFFF}] - Номер : %d ~ [{FFFF00}%s (%d вирт){FFFFFF}]\n",d,i,PlayerInfo[i][pName],PlayerInfo[i][pHeadValue]),strcat(string, stringer);
			}
		}
	}
	if(d == 0) return ShowPlayerDialog(playerid,5232,DIALOG_STYLE_MSGBOX,"Доступные контракты","Нету доступных контрактов","Ок","");
	ShowPlayerDialog(playerid,5230,DIALOG_STYLE_INPUT,"Доступные контракты",string,"Далее","Назад");
	return true;
}
forward LoadGZ();
public LoadGZ()
{
	new rows, fields, temp[64],i=0;
	cache_get_data (rows, fields);
	if(rows)
	{
		for(new g; g < rows ; g++)
		{
			cache_get_row(g, 1, temp),GZInfo[g][gFrakVlad] = strval(temp);
			cache_get_row(g, 2, temp), GZInfo[g][gCoords][0] = floatstr(temp);
			cache_get_row(g, 3, temp), GZInfo[g][gCoords][1] = floatstr(temp);
			cache_get_row(g, 4, temp), GZInfo[g][gCoords][2] = floatstr(temp);
			cache_get_row(g, 5, temp), GZInfo[g][gCoords][3] = floatstr(temp);
			i++;
			GZInfo[g][gID] = GangZoneCreate(GZInfo[g][gCoords][0],GZInfo[g][gCoords][1],GZInfo[g][gCoords][2],GZInfo[g][gCoords][3]);
		}
		printf("[Загрузка]: LoadGZ | Загрузка: %d", i);
	}
	else printf("[ERROR] GangZone не загружены.");
	return true;
}
stock SaveGZ(i)
{
	mysql_format(dbHandle, QUERY, sizeof(QUERY), "UPDATE "TABLE_GANGZONE" SET `gFrakVlad`= '%d' WHERE `gID` = '%d'",GZInfo[i][gFrakVlad],i);
	mysql_function_query(dbHandle, QUERY, false, "", "");
	return true;
}
stock SetOtherInt(stolb[], znach)
{
	mysql_format(dbHandle, QUERY, 128, "UPDATE "TABLE_OTHER" SET `%s` = '%d'", stolb, znach);
	mysql_function_query(dbHandle, QUERY, false, "", "");
}
