						format(stringer1,sizeof(stringer1), "Надел(а) бандану");
						SetPlayerChatBubble(playerid,stringer1,COLOR_YELLOW,30.0,10000);
						return true;
					}
				case 15:
					{
						SetPlayerAttachedObject(playerid, 0, 18918, 2, 0.1, 0.03, -0.005, 90.0, 180.0, 90.0);
						mask[playerid] = 1;
						SetPlayerToTeamColor(playerid);
						format(stringer1,sizeof(stringer1), "Надел(а) бандану");
						SetPlayerChatBubble(playerid,stringer1,COLOR_YELLOW,30.0,10000);
						return true;
					}
				}
				SetPlayerAttachedObject(playerid, 0, 18912, 2, 0.1, 0.03, -0.005, 90.0, 180.0, 90.0);
				mask[playerid] = 1;
				SetPlayerToTeamColor(playerid);
				format(stringer1,sizeof(stringer1), "Надел(а) бандану");
				SetPlayerChatBubble(playerid,stringer1,COLOR_YELLOW,30.0,10000);
			}
			else
			{
				RemovePlayerAttachedObject(playerid, 0);
				mask[playerid] = 0;
				SetPlayerColor(playerid, 0xFFFFFF20);
				format(stringer1,sizeof(stringer1), "Снял(а) бандану");
				SetPlayerChatBubble(playerid,stringer1,COLOR_YELLOW,30.0,10000);
			}
		}
	}
	return true;
}
CMD:materials(playerid, params[])
{
	if(!IsAGang(playerid)) return SendClientMessage(playerid,COLOR_GREY,"Вы не бандит");
	if(sscanf(params, "s[128]",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /materials [get/put]");
	if(strcmp(params[0],"get",true) == 0)
	{
		if(IsAGang(playerid))
		{
			if(PlayerToPoint(10.0,playerid,-1290.9072,501.4489,11.1953))
			{
				if(armmatsf == 0)return SendClientMessage(playerid,COLOR_GRAD1,"Склад армии SF пуст");
				if(PlayerInfo[playerid][pMats] >= 250) return SendClientMessage(playerid,COLOR_GRAD1,"Вы не можете взять больше");
				SendClientMessage(playerid, 0x6495EDFF, "Вы взяли 250 материалов со склада армии");
				SendClientMessage(playerid, COLOR_GREEN, "Несите ящик в грузовик (( /materialsput ))");
				PlayerInfo[playerid][pMats] += 250;
				ApplyAnimation(playerid,"CARRY","crry_prtial",4.0,1,0,0,1,1,1);
				SetPlayerAttachedObject(playerid, 1 , 2358, 1,0.11,0.36,0.0,0.0,90.0);
				ApplyAnimation(playerid,"CARRY","crry_prtial",4.0,1,0,0,1,1,1);
				usemats[playerid] = 1;
				armmatsf -= 250;
				SetOtherInt("armmatsf", armmatsf);
			}
			if(PlayerToPoint(10.0,playerid,316.8127,-167.5395,999.5938))
			{
				if(armmatbi == 0)return SendClientMessage(playerid,COLOR_GRAD1,"Склад армии LV пуст");
				if(PlayerInfo[playerid][pMats] >= 250) return SendClientMessage(playerid,COLOR_GRAD1,"Вы не можете взять больше");
				SendClientMessage(playerid, 0x6495EDFF, "Вы взяли 250 материалов со склада армии");
				SendClientMessage(playerid, COLOR_GREEN, "Несите ящик в грузовик (( /materialsput ))");
				PlayerInfo[playerid][pMats] += 250;
				ApplyAnimation(playerid,"CARRY","crry_prtial",4.0,1,0,0,1,1,1);
				SetPlayerAttachedObject(playerid, 1 , 2358, 1,0.11,0.36,0.0,0.0,90.0);
				ApplyAnimation(playerid,"CARRY","crry_prtial",4.0,1,0,0,1,1,1);
				usemats[playerid] = 1;
				armmatbi -= 250;
				SetOtherInt("armmatbi", armmatbi);
			}
		}
	}
	return true;
}
