CMD:gotome(playerid, params[])
{
	if(!IsACop(playerid)) return SendClientMessage(playerid, COLOR_GREY, "Вы не полицейский!");
	if(sscanf(params, "d",params[0])) return  SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /gotome [playerid]");
	if(IsPlayerInAnyVehicle(playerid) || IsPlayerInAnyVehicle(params[0])) return SendClientMessage(playerid,COLOR_GREY,"Вы или игрок находится в машине!");
	if(PlayerInfo[params[0]][pJailed] > 0) return SendClientMessage(playerid,COLOR_LIGHTRED,"Игрок в тюрьме!");
	if(PlayerCuffed[params[0]] <= 0) return SendClientMessage(playerid,COLOR_LIGHTRED,"Игрок в не в наручниках!");
	if(!ProxDetectorS(10.0, playerid, params[0])) return SendClientMessage(playerid, COLOR_GRAD1, " Человек далеко от вас");
	new Float:xe, Float:ye, Float:ze;
	GetPlayerPos(playerid,xe,ye,ze);
	SetPlayerPos(params[0],xe+0.5,ye+0.5,ze);
	SendClientMessage(params[0],COLOR_LIGHTRED,"Вас насильно потащили за собой!");
	return true;
}
CMD:cput(playerid, params[])
{
	if(IsACop(playerid) || ISAMAFIA(playerid))
	{
		new carr = GetVehicleModel(GetPlayerVehicleID(playerid));
		if(carr!=441||carr!=446||carr!=448||carr!=449||carr!=452||carr!=450||carr!=453||carr!=454||carr!=460||carr!=461||carr!=462||carr!=463||carr!=464||carr!=465||carr!=468
				||carr!=472||carr!=473||carr!=481||carr!=484||carr!=493||carr!=501||carr!=509||carr!=510||carr!=521||carr!=522||carr!=523||carr!=539||carr!=564||carr!=568 ||carr!=569
				||carr!=570||carr!=571||carr!=584||carr!=586||carr!=595)
		{
			if(sscanf(params, "d",params[0])) return  SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /cput [playerid]");
			if(!IsPlayerConnected(params[0])) return true;
			if(params[0] == INVALID_PLAYER_ID) return SendClientMessage(playerid, COLOR_GRAD1, "[Ошибка] Человек небыл найден");
			if(!ProxDetectorS(5.0, playerid, params[0])) return SendClientMessage(playerid, COLOR_GRAD1, "[Ошибка] Человек далеко от вас");
			if(params[0] == playerid) return SendClientMessage(playerid, COLOR_GRAD1, "[Ошибка] Вы не можете затащить в машину самого себя");
			if(PlayerCuffed[params[0]] == 0 && IsACop(playerid)) return  SendClientMessage(playerid,COLOR_GREY,"Игрок без наручников.");
			if(GetPlayerState(params[0]) != PLAYER_STATE_ONFOOT) return SendClientMessage(playerid, COLOR_GRAD1, "[Ошибка] Человек в автомобиле");
			new mesto2,vehicle=GetPlayerVehicleID(playerid);
			PlayerForeach(i)
			{
				if(IsPlayerInVehicle(i,vehicle))
				{
					mesto2 = GetPlayerVehicleSeat(i);
					if(mesto2==2) return SendClientMessage(playerid, COLOR_GRAD1, "[Ошибка] Место в машине уже занято");
				}
			}
			PutPlayerInVeh(params[0],vehicle,1);
			format(stringer1,sizeof(stringer1), "Вы были затащены в машину %s",PlayerInfo[playerid][pName]);
			SendClientMessage(params[0],0x64E96EDFF,stringer1);
			format(stringer1,sizeof(stringer1), "Вы затащили в машину %s",PlayerInfo[params[0]][pName]);
			SendClientMessage(playerid,0x64E96EDFF,stringer1);
		}
	}
	return true;
}
CMD:find(playerid, params[])
{
	if(IsACop(playerid) || PlayerInfo[playerid][pMember] == 23)
	{
		if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /find [id]");
		if(!IsPlayerConnected(params[0])) return true;
		if(PlayerInfo[params[0]][pInt] > 0) SendClientMessage(playerid,COLOR_GREY,"Человек возможно находиться в интерьере.");
		if(params[0] == playerid) { SendClientMessage(playerid, COLOR_GREY, "[Ошибка] Вы указали свой ID"); return true; }
		new Float:X,Float:Y,Float:Z;
		GetPlayerPos(params[0], X,Y,Z);
		SetPlayerCheckpoint(playerid, X,Y,Z, 6);
	}
	return true;
}
CMD:undemote(playerid, params[])
{
	if(PlayerInfo[playerid][pMember] != 26 || PlayerInfo[playerid][pRank] < 9) return true;
	if(sscanf(params, "dd",params[0],params[1])) return  SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /undemote [id] [ранг]");
	if(PlayerInfo[params[0]][pLeader] > 0) return SendClientMessage(playerid,COLOR_WHITE,"Вы не можете уволить лидера!");
	switch(PlayerInfo[params[0]][pMember])
	{
	case 1,10,3,19,21: if(params[1] > 14 || params[1] < 0) return SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 0 и больше 14!");
	case 2,11,25: if(params[1] > 9 || params[1] < 0) return SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 0 и больше 9!");
	case 7: if(params[1] > 5 || params[1] < 0) return SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 0 и больше 5!");
	case 16: if(params[1] > 12 || params[1] < 0) return SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 0 и больше 12!");
	}
	if(!IsPlayerConnected(params[0]) || params[0] == INVALID_PLAYER_ID || params[0] == playerid) return true;
	if(params[1] > 0)
	{
		switch(PlayerInfo[params[0]][pMember])
		{
		case 11..15,26:return true;
		case 17,18,0,5,6,9,20,23:return true;
		}
		PlayerInfo[params[0]][pRank] = params[1];
		format(stringer1, sizeof(stringer1), "Вы были повышены/понижены до %i ранга Министром %s",params[1], PlayerInfo[playerid][pName]);
		SendClientMessage(params[0], 0x6495EDFF, stringer1);
		format(stringer1, sizeof(stringer1), "Вы повысили/понизили %s до %i ранга.", PlayerInfo[params[0]][pName],params[1]);
		SendClientMessage(playerid, 0x6495EDFF, stringer1);
	}
	else
	{
		switch(PlayerInfo[params[0]][pMember])
		{
		case 11..15,26:return true;
		case 17,18,0,5,6,9,20,23:return true;
		}
		PlayerInfo[params[0]][pMember] = 0;
		PlayerInfo[params[0]][pRank] = 0;
		SetPlayerArmour(params[0],0);
		SetPlayerColor(params[0], 0xFFFFFF20);
		SetPlayerSkin(params[0], PlayerInfo[params[0]][pChar]);
		SendClientMessage(params[0], COLOR_BLUE, "Вы были уволены Министром.");
		SendClientMessage(params[0], 0x6495EDFF, "Теперь вы снова гражданский...");
		SendClientMessage(playerid,COLOR_GREY,"Вы успешно уволили данного игрока");
	}
	return true;
}
CMD:ginfo(playerid, params[])
{
	for(new i =0;i<sizeof(VladGzone);i++)  VladGzone[i] = 0;
	for(new i =0;i<sizeof(GZInfo);i++)
	{
		switch(GZInfo[i][gFrakVlad])
		{
		case 12: VladGzone[0] +=1;
		case 13: VladGzone[1] +=1;
		case 15: VladGzone[2] +=1;
		case 17: VladGzone[3] +=1;
		case 18: VladGzone[4] +=1;
		}
	}
	switch(PlayerInfo[playerid][pMember])
	{
	case 12:format(stringer, sizeof(stringer), "{FFFFFF}Территории под контролем: %i\nВ час банда зарабатывает: {37F222}$%i\n\n{FFFFFF}На складе: %i м.\nВ банке банды: {37F222}$%i",VladGzone[0],300*VladGzone[0],ballasmatbi,FracBank[0][fBallas]);
	case 13:format(stringer, sizeof(stringer), "{FFFFFF}Территории под контролем: %i\nВ час банда зарабатывает: {37F222}$%i\n\n{FFFFFF}На складе: %i м.\nВ банке банды: {37F222}$%i",VladGzone[1],300*VladGzone[1],vagosmatbi,FracBank[0][fVagos]);
	case 17:format(stringer, sizeof(stringer), "{FFFFFF}Территории под контролем: %i\nВ час банда зарабатывает: {37F222}$%i\n\n{FFFFFF}На складе: %i м.\nВ банке банды: {37F222}$%i",VladGzone[3],300*VladGzone[3],aztekmatbi,FracBank[0][fAztek]);
	case 18:format(stringer, sizeof(stringer), "{FFFFFF}Территории под контролем: %i\nВ час банда зарабатывает: {37F222}$%i\n\n{FFFFFF}На складе: %i м.\nВ банке банды: {37F222}$%i",VladGzone[4],300*VladGzone[4],rifamatbi,FracBank[0][fRifa]);
	case 15:format(stringer, sizeof(stringer), "{FFFFFF}Территории под контролем: %i\nВ час банда зарабатывает: {37F222}$%i\n\n{FFFFFF}На складе: %i м.\nВ банке банды: {37F222}$%i",VladGzone[2],300*VladGzone[2],groovmatbi,FracBank[0][fGrove]);
	}
	ShowPlayerDialog(playerid,2234,DIALOG_STYLE_MSGBOX, "Статистика группировки",stringer,"Скрыть","");
	return true;
}
CMD:narkoz(playerid, params[])
{
	if(PlayerInfo[playerid][pMember] != 4) return true;
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /narkoz [id]");
	if(!IsPlayerConnected(params[0]) || params[0] == INVALID_PLAYER_ID || params[0] == playerid) return true;
	if(!PlayerToPoint(30.0,playerid,-2659.1233,611.1161,14.4531) || !PlayerToPoint(30.0,playerid,2033.8335,-1406.4746,17.2076)) return true;
	if(seans[params[0]] == 1) return SendClientMessage(playerid,COLOR_GREEN,"Следущий сеанс можно провести через час");
	if(PlayerInfo[params[0]][pNarcoLomka] <= 100)  return  SendClientMessage(playerid,COLOR_GREEN,"У пациенат нет зависимости");
	PlayerInfo[params[0]][pNarcoLomka] -=500;
	SetPlayerWeather(params[0], 7);
	SendMes(params[0],COLOR_GREEN,"Медик %s провёл с вами сеанс от наркозависимости",PlayerInfo[playerid][pName]);
	SendMes(playerid,COLOR_GREEN,"Вы провели сеанс от наркозависимости с %s",PlayerInfo[params[0]][pName]);
	seans[params[0]] = 1;
	return true;
}
CMD:gmenu(playerid, params[])
{
	if(PlayerInfo[playerid][pMember] == 13 || PlayerInfo[playerid][pMember] == 12 || PlayerInfo[playerid][pMember] == 15 || PlayerInfo[playerid][pMember] == 17 || PlayerInfo[playerid][pMember] == 18)
	ShowPlayerDialog(playerid,9595,DIALOG_STYLE_LIST,"Меню банды","[0] Склад оружия\n[1] Проверить склад\n[2] Положить деньги в банк банды\n[3] Снять деньги с банка банды\n[4] Проверить банк банды\n[5] Продать материалы мафии\n[6] Проверить запас алкоголя", "Далее", "Скрыть");
	return true;
}
CMD:bpanel(playerid, params[])
{
	if(PlayerInfo[playerid][pPbiskey] == 255) return true;
	format(stringer1, sizeof(stringer1), "[0] Статистика бизнеса\n[1] Снять деньги с бизнеса\n[2] Установить цену за товар\n[3] Установить цену за вход\n[4] Продать бизнес государству\n[5] Продать бизнес игроку");
	ShowPlayerDialog(playerid,9397,DIALOG_STYLE_LIST,"Управление бизнесом",stringer1,"Ок","Скрыть");
	return true;
}
CMD:lpanel(playerid, params[])
{
	if(PlayerInfo[playerid][pLeader] <= 0) return SendClientMessage(playerid, COLOR_GRAD1, "Вы не уполномочены использовать данную команду!");
	ShowPlayerDialog(playerid, 9391, 2, "Управление фракцией:","[0] Члены организации ONLINE\n[1] Управление игроками OFFLINE{FFFFFF}\n[2] Принять игрока\n[3] Уволить игрока\n[4] Понизить/Повысить игрока", "Далее", "Скрыть");
	return true;
}
CMD:mmenu(playerid, params[])
{
	if(PlayerInfo[playerid][pMember] != 6 && PlayerInfo[playerid][pMember] != 14 && PlayerInfo[playerid][pMember] != 5) return 1;
	ShowPlayerDialog(playerid,9596,DIALOG_STYLE_LIST,"Mafia Menu","[0] Проверить банк мафии\n[1] Пополнить банк мафии \n[2] Снять деньги с банка мафии\n[3] Проверить склад мафии\n[4] Захваченные бизнесы", "Далее", "Скрыть");
	return true;
}

CMD:hi(playerid, params[])
{
	if(IsPlayerInAnyVehicle(playerid)) return SendClientMessage(playerid, COLOR_GREY, "Нельзя использовать в машине");
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /hi [id]");
	if(!IsPlayerConnected(params[0])) return true;
	if(!ProxDetectorS(2.0, playerid, params[0])) return true;
	if(params[0] == playerid)  return  SendClientMessage(playerid,COLOR_GRAD1, "[Ошибка] Вы указали свой ID");
	new Float:angle;
	GetPlayerFacingAngle(playerid, angle);
	SetPlayerFacingAngle(params[0], angle + 180);
	format(stringer1, sizeof(stringer1), "%s пожал(а) руку %s'у",PlayerInfo[playerid][pName],PlayerInfo[params[0]][pName]);
	ProxDetector(30.0, playerid, stringer1, COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW);
	if(PlayerCuffed[playerid] == 0) { ApplyAnimation(playerid, "GANGS", "hndshkfa",4.0,0,0,0,0,0,1); }
	if(PlayerCuffed[params[0]] == 0) { ApplyAnimation(params[0], "GANGS", "hndshkfa",4.0,0,0,0,0,0,1); }
	return true;
}
CMD:keys(playerid, params[])
{
	if(!IsAGang(playerid)) return true;
	if(keys[playerid] <= 0) return SendClientMessage(playerid, COLOR_GRAD1, "У Вас нет ключей от тюрьмы!");
	format(stringer1, sizeof(stringer1), "У Вас %i ключей", keys[playerid]);
	SendClientMessage(playerid, COLOR_YELLOW, stringer1);
	format(stringer1, sizeof(stringer1), "%s достаёт ключи",PlayerInfo[playerid][pName]);
	ProxDetector(30.0, playerid, stringer1, COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW);
	return true;
}
CMD:givecopkeys(playerid, params[])
{
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /givecopkeys [id]");
	if(PlayerInfo[playerid][pMember] == 1 || PlayerInfo[playerid][pMember] == 2 || PlayerInfo[playerid][pMember] == 10 || PlayerInfo[playerid][pMember] == 21 || PlayerInfo[playerid][pMember] == 25 )
	{
		if(!IsPlayerConnected(params[0])) return true;
		keys[params[0]] += 1;
		format(stringer1, sizeof(stringer1), "Офицер %s выдал ключи от полицейского участка %s",PlayerInfo[playerid][pName],PlayerInfo[params[0]][pName]);
		ProxDetector(30.0, playerid, stringer1, COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW);
	}
	return true;
}
CMD:yes(playerid, params[])
{
	if(PlayerInfo[playerid][pMember] == 16)
	{
		if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /yes [id]");
		if(!IsPlayerConnected(params[0])) return true;
		if(zvonok[params[0]] !=1) return SendClientMessage(playerid, COLOR_GRAD1, "Этот человек не звонил в студию!");
		format(stringer1, sizeof(stringer1), "Вы приняли звонок от %s",PlayerInfo[params[0]][pName]);
		SendClientMessage(playerid, COLOR_WHITE, stringer1);
		Tel[params[0]] = 1;
		SendClientMessage(params[0], COLOR_YELLOW, "Вы попали в студию, говорите.");
		if(PlayerInfo[playerid][pMember] == 16)
		{
			TalkingLivels[params[0]] = 2;
			PlayerInfo[params[0]][pMobile] -= smspricels;
			FracBank[0][fLsnews] += smspricels;
		}
	}
	return true;
}
CMD:off(playerid, params[])
{
	if(PlayerInfo[playerid][pMember] == 16)
	{
		if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /off [id]");
		if(!IsPlayerConnected(params[0])) return true;
		if(zvonok[params[0]] !=1) return SendClientMessage(playerid, COLOR_GRAD1, "Этот человек не звонил в студию!");
		format(stringer1, sizeof(stringer1), "Вы завершили звонок от %s",PlayerInfo[params[0]][pName]);
		SendClientMessage(playerid, COLOR_BLUE, stringer1);
		SetPlayerSpecialAction(params[0],SPECIAL_ACTION_STOPUSECELLPHONE);
		SendClientMessage(params[0], COLOR_YELLOW, "Звонок завершён.");
		zvonok[params[0]] = 0;
		Tel[params[0]] = INVALID_PLAYER_ID;
		TalkingLivels[params[0]] = INVALID_PLAYER_ID;
	}
	return true;
}
CMD:sethpprice(playerid, params[])
{
	if(PlayerInfo[playerid][pMember] == 4 && PlayerInfo[playerid][pRank] >= 8)
	{
		if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /sethealcost [сумма]");
		if(params[0] < 1 || params[0] > 1000) { SendClientMessage(playerid, COLOR_GREY, "Вы не можете поставить меньше 0 и больше 1000"); return true; }
		healpric = params[0];
		SendClientMessageToAll(COLOR_WHITE, "============= Государственные Новости =============");
		format(stringer1, sizeof(stringer1), "Цена лечения, в размере %i вирт. установлена Глав. Врачом LS: %s.", healpric,PlayerInfo[playerid][pName]);
		SendClientMessageToAll(0xA52A2AFF, stringer1);
		return true;
	}
	return true;
}
CMD:play(playerid, params[])
{
	if(playerradio[playerid] == 1)
	{
		StopAudioStreamForPlayer(playerid);
		SendClientMessage(playerid, -1, "{FE6500}Радио отключено");
		playerradio[playerid] = 0;
	}
	ShowPlayerDialog(playerid, 245, DIALOG_STYLE_LIST, "{FFCD00}Онлайн радио", "{ffffff}1. Зайцев FM\n3. Радио Шансон\n4. Радио Рекорд\n5. Sky Radio\n6. DFM Radio\n7. ICE FM", "Принять", "Скрыть");
	return true;
}
CMD:members(playerid, params[])
{
	new teamnumber;
	if(PlayerInfo[playerid][pLeader] != 0) teamnumber = PlayerInfo[playerid][pLeader];
	else if(PlayerInfo[playerid][pMember] != 0) teamnumber = PlayerInfo[playerid][pMember];
	else return SendClientMessage(playerid, COLOR_GRAD1, "Вы ни где не состоите!");
	SendClientMessage(playerid, 0x059BD3AA, "Члены организации Online:");
	new countmute = 0;
	PlayerForeach(i)
	{
		if(PlayerInfo[i][pAdmin] > 0) continue;
		if(PlayerInfo[i][pMember] == teamnumber && IsPlayerConnected(i))
		{
			countmute++;
			if(PlayerInfo[i][pLeader] == teamnumber) format(stringer1, sizeof(stringer1), "{ffffff}%s ({00a36d}%d{ffffff}) {00a36d}|{FFFFFF} Ранг: {00a36d}Лидер {FFFFFF}", PlayerInfo[i][pName], i);
			else if(PlayerInfo[i][pMember] == teamnumber) format(stringer1, sizeof(stringer1), "{ffffff}%s ({00a36d}%d{ffffff}) {00a36d}|{FFFFFF} Ранг: {00a36d}%s(%d) {FFFFFF}", PlayerInfo[i][pName], i, GetPlayerRank(i),PlayerInfo[i][pRank]);
			if(strlen(stringer1) > 1) SendClientMessage(playerid, 0xC0E1EEFF, stringer1);
		}
	}
	if(countmute == 0) SendClientMessage(playerid, COLOR_GRAD1, "Нет игроков");
	else SendMes(playerid, COLOR_WHITE, "Всего: {00a36d}%d {FFFFFF}человек.", countmute);
	return true;
}
CMD:call(playerid, params[])
{
	if(PlayerInfo[playerid][pMuted] == 1) return SendMes(playerid, TEAM_CYAN_COLOR, "У Вас заблокирован чат, Вы не можете разговаривать. До снятия: %d секунд", PlayerInfo[playerid][pMuteTime]);
	if(PhoneOnline[playerid] > 0) return SendClientMessage(playerid, COLOR_GREY, "У вас выключен телефон!");
	if(Mobile[playerid] != -1) return SendClientMessage(playerid, COLOR_GREY, "Вы уже разговариваете по телефону!");
	if(PlayerInfo[playerid][pPnumber] == 0) return SendClientMessage(playerid, COLOR_GREY, "Вы не владеете телефоном!");
	if(gag[playerid] == 1) return SendClientMessage(playerid, COLOR_LIGHTRED, "У Вас кляп, вы не можете говорить!");
	if(takephone[playerid] == 1) return SendClientMessage(playerid, COLOR_LIGHTRED, "У Вас нет телефона");
	if(sscanf(params, "i", params[0])) return ShowPlayerDialog(playerid, 9956, 2, "Выберите сервис", "[0] Вызвать Таксиста\n[1] Вызвать Медицинскую помощь\n[2] Вызвать Механика\n[3] Вызвать Полицию", "Далее", "Скрыть");
	if(params[0] < 0 || params[0] > 9999999) return SendClientMessage(playerid, COLOR_GREY, "Неверный номер телефона!");
	if(params[0] == PlayerInfo[playerid][pPnumber]) return SendClientMessage(playerid, COLOR_GREY, "Ты не можешь позвонить самому себе!");
	if(PlayerInfo[playerid][pBank] <= 0) return SendClientMessage(playerid, COLOR_GREY, "Сумма на вашем счету не достаточна для совершения звонка");
	new string[128];
	new full;
	PlayerForeach(i)
	{
		if(!IsPlayerConnected(i) || gPlayerLogged[playerid] == 0) continue;
		if(params[0] == 11888)
		{
			if(smsls == 0) return SendClientMessage(playerid, COLOR_GREY, "Прямой эфир отключен.");
			format(stringer1, sizeof(stringer1), "В студию звонит: %s. Введите /yes [%i], чтобы ответить",PlayerInfo[playerid][pName], playerid);
			SendFamilyMessage(16, COLOR_YELLOW, stringer1);
			SendClientMessage(playerid,  COLOR_WHITE, "Чтобы повесить трубку введите /h");
			if(!IsPlayerInAnyVehicle(playerid)) SetPlayerSpecialAction(playerid, 11);
			zvonok[playerid] = 1;
			PlayerInfo[playerid][pBank] -= smspricels;
			FracBank[0][fLsnews] += smspricels;
			full++;
			return true;
		}
		if(params[0] == PlayerInfo[i][pPnumber] && params[0] != 0)
		{
			if(PhoneOnline[i] > 0) return SendClientMessage(playerid, COLOR_GREY, "Игрок выключил телефон!");
			if(Mobile[i] != -1) return SendClientMessage(playerid, COLOR_GREY, "Игрок уже разговаривает по телефону!");
			Mobile[playerid] = i;
			format(stringer1, 100,"Ваc вызывает: %s. Чтобы ответить, {FFA200}[Подсказка]: {FFFFFF} /p", PlayerInfo[playerid][pName]);
			SendClientMessage(i,COLOR_GRAD2, stringer1);
			format(string, 90, "У %s звонит мобильный телефон", PlayerInfo[i][pName]);
			ProxDetector(30.0, i, string, COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW);
			PlayerPlaySound(playerid, 1057, 0.0, 0.0, 0.0);
			SendClientMessage(playerid, COLOR_WHITE, "Чтобы повесить трубку, {FFA200}[Подсказка]: {FFFFFF} /h");
			if(!IsPlayerInAnyVehicle(playerid)) SetPlayerSpecialAction(playerid, 11);
			CellTime[playerid] = 1;
			full++;
			break;
		}
	}
	if(full == 0) return SendClientMessage(playerid, COLOR_GREY, "Игрок с данным номером не найден!");
	return true;
}
CMD:pickup(playerid, params[])
{
	if(Mobile[playerid] != -1) return SendClientMessage(playerid, COLOR_GREY, "Вы уже разговариваете по телефону!");
	PlayerForeach(i)
	{
		if(!IsPlayerConnected(i) || gPlayerLogged[playerid] == 0) continue;
		if(Mobile[i] == playerid)
		{
			Mobile[playerid] = i;
			format(stringer1, 128,"%s поднял трубку мобильного", PlayerInfo[playerid][pName]);
			SendClientMessage(i,COLOR_GRAD2, stringer1);
			format(stringer1, 90, "%s ответил на звонок", PlayerInfo[playerid][pName]);
			ProxDetector(30.0, playerid, stringer1, COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW);
			if(!IsPlayerInAnyVehicle(playerid)) SetPlayerSpecialAction(playerid, SPECIAL_ACTION_USECELLPHONE);
			return true;
		}
	}
	return true;
}
CMD:hangup(playerid, params[])
{
	if(Mobile[playerid] == -1) return SendClientMessage(playerid, COLOR_GREY, "Вы не разговариваете по телефону!");
	new caller = Mobile[playerid];
	if(IsPlayerConnected(caller))
	{
		SendClientMessage(caller, COLOR_GRAD2, "Абонент положил трубку");
		SetPlayerSpecialAction(caller,SPECIAL_ACTION_STOPUSECELLPHONE);
		Mobile[caller] = -1;
		SendClientMessage(playerid,  COLOR_GRAD2, "Вы положили трубку");
		Mobile[playerid] = -1;
		SetPlayerSpecialAction(playerid,SPECIAL_ACTION_STOPUSECELLPHONE);
		CellTime[caller] = 0;
		CellTime[playerid] = 0;
		return true;
	}
	SetPlayerSpecialAction(playerid,SPECIAL_ACTION_STOPUSECELLPHONE);
	TalkingLive[playerid] = INVALID_PLAYER_ID;
	TalkingLivels[playerid] = INVALID_PLAYER_ID;
	zvonok[playerid] = 0;
	Tel[playerid] = INVALID_PLAYER_ID;
	return true;
}
CMD:kickpb(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 4) return true;
	if(sscanf(params, "d",params[0])) return	SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /kickpb [id]");
	if(TeamPain[params[0]] == 0 && StartPaintBall == 0) return SendClientMessage(playerid,COLOR_GREY,"Игрок не участвует в PaintBall.");
	if(!IsPlayerConnected(params[0])) return true;
	if(PlayerInfo[params[0]][pAdmin] > PlayerInfo[playerid][pAdmin]) return SendClientMessage(playerid, COLOR_GRAD2, "Администратор не может быть дисквалефицирован!");
	format(stringer1, sizeof(stringer1), "Администратор {FF0000}%s {FFFFFF}дисквалифицировал с PaintBall игрока {FF0000}%s{FFFFFF}.",PlayerInfo[playerid][pName],PlayerInfo[params[0]][pName]);
	SendClientMessageToAll(-1,stringer1);
	if(TeamPain[params[0]] == 1) BluePlayer --;
	if(TeamPain[params[0]] == 2) RedPlayer --;
	TeamPain[params[0]] = 0;
	KillPain[params[0]] = 0;
	DeathPain[params[0]] = 0;
	SetPlayerPos(params[0], 951.6490,-1755.6156,13.5469);
	TextDrawHideForPlayer(params[0], BlueTeam);
	TextDrawHideForPlayer(params[0], RedTeam);
	if(PlayerInfo[params[0]][pMember] != 0) SetPlayerSkin(params[0], PlayerInfo[params[0]][pModel]);
	else SetPlayerSkin(params[0], PlayerInfo[params[0]][pChar]);
	SetPlayerToTeamColor(params[0]);
	return true;
}
CMD:hhelp(playerid, params[])
{
	if(PlayerInfo[playerid][pHelper] < 1) return true;
	ShowPlayerDialog(playerid, 7000, DIALOG_STYLE_LIST, "Помощь хелперу", "{FFD700} [1] Агент поддержки\n [2] Агент поддержки\n [3] Агент поддержки\n [4] Агент поддержки\n [8] {FF0000}Главный хелпер", "Ок", "");
	return true;
}
CMD:leaders(playerid, params[])
{
	SendClientMessage(playerid,COLOR_WHITE,"========== РУКОВОДИТЕЛЬ ФРАКЦИИ ==========");
	new b=0,ttext[32];
	PlayerForeach(i)
	{
		if(PlayerInfo[i][pAdmin] > 0) continue;
		if(PlayerInfo[i][pLeader] > 0)
		{
			switch(PlayerInfo[i][pLeader])
			{
			case 1: ttext = "{2641FE}LSPD";
			case 2: ttext = "{313131}ФБР";
			case 3: ttext = "{33AA33}Армия: Авианосец";
			case 4: ttext = "{A52A2A}МЧС";
			case 5: ttext = "{DDA701}LCN";
			case 6: ttext = "{FF0000}Yakuza";
			case 7: ttext = "{114D71}Мэрия";
			case 8: ttext = "{B313E7}Casino Rich";
			case 10: ttext = "{2641FE}SFPD";
			case 11: ttext = "{139BEC}Инструкторы";
			case 12: ttext = "{8813E7}The Ballas";
			case 13: ttext = "{DBD604}The Vagos";
			case 14: ttext = "{B4B5B7}Русская мафия";
			case 15: ttext = "{009F00}The Groove";
			case 16: ttext = "{40848B}San News";
			case 17: ttext = "{01FCFF}The Aztecas";
			case 18: ttext = "{83BFBF}The Rifa";
			case 19: ttext = "{33AA33}Армия: Зона 51";
			case 21: ttext = "{2641FE}LVPD";
			case 23: ttext = "{708090}Хитман";
			case 26: ttext = "{708090}Правительство";
			default: ttext = "{FF0000}Неизвестно";
			}
			b++;
			SendMes(playerid,COLOR_GREY,"%s - %s[%d]",ttext,PlayerInfo[i][pName],i);
		}
	}
	if(b>0) SendMes(playerid,COLOR_GREY,"В сети всего %d лидеров.",b);
	else return SendMes(playerid,COLOR_GREY,"Нету ни кого из лидеров в сети.");
	return true;
}
CMD:clear(playerid, params[])
{
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_FADE4, "Используйте: /clear [id игрока]");
	if(!IsPlayerConnected(params[0])) return true;
	if(params[0] == INVALID_PLAYER_ID) return true;
	if(IsACop(playerid) || PlayerInfo[playerid][pAdmin] >= 2)
	{
		SendMes(playerid, -1, "{3399FF}Вы сняли розыск с %s", PlayerInfo[params[0]][pName]);
		SendMes(params[0], -1, "{3399FF}Офицер %s снял с Вас розыск", PlayerInfo[playerid][pName]);
		PlayerInfo[params[0]][pWanted] = 0;
		WantedPoints[params[0]] = 0;
		WantedLevel[params[0]] = 0;
		SetPlayerWantedLevel(params[0], 0);
	}
	return true;
}
CMD:time(playerid,params[])
{
	if(GetPlayerState(playerid) == PLAYER_STATE_ONFOOT) ApplyAnimation(playerid,"COP_AMBIENT","Coplook_watch",4.1,0,0,0,0,0,1);
	format(stringer1, sizeof(stringer1), "%s завернув рукав, посмотрел(а) на часы", PlayerInfo[playerid][pName]);
	ProxDetector(25.0, playerid, stringer1, COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW);
	new jail = PlayerInfo[playerid][pJailTime];
	new hour,minuite,second;
	new year, month,day, mtext[20];
	getdate(year, month, day);
	gettime(hour,minuite,second);
	FixHour(hour);
	hour = shifthour;
	switch(month)
	{
	case 1: mtext = "January";
	case 2: mtext = "February";
	case 3: mtext = "March";
	case 4: mtext = "April";
	case 5: mtext = "May";
	case 6: mtext = "June";
	case 7: mtext = "July";
	case 8: mtext = "August";
	case 9: mtext = "September";
	case 10: mtext = "October";
	case 11: mtext = "November";
	case 12: mtext = "December";
	}
	if(PlayerInfo[playerid][pJailTime] > 1) format(stringer1, sizeof(stringer1), "~y~%02d %s~n~~g~%02d:%02d~n~~w~%02d sec",day, mtext,hour, minuite, jail);
	else format(stringer1, sizeof(stringer1), "~y~%02d %s~n~~g~%02d:%02d",day, mtext,hour, minuite);
	GameTextForPlayer(playerid, stringer1, 5000, 1);
	return true;
}
CMD:directory(playerid, params[])
{
	ShowPlayerDialog(playerid,5454,DIALOG_STYLE_LIST,"{CCFF00}Игровой справочник","{99FF99}Государственные сотрудники:{FFFFFF}\n1) Адвокаты\n2) Медики\n3) Пресса\n4) Агенты ФБР\n \n{99FF99}Рабочая группа:{FFFFFF}\n1) Механики\n2) Таксисты\n3) Развозчики продуктов\n \n{99FF99}Руководство:{FFFFFF}\n1) Администрация\n2) Лидеры","Далее","Скрыть");
	return true;
}
CMD:changeskin(playerid, params[])
{
	if(!PlayerInfo[playerid][pMember]) return SendClientMessage(playerid,COLOR_WHITE,"Вы не состоите во организации");
	new fractionid = PlayerInfo[playerid][pMember] - 1;
	if(!IsAbleToGiveSkin(playerid)) return SendClientMessage(playerid,COLOR_WHITE,"Ваш ранг недостаточен");
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_WHITE, "Используйте: /changeskin [id игрока]");
	if(!IsPlayerConnected(params[0])) return true;
	if(params[0] == INVALID_PLAYER_ID) return true;
	if(!ProxDetectorS(8.0, playerid, params[0]) || GetPlayerVirtualWorld(playerid) != GetPlayerVirtualWorld(params[0])) return SendClientMessage(playerid,COLOR_WHITE,"Вы далеко друг от друга");
	if(PlayerInfo[params[0]][pMember] != PlayerInfo[playerid][pMember]) return SendClientMessage(playerid,COLOR_WHITE,"Игрок не состоит в вашей организации");
	if(PlayerInfo[params[0]][pRank] >= PlayerInfo[playerid][pRank] && params[0] != playerid) return SendClientMessage(playerid,COLOR_WHITE,"Ваш ранг недостаточен");
	SetPVarInt(playerid,"actplayerid",params[0]);
	new mes[128];
	for(new i;i<8;i++)
	{
		new skinid = gFractionSkin[fractionid][i];
		if(!skinid) break;
		if(skinid == PlayerInfo[params[0]][pModel])
		{
			if(!i) format(mes,sizeof(mes),"{33AA33}Скин %d [%d]",i+1,skinid);
			else format(mes,sizeof(mes),"%s\n{33AA33}Скин %d [%d]",mes,i+1,skinid);
		}
		else
		{
			if(!i) format(mes,sizeof(mes),"Скин %d [%d]",i+1,skinid);
			else format(mes,sizeof(mes),"%s\nСкин %d [%d]",mes,i+1,skinid);
		}
	}
	ShowPlayerDialog(playerid,2213,2,PlayerInfo[params[0]][pName],mes,"OK","Скрыть");
	return true;
}
CMD:bizstats(playerid, params[])
{
	new bouse = PlayerInfo[playerid][pPbiskey];
	if(bouse == 255)  return SendClientMessage(playerid, COLOR_GREY, "У вас нет бизнеса!");
	if(bouse != 255) PrintBizInfo(playerid,bouse);
	return true;
}
CMD:bizlock(playerid, params[])
{
	for(new i = 0; i < sizeof(Business); i++)
	{
		if(PlayerToPoint(3, playerid,Business[i][bEntranceX], Business[i][bEntranceY], Business[i][bEntranceZ]) || PlayerToPoint(3, playerid,Business[i][bExitX], Business[i][bExitY], Business[i][bExitZ]))
		{
			if(PlayerInfo[playerid][pPbiskey] == i || PlayerInfo[playerid][pMember] == 2 && PlayerInfo[playerid][pRank] >= 5)
			{
				if(Business[i][bLocked] == 1)
				{
					Business[i][bLocked] = 0;
					SendClientMessage(playerid, COLOR_GRAD1, "Вы открыли бизнес");
					PlayerPlaySound(playerid, 1145, 0.0, 0.0, 0.0);
					return true;
				}
				if(Business[i][bLocked] == 0)
				{
					Business[i][bLocked] = 1;
					SendClientMessage(playerid, COLOR_GRAD1, "Вы закрыли бизнес");
					PlayerPlaySound(playerid, 1145, 0.0, 0.0, 0.0);
					return true;
				}
			}
			else return SendClientMessage(playerid, COLOR_GRAD1, "Бизнес закрыт");
		}
	}
	return true;
}
CMD:buyhouse(playerid, params[])
{
	new platas;
	new Float:oldposx, Float:oldposy, Float:oldposz;
	GetPlayerPos(playerid, oldposx, oldposy, oldposz);
	for(new h = 0; h < sizeof(HomeInfo); h++)
	{
		if(PlayerToPoint(2.0, playerid, HomeInfo[h][hEntrancex], HomeInfo[h][hEntrancey], HomeInfo[h][hEntrancez]) && HomeInfo[h][hOwned] == 0)
		{
			if(PlayerInfo[playerid][pPhousekey] != 255 && strcmp(PlayerInfo[playerid][pName], HomeInfo[PlayerInfo[playerid][pPhousekey]][hOwner], true) == 0)
			{
				SendClientMessage(playerid, COLOR_YELLOW, "У вас уже есть квартира...");
				SendClientMessage(playerid, COLOR_WHITE, "(( /hmenu - [3] Продать квартиру ))");
				return true;
			}
			if(PlayerInfo[playerid][pCash] > HomeInfo[h][hValue])
			{
				if(PlayerInfo[playerid][pCash] < HomeInfo[h][hValue]) return	SendClientMessage(playerid, COLOR_WHITE, "У вас нет столько денег на руках!");
				HomeInfo[h][hOwned] = 1;
				HomeInfo[h][hHel] = 0;
				HomeInfo[h][hTakings] = 400;
				strmid(HomeInfo[h][hOwner], PlayerInfo[playerid][pName], 0, strlen(PlayerInfo[playerid][pName]), 255);
				PlayerInfo[playerid][pCash] -= HomeInfo[h][hValue];
				SetPlayerInterior(playerid,HomeInfo[h][hInt]);
				SetPlayerPos(playerid,HomeInfo[h][hExitx],HomeInfo[h][hExity],HomeInfo[h][hExitz]);
				PlayerInfo[playerid][pInt] = HomeInfo[h][hInt];
				SetPlayerVirtualWorld(playerid, h+50);
				PlayerInfo[playerid][pLocal] = h;
				switch(HomeInfo[h][hKlass])
				{
				case 1: platas = 100;
				case 2: platas = 150;
				case 3: platas = 100;
				case 4: platas = 200;
				case 5: platas = 0;
				default: platas = 50;
				}
				SendClientMessage(playerid, COLOR_WHITE, "Поздравляем с покупкой!");
				SendMes(playerid,COLOR_YELLOW, "Внимание! Теперь каждый час со счёта вашего дома будут снимать комунальные платежи, в размере %d вирт", platas);
				SendClientMessage(playerid,COLOR_YELLOW,"Если на счету недостаточно денег, вас выселят");
				SendClientMessage(playerid,COLOR_YELLOW,"Пополнить домашний счёт или узнать баланс можно через банк/банкомат (помощь: /mm => команды)");
				GameTextForPlayer(playerid, "~w~WELCOME HOME~n~~w~PRINT: ~g~/hmenu", 5000, 4);
				if(PlayerInfo[playerid][pCar] == 0) PlayerInfo[playerid][pCar] = 462;
				PlayerInfo[playerid][pPhousekey] = h;
				new house = PlayerInfo[playerid][pPhousekey];
				caridhouse[playerid] = CreateVehicle(PlayerInfo[playerid][pCar], HomeInfo[house][hCarx], HomeInfo[house][hCary], HomeInfo[house][hCarz], HomeInfo[house][hCarc], PlayerInfo[playerid][pVcol1], PlayerInfo[playerid][pVcol2],7200);
				LockCar(caridhouse[playerid]);
				Fuell[caridhouse[playerid]] = 300;
				PlayerInfo[playerid][pFuelcar] = 300;
				BuyHouse(house);
				OnPlayerUpdateRL(playerid);
				SaveHouse(h);
				return true;
			}
		}
	}
	return true;
}
CMD:buytune(playerid, params[])
{
	if(!PlayerToPoint(2.0,playerid,605.2967,-17.4146,1000.8986)) return true;
	if(PlayerInfo[playerid][pCar] == 0) return SendClientMessage(playerid, -1, "Ошибка: У Вас нет машины");
	ShowPlayerDialog(playerid, 9594, DIALOG_STYLE_LIST, "Тюнинг авто", "[1] Установка колёс\n[2] Установка спойлера\n[3] Установка бампера\n[4] Покраска\n[5] Установка капота\n[6] Установка воздухборников\n[7] Установка боковых юбок\n[8] Установка выхлопных труб\n[9] Дополнительные фары\n[10] Ремонт двигателя [500 000 вирт]\n[11] INFO\n[12] Закись азота\n[13] Гидравлика [200 000]\n[14] Покрасочные работы", "Далее", "Скрыть");
	SendClientMessage(playerid, COLOR_WHITE, "Ваши заказы должен установить механик!");
	return true;
}
CMD:buydrugs(playerid, params[])
{
	if(!IsAGang(playerid)) return SendClientMessage(playerid,COLOR_GRAD1,"Вы не бандит!");
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /buydrugs [количество]");
	if(!PlayerToPoint(3.0,playerid,322.1280,1118.8314,1083.8828)) return SendClientMessage(playerid, COLOR_GRAD1, "Вы не в притоне!");
	if(PlayerInfo[playerid][pCash] < 100)  return SendClientMessage(playerid,COLOR_GRAD1,"У вас недостаточно денег");
	if(PlayerInfo[playerid][pDrugs] >= 50) return SendClientMessage(playerid, COLOR_GREY, "Нельзя купить больше");
	if(params[0] > 150 || params[0] < 1) return SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 или больше 150!");
	if(PlayerInfo[playerid][pCash] < params[0]*35) return SendClientMessage(playerid, COLOR_GREY, "У вас нет столько денег!");
	PlayerInfo[playerid][pCash] -=params[0]*35;
	PlayerInfo[playerid][pDrugs] += params[0];
	SendMes(playerid,0x6ab1ffaa,"Вы купили %d грамм наркотиков за %d вирт", params[0],params[0]*35);
	return true;
}
CMD:lomka(playerid, params[])
{
	if(PlayerInfo[playerid][pMember] != 4) return true;
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /lomka [id]");
	if(!IsPlayerConnected(params[0]) || params[0] == INVALID_PLAYER_ID || params[0] == playerid) return true;
	PlayerStoned[params[0]] = 0;
	SetPlayerWeather(params[0],14);
	SendMes(playerid,COLOR_GREEN,"Вы спасли %s от ломки",PlayerInfo[params[0]][pName]);
	SendMes(params[0],COLOR_GREEN,"Медик %s спас вас от ломки",PlayerInfo[playerid][pName]);
	startnarko[params[0]] = 0;
	send[params[0]] = 0;
	ApplyAnimation(params[0],"CARRY","crry_prtial",4.0,0,0,0,0,0,1);
	return true;
}
CMD:report(playerid, params[])
{
	if(PlayerInfo[playerid][pReportTime] > 0) return SendClientMessage(playerid, COLOR_GREY, "У вас заблокирован репорт!");
	if(GetPVarInt(playerid,"AntiFloodRep") > gettime()) return SendClientMessage(playerid, COLOR_GREY, "На отправку жалобы существует лимит времени, пожалуйста подождите.");
	if(sscanf(params, "s[128]",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /report [текст]");
	SendClientMessage(playerid, COLOR_LIGHTRED,"Ваш репорт успешно создан. Пожалуйста ожидайте ответа.");
	format(stringer, sizeof(stringer), "[!] Репорт от %s[%d]: %s", PlayerInfo[playerid][pName], playerid, params[0]);
	SCMAH(COLOR_BLUE,stringer);
	SetPVarInt(playerid,"AntiFloodRep",gettime() + 10);
	return true;
}
CMD:clist(playerid, params[])
{
