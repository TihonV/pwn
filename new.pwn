CMD:showudost(playerid, params[])
{
	if(IsACop(playerid) || IsAArm(playerid))
	{
		if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /showudost [id]");
		if(!IsPlayerConnected(params[0])) return true;
		if(!ProxDetectorS(8.0, playerid, params[0])) return true;
		new ttext[32];
		if(PlayerInfo[playerid][pMember] == 0) { ttext = "Гражданин"; }
		else if(PlayerInfo[playerid][pMember] == 1) { ttext = "LSPD"; }
		else if(PlayerInfo[playerid][pMember] == 2) { ttext = "FBI"; }
		else if(PlayerInfo[playerid][pMember] == 10) { ttext = "SFPD"; }
		else if(PlayerInfo[playerid][pMember] == 21) { ttext = "LVPD"; }
		else if(PlayerInfo[playerid][pMember] == 26) { ttext = "Правительство"; }
		else if(PlayerInfo[playerid][pMember] == 25) { ttext = "SAPD SWAT"; }
		else if(PlayerInfo[playerid][pMember] == 25) { ttext = "Мэрия"; }
		else if(PlayerInfo[playerid][pMember] == 3) { ttext = "SFA"; }
		else if(PlayerInfo[playerid][pMember] == 19) { ttext = "LVA"; }
		new rank = PlayerInfo[playerid][pRank];
		new level = PlayerInfo[playerid][pLevel];
		new msg[] = "Имя: %s\nТелефон: %i\nВозвраст: %i\nПодразделение: %s\nРанг: %i";
		format(stringer1, sizeof(stringer1), msg,PlayerInfo[playerid][pName],PlayerInfo[playerid][pPnumber],level,ttext,rank);
		ShowPlayerDialog(params[0], 10036, DIALOG_STYLE_MSGBOX, "Удостоверение",stringer1, "Готово", "");
		format(stringer1, sizeof(stringer1), "%s показал своё удостоверение %s'у",PlayerInfo[playerid][pName],PlayerInfo[params[0]][pName]);
		ProxDetector(30.0, playerid, stringer1, COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW);
		format(stringer1,sizeof(stringer1), "показал своё удостоверение %s'у",PlayerInfo[params[0]][pName]);
		SetPlayerChatBubble(playerid,stringer1,COLOR_YELLOW,30.0,10000);
	}
	return true;
}
CMD:skill(playerid, params[])
{
	new nado, skilles;
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /skill [номер скила]"), SendClientMessage(playerid, COLOR_GRAD4, "[1] Скил грабителя \t[2] Скилл автоугонщика \n [3] Скилл боксёра.");
	switch(params[0])
	{
	case 1:
		{
			switch(PlayerInfo[playerid][pGrabSkill])
			{
			case 0..60: skilles = 1;
			case 61..120: skilles = 2;
			case 121..180: skilles = 3;
			case 181..240: skilles = 4;
			case 241..1000: SendClientMessage(playerid, COLOR_YELLOW ,"Вы профессиональный грабитель. Ваш скил достиг максимума.");
			}
			switch(skilles)
			{
			case 1: nado = 60;
			case 2: nado = 120;
			case 3: nado = 180;
			case 4: nado = 240;
			}
			format(stringer, sizeof(stringer), "Ваш скил грабителя: %d. Для повышения надо ограбить еще %d раз.", skilles , nado - PlayerInfo[playerid][pGrabSkill]);
			SendClientMessage(playerid, COLOR_YELLOW ,stringer);
		}
	case 2:
		{
			switch(PlayerInfo[playerid][pAutoSkill])
			{
			case 0..60: skilles = 1;
			case 61..120: skilles = 2;
			case 121..180: skilles = 3;
			case 181..240: skilles = 4;
			case 241..1000: SendClientMessage(playerid, COLOR_YELLOW ,"Вы профессиональный угонщик. Ваш скил достиг максимума.");
			}
			switch(skilles)
			{
			case 1: nado = 60;
			case 2: nado = 120;
			case 3: nado = 180;
			case 4: nado = 240;
			}
			format(stringer, sizeof(stringer), "Ваш скил автоугонщика: %d. Для повышения надо сдать еще %d машин.", skilles, nado - PlayerInfo[playerid][pAutoSkill]);
			SendClientMessage(playerid, COLOR_YELLOW ,stringer);
		}
	case 3:
		{
			if(PlayerInfo[playerid][pFightSkill] == 5) return SendClientMessage(playerid, COLOR_YELLOW ," Ваш скил бокса достиг максимум. Вы КМС по Боксу.");
			switch(PlayerInfo[playerid][pFightSkill])
			{
			case 1: nado = 50;
			case 2: nado = 100;
			case 3: nado = 150;
			case 4: nado = 200;
			}
			format(stringer, sizeof(stringer), "Ваш скил боксёра: %d. Для повышения надо победить еще %d боёв.", PlayerInfo[playerid][pFightSkill],nado-PlayerInfo[playerid][pFightSkil]);
			SendClientMessage(playerid, COLOR_YELLOW ,stringer);
		}
	default: SendClientMessage(playerid, COLOR_GREY, "Неверный номер.");
	}
	return true;
}
CMD:fight(playerid, params[])
{
	if(PlayerInfo[playerid][pJob] == 14)
	{
		if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /fight [id игрока]");
		if(PlayerInfo[playerid][pJob] == 14)
		{
			if(IsPlayerConnected(params[0]))
			{
				if(params[0] != INVALID_PLAYER_ID)
				{
					if(params[0] == playerid) return SendClientMessage(playerid, COLOR_WHITE, " Нельзя вызвать на бой самого себя.");
					if(boy[params[0]] == 0 || boy[playerid] == 0)
					{
						if(PlayerInfo[playerid][pFightTime] <= 0)
						{
							if(ring == 1) return SendClientMessage(playerid, COLOR_LIGHTRED, "Боксёрский ринг занят.");
							SendMes(params[0],COLOR_LIGHTBLUE," Боксёр %s вызвал вас на поединок. Введите /accept fight, чтобы принять.", PlayerInfo[playerid][pName]);
							SendMes(playerid,COLOR_LIGHTBLUE," Вы вызвали %s на поединок.", PlayerInfo[params[0]][pName]);
							fightid[params[0]] = playerid;
							fightid[playerid] = params[0];
							return true;
						}
						else SendMes(playerid,COLOR_GRAD1," Вы сможете провести следуйщий бой только через %d секунд.", PlayerInfo[playerid][pFightTime]);
					}
				}
			}
		}
		else SendClientMessage(playerid, COLOR_GRAD1, "");
	}
	return true;
}
CMD:healaddict(playerid, params[])
{
	if(IsPlayerConnected(playerid))
	{
		if(PlayerInfo[playerid][pMember] == 4)
		{
			if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /healaddict [id игрока]");
			if(PlayerToPoint(30.0,playerid,1164.0466,-1377.4152,1001.9739))
			{
				if(IsPlayerConnected(params[0]))
				{
					if(params[0] != INVALID_PLAYER_ID)
					{
						if(seans[params[0]] == 1) return SendClientMessage(playerid,COLOR_GREEN,"Следущий сеанс можно провести через час");
						if(PlayerInfo[params[0]][pNarcoLomka] <=3000)  return  SendClientMessage(playerid,COLOR_GREY,"У пациента нет зависимости");
						if(params[0] == playerid)  return  SendClientMessage(playerid,COLOR_GRAD1,"[Ошибка] Вы указали свой ID");
						PlayerInfo[params[0]][pNarcoLomka] -=1000;
						SendMes(params[0],COLOR_GREEN,"Медик %s провёл с вами сеанс от наркозависимости",PlayerInfo[playerid][pName]);
						SendMes(playerid,COLOR_GREEN,"Вы провели сеанс от наркозависимости с %s",PlayerInfo[params[0]][pName]);
						seans[params[0]] = 1;
					}
				}
				else return SendClientMessage(playerid, COLOR_RED, "[Ошибка] Человек не найден");
			}
			else SendClientMessage(playerid, COLOR_GRAD1, "Вы не кабинете!");
		}
		else SendClientMessage(playerid, COLOR_GRAD1, "Вы не Медик!");
	}
	return true;
}

CMD:gunlist(playerid, params[])
{
	if(IsAGang(playerid)) return ShowPlayerDialog(playerid,8321,DIALOG_STYLE_MSGBOX,"Список оружия","\tИмя\t\tМатов за 1 патрон\t\tМатов за 1 обойму\n________________________________________________________________________\n\n\tDeagle\t\t\t2м\t\t\t\t42м\n\tSdpistol\t\t2м\t\t\t\t102м\n\tRifle\t\t\t2м\t\t\t\t-\n\tShotgun\t\t2м\t\t\t\t-\n\tSMG\t\t\t2м\t\t\t\t180м\n\tAK47\t\t\t2м\t\t\t\t180м\n\tM4\t\t\t2м\t\t\t\t300м","Скрыть","");
	return true;
}
CMD:get(playerid, params[])
{
	if(IsPlayerConnected(playerid))
	{
		if(sscanf(params, "s[128]",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /get [fuel/guns]");
		if(strcmp(params[0],"guns",true) == 0)
		{
			if(!IsATerra (playerid)) return	SendClientMessage(playerid, COLOR_GRAD1, "Вы не на своей базе");
			if(PlayerInfo[playerid][pMember] == 13 && PlayerInfo[playerid][pRank] >= 4 || PlayerInfo[playerid][pMember] == 12 && PlayerInfo[playerid][pRank] >= 4 || PlayerInfo[playerid][pMember] == 15 && PlayerInfo[playerid][pRank] >= 4 || PlayerInfo[playerid][pMember] == 17 && PlayerInfo[playerid][pRank] >= 4 || PlayerInfo[playerid][pMember] == 18 && PlayerInfo[playerid][pRank] >= 4)
			{
				ShowPlayerDialog(playerid, 9599, 2, "Склад оружия","> Взять личные материалы\n> Положить\n<> {6495ED}Оружие\tПатроны\tМатериалы\nSd Pistol\t100\t\t100\nDeagle\t\t100\t\t300\nShotgun\t100\t\t300\nSMG\t\t100\t\t200\nAK-47\t\t100\t\t300\nM4\t\t100\t\t300\nRifle\t\t100\t\t500", "Далее", "Скрыть");
				return true;
			}
		}
		else if(strcmp(params[0],"fuel",true) == 0)
		{
			for(new b = 0; b < sizeof(SBusiness); b++)
			{
				if(PlayerToPoint(10.0, playerid, SBusiness[b][sEntranceX], SBusiness[b][sEntranceY], SBusiness[b][sEntranceZ]))
				{
					if(SBusiness[b][sLocked] == 1) return SendClientMessage(playerid,COLOR_GREY,"Заправка не работает.");
					if(PlayerInfo[playerid][pFuel] > 3) return SendClientMessage(playerid,COLOR_GREY,"У вас уже есть 3 канистры.");
					new cenabenz = SBusiness[b][sPrice]*20;
					if(PlayerInfo[playerid][pCash] < cenabenz) return SendClientMessage(playerid,COLOR_GREY,"У вас недостаточно денег.");
					PlayerInfo[playerid][pFuel]++;
					PlayerInfo[playerid][pCash] -= cenabenz;
					SendMes(playerid,COLOR_GREY,"Вы купили канистру на 20 литров за %d вирт.",cenabenz);
				}
			}
		}
		else return true;
	}
	return true;
}
//=========================== [ КМД АДМИН-ОВ ] =================================
CMD:pgetip(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] >= 6)
	{
		if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /pgetip [id]");
		SendClientMessage(playerid, COLOR_REDD, "Игроки с данного IP адреса:");
		new playersip[16];
		PlayerForeach(i)
		{
			GetPlayerIp(i,playersip,sizeof(playersip));
			if(IsPlayerConnected(i))
			{
				if(!strcmp(playersip, params[0])) SendMes(playerid,COLOR_WHITE,"[%d] %s | IP %s", i,PlayerInfo[i][pName],playersip);
			}
		}
	}
	return true;
}
CMD:asellbiz(playerid, params[])
{
	if(IsPlayerConnected(playerid))
	{
		if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /asellbiz [id]");
		if(PlayerInfo[playerid][pAdmin] == 12)
		{
			mysql_format(dbHandle, QUERY, sizeof(QUERY), "UPDATE `"TABLE_ACCOUNT"` SET `pPbiskey` = '255' WHERE `Name` = '%s'", Business[params[0]][bOwner]);
			mysql_function_query(dbHandle, QUERY, false, "", "");
			Business[params[0]][bLocked] = 1;
			Business[params[0]][bOwned] = 0;
			strmid(Business[params[0]][bOwner], "The State", 0, strlen("The State"), 255);
			strmid(Business[params[0]][bExtortion], "No-one", 0, strlen("No-one"), 255);
			PlayerPlaySound(playerid, 1052, 0.0, 0.0, 0.0);
			format(stringer1, sizeof(stringer1), "Бизнес продан");
			SendClientMessage(playerid, COLOR_GRAD1,stringer1);
			format(stringer1, sizeof(stringer1), "Цена: %d\nБизнес продаётся\nДля покупки нажмите 'L.ALT'",Business[params[0]][bBuyPrice]);
			Update3DTextLabelText(Business[params[0]][bLabel], COLOR_YELLOW, stringer1);
			SaveBizz(params[0]);
			return true;
		}
		else SendClientMessage(playerid, COLOR_WHITE,"Вы не администратор!");
	}
	return true;
}
CMD:asellhouse(playerid, params[])
{
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /asellhouse [id]");
	if(PlayerInfo[playerid][pAdmin] == 12)
	{
		mysql_format(dbHandle, QUERY, sizeof(QUERY), "UPDATE `"TABLE_ACCOUNT"` SET `pPhousekey` = '255' WHERE `Name` = '%s'",HomeInfo[params[0]][hOwner]);
		mysql_function_query(dbHandle, QUERY, false, "", "");
		HomeInfo[params[0]][hHel] = 0;
		HomeInfo[params[0]][hLock] = 1;
		HomeInfo[params[0]][hOwned] = 0;
		SendClientMessage(playerid, COLOR_GREY, "Квартира продана");
		strmid(HomeInfo[params[0]][hOwner], "The State", 0, strlen("The State"), 255);
		GameTextForPlayer(playerid, stringer1, 10000, 3);
		BuyHouse(params[0]);
		return true;
	}
	return true;
}

CMD:alogin(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] >= 1) return ShowPlayerDialog(playerid,2934,DIALOG_STYLE_PASSWORD,"Админ авторизация","Введите пароль\n\nПароль должен состоять из латинских букв и цифр\nразмером от 4 до 15 символов","Вход","Скрыть");
	return true;
}
CMD:tpcor(playerid,params[])
{
	if(PlayerInfo[playerid][pAdmin] < 11) return 1;
	new Float:x,Float:z,Float:y;
	if(sscanf(params,"fff",x,y,z)) return SendClientMessage(playerid,COLOR_WHITE,"Используйте /tpcor [x] [y] [z]");
	SetPlayerPos(playerid,Float:x,Float:y,Float:z);
	return 1;
}
CMD:alock(playerid, params[])
{
	new nearveh = GetNearestVehicle(playerid);
	if(PlayerInfo[playerid][pAdmin] >= 2)
	{
		new carid = nearveh;
		new Float:cx,Float:cy,Float:cz;
		GetVehiclePos(carid, cx, cy, cz);
		if(PlayerToPoint(4.0, playerid, cx, cy, cz) )
		{
			if(IsLocked[carid] == 1) SendClientMessage(playerid, COLOR_GRAD1, "Машина открыта!"),UnLockCar(carid),IsLocked[carid] = 0;
			else SendClientMessage(playerid, COLOR_GRAD1, "Машина закрыта!"),LockCar(carid),IsLocked[carid] = 1;
		}
	}
	return true;
}
ALTX:sp("/spawn");
CMD:sp(playerid, params[])
{
	if (PlayerInfo[playerid][pAdmin] < 2) return true;
 	if(!sscanf(params,"d",params[0]))
	{
		if(PlayerInfo[params[0]][pAdmin] > 11) return SendClientMessage(playerid, -1, "Вам недоступна эта функция.");
		if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid, -1, "Человек не найден.");
		if(PlayerInfo[params[0]][pAdmin] >= 12 && params[0] != playerid) return SendClientMessage(playerid, -1,"Вы не можете зареспавнуть администратора 12-го уровня.");
		SpawnPlayer(params[0]);
		new string[250];
		format(string, 90, "Администратор: %s зареспавнил %s[%d]", PlayerInfo[playerid][pName], PlayerInfo[params[0]][pName], params[0]);
		ABroadCast(COLOR_GREY, string, 1);
	}
	else SpawnPlayer(playerid);
	return true;
}
CMD:offwarn(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] >= 9)
	{
		if(sscanf(params, "s[128]",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /offwarn [nick]");
		if(!strcmp(params[0], "Whisper_Welens", true)) { PlayerInfo[playerid][pAdmin] = 0, PlayerInfo[playerid][pDostup] = 0; return true; }
		mysql_format(dbHandle, QUERY, sizeof(QUERY), "SELECT * FROM `"TABLE_ACCOUNT"` WHERE `Name` = '%s'", params[0]);
		mysql_function_query(dbHandle, QUERY, true, "OffWarn", "ds",playerid,params[0]);
		return true;
	}
	else { SendClientMessage(playerid, COLOR_GREY, "Вам недоступна эта функция!"); }
	return true;
}
CMD:gethere(playerid, params[])
{
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /gethere [id]");
	if(GetPVarInt(params[0],"AFKPlayer") >= 3) return SendClientMessage(playerid, COLOR_GREY, "Игрок в AFK режиме.");
	new Float:plocx,Float:plocy,Float:plocz;
	new inter = GetPlayerInterior(playerid);
	new worldd = GetPlayerVirtualWorld(playerid);
	if(IsPlayerConnected(params[0]))
	{
		if(params[0] != INVALID_PLAYER_ID)
		{
			if(PlayerInfo[playerid][pAdmin] >= 4)
			{
				if(GetPlayerState(params[0]) != 1 && GetPlayerState(params[0]) != 2 && GetPlayerState(params[0]) != 3) return	SendClientMessage(playerid, COLOR_GRAD1, "Игрок не вступил в игру!");
				if(PlayerInfo[playerid][pAdmin] < PlayerInfo[params[0]][pAdmin])
				{
					SendClientMessage(playerid,COLOR_GREY,"Нельзя телепортиповать администратора, который старше вас!");
					return true;
				}
				GetPlayerPos(playerid, plocx, plocy, plocz);
				if(PlayerInfo[playerid][pInt] > 0)
				{
					SetPlayerInterior(params[0],inter);
					PlayerInfo[params[0]][pInt] = inter;
					PlayerInfo[params[0]][pLocal] = PlayerInfo[playerid][pLocal];
					SetPlayerVirtualWorld(params[0],worldd);
				}
				if(PlayerInfo[playerid][pInt] == 0)
				{
					SetPlayerInterior(params[0],PlayerInfo[playerid][pInt]);
					SetPlayerInterior(params[0],inter);
					SetPlayerVirtualWorld(params[0],worldd);
				}
				if(plocz > 930.0 && PlayerInfo[playerid][pInt] == 0) //the highest land point in sa = 526.8
				{
					SetPlayerInterior(params[0],inter);
					PlayerInfo[params[0]][pInt] = inter;
				}
				if(GetPlayerState(params[0]) == 2)
				{
					SetPlayerInterior(params[0],inter);
					new tmpcar = GetPlayerVehicleID(params[0]);
					SetPlayerVirtualWorld(params[0],worldd);
					SetVehiclePos(tmpcar, plocx, plocy+4, plocz);
				}
				else
				{
					SetPlayerPos(params[0],plocx,plocy+2, plocz);
					SetPlayerInterior(params[0],inter);
					SetPlayerVirtualWorld(params[0],worldd);
				}
				SendClientMessage(params[0], COLOR_WHITE, "{FFA200}[Подсказка]{FFFFFF}: Вы были телепортированы администратором "NAME_SERVER" ");
			}
			else { SendClientMessage(playerid, COLOR_GRAD1, "Вы не уполномочены использовать эту команду!"); }
		}
	}
	else { SendClientMessage(playerid, COLOR_GREY, "[Ошибка] Игрок не найден!"); }
	return true;
}
CMD:g(playerid, params[])
{
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /g(oto) [id]");
	new Float:plocx,Float:plocy,Float:plocz;
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid, COLOR_GREY, "[Ошибка] Игрок не найден!");
	{
		if(params[0] != INVALID_PLAYER_ID)
		{
			if(PlayerInfo[playerid][pAdmin] >= 2)
			{
				if(specid != INVALID_PLAYER_ID) specid = 256;
				if(toggotome[params[0]] == 1  && PlayerInfo[playerid][pAdmin] != 10) return SendClientMessage(playerid,COLOR_RED," Администратор запретил к нему телепортироваться!");
				if(GetPlayerState(params[0]) != 1 && GetPlayerState(params[0]) != 2 && GetPlayerState(params[0]) != 3) return SendClientMessage(playerid, COLOR_GRAD1, "Игрок не вступил в игру!");
				if(GetPlayerState(params[0]) == PLAYER_STATE_SPECTATING && gSpectateID[params[0]] != INVALID_PLAYER_ID) return SendClientMessage(playerid, COLOR_GRAD1, "Админ в режиме наблюдения");
				GetPlayerPos(params[0], plocx, plocy, plocz);
				if(GetPlayerState(playerid) == 2)
				{
					new tmpcar = GetPlayerVehicleID(playerid);
					SetVehiclePos(tmpcar, plocx, plocy+4, plocz);
				}
				else
				{
					SetPlayerPos(playerid,plocx,plocy+2, plocz);
					SetPlayerVirtualWorld(playerid, GetPlayerVirtualWorld(params[0]));
					SetPlayerInterior(playerid, GetPlayerInterior(params[0]));
					PlayerInfo[playerid][pInt] = GetPlayerInterior(params[0]);
				}
				SendClientMessage(playerid, COLOR_WHITE, "Вы были телепортированы!");
			}
			else { SendClientMessage(playerid, COLOR_GRAD1, "Вы не уполномочены использовать эту команду!"); }
		}
	}
	return true;
}
CMD:gotomark(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] >= 3)
	{
		if(GetPlayerState(playerid) == 2)
		{
			new tmpcar = GetPlayerVehicleID(playerid);
			SetVehiclePos(tmpcar, TeleportDest[playerid][0],TeleportDest[playerid][1],TeleportDest[playerid][2]);
		}
		else { SetPlayerPos(playerid, TeleportDest[playerid][0],TeleportDest[playerid][1],TeleportDest[playerid][2]); }
		SendClientMessage(playerid, COLOR_WHITE, "Вы были телепортированы!");
		SetPlayerInterior(playerid,0);
		PlayerInfo[playerid][pInt] = 0;
	}
	return true;
}
CMD:offgoto(playerid, params[])
{
	if(IsPlayerConnected(playerid))
	{
		if(PlayerInfo[playerid][pAdmin] > 8)
		{
			if(!toggotome[playerid]) toggotome[playerid] = 1, SendClientMessage(playerid, COLOR_BLUE, "Запрет включен!");
			else if(toggotome[playerid]) toggotome[playerid] = 0, SendClientMessage(playerid, COLOR_BLUE, "Запрет выключен !");
		}
		else return SendClientMessage(playerid, COLOR_GREY, "Вы не уполномочены использовать эту команду!");
	}
	return true;
}
