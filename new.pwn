CMD:atm(playerid, params[])
{
	if(IsABankomat(playerid))
	{
		if(PlayerInfo[playerid][pBankKart] == 0) return ShowPlayerDialog(playerid, 2111, DIALOG_STYLE_INPUT, "Установка PIN-кода [ВТБ]", "\
			{39DE0B}Введи новый PIN-код:\n\n\
			{FFFFFF}Примечания :\n\
			- Длина PIN-кода должна быть ровно 6 цифр.\n\
			- PIN-код должен состоять только из цифр.\n\n\
			Введите PIN-код и запишите его..\
			", "Далее", "Скрыть");
		if(PlayerInfo[playerid][pBankKart] == 1) return ShowPlayerDialog(playerid, 2112, DIALOG_STYLE_INPUT, "Ввод PIN-кода lkz", "\
			Введи свой PIN-код:\
			", "Далее", "Скрыть");
		if(GetPlayerState(playerid) != PLAYER_STATE_ONFOOT) return true;
		ApplyAnimation(playerid, "CRIB", "CRIB_Use_Switch", 4.0, 0, 0, 0, 0, 0);
		ShowPlayerDialog(playerid, dBankomat, DIALOG_STYLE_LIST, "Банкомат", "[0] Снять наличные\n[1] Баланс\n[2] Домашний счёт", "Далее", "Скрыть");
		return true;
	}
	return true;
}
CMD:fuel(playerid, params[])
{
	if(IsPlayerConnected(playerid))
	{
		if(PlayerInfo[playerid][pAdmin] >= 8)
		{
			if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /fuel [id]");
			SetPlayerPos(playerid,SBusiness[params[0]][sEntranceX],SBusiness[params[0]][sEntranceY],SBusiness[params[0]][sEntranceZ]);
		}
	}
	return true;
}

CMD:fill(playerid, params[])
{
	if(IsPlayerConnected(playerid))
	{
		for(new b = 0; b < sizeof(SBusiness); b++)
		{
			if(PlayerToPoint(10.0, playerid, SBusiness[b][sEntranceX], SBusiness[b][sEntranceY], SBusiness[b][sEntranceZ]))
			{
				if(SBusiness[b][sLocked] == 1) return SendClientMessage(playerid,COLOR_GREY,"Заправка не работает.");
				new vehicleid = GetPlayerVehicleID(playerid);
				if(Fuell[vehicleid] > 98) return SendClientMessage(playerid,COLOR_GREY,"Вашему автомобилю не требуется заправка.");
				new Float:benz = 100.0 - Fuell[vehicleid];
				new cenabenz = SBusiness[b][sPrice]*floatround(benz);
				if(PlayerInfo[playerid][pCash] < cenabenz) return SendMes(playerid,COLOR_GREY,"У вас не хватает денег. Нужно %d вирт",cenabenz);
				PlayerInfo[playerid][pCash] -= cenabenz;
				SBusiness[b][sTill] += cenabenz;
				SBusiness[b][sBenz] -= floatround(benz);
				Fuell[vehicleid] += benz;
				SendMes(playerid,COLOR_GREY,"Вы успешно заправили свой транспорт на %.0f литров бензина за %d вирт.",benz,cenabenz);
				format(stringer1, sizeof(stringer1), "{FFFF00}%s\n{FFFFFF}Владелец: {32CD32}%s\nБензин: %d/10000\nСтоимость: %d вирт.\n\n{FFFFFF}[{32CD32}Заправка работает{FFFFFF}]",SBusiness[b][sMessage],SBusiness[b][sOwner],SBusiness[b][sBenz],SBusiness[b][sPriceBenz]);
				Update3DTextLabelText(SBusiness[b][sLabel], TEAM_GROVE_COLOR, stringer1);
			}
		}
	}
	return true;
}
CMD:sellfuel(playerid, params[])
{
	if(IsPlayerConnected(playerid))
	{
		if(PlayerInfo[playerid][pPsbiskey] == 255) return SendClientMessage(playerid,COLOR_GREY,"У вас нету заправки.");
		for(new b = 0; b < sizeof(SBusiness); b++)
		{
			if(PlayerToPoint(10.0, playerid, SBusiness[b][sEntranceX], SBusiness[b][sEntranceY], SBusiness[b][sEntranceZ]))
			{

				if(PlayerInfo[playerid][pPsbiskey] != b) return SendClientMessage(playerid,COLOR_GREY,"Вы не владелец этой заправки.");
				new nalogs = SBusiness[b][sBuyPrice]/10;
				PlayerInfo[playerid][pBank] += (SBusiness[b][sBuyPrice]-nalogs);
				PlayerInfo[playerid][pPsbiskey] = 255;
				SBusiness[b][sBuyPrice] = 1000000;
				SBusiness[b][sOwned] = 0;
				SBusiness[b][sLocked] = 1;
				SBusiness[b][sPrice] = 2500;
				SBusiness[b][sBenz] = 2500;
				SBusiness[b][sPriceBenz] = 2500;
				SBusiness[b][sTill] = 100000;
				strmid(SBusiness[b][sOwner], "No-one", 0, strlen("No-one"), 255);
				mysql_format(dbHandle, QUERY, sizeof(QUERY), "UPDATE `"TABLE_SBIZZ"` SET `sOwner` = 'No-one' WHERE sID = %i",b);
				mysql_function_query(dbHandle, QUERY, false, "", "");
				OnPlayerUpdateRL(playerid);
				SaveSBizz(b);
				UpdateSBizz();
				return true;
			}
		}
	}
	return true;
}
CMD:gps(playerid, params[])
{
	MeAction(playerid,"достал карту из кармана");
	SetPlayerAttachedObject(playerid, 5, 19167, 6, 0.265382, 0.041968, 0.000000, 119.981117, 0.000000, 0.000000, 1.000000, 1.000000, 1.000000);
	ShowPlayerDialog(playerid,dGPS,2,"{f3d10c}КАРТА: {ffffff}Выбор места","[0] Общественные места\n[1] Работы\n[2] Убрать карту","Выбрать","Выход");
}
CMD:gpsoff(playerid, params[])
{
	SendClientMessage(playerid, -1, "Вы успешно выключили GPS навигатор");
	DisablePlayerRaceCheckpoint(playerid);
	return true;
}
CMD:enter(playerid, params[])
{
	for(new i = 0; i < sizeof(HomeInfo); i++)
	{
		if(PlayerToPoint(2, playerid, HomeInfo[i][hEntrancex], HomeInfo[i][hEntrancey], HomeInfo[i][hEntrancez]))
		{
			if(PlayerInfo[playerid][pPhousekey] == i || HomeInfo[i][hLock] == 0)
			{
				SetPlayerInterior(playerid, HomeInfo[i][hInt]);
				SetPlayerVirtualWorld(playerid, i+50);
				SetPlayerPos(playerid, HomeInfo[i][hExitx], HomeInfo[i][hExity], HomeInfo[i][hExitz]);
				PlayerInfo[playerid][pInt] = HomeInfo[i][hInt];
				return true;
			}
			else return GameTextForPlayer(playerid, "~r~Closed", 5000, 1);
		}
	}
	return true;
}
CMD:exit(playerid, params[])
{
	for(new i = 0; i < sizeof(HomeInfo); i++)
	{
		if(PlayerToPoint(3, playerid,HomeInfo[i][hExitx], HomeInfo[i][hExity], HomeInfo[i][hExitz]))
		{
			if(GetPlayerVirtualWorld(playerid) == i+50)
			{
				SetPlayerInterior(playerid,0);
				SetPlayerVirtualWorld(playerid,0);
				SetPlayerPos(playerid,HomeInfo[i][hEntrancex],HomeInfo[i][hEntrancey],HomeInfo[i][hEntrancez]);
				PlayerInfo[playerid][pInt] = 0;
				PlayerInfo[playerid][pLocal] = 255;
			}
		}
	}
	return true;
}
CMD:dir(playerid, params[]) return ShowPlayerDialog(playerid,5454,DIALOG_STYLE_LIST,"Справочник","[0] Адвокаты\n[1] Таксисты\n[2] Крупье\n[3] Инструкторы\n[4] Механики\n[5] Медики\n[6] Развозчики продуктов\n[7] Тренеры\n[8] Развозчик строй-материалов","Далее","Скрыть");
CMD:switchskin(playerid, params[])
{
	if(IsAGang(playerid))
	{
		if(forma[playerid] !=1) return  SendClientMessage(playerid, COLOR_GRAD1, "У вас нет формы армейца");
		SetPlayerSkin(playerid,287);
		SetPlayerColor(playerid, COLOR_GREEN);
		forma[playerid] = 0;
		proverkaforma[playerid] = 1;
	}
	return true;
}
CMD:carm(playerid, params[])
{
	if(PlayerInfo[playerid][pMember] == 19 || proverkaforma[playerid] == 1) return ShowPlayerDialog(playerid, 9653, DIALOG_STYLE_LIST, "Развозка Оружия", "- Загрузиться\n- Разгрузиться\n- Разгрузить на склад Армии SF\n- Разгрузка в LSPD\n- Разгрузка в FBI\n- Разгрузка в SFPD\n- Разгрузка Бандам\n- Разгрузка в LVPD", "Далее", "Скрыть");
	return true;
}
CMD:showpass(playerid, params[])
{
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /showpass [id]");
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid, COLOR_RED, "[Ошибка] Человек не найден!");
	{
		if(params[0] != INVALID_PLAYER_ID)
		{
			if(!ProxDetectorS(8.0, playerid, params[0])) return SendClientMessage(playerid, COLOR_RED, "Человек слишком далеко!");
			{
				new jtext[32];
				switch(PlayerInfo[playerid][pJob])
				{
				case 2: { jtext = "Механик"; }
				case 3: { jtext = "Продавец ХотДогов"; }
				case 4: { jtext = "Таксист"; }
				case 5: { jtext = "Развозчик продуктов"; }
				case 6: { jtext = "Тренер"; }
				case 7: { jtext = "Неизвестно"; }
				case 8: { jtext = "Инкасатор"; }
				case 9: { jtext = "Неизвестно"; }
				case 10: { jtext = "Мусоровоз"; }
				case 13: { jtext = "Автоугонщик"; }
				case 14: { jtext = "Боксёр"; }
				default: { jtext = "Безработный"; }
				}
				new shltext[32];
				if(PlayerInfo[playerid][pGunLic]) { shltext = "Есть"; } else { shltext = "Нет"; }
				new level = PlayerInfo[playerid][pLevel];
				SendClientMessage(playerid,COLOR_GREY, "-----------===[ PASSPORT ]===----------");
				SendMes(params[0], COLOR_YELLOW2, "Имя: %s ",PlayerInfo[playerid][pName]);
				SendMes(params[0], COLOR_YELLOW2, "Возраст: %d  Телефон: %d",level,PlayerInfo[playerid][pPnumber]);
				if(PlayerInfo[playerid][pFacePass] == 1)//Настояший паспорт
				{
					SendMes(params[0], COLOR_YELLOW2, "Фракция: %s",GetPlayerFracName(playerid));
					SendMes(params[0], COLOR_YELLOW2, "Работа: %s",jtext);
					SendMes(params[0], COLOR_YELLOW2, "Разрешение на оружие: %s",shltext);
					SendMes(params[0], COLOR_YELLOW2, "Законопослушность: %d",PlayerInfo[playerid][pZakonp]);
					if(PlayerInfo[playerid][pWanted] > 0) SendClientMessage(params[0], COLOR_REDD, "Внимание! Это человек в розыске!");
				}
				if(PlayerInfo[playerid][pFacePass] == 2)//Гражданина
				{
					SendMes(params[0], COLOR_YELLOW2, "Фракция: Гражданин");
					SendMes(params[0], COLOR_YELLOW2, "Работа: Безработный");
					SendMes(params[0], COLOR_YELLOW2, "Разрешение на оружие: Есть");
					SendMes(params[0], COLOR_YELLOW2, "Преступлений: 0");
					SendMes(params[0], COLOR_YELLOW2, "Законопослушность: 100");
				}
				if(PlayerInfo[playerid][pFacePass] == 3)//FBI
				{
					SendMes(params[0], COLOR_YELLOW2, "Фракция: FBI");
					SendMes(params[0], COLOR_YELLOW2, "Работа: Безработный");
					SendMes(params[0], COLOR_YELLOW2, "Разрешение на оружие: Есть");
					SendMes(params[0], COLOR_YELLOW2, "Преступлений: 0");
					SendMes(params[0], COLOR_YELLOW2, "Законопослушность: 100");
				}
				if(PlayerInfo[playerid][pFacePass] == 4)//swat
				{
					SendMes(params[0], COLOR_YELLOW2, "Фракция: S.W.A.T");
					SendMes(params[0], COLOR_YELLOW2, "Работа: Безработный");
					SendMes(params[0], COLOR_YELLOW2, "Разрешение на оружие: Есть");
					SendMes(params[0], COLOR_YELLOW2, "Преступлений: 0");
					SendMes(params[0], COLOR_YELLOW2, "Законопослушность: 100");
				}
				if(PlayerInfo[playerid][pFacePass] == 5)//правительство
				{
					SendMes(params[0], COLOR_YELLOW2, "Фракция: Правительство");
					SendMes(params[0], COLOR_YELLOW2, "Работа: Безработный");
					SendMes(params[0], COLOR_YELLOW2, "Разрешение на оружие: Есть");
					SendMes(params[0], COLOR_YELLOW2, "Преступлений: 0");
					SendMes(params[0], COLOR_YELLOW2, "Законопослушность: 100");
				}
				SendClientMessage(playerid,COLOR_GREY, "=============================");
				format(stringer1,sizeof(stringer1), "%s показал(а) свой паспорт %s'у", PlayerInfo[playerid][pName], PlayerInfo[params[0]][pName]);
				SetPlayerChatBubble(playerid,stringer1,COLOR_YELLOW,30.0,10000);
				format(stringer1, sizeof(stringer1), "%s показал(a) свой паспорт", PlayerInfo[playerid][pName]);
				ProxDetector(10.0, playerid, stringer1, COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW);
			}
		}
	}
	return true;
}
CMD:crashcuff(playerid, params[])
{
	if(IsPlayerConnected(playerid))
	{
		if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /crashcuff [id]");
		if(IsPlayerConnected(params[0]))
		{
			if(params[0] != INVALID_PLAYER_ID)
			{
				if(PlayerInfo[playerid][pOtmbI4ka] == 0) return SendClientMessage(playerid, COLOR_GREY, "У вас нету отмычек");
				if(PlayerCuffed[playerid] == 0) return SendClientMessage(playerid, COLOR_GREY, "Игрок не в наручниках");
				if(crashcuff[playerid] > 0) return SendClientMessage(playerid, COLOR_GREY, "Команду можно использовать раз в 30 секунд");
				if(ProxDetectorS(8.0, playerid, params[0]))
				{
					new randomm;
					switch(PlayerInfo[playerid][pDonateRank])
					{
					case 1: { randomm = random(12)+1; }
					case 2: { randomm = random(11)+1; }
					case 3: { randomm = random(10)+1; }
					default: { randomm = random(13)+1; }
					}
					switch(randomm)
					{
					case 1..3:
						{
							TogglePlayerControllable(params[0], 1);
							SetPlayerSpecialAction(params[0],SPECIAL_ACTION_NONE);
							RemovePlayerAttachedObject(params[0],0);
							PlayerCuffed[params[0]] = 0;
							crashcuff[playerid] = 30;
							PlayerInfo[playerid][pOtmbI4ka]--;
							format(stringer1, sizeof(stringer1), "Игрок %s скинул с себя наручники.", PlayerInfo[params[0]][pName]);
							ProxDetector(30.0, playerid, stringer1, COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW);
						}
					default:
						{
							SendClientMessage(playerid, COLOR_GREY, "Вам не удалось скинуть наручники.");
							PlayerInfo[playerid][pOtmbI4ka]--;
							crashcuff[playerid] = 30;
						}
					}
				}
				else return SendClientMessage(playerid, COLOR_GREY, "Игрок не рядом с вами.");
			}
		}
		else return SendClientMessage(playerid, COLOR_GREY, "Этот игрок в оффлайн!");
	}
	return true;
}
CMD:cuff(playerid, params[])
{
	if(!IsACop(playerid)) return SendClientMessage(playerid, COLOR_GREY, YouCanNot);
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /cuff [id]");
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid, COLOR_GREY, "Игрок не найден");
	{
		if(params[0] != INVALID_PLAYER_ID)
		{
			if(PlayerTied[playerid] > 0)  return SendClientMessage(playerid, COLOR_GREY, "Вы связаны!");
			if(IsACop(params[0])) return    SendClientMessage(playerid, COLOR_GREY, "Вы не можете надеть наручники на законника");
			if(PlayerCuffed[params[0]] == 2) return    SendClientMessage(playerid, COLOR_GREY, "На этого человека уже одеты наручники");
			if(PlayerInfo[params[0]][pWanted] == 0) return    SendClientMessage(playerid, COLOR_GREY, "Вы не можете надеть наручники на этого человека (он не в розыске)");
			if(!ProxDetectorS(2.0, playerid, params[0])) return SendClientMessage(playerid, COLOR_GREY, "Рядом с вами никого нет !");
			if(PlayerCuffed[params[0]] != 1) return SendClientMessage(playerid, COLOR_GREY, "Игрок не оглушен, используйте тазер.");
			if(params[0] == playerid) { SendClientMessage(playerid, COLOR_GREY, "Вы не можете надеть наручники на самого себя!"); return true; }
			if(IsACop(playerid))
			{
				format(stringer1, sizeof(stringer1), "На Вас надел наручники %s.", PlayerInfo[playerid][pName]);
				SendClientMessage(params[0], 0x6ab1ffaa, stringer1);
				format(stringer1, sizeof(stringer1), "Вы надели наручники на %s.", PlayerInfo[params[0]][pName]);
				SendClientMessage(playerid, 0x6ab1ffaa, stringer1);
				format(stringer1, sizeof(stringer1), "%s надел(а) на %s наручники.", PlayerInfo[playerid][pName] ,PlayerInfo[params[0]][pName]);
				SetPlayerAttachedObject(params[0], 0, 19418, 6, -0.011000, 0.028000, -0.022000, -15.600012, -33.699977, -81.700035, 0.891999, 1.000000, 1.168000);
				GameTextForPlayer(params[0], "~r~Cuffed", 2500, 3);
				ProxDetector(30.0, playerid, stringer1, COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW);
				SetPlayerSpecialAction(params[0],SPECIAL_ACTION_CUFFED);
				TogglePlayerControllable(params[0], false);
				PlayerCuffed[params[0]] = 2;
				PlayerCuffedTime[params[0]] = 3600;
			}
		}
	}
	return true;
}
CMD:uncuff(playerid, params[])
{
	if(!IsACop(playerid)) return SendClientMessage(playerid, COLOR_GREY, YouCanNot);
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /uncuff [id]");
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid, COLOR_GREY, "{DB7093} [Ошибка]: {D3D3D3} Игрок не найден!");
	{
		if(params[0] != INVALID_PLAYER_ID)
		{
			if(PlayerTied[playerid] > 0)  return SendClientMessage(playerid, COLOR_GREY, "Вы связаны!");
			if(!ProxDetectorS(5.0, playerid, params[0])) return SendClientMessage(playerid, COLOR_GREY, "Рядом с вами никого нет !");
			if(params[0] == playerid) { SendClientMessage(playerid, COLOR_GREY, "Вы не можете снять наручники с самого себя!"); return true; }
			if(PlayerCuffed[params[0]] == 2)
			{
				format(stringer1, sizeof(stringer1), "С Вас снял наручники %s.", PlayerInfo[playerid][pName]);
				SendClientMessage(params[0], 0x6ab1ffaa, stringer1);
				GameTextForPlayer(params[0], "~g~Uncuffed", 2500, 3);
				format(stringer1, sizeof(stringer1), "Вы сняли наручники с %s.", PlayerInfo[params[0]][pName]);
				SendClientMessage(playerid, 0x6ab1ffaa, stringer1);
				SetPlayerSpecialAction(params[0],SPECIAL_ACTION_NONE); RemovePlayerAttachedObject(params[0],0); TogglePlayerControllable(params[0], true); PlayerCuffed[params[0]] = 0;
			}
			else { SendClientMessage(playerid, COLOR_GREY, "Этот игрок не в наручниках !"); return true; }
		}
	}
	return true;
}
CMD:accept(playerid, params[])
{
	if(sscanf(params, "s[128]",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /accept [name]");
	if(strcmp(params[0],"witness",true) == 0)
	{
		if(MarryWitnessOffer[playerid] != INVALID_PLAYER_ID)
		{
			if(IsPlayerConnected(MarryWitnessOffer[playerid]))
			{
				if(ProxDetectorS(10.0, playerid, MarryWitnessOffer[playerid]))
				{
					format(stringer1, sizeof(stringer1), "Вы приняли предложение  %s's быть свидетелем на свадьбе", PlayerInfo[MarryWitnessOffer[playerid]][pName]);
					SendClientMessage(playerid, 0x6ab1ffaa, stringer1);
					format(stringer1, sizeof(stringer1), "%s согласился быть вашим свидетелем на свадьбе.", PlayerInfo[playerid][pName]);
					SendClientMessage(MarryWitnessOffer[playerid], 0x6ab1ffaa, stringer1);
					MarryWitness[MarryWitnessOffer[playerid]] = playerid;
					MarryWitnessOffer[playerid] = INVALID_PLAYER_ID;
					return true;
				}
				else return SendClientMessage(playerid, COLOR_GREY, "Игрок, который просил, чтобы вы были свидетелем не рядом с вами !");
			}
		}
		else return SendClientMessage(playerid, COLOR_GREY, "Вам не предлагали быть свидетелем!");
	}
	else if(strcmp(params[0],"fight",true) == 0)
	{
		if(fightid[playerid] < 176 && boy[playerid] == 0)
		{
			if(ring == 1) return SendClientMessage(playerid, COLOR_LIGHTRED, "Боксёрский ринг занят.");
			new healthh = 30+ (PlayerInfo[playerid][pFightSkill]*10);
			new healthhg = 30+ (PlayerInfo[fightid[playerid]][pFightSkill]*10);
			boy[playerid] = 1;
			boy[fightid[playerid]] = 1;
			SetPlayerHealth(playerid, healthh);
			SetPlayerHealth(fightid[playerid], healthhg);
			TogglePlayerControllable(playerid, 0);
			TogglePlayerControllable(fightid[playerid], 0);
			SetPlayerPos(playerid,758.7978,-1.7495,1001.5942);
			SetPlayerPos(fightid[playerid],762.9683,2.4081,1001.5942);
			SetPlayerFacingAngle(playerid, 319.6382);
			SetPlayerFacingAngle(fightid[playerid], 137.3811);
			format(stringer1, sizeof(stringer1), " ~g~%d HP", healthh);
			GameTextForPlayer(playerid, stringer1, 3000, 1);
			format(stringer1, sizeof(stringer1), " ~g~%d HP", healthhg);
			GameTextForPlayer(fightid[playerid], stringer1, 3000, 1);
			ring = 1;
			TimeBox[playerid] = 10;
			TimeBoxAll[playerid] = 600;
			TimeBox[fightid[playerid]] = 10;
			TimeBoxAll[fightid[playerid]] = 600;
			SendClientMessage(playerid, COLOR_LIGHTRED, "Используйте свои навыки драки, чтобы победить противника.");
			SendClientMessage(fightid[playerid], COLOR_LIGHTRED, "Используйте свои навыки драки, чтобы победить противника.");
		}
	}
	else if(strcmp(params[0], "marriage",true) == 0)
	{
		if(ProposeOffer[playerid] != INVALID_PLAYER_ID)
		{
			if(!PlayerToPoint(10.0, playerid, -1988.6638,1117.8837,54.4726)) return SendClientMessage(playerid, COLOR_GREY, "Вы не у церкви в San Fierro!");
			if(IsPlayerConnected(ProposeOffer[playerid]))
			{
				if(ProxDetectorS(10.0, playerid, ProposeOffer[playerid]))
				{
					format(stringer1, sizeof(stringer1), "Вы приняли предложение от %s's", PlayerInfo[ProposeOffer[playerid]][pName]);
					SendClientMessage(playerid, 0x6ab1ffaa, stringer1);
					format(stringer1, sizeof(stringer1), "%s приняла Ваш запрос быть Вашей Женой.", PlayerInfo[playerid][pName]);
					SendClientMessage(ProposeOffer[playerid], 0x6ab1ffaa, stringer1);
					SendClientMessageToAll(COLOR_WHITE,"{FFA500}********** {FF0000}ДВОРЕЦ БРАКОСОЧЕТАНИЯ {FFa500}**********");
					format(stringer1, sizeof(stringer1), "{FC6DEC}Поздравляем! %s и %s теперь муж и жена!", PlayerInfo[playerid][pName], PlayerInfo[ProposeOffer[playerid]][pName]);
					SendClientMessageToAll(COLOR_WHITE,stringer1);
					PlayerInfo[ProposeOffer[playerid]][pCash] -= 100000;
					PlayerInfo[playerid][pMarried] = 1;
					PlayerInfo[ProposeOffer[playerid]][pMarried] = 1;
					MarryWitness[ProposeOffer[playerid]] = INVALID_PLAYER_ID;
					ProposeOffer[playerid] = INVALID_PLAYER_ID;
				}
				return true;
			}
			else
			{
				SendClientMessage(playerid, COLOR_GREY, "Жених/Невеста не рядом с Вам!");
				return true;
			}
		}
		else
		{
			SendClientMessage(playerid, COLOR_GREY, "Вам ни кто не предлагал!");
			return true;
		}
	}
	else if(strcmp(params[0],"taxi",true) == 0)
	{
		if(TransportDuty[playerid] != 1) return   SendClientMessage(playerid, COLOR_GREY, "Вы не таксист!");
		if(TaxiCall != INVALID_PLAYER_ID)
		{
			if(IsPlayerConnected(TaxiCall))
			{
				format(stringer1, sizeof(stringer1), "Вы приняли вызов от %s.",PlayerInfo[TaxiCall][pName]);
				SendClientMessage(playerid, 0x6ab1ffaa, stringer1);
				format(stringer1, sizeof(stringer1), "Водитель такси %s принял ваш вызов, оставайтесь на месте.",PlayerInfo[playerid][pName]);
				SendClientMessage(TaxiCall, COLOR_GREEN, stringer1);
				TaxiCall = INVALID_PLAYER_ID;
				return true;
			}
		}
		else return SendClientMessage(playerid, COLOR_GREY, "Нет Вызовов");
	}
	else if(strcmp(params[0],"ticket",true) == 0)
	{
		if(TicketOffer[playerid] != INVALID_PLAYER_ID)
		{
			if(IsPlayerConnected(TicketOffer[playerid]))
			{
				if(ProxDetectorS(5.0, playerid, TicketOffer[playerid]))
				{
					format(stringer1, sizeof(stringer1), "Вы оплатили штраф в размере %d вирт офицеру %s.", TicketMoney[playerid], PlayerInfo[TicketOffer[playerid]][pName]);
					SendClientMessage(playerid, COLOR_BLUE, stringer1);
					format(stringer1, sizeof(stringer1), "%s оплатил штраф в размере %d вирт.", PlayerInfo[playerid][pName], TicketMoney[playerid]);
					SendClientMessage(TicketOffer[playerid], COLOR_BLUE, stringer1);
					PlayerInfo[playerid][pCash] -=TicketMoney[playerid];
					PlayerInfo[TicketOffer[playerid]][pCash] +=TicketMoney[playerid];
					TicketOffer[playerid] = INVALID_PLAYER_ID;
					TicketMoney[playerid] = 0;
					return true;
				}
				else return SendClientMessage(playerid, COLOR_GREY, "Полицейскйи не рядом с вами!");
			}
		}
		else return SendClientMessage(playerid, COLOR_GREY, "Вам не выписывали штраф!");
	}
	else if(strcmp(params[0],"vehicle",true) == 0)
	{
		if(CarOffer[playerid] != INVALID_PLAYER_ID)
		{
			if(ProxDetectorS(8.0, playerid, CarOffer[playerid]))
			{
				if(PlayerInfo[playerid][pCash] < CarPrice[playerid]) return SendClientMessage(playerid, COLOR_GREY, "У вас нет столько денег на руках!");
				PlayerInfo[playerid][pProz] = PlayerInfo[CarOffer[playerid]][pProz];
				PlayerInfo[playerid][pCar] = PlayerInfo[CarOffer[playerid]][pCar];
				PlayerInfo[CarOffer[playerid]][pCar] = 462;
				PlayerInfo[playerid][pCash] -=CarPrice[playerid];
				PlayerInfo[CarOffer[playerid]][pCash] +=CarPrice[playerid];
				format(stringer1, sizeof(stringer1), "Вы продали машину %s за %d вирт!", PlayerInfo[playerid][pName], CarPrice[playerid]);
				SendClientMessage(CarOffer[playerid], 0x6ab1ffaa, stringer1);
				format(stringer1, sizeof(stringer1), "Вы купили машину у %s за %d вирт!", PlayerInfo[CarOffer[playerid]][pName], CarPrice[playerid]);
				SendClientMessage(playerid, 0x6ab1ffaa, stringer1);
				if(caridhouse[playerid] != 0)
				{
					DestroyVehicle(caridhouse[playerid]);
					caridhouse[playerid] = 0;
				}
				DestroyVehicle(caridhouse[CarOffer[playerid]]);
				CarOffer[playerid] = INVALID_PLAYER_ID;
				CarPrice[playerid] = 0;
			}
			else return SendClientMessage(playerid, COLOR_GREY, "Игрок слишком далеко от вас!");
		}
		else return SendClientMessage(playerid, COLOR_GREY, "Вам никто не предлагал купить машину!");
	}
	else if(strcmp(params[0],"house",true) == 0)
	{
		if(ChangeHouse[playerid][hCena] > 89999 && ChangeHouse[playerid][hProdaet] != INVALID_PLAYER_ID)
		{
			if(ProxDetectorS(8.0, playerid, ChangeHouse[playerid][hProdaet]))
			{
				new house = PlayerInfo[ChangeHouse[playerid][hProdaet]][pPhousekey];
				if(PlayerInfo[playerid][pCash] < ChangeHouse[playerid][hCena])return SendClientMessage(playerid, COLOR_GREY, "У вас нет столько денег на руках!");
				PlayerInfo[playerid][pCash] -= ChangeHouse[playerid][hCena];
				PlayerInfo[ChangeHouse[playerid][hProdaet]][pCash] += ChangeHouse[playerid][hCena];
				PlayerInfo[playerid][pPhousekey] = PlayerInfo[ChangeHouse[playerid][hProdaet]][pPhousekey];
				PlayerInfo[ChangeHouse[playerid][hProdaet]][pPhousekey] = 255;
				strmid(HomeInfo[house][hOwner], PlayerInfo[playerid][pName], 0, strlen(PlayerInfo[playerid][pName]), 255);
				SendMes(playerid,COLOR_WHITE,"Вы купили дом у %s за %d вирт.",PlayerInfo[ChangeHouse[playerid][hProdaet]][pName],ChangeHouse[playerid][hCena]);
				SendMes(ChangeHouse[playerid][hProdaet],COLOR_WHITE,"Вы продали дом %s за %d вирт.",PlayerInfo[playerid][pName],ChangeHouse[playerid][hCena]);
				PlayerInfo[playerid][pVcol1] = PlayerInfo[ChangeHouse[playerid][hProdaet]][pVcol1];
				PlayerInfo[ChangeHouse[playerid][hProdaet]][pVcol1] = 0;
				PlayerInfo[playerid][pVcol2] = PlayerInfo[ChangeHouse[playerid][hProdaet]][pVcol2];
				PlayerInfo[ChangeHouse[playerid][hProdaet]][pVcol2] = 0;
				PlayerInfo[playerid][pKolesocar] = PlayerInfo[ChangeHouse[playerid][hProdaet]][pKolesocar];
				PlayerInfo[ChangeHouse[playerid][hProdaet]][pKolesocar] = 0;
				PlayerInfo[playerid][pNitro] = PlayerInfo[ChangeHouse[playerid][hProdaet]][pNitro];
				PlayerInfo[ChangeHouse[playerid][hProdaet]][pNitro] = 0;
				PlayerInfo[playerid][pGidra] = PlayerInfo[ChangeHouse[playerid][hProdaet]][pGidra];
				PlayerInfo[ChangeHouse[playerid][hProdaet]][pGidra] = 0;
				new model = GetVehicleModel(caridhouse[ChangeHouse[playerid][hProdaet]]);
				if(model == 534 || model == 535 || model == 536 || model ==558 || model ==559 || model ==560 || model ==561 || model ==562 || model ==565 || model ==576 || model ==483 || model == 567)
				{
					PlayerInfo[playerid][pPokraska] = PlayerInfo[ChangeHouse[playerid][hProdaet]][pPokraska];
					PlayerInfo[ChangeHouse[playerid][hProdaet]][pPokraska] = 0;
					PlayerInfo[playerid][pSpoiler] = PlayerInfo[ChangeHouse[playerid][hProdaet]][pSpoiler];
					PlayerInfo[ChangeHouse[playerid][hProdaet]][pSpoiler] = 0;
					PlayerInfo[playerid][pHood] = PlayerInfo[ChangeHouse[playerid][hProdaet]][pHood];
					PlayerInfo[ChangeHouse[playerid][hProdaet]][pHood] = 0;
					PlayerInfo[playerid][pExhaust] = PlayerInfo[ChangeHouse[playerid][hProdaet]][pExhaust];
					PlayerInfo[ChangeHouse[playerid][hProdaet]][pExhaust] = 0;
					PlayerInfo[playerid][pLamps] = PlayerInfo[ChangeHouse[playerid][hProdaet]][pLamps];
					PlayerInfo[ChangeHouse[playerid][hProdaet]][pLamps] = 0;
					PlayerInfo[playerid][pSideskirt] = PlayerInfo[ChangeHouse[playerid][hProdaet]][pSideskirt];
					PlayerInfo[ChangeHouse[playerid][hProdaet]][pSideskirt] = 0;
					PlayerInfo[playerid][pVozdyx] = PlayerInfo[ChangeHouse[playerid][hProdaet]][pVozdyx];
					PlayerInfo[ChangeHouse[playerid][hProdaet]][pVozdyx] = 0;
					PlayerInfo[playerid][pBamper1] = PlayerInfo[ChangeHouse[playerid][hProdaet]][pBamper1];
					PlayerInfo[ChangeHouse[playerid][hProdaet]][pBamper1] = 0;
					PlayerInfo[playerid][pBamper2] = PlayerInfo[ChangeHouse[playerid][hProdaet]][pBamper2];
					PlayerInfo[ChangeHouse[playerid][hProdaet]][pBamper2] = 0;
				}
				if(caridhouse[ChangeHouse[playerid][hProdaet]] != 0)
				{
					DestroyVehicle(caridhouse[ChangeHouse[playerid][hProdaet]]);
					caridhouse[ChangeHouse[playerid][hProdaet]] = 0;
				}
				PlayerInfo[playerid][pCar] = PlayerInfo[ChangeHouse[playerid][hProdaet]][pCar];
				PlayerInfo[ChangeHouse[playerid][hProdaet]][pCar] = 0;
				OnPlayerUpdateRL(playerid);
				mysql_format(dbHandle, QUERY, sizeof(QUERY), "UPDATE `"TABLE_HOUSE"` SET `hOwner` = '%s' WHERE hID = '%i'",PlayerInfo[playerid][pName],PlayerInfo[playerid][pPhousekey]);
				mysql_function_query(dbHandle, QUERY, false, "", "");
				ChangeHouse[playerid][hProdaet] = INVALID_PLAYER_ID;
				ChangeHouse[ChangeHouse[playerid][hProdaet]][hPokypaet] = INVALID_PLAYER_ID;
				ChangeHouse[playerid][hCena] = 0;
			}
			else return SendClientMessage(playerid,COLOR_GREY,"Вы далеко от продавца.");
		}
		else return SendClientMessage(playerid,COLOR_GREY,"Вам не предлагали купить дом.");
	}
	else if(strcmp(params[0],"medic",true) == 0)
	{
		if(PlayerInfo[playerid][pMember] == 4 || PlayerInfo[playerid][pLeader] == 4)
		{
			if(MedicCall != INVALID_PLAYER_ID)
			{
				if(IsPlayerConnected(MedicCall))
				{
					format(stringer1, sizeof(stringer1), "Вы приняли запрос от %s.",PlayerInfo[MedicCall][pName]);
					SendClientMessage(playerid, 0x6ab1ffaa, stringer1);
					format(stringer1, sizeof(stringer1), "Медик %s принял ваш вызов!",PlayerInfo[playerid][pName]);
					SendClientMessage(MedicCall, COLOR_GREEN, stringer1);
					new Float:X,Float:Y,Float:Z;
					GetPlayerPos(MedicCall, X, Y, Z);
					SetPlayerCheckpoint(playerid, X, Y, Z, 5);
					MedicCall = INVALID_PLAYER_ID;
					return true;
				}
			}
			else { SendClientMessage(playerid, COLOR_GREY, "Вызовов нет!"); return true; }
		}
		else { SendClientMessage(playerid, COLOR_GREY, "Вы не медик!"); return true; }
	}
	else if(strcmp(params[0],"police",true) == 0)
	{
		if(!IsACop(playerid)) return      SendClientMessage(playerid, COLOR_GREY, "Вы не полицейский!");
		if(PoliceCall != INVALID_PLAYER_ID)
		{
			if(IsPlayerConnected(PoliceCall))
			{
				format(stringer1, sizeof(stringer1), "Вы приняли вызов от %s",PlayerInfo[PoliceCall][pName]);
				SendClientMessage(playerid, 0x6ab1ffaa, stringer1);
				format(stringer1, sizeof(stringer1), "Патрульный %s принял Ваш вызов!",PlayerInfo[playerid][pName]);
				SendClientMessage(PoliceCall, COLOR_GREEN, stringer1);
				new Float:X,Float:Y,Float:Z;
				GetPlayerPos(PoliceCall, X, Y, Z);
				SetPlayerCheckpoint(playerid, X, Y, Z, 5);
				PoliceCall = INVALID_PLAYER_ID;
				return true;
			}
		}
		else { SendClientMessage(playerid, COLOR_GREY, "Вызовов нет!"); return true; }
	}
	else if(strcmp(params[0],"mechanic",true) == 0)
	{
		if(PlayerInfo[playerid][pJob] != 2) return SendClientMessage(playerid, COLOR_GREY, "Вы не механик!");
		if(MechanicCall != INVALID_PLAYER_ID)
		{
			if(IsPlayerConnected(MechanicCall))
			{
				format(stringer1, sizeof(stringer1), "Вы приняли вызов от %s",PlayerInfo[MechanicCall][pName]);
				SendClientMessage(playerid, 0x6ab1ffaa, stringer1);
				format(stringer1, sizeof(stringer1), "Механик %s принял Ваш вызов!",PlayerInfo[playerid][pName]);
				SendClientMessage(MechanicCall, COLOR_GREEN, stringer1);
				new Float:X,Float:Y,Float:Z;
				GetPlayerPos(MechanicCall, X, Y, Z);
				SetPlayerCheckpoint(playerid, X, Y, Z, 5);
				MechanicCall = INVALID_PLAYER_ID;
				return true;
			}
		}
		else { SendClientMessage(playerid, COLOR_GREY, "Вызовов нет!"); return true; }
	}
	else if(strcmp(params[0],"livels",true) == 0)
	{
		if(LiveOfferls[playerid] != INVALID_PLAYER_ID)
		{
			if(IsPlayerConnected(LiveOfferls[playerid]))
			{
				if(ProxDetectorS(5.0, playerid, LiveOfferls[playerid]))
				{
					TalkingLivels[LiveOfferls[playerid]] = 2;
					SendClientMessage(LiveOfferls[playerid], COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /live чтобы закончить интервью");
					lNews[playerid] = 0;
					lNews[LiveOfferls[playerid]] = 0;
					LiveOfferls[playerid] = INVALID_PLAYER_ID;
					TalkingLivels[playerid] = 2;
					SendClientMessage(playerid, COLOR_YELLOW, "Вы даёте интервью в прямом эфире радио Los Santos");
					return true;
				}
				else return SendClientMessage(playerid, COLOR_GREY, "Вы далеко от репортёра");
			}
			return true;
		}
		else { SendClientMessage(playerid, COLOR_GREY, "Вам никто не предлагал дать интервью"); return true; }
	}
	else if(strcmp(params[0],"refill",true) == 0)
	{
		if(RefillOffer[playerid] != INVALID_PLAYER_ID)
		{
			if(IsPlayerConnected(RefillOffer[playerid]))
			{
				if(PlayerInfo[playerid][pCash] > RefillPrice[playerid])
				{
					new car = GetPlayerVehicleID(RefillOffer[playerid]);
					format(stringer1, sizeof(stringer1), "Механик %s заправил вашу машину на 100 литров за %d вирт.",PlayerInfo[RefillOffer[playerid]][pName],RefillPrice[playerid]);
					SendClientMessage(playerid, 0x6ab1ffaa, stringer1);
					format(stringer1, sizeof(stringer1), "Вы заправили машину  %s за %d вирт.",PlayerInfo[playerid][pName],RefillPrice[playerid]);
					SendClientMessage(RefillOffer[playerid], 0x6ab1ffaa, stringer1);
					PlayerInfo[playerid][pCash] -=RefillPrice[playerid];
					PlayerInfo[RefillOffer[playerid]][pCash] +=RefillPrice[playerid];
					if(!IsPlayerInAnyVehicle(playerid) && GetPlayerState(playerid) == PLAYER_STATE_DRIVER || GetVehicleModel(car) == 481 || GetVehicleModel(car) == 509 || GetVehicleModel(car) == 510) return SendClientMessage(playerid,COLOR_YELLOW,".: Вы не в машине, или машина не требует бензина :.");
					if(Fuell[car] >= 100) SendClientMessage(playerid,COLOR_GRAD1,"Ваш бак полон");
					else
					{
						Fuell[car] = 100;
						PlayerInfo[playerid][pFuelcar] = 100;
						OldFuel[playerid] = floatround(Fuell[car]);
						Refueling[playerid] = 0;
					}
					return true;
				}
				else { SendClientMessage(playerid, COLOR_GREY, "Не достаточно денег!"); return true; }
			}
			return true;
		}
		else { SendClientMessage(playerid, COLOR_GREY, "Вам не предлагали заправиться!"); return true; }
	}
	else if(strcmp(params[0],"hotdog",true) == 0)
	{
		if(HotdogOffer[playerid] != INVALID_PLAYER_ID)
		{
			if(IsPlayerConnected( HotdogOffer[playerid]))
			{
				if(PlayerInfo[playerid][pCash] > HotdogPrice[playerid])
				{
					new Float:health;
					GetPlayerHealth(playerid,health);
					format(stringer1, sizeof(stringer1), "Вы купили ХотДог у %s за %d вирт.",PlayerInfo[HotdogOffer[playerid]][pName], HotdogPrice[playerid]);
					SendClientMessage(playerid, 0x6ab1ffaa, stringer1);
					format(stringer1, sizeof(stringer1), " Вы продали ХотДог %s за %d вирт.",PlayerInfo[playerid][pName],HotdogPrice[playerid]);
					SendClientMessage(HotdogOffer[playerid], 0x6ab1ffaa, stringer1);
					PlayerInfo[playerid][pCash] -=HotdogPrice[playerid];
					SetPlayerHealth(playerid, health + 20.0);
					SetPlayerChatBubble(playerid,"съела(а) хотдог",COLOR_YELLOW,30.0,10000);
					PlayerInfo[HotdogOffer[playerid]][pCash]+= HotdogPrice[playerid];
					HotdogOffer[playerid] = INVALID_PLAYER_ID;
					HotdogPrice[playerid] = 0;
					return true;
				}
				else return SendClientMessage(playerid, COLOR_GREY, "У вас недостаточно денег!");
			}
			return true;
		}
		else return SendClientMessage(playerid, COLOR_GREY, "Вам ни кто не предлагал ХотДог!");
	}
	else if(strcmp(params[0], "free",true) == 0 && FreeOffer[playerid] == 999 || strcmp(params[0], "free",true) == 0 && !IsPlayerConnected( FreeOffer[playerid]))
	{
		if(PlayerInfo[playerid][pCash] < FreePrice[playerid]) return SendClientMessage(playerid, COLOR_RED, "У вас недостаточно денег");
		format(stringer1, 128, "Вы заплатили адвокату %s %d вирт.",PlayerInfo[FreeOffer[playerid]][pName], FreePrice[playerid]);
		SendClientMessage(playerid, 0x6495EDFF, stringer1);
		format(stringer1, 128, "Вы выпустили %s из тюрьмы за %d вирт.",PlayerInfo[playerid][pName],FreePrice[playerid]);
		SendClientMessage(FreeOffer[playerid], 0x6495EDFF, stringer1);
		if(SposobOffer[playerid] == 0) PlayerInfo[playerid][pCash] -= FreePrice[playerid];
		if(SposobOffer[playerid] == 1) PlayerInfo[playerid][pBank] -= FreePrice[playerid];
		PlayerInfo[FreeOffer[playerid]][pCash]+= FreePrice[playerid];
		FreeOffer[playerid] = 999;
		FreePrice[playerid] = 0;
		SposobOffer[playerid] = 0;
		SetPlayerInterior(playerid, 0);
		SetPlayerPos(playerid,1553.4962,-1675.2714,16.1953);
		SetPlayerFacingAngle(playerid, 95.0636);
		PlayerInfo[playerid][pJailTime] = 0;
		PlayerInfo[playerid][pJailed] = 0;
		PlayerInfo[playerid][pWanted] = 0;
		SendClientMessage(playerid, COLOR_YELLOW, "Вы свободны");
		SendClientMessage(playerid, COLOR_GREEN, "Вы заплатили свой долг обществу");
		WantedLevel[playerid] = 0;
		WantedPoints[playerid] = 0;
		SetPlayerWantedLevel(playerid, 0);
		SetPlayerVirtualWorld(playerid, 0);
		return true;
	}
	else if(strcmp(params[0],"zone",true) == 0)
	{
		if(ZoneOffer[playerid] != INVALID_PLAYER_ID)
		{
			if(PlayerInfo[playerid][pCash] > ZonePrice[playerid])
			{
				for(new i = 0;i<130;i++)
				{
					if(PlayerToKvadrat(playerid,GZInfo[i][gCoords][0], GZInfo[i][gCoords][1],GZInfo[i][gCoords][2],GZInfo[i][gCoords][3]))
					{
						if(GZInfo[i][gFrakVlad] != sellzone[playerid]) return 	SendClientMessage(playerid, -1, "Вам не предлагали купить эту территорию");
						GZInfo[i][gFrakVlad] = PlayerInfo[playerid][pMember];
						GangZoneStopFlashForAll(GZInfo[i][gID]);
						GangZoneHideForAll(GZInfo[i][gID]);
						GangZoneShowForAll(GZInfo[i][gID],GetGangZoneColor(i));
						SaveGZ(i);
					}
				}
				format(stringer, sizeof(stringer), "Вы купили территорию у %s за %d вирт.",PlayerInfo[playerid][pName], ZonePrice[playerid]);
				SendClientMessage(playerid, 0x6ab1ffaa, stringer);
				format(stringer, sizeof(stringer), "Вы продали территорию %s за %d вирт.",PlayerInfo[playerid][pName],ZonePrice[playerid]);
				SendClientMessage(ZoneOffer[playerid], 0x6ab1ffaa, stringer);
				PlayerInfo[playerid][pCash] -=ZonePrice[playerid];
				PlayerInfo[ZoneOffer[playerid]][pCash]+= ZonePrice[playerid];
				ZoneOffer[playerid] = INVALID_PLAYER_ID;
				ZonePrice[playerid] = 0;
				sellzone[playerid] = 0;
			}
			else SendClientMessage(playerid, -1, "У вас недостаточно денег!");
		}
		else SendClientMessage(playerid, -1, "Вам ни кто не предлагал территорию!");
	}
	else if(strcmp(params[0],"repair",true) == 0)
	{
		if(RepairOffer[playerid] != INVALID_PLAYER_ID)
		{
			if(PlayerInfo[playerid][pCash] > RepairPrice[playerid])
			{
				if(IsPlayerInAnyVehicle(playerid))
				{
					if(IsPlayerConnected(RepairOffer[playerid]))
					{
						RepairCar[playerid] = GetPlayerVehicleID(playerid);
						SetVehicleHealth(RepairCar[playerid], 1000.0);
						AnRepairVehicle(GetPlayerVehicleID(playerid));
						format(stringer1, sizeof(stringer1), "Механик %s починил вашу машину за %d вирт",PlayerInfo[RepairOffer[playerid]][pName], RepairPrice[playerid]);
						SendClientMessage(playerid, 0x6ab1ffaa, stringer1);
						format(stringer1, sizeof(stringer1), "Вы починили атомобиль %s за %d вирт",PlayerInfo[playerid][pName],RepairPrice[playerid]);
						SendClientMessage(RepairOffer[playerid], 0x6ab1ffaa, stringer1);
						PlayerInfo[playerid][pCash] -=RepairPrice[playerid];
						PlayerInfo[RepairOffer[playerid]][pCash] +=RepairPrice[playerid];
						RepairOffer[playerid] = INVALID_PLAYER_ID;
						RepairPrice[playerid] = 0;
						return true;
					}
					return true;
				}
				return true;
			}
			else { SendClientMessage(playerid, COLOR_GREY, "У вас не хватает денег!"); return true; }
		}
		else { SendClientMessage(playerid, COLOR_GREY, "Вам не предлагали чинить машину!"); return true; }
	}
	else { return true; }
	return true;
}
CMD:refill(playerid, params[])
{
	if(PlayerInfo[playerid][pJob] != 2) return    SendClientMessage(playerid, COLOR_GREY, "Вы не механик!");
	if(gcontract[playerid] != 1) return SendClientMessage(playerid, COLOR_GREY, "У Вас не подписан контракт с заправкой!");
	if(sscanf(params, "dd",params[0],params[1])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /refill [id] [цена]");
	if(params[1] < 1 || params[1] > 5000) { SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1, и больше 5000!"); return true; }
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid, COLOR_GREY, "[Ошибка] Игрок не найден!");
	{
		if(params[0] != INVALID_PLAYER_ID)
		{
			if(GetVehicleModel(GetPlayerVehicleID(playerid)) != 525) return    SendClientMessage(playerid, COLOR_GREY, "Вы не на эвакуаторе!");
			if(ProxDetectorS(8.0, playerid, params[0])&& IsPlayerInAnyVehicle(params[0]))
			{
				if(params[0] == playerid) { SendClientMessage(playerid, COLOR_GREY, "[Ошибка] Вы указали свой ID!"); return true; }
				format(stringer1, sizeof(stringer1), "Вы предложили %s заправить его машину за %d вирт.",PlayerInfo[params[0]][pName],cenabenza[playerid]);
				SendClientMessage(playerid, 0x6ab1ffaa, stringer1);
				format(stringer1, sizeof(stringer1), "Механик %s предлагает заправить вашу машину за %d вирт.(Введите /accept refill), чтобы потвердить заправку.",PlayerInfo[playerid][pName],cenabenza[playerid]);
				SendClientMessage(params[0], 0x6ab1ffaa, stringer1);
				RefillOffer[params[0]] = playerid;
				RefillPrice[params[0]] = cenabenza[playerid];
			}
			else { SendClientMessage(playerid, COLOR_GREY, "Он не в машине!"); }
		}
	}
	return true;
}
CMD:changehouse(playerid, params[])
{
	if(sscanf(params, "dd",params[0],params[1])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /changehouse [id] [цена]");
	if(PlayerInfo[playerid][pPhousekey] == 255) return SendClientMessage(playerid,COLOR_GREY,"У вас нету дома.");
	if(params[1] < 90000 || params[1] > 25000000) return SendClientMessage(playerid,COLOR_GREY,"Цена не может быть меньше 90000 и больше 25000000.");
	if(IsPlayerConnected(params[0]))
	{
		if(params[0] != INVALID_PLAYER_ID)
		{
			if(ProxDetectorS(5.0, playerid, params[0]))
			{
				if(PlayerInfo[params[0]][pPhousekey] != 255) return SendClientMessage(playerid,COLOR_GREY,"У игрока есть дом.");
				if(params[0] == playerid) return SendClientMessage(playerid, COLOR_GREY, "Вы не можете продать дом самому себе.");
				SendMes(params[0],COLOR_WHITE,"Игрок %s предлагает вам купить его дом за %d вирт. Введите /accept house.", PlayerInfo[playerid][pName], params[1]);
				SendMes(playerid,COLOR_WHITE,"Вы предложили %s купить ваш дом за %d вирт.", PlayerInfo[params[0]][pName], params[1]);
				ChangeHouse[params[0]][hProdaet] = playerid;
				ChangeHouse[playerid][hPokypaet] = params[0];
				ChangeHouse[params[0]][hCena] = params[1];
			}
			else return SendClientMessage(playerid,COLOR_GREY,"Вы далеко от покупателя.");
		}
	}
	return true;
}
CMD:changecar(playerid, params[])
{
	new caren = GetVehicleModel(caridhouse[playerid]);
	if(caren == 462) return SendClientMessage(playerid, COLOR_GREY, "У Вас мопед");
	if(PlayerInfo[playerid][pPhousekey] == 255) return SendClientMessage(playerid,COLOR_RED,"У вас нет дома");
	if(sscanf(params, "dd",params[0],params[1])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /changecar [id] [цена]");
	if(params[1] < 1 || params[1] > 1000000000) { SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1, и больше 100000000!"); return true; }
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid, COLOR_GREY, "[Ошибка] Игрок не найден!");
	{
		if(params[0] != INVALID_PLAYER_ID)
		{
			if(!ProxDetectorS(8.0, playerid, params[0])) return SendClientMessage(playerid, COLOR_GREY, "Игрок не рядом с вами!");
			{
				if(params[0] == playerid) { SendClientMessage(playerid, COLOR_GREY, "Вы не можете продать самому себе машину!"); return true; }
				format(stringer1, sizeof(stringer1), "Вы предложили %s купить вашу машину за %d вирт.",PlayerInfo[params[0]][pName],params[1]);
				SendClientMessage(playerid, 0x6ab1ffaa, stringer1);
				format(stringer1, sizeof(stringer1), "%s предлагает вам купить его машину за %d вирт.(( Введите /accept vehicle,чтобы совершить сделку )).",PlayerInfo[playerid][pName],params[1]);
				SendClientMessage(params[0], 0x6ab1ffaa, stringer1);
				format(stringer1, sizeof(stringer1), "%s предложил(а) %s купить его машину", PlayerInfo[playerid][pName] ,PlayerInfo[params[0]][pName]);
				ProxDetector(30.0, playerid, stringer1, COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW);
				CarOffer[params[0]] = playerid;
				CarPrice[params[0]] = params[1];
			}
		}
	}
	return true;
}
CMD:eject(playerid, params[])
{
	if(IsPlayerInAnyVehicle(playerid))
	{
		new State=GetPlayerState(playerid);
		if(State!=PLAYER_STATE_DRIVER) return SendClientMessage(playerid,COLOR_GREY,"Вы не водитель!");
		if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /eject [id]");
		new test = GetPlayerVehicleID(playerid);
		if(IsPlayerConnected(params[0]))
		{
			if(params[0] != INVALID_PLAYER_ID)
			{
				if(params[0] == playerid) { SendClientMessage(playerid, COLOR_GREY, "Вы не можете выкинуть из машины себя!"); return true; }
				if(IsPlayerInVehicle(params[0],test))
				{
					if(PlayerCuffed[params[0]] > 0)
					{
						RemovePlayerFromVehicle(params[0]);
						format(stringer1, sizeof(stringer1), "Вы выкинули из машины %s, наручники сломались!", PlayerInfo[params[0]][pName]);
						SendClientMessage(playerid, 0x6495EDFF, stringer1);
						format(stringer1, sizeof(stringer1), "Вас выкинул из машины %s, наручники сломались!!", PlayerInfo[playerid][pName]);
						SendClientMessage(params[0], 0x6495EDFF, stringer1);
						TogglePlayerControllable(params[0], 1);
						SetPlayerSpecialAction(params[0],SPECIAL_ACTION_NONE);
						RemovePlayerAttachedObject(params[0],0);
						PlayerCuffed[params[0]] = 0;
					}
					else
					{
						format(stringer1, sizeof(stringer1), "Вы выкинули из машины %s!", PlayerInfo[params[0]][pName]);
						SendClientMessage(playerid, 0x6495EDFF, stringer1);
						format(stringer1, sizeof(stringer1), "Вас выкинул из машины %s!", PlayerInfo[playerid][pName]);
						SendClientMessage(params[0], 0x6495EDFF, stringer1);
						RemovePlayerFromVehicle(params[0]);
						PlayerTied[params[0]] = 0;
						TogglePlayerControllable(params[0], 1);
					}
				}
				else return SendClientMessage(playerid, COLOR_GREY, "Не рядом с вами!");
			}
		}
		else SendClientMessage(playerid, COLOR_GREY, "[Ошибка] Игрок не найден!");
	}
	else SendClientMessage(playerid, COLOR_GREY, "Вы должны быть в машине!");
	return true;
}
public OnPlayerClickTextDraw(playerid, Text:clickedid)
{
	return 1;
}
stock PriceCar(newcar)
{
	new buycena;
	switch(GetVehicleModel(newcar))
	{
	case  466: buycena = 16600; case  542: buycena = 15100; case  492: buycena = 19000;
	case  517: buycena = 18600; case  516: buycena = 20350; case  467: buycena = 22300;
	case  600: buycena = 19500; case  549: buycena = 21000; case  529: buycena = 25000;
	case  404: buycena = 13400; case 474: buycena = 16500; case  410: buycena = 20410;
	case  422: buycena = 19900; case  439: buycena = 31400; case  479: buycena = 27000;
	case  535: buycena = 28900; case  543: buycena = 14500; case  575: buycena = 27400;
	case  545: buycena = 23900; case  411: buycena = 848000; case  560: buycena = 356400;
	case  562: buycena = 212300; case  579: buycena = 311900; case  429: buycena = 549300;
	case  415: buycena = 600100; case  559: buycena = 289000; case  581: buycena = 113000;
	case  506: buycena = 431000; case  402: buycena = 234900; case  541: buycena = 705000; case  461: buycena = 960400;
	case  522: buycena = 560400; case  481: buycena = 12600; case  510: buycena = 15600; case  463: buycena = 39700;
	case  586: buycena = 72000; case  468: buycena = 51000; case  451: buycena = 790000;  case  521: buycena = 152400;
	default: buycena = 80000;
	}
	return buycena;
}
public Random(min, max)
{
	new a = random(max - min) + min;
	return a;
}
stock Float:PointToPoint2D(Float:x1,Float:y1,Float:x2,Float:y2) return floatsqroot(floatadd(floatpower(x2-x1,2),floatpower(y2-y1,2)));
stock Float:GetPlayerDistanceToPlayer(playerid, targetid)
{
	new Float:x, Float:y, Float:z, Float:x2, Float:y2, Float:z2;
	GetPlayerPos(playerid, x, y, z);
	GetPlayerPos(targetid, x2, y2, z2);
	return PointToPoint2D(x, y, x2, y2);
}
stock MeAction(playerid,action[],Float:distance = 13.0)
{
	new mes[200];
	if(PlayerInfo[playerid][pMuted]) return SendMes(playerid, TEAM_CYAN_COLOR, "У Вас заблокирован чат, Вы не можете разговаривать. До снятия: %d секунд", PlayerInfo[playerid][pMuteTime]);
	format(mes, sizeof(mes),"%s %s", PlayerInfo[playerid][pName], action);
	PlayerForeach(i)
	{
		if(!IsPlayerConnected(i) || GetPlayerDistanceToPlayer(playerid,i) > distance || GetPlayerVirtualWorld(i) != GetPlayerVirtualWorld(playerid)) continue;
		SendClientMessage(i, 0xE75480FF, mes);
	}
	return true;
}
stock strreplace(string[], find, replace)
{
	for(new i=0; string[i]; i++)
	if(string[i] == find) string[i] = replace;
}
GoAnim(playerid,alib[],aanim[],Float:atime,amove,ax,ay,az,af,ac) return ApplyAnimation(playerid,alib,aanim,atime,amove,ax,ay,az,af,ac);
stock PreloadAnimLib(playerid, animlib[])
{
	ApplyAnimation(playerid,animlib,"null",0.0,0,0,0,0,0);
	return 1;
}
