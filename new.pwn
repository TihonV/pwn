				format(stringer,sizeof(stringer),"Спасибо за покупку. $%d",strval(inputtext)*1000); // Форматируем сообщение
				SendClientMessage(playerid,0x29FF00AA,stringer);
				ShowPlayerDialog(playerid, 7925, 2, "Доступное оружие", "Desert Eagle\t[$500]\nSilenced 9mm\t[$300]\nCountry Rifle\t[$750]\nShotgun\t[$500]\nSMG\t\t[$250]\nAK47\t\t[$500]\nM4\t\t[$500]\nTear Gas\t[$1000]\n\n\nGolf Club\t[$1200]\nBaseboll Bat\t[$1000]\nShovel\t\t[$1200]\nPool Cue\t[$1300]\nKatana\t\t[$2500]\nPurle Dildo\t[$1500]\nFlowers\t[$3000]\nCane\t\t[$1300]\nParachute\t[$1000]", "Далее", "Выйти");
				return 1; // Завершаем действие
			}
			else ShowPlayerDialog(playerid, 7925, 2, "Доступное оружие", "Desert Eagle\t[$500]\nSilenced 9mm\t[$300]\nCountry Rifle\t[$750]\nShotgun\t[$500]\nSMG\t\t[$250]\nAK47\t\t[$500]\nM4\t\t[$500]\nTear Gas\t[$1000]\n\n\nGolf Club\t[$1200]\nBaseboll Bat\t[$1000]\nShovel\t\t[$1200]\nPool Cue\t[$1300]\nKatana\t\t[$2500]\nPurle Dildo\t[$1500]\nFlowers\t[$3000]\nCane\t\t[$1300]\nParachute\t[$1000]", "Далее", "Выйти");
		}
	case 2934:
		{
			if(!response) return true;
			if(PlayerInfo[playerid][pAdmin] <= 0) return SendClientMessage(playerid, COLOR_LIGHTRED, "Вам запрещено использовать команду. Причина: Вы не администратор.");
			if(!strlen(inputtext)) return  ShowPlayerDialog(playerid,2934,DIALOG_STYLE_PASSWORD,"Авторизация администратора | {FF0000}3","Введите пароль\n\nКлюч должен состоять из латинских букв и цифр\nразмером от 4 до 15 символов","Авторизация","Скрыть");
			new pip[16];
			if(strval(inputtext) != PlayerInfo[playerid][pDostup]) return true;
			dostup[playerid] = 1;
			GetPlayerIp(playerid, pip, sizeof(pip));
			SendMes(playerid,0xF4B800AA, "Вы авторизировались как модератор %d уровня", PlayerInfo[playerid][pAdmin]);
			AdminText3D[playerid] = Create3DTextLabel(".::: Администратор :::.",0xFFDD00FF,0.0,0.0,0.0,50.0,0,1);
			Attach3DTextLabelToPlayer(AdminText3D[playerid],playerid,0.0,0.0,0.4);
			SetPlayerColor(playerid,0xFFDD00FF);
			format(stringer, sizeof(stringer), "[A] Администратор %s авторизовался | IP %s",PlayerInfo[playerid][pName],pip); //PlayerInfo[params[0]][pName],playersip
			ABroadCast(0xF4B800AA,stringer,1);
			return true;
		}
	case dGPS:
		{
			if(!response) return true;
			switch(listitem)
			{
			case 0:
				{
					new dialog[512];
					strcat(dialog, "1. Аэропорт\n2. Автошкола\n3. Банк LS\n4. Банк SF\n5. Банк LV\n6. Автомастерская\n7. Мэрия\n8. Больница\n9. Полиция LS\n10. Полиция SF\n11. Полиция LV\n12. Военкомат\n13. Церковь");
					strcat(dialog, "\n14. Магазин охотника LS\n15. Магазин охотника SF\n16. Магазин охотника LV\n17. Автосалон LV [Класс: A-B]\n18. Автосалон LS [Класс: N-C]\n19. Автосалон SF [#1] [Класс: N-C]\n20. Автосалон SF [#2] [Класс: N]\n21. Пейнтболл\n22. Казино");
					ShowPlayerDialog(playerid, dGPSMain, DIALOG_STYLE_LIST, "{f3d10c}КАРТА: {ffffff}Выбор места",dialog, "Далее", "Скрыть");
				}
			case 1:
				{
					new dialog[168];
					strcat(dialog, "1. Лесопилка \t\t {FFAA00}100 {FFFFFF}Donate\n2. Грузчики\t\t {FFAA00}100 {FFFFFF}Donate\n3. Завод металла\t {FFAA00}100 {FFFFFF}Donate");
					ShowPlayerDialog(playerid, dGPSMainJob, DIALOG_STYLE_LIST, "{f3d10c}КАРТА: {ffffff}Выбор места",dialog, "Далее", "Скрыть");
				}
			case 2:
				{
					DisablePlayerCheckpoint(playerid);
					RemovePlayerAttachedObject(playerid, 5);
					SetPVarInt(playerid,"GPS",0);
					SendClientMessage(playerid, COLOR_BLUE, "Карта убрана.");
				}
			}
			return true;
		}
	case dGPSMain:
		{
			if(!response) return ShowPlayerDialog(playerid,dGPS,2,"{f3d10c}КАРТА: {ffffff}Выбор места","[0] Общественные места\n[1] Работы\n[2] Убрать карту","Выбрать","Выход");
			switch(listitem)
			{
			case 0: SetPlayerCheckpoint(playerid,1685.8225,-2330.1467,13.5255,4.0); //АЭРОПОРТ
			case 1: SetPlayerCheckpoint(playerid,606.5971,-1459.5380,14.3969,4.0); //Автошкола
			case 2: SetPlayerCheckpoint(playerid,1463.0750,-1168.8431,23.8204,4.0); //Банк LS
			case 3: SetPlayerCheckpoint(playerid,-2171.5984,252.0814,35.3373,4.0); //Банк SF
			case 4: SetPlayerCheckpoint(playerid,2474.5981,1024.2528,10.8203,4.0); //Банк LV
			case 5: SetPlayerCheckpoint(playerid,1793.3774,-1709.2683,13.4904,4.0); //СТО LS
			case 6: SetPlayerCheckpoint(playerid,1481.1857,-1740.9348,13.5495,4.0); //Мэрия
			case 7: SetPlayerCheckpoint(playerid,1172.0792,-1323.3489,15.4030,4.0); // Больница
			case 8: SetPlayerCheckpoint(playerid,1542.5919,-1676.4452,13.5548,4.0); // Полиция LS
			case 9: SetPlayerCheckpoint(playerid,-1605.0452,720.4929,11.8777,4.0); // Полиция SF
			case 10: SetPlayerCheckpoint(playerid,2286.6794,2426.7869,10.8203,4.0); // Полиция LV
			case 11: SetPlayerCheckpoint(playerid,1168.6866,1363.2560,10.9218,4.0); // Военкомат
			case 12: SetPlayerCheckpoint(playerid,2224.8792,2522.1580,10.8203,4.0); // ЦЕРКОВЬ
			case 13: SetPlayerCheckpoint(playerid,1364.2766,-1280.9039,13.5469,4.0); // ТИР ЛС
			case 14: SetPlayerCheckpoint(playerid,-2626.0842,211.0941,4.6120,4.0); // ТИР СФ
			case 15: SetPlayerCheckpoint(playerid,2155.4641,942.9924,10.8203,4.0); // ТИР ЛВ
			case 16: SetPlayerCheckpoint(playerid,2466.9783,1319.7236,10.8095,4.0); // Автосалон А класс LV
			case 17: SetPlayerCheckpoint(playerid,556.4836,-1253.8977,17.0809,4.0); // Автосалон LS nooboklass
			case 18: SetPlayerCheckpoint(playerid,-1993.9950,287.5295,33.8689,4.0); // Автосалон SF nooboklass
			case 19: SetPlayerCheckpoint(playerid,-1634.4080,1199.8348,7.1875,4.0); // Автосалон SF 2 nooboklass
			case 20: SetPlayerCheckpoint(playerid,-2109.7368,-444.9375,38.7344,4.0); // PaintBall
			case 21: SetPlayerCheckpoint(playerid,1657.4541,2257.0342,10.8203,4.0); // Казино
			}
			SetPVarInt(playerid,"GPS",1);
			SendClientMessage(playerid,0xFFFF00FF,"Место отмечено у Вас на карте.");
		}
	case dGPSMainJob:
		{
			if(!response) return ShowPlayerDialog(playerid,dGPS,2,"{f3d10c}КАРТА: {ffffff}Выбор места","[0] Общественные места\n[1] Работы\n[2] Убрать карту","Выбрать","Выход");
			switch(listitem)
			{
			case 0: SetPlayerCheckpoint(playerid,2355.0295,-652.6135,128.0547,4.0); //Лесопилка
			case 1: SetPlayerCheckpoint(playerid,2206.7998,-2252.7327,13.9496,4.0); //Грузчики
			case 2: SetPlayerCheckpoint(playerid,-49.97, -269.363, 6.63319,4.0); //Завод
			}
			SetPVarInt(playerid,"GPS",1);
			SendClientMessage(playerid,0xFFFF00FF,"Место отмечено у Вас на карте.");
		}
	}
	while(strfind(inputtext,"%s",true)!=-1) strdel(inputtext,strfind(inputtext,"%s",true),strfind(inputtext,"%s",true)+2);
	return true;
}
public OnPlayerDisconnect(playerid, reason)
{
	if(GetPVarInt(playerid, "Kick") != 0) KillTimer(GetPVarInt(playerid, "Kick"));
	for (new cmdid; cmdid < MAX_CMDS; cmdid++) if(AntiFlood[playerid][cmdid] > 0) AntiFlood[playerid][cmdid] = 0;
	if(activemusic[playerid] == true)
	{
		activemusic[playerid] = false;
		StopAudioStreamForPlayer(playerid);
	}
	KillTimer(RTimer[playerid]);
	if(tChainSaw[playerid] != -1) KillTimer(tChainSaw[playerid]), tChainSaw[playerid] = -1;
	PlayerTextDrawDestroy(playerid,CarSpeed[playerid]);
	PlayerTextDrawDestroy(playerid,CarFuel[playerid]);
	PlayerTextDrawDestroy(playerid,CarMilliage[playerid]);
	PlayerTextDrawDestroy(playerid,CarLights[playerid]);
	PlayerTextDrawDestroy(playerid,CarEngine[playerid]);
	TextDrawHideForPlayer(playerid, SBox);
	Delete3DTextLabel(AdminText3D[playerid]);
	IsConnected{playerid} = 0;
	if(TeamPain[playerid] == 1) BluePlayer--;
	if(TeamPain[playerid] == 2) RedPlayer--;
	TeamPain[playerid] = 0;
	KillPain[playerid] = 0;
	DeathPain[playerid] = 0;
	if(IsACop(playerid)) zakonn --;
	if(PlantObject[playerid] != -1)
	{
		DestroyObject(PlantObject[playerid]);
		PlantObject[playerid] = -1;
	}
	if(ContractInfo[playerid][cHitman] != INVALID_PLAYER_ID)
	{
		if(IsPlayerConnected(ContractInfo[playerid][cHitman]))
		{
			SendMes(ContractInfo[playerid][cHitman],COLOR_YELLOW,"~~~ Жертва %s[%d] вышла из игры ~~~", PlayerInfo[playerid][pName],playerid);
			ContractInfo[ContractInfo[playerid][cHitman]][cZakaz] = INVALID_PLAYER_ID;
		}
	}
	if(PlayerInfo[playerid][pAdmin] > 0)
	{
		format(stringer1, sizeof(stringer1), "[A] вышел %s [lvl: %d]",PlayerInfo[playerid][pName],PlayerInfo[playerid][pAdmin]);
		Delete3DTextLabel(AdminText3D[playerid]);
		ABroadCast(0xF4B800AA,stringer1,1);
	}
	mysql_format(dbHandle, QUERY, sizeof(QUERY), "UPDATE `"TABLE_ACCOUNT"` SET `pOnline` = '1001' WHERE `Name` = '%s'",PlayerInfo[playerid][pName]);
	mysql_function_query(dbHandle, QUERY, false, "", "");
	ResetCarInfo(playerid);
	if(PlayerCuffed[playerid] > 0 && PlayerInfo[playerid][pWanted] > 0 || Tazer[playerid] > 0 && PlayerInfo[playerid][pWanted] > 0)
	{
		PlayerInfo[playerid][pJailTime] = PlayerInfo[playerid][pWanted]*600;
		PlayerInfo[playerid][pJailed] = 1;
		PlayerInfo[playerid][pCash] -= 1000000;
		PlayerInfo[playerid][pMestoJail] = 2;
	}
	if(GetPVarInt(playerid,"GzOn") == 1)
	{
		SetPVarInt(playerid,"GzOn",0);
		PlayerTextDrawDestroy(playerid, BandaCapt1a[playerid]);
		PlayerTextDrawDestroy(playerid, BandaCapt2a[playerid]);
		PlayerTextDrawDestroy(playerid, ScoreCapt1a[playerid]);
		PlayerTextDrawDestroy(playerid, ScoreCapt2a[playerid]);
		PlayerTextDrawDestroy(playerid, ScoreCaptTire[playerid]);
		PlayerTextDrawDestroy(playerid, CaptTime[playerid]);
		PlayerTextDrawDestroy(playerid, ScoreCapt[playerid]);
		PlayerTextDrawDestroy(playerid, Textdraw4[playerid]);
	}
	if(RB[playerid] != 255)
	{
		DestroyDynamicObject(BlockPost[RB[playerid]]);
		DestroyDynamic3DTextLabel(Block3D[RB[playerid]]);
		RB[playerid] = 255;
		rbtime[playerid] = 0;
	}
	if(PlayerTied[playerid] > 0)
	{
		format(stringer1, sizeof(stringer1), " %s вышел из игры при похищении, данный игрок будет наказан.", PlayerInfo[playerid][pName]);
		SendClientMessageToAll(COLOR_LIGHTRED, stringer1);
		PlayerInfo[playerid][pExitTied]++;
		PlayerInfo[playerid][pExitTiedNomer] = 1;
	}
	CancelSelectTextDraw(playerid);
	if(boy[playerid] == 1)
	{
		ring = 0;
		boy[playerid] = 0;
		boy[fightid[playerid]] = 0;
		TimeBox[playerid] = 0;
		TimeBoxAll[playerid] = 0;
		TimeBox[fightid[playerid]] = 0;
		TimeBoxAll[fightid[playerid]] = 0;
		SetPlayerPos(fightid[playerid],770.7488,6.9432,1000.7118);
		SetPlayerFacingAngle(fightid[playerid], 90.0);
		switch(PlayerInfo[fightid[playerid]][pFightSkil])
		{
		case 0..49: PlayerInfo[fightid[playerid]][pFightSkil]++, PlayerInfo[fightid[playerid]][pFightTime]= 600;
		case 50: PlayerInfo[fightid[playerid]][pFightSkill]++, PlayerInfo[fightid[playerid]][pFightTime]= 600;
		case 51..99: PlayerInfo[fightid[playerid]][pFightSkil]++, PlayerInfo[fightid[playerid]][pFightTime]= 540;
		case 100: PlayerInfo[fightid[playerid]][pFightSkill]++, PlayerInfo[fightid[playerid]][pFightTime]= 540;
		case 101..149: PlayerInfo[fightid[playerid]][pFightSkil]++, PlayerInfo[fightid[playerid]][pFightTime]= 480;
		case 150: PlayerInfo[fightid[playerid]][pFightSkill]++, PlayerInfo[fightid[playerid]][pFightTime]= 480;
		case 151..199: PlayerInfo[fightid[playerid]][pFightSkil]++, PlayerInfo[fightid[playerid]][pFightTime]= 420;
		case 200: PlayerInfo[fightid[playerid]][pFightSkill]++, PlayerInfo[fightid[playerid]][pFightTime]= 420;
		}
		SendMes(fightid[playerid],COLOR_LIGHTRED," Ваш противник вышел из игры на ринге. Время до след. боя: %d секунд", PlayerInfo[fightid[playerid]][pFightTime]);
		PlayerInfo[playerid][pFightTime] = 600;
		fightid[playerid] = INVALID_PLAYER_ID;
		fightid[fightid[playerid]] = INVALID_PLAYER_ID;
		TogglePlayerControllable(fightid[playerid], 0);
	}
	PlayerForeach(i)
	{
		if(GetPlayerState(i) == PLAYER_STATE_SPECTATING && gSpectateID[i] == playerid)
		{
			StopSpectate(i);
			SetPlayerHealth(i, 100);
			GameTextForPlayer(i,"~w~RECON ~r~ OFF~n~ ~r~PLAYER DISCONNECT", 5000, 3);
		}
	}
	if(PlayerInfo[playerid][pJob] == 2)
	{
		if(gcontract[playerid] == 1)
		{
			Delete3DTextLabel(Meh3d[GetPlayerVehicleID(playerid)]);
			gcontract[playerid] = 0;
		}
	}
	if(PlayerInfo[playerid][pPhousekey] !=255)
	{
		PlayerInfo[playerid][pProz] = PlayerInfo[playerid][pProz];
		if(caridhouse[playerid] != 0)
		{
			DestroyVehicle(caridhouse[playerid]);
			caridhouse[playerid] = 0;
		}
	}
	new playersip[16];
	new year, month,day;
	zips[playerid] = 0;
	getdate(year, month, day);
	new hour, minute, second;
	gettime(hour, minute, second);
	GetPlayerIp(playerid,playersip,sizeof(playersip));
	if(IsPlayerAttachedObjectSlotUsed(playerid,1)) RemovePlayerAttachedObject(playerid,1);
	if(SelectChar[playerid] == INVALID_PLAYER_ID)
	{
		SetPlayerSkin(playerid, OldSkin[playerid]);
		PlayerInfo[playerid][pChar] = OldSkin[playerid];
		SelectChar[playerid] = 0;
	}
	OnPlayerUpdateRL(playerid);
	tune[playerid] = 0;
	soglasen[playerid] = 0;
	SelectCharPlace[playerid] = 0;
	CharPrice[playerid] = 0;
	SelectCharID[playerid] = 0;
	SelectChar[playerid] = 0;
	PicCP[playerid] = 0;
	takephone[playerid] = 0;
	gag[playerid] = 0;
	dostup[playerid] = 0;
	PicCP[playerid] = 0;
	enterbiz[playerid] = 0;
	PlayerInfo[playerid][pDrugtime] = 0;
	PlayerInfo[playerid][pGunfbiTime] = 0;
	forma[playerid] = 0;
	proverkaforma[playerid] = 0;
	keys[playerid] = 0;
	SetPlayerSkills(playerid);
	SelectCharPlace[playerid] = 0;
	CharPrice[playerid] = 0;
	SelectCharID[playerid] = 0;
	SelectChar[playerid] = 0;
	if(TransportDuty[playerid] == 1) TaxiDrivers -= 1;
	if(PlayerInfo[playerid][pMember] == 4) Medics -= 1;
	if(PlayerInfo[playerid][pMember] == 1 || PlayerInfo[playerid][pMember] == 10 || PlayerInfo[playerid][pMember] == 21 ) Police +=1;
	else if(PlayerInfo[playerid][pJob] == 2) Mechanics -= 1;
	if(TransportCost[playerid] > 0 && TransportDriver[playerid] != INVALID_PLAYER_ID)
	{
		if(IsPlayerConnected(TransportDriver[playerid]))
		{
			TransportMoney[TransportDriver[playerid]] += TransportCost[playerid];
			TransportTime[TransportDriver[playerid]] = 0;
			TransportCost[TransportDriver[playerid]] = 0;
			format(stringer1, sizeof(stringer1), "~g~+%d",TransportCost[playerid]);
			GameTextForPlayer(TransportDriver[playerid], stringer1, 5000, 1);
		}
	}
	return true;
}

public OnPlayerSelectObject(playerid, type, objectid, modelid, Float:fX, Float:fY, Float:fZ)
{
	new string[80];
	format(string, sizeof(string), "ID объекта: %d\nКоординаты объекта: %f,%f,%f", modelid,fX,fY,fZ);
	ShowPlayerDialog(playerid, 6567, DIALOG_STYLE_MSGBOX, "Редактор", string ,"Изменить", "Удалить");
	SetPVarInt(playerid, "SelectedObject", objectid);
	return true;
}

public OnPlayerEditObject(playerid, playerobject, objectid, response, Float:fX, Float:fY, Float:fZ, Float:fRotX, Float:fRotY, Float:fRotZ)
{
	if(!playerobject)
	{
		if(!IsValidObject(objectid)) return true;
		MoveObject(objectid, fX, fY, fZ, 10.0, fRotX, fRotY, fRotZ);
	}
	if(response == EDIT_RESPONSE_FINAL)
	{
		printf("Ид обьекта %d коорды по X %f коорды по Y %f коорды по Z %f",objectid,fX, fY, fZ);
		SendMes(playerid,COLOR_LIGHTRED,"Ид обьекта %d коорды по X %f коорды по Y %f коорды по Z %f",objectid,fX, fY, fZ);
	}
	return true;
}

public OnPlayerEditAttachedObject(playerid, response, index, modelid, boneid, Float:fOffsetX, Float:fOffsetY, Float:fOffsetZ, Float:fRotX, Float:fRotY, Float:fRotZ, Float:fScaleX, Float:fScaleY, Float:fScaleZ) return true;

stock SetPlayerWeapons(playerid)
{
	if(IsPlayerConnected(playerid))
	{
		ResetPlayerWeapons(playerid);
		if(PlayerInfo[playerid][pJailed] < 1)
		{
			if(IsACop(playerid)) GivePlayerWeapon(playerid, 0, 1);
			if(PlayerInfo[playerid][pMember] == 5 || PlayerInfo[playerid][pLeader] == 5) GivePlayerWeapon(playerid, 5, 1);
			if(PlayerInfo[playerid][pMember] == 24 || PlayerInfo[playerid][pLeader] == 24) GivePlayerWeapon(playerid, 5, 1);
			if(PlayerInfo[playerid][pMember] == 6 || PlayerInfo[playerid][pLeader] == 6) GivePlayerWeapon(playerid, 8, 1);
			if(PlayerInfo[playerid][pMember] == 7 && PlayerInfo[playerid][pRank] == 3) GivePlayerWeapon(playerid, 24, 100),SetPlayerArmour(playerid, 100);
			if(PlayerInfo[playerid][pMember] == 7 && PlayerInfo[playerid][pRank] == 4) GivePlayerWeapon(playerid, 24, 100),SetPlayerArmour(playerid, 100);
			if(PlayerInfo[playerid][pMember] == 8 && PlayerInfo[playerid][pRank] == 2) GivePlayerWeapon(playerid, 24, 100),SetPlayerArmour(playerid, 100);
			if(PlayerInfo[playerid][pMember] == 10 || PlayerInfo[playerid][pLeader] == 10) GivePlayerWeapon(playerid, 0, 1);
			if(PlayerInfo[playerid][pMember] == 11 || PlayerInfo[playerid][pLeader] == 11) GivePlayerWeapon(playerid, 0, 34);
			if(PlayerInfo[playerid][pMember] == 12 || PlayerInfo[playerid][pLeader] == 12) GivePlayerWeapon(playerid, 5, 1);
			if(PlayerInfo[playerid][pMember] == 13 || PlayerInfo[playerid][pLeader] == 13) GivePlayerWeapon(playerid, 5, 1);
			if(PlayerInfo[playerid][pMember] == 14 || PlayerInfo[playerid][pLeader] == 14) GivePlayerWeapon(playerid, 1, 1);
			if(PlayerInfo[playerid][pMember] == 15 || PlayerInfo[playerid][pLeader] == 15) GivePlayerWeapon(playerid, 5, 1);
			if(PlayerInfo[playerid][pMember] == 16 || PlayerInfo[playerid][pLeader] == 16) GivePlayerWeapon(playerid, 43, 30);
			if(PlayerInfo[playerid][pMember] == 17 || PlayerInfo[playerid][pLeader] == 17) GivePlayerWeapon(playerid, 5, 1);
			if(PlayerInfo[playerid][pMember] == 18 || PlayerInfo[playerid][pLeader] == 18) GivePlayerWeapon(playerid, 5, 1);
			if(PlayerInfo[playerid][pMember] == 21 || PlayerInfo[playerid][pLeader] == 21) GivePlayerWeapon(playerid, 0, 1);
		}
	}
	return true;
}
stock SetPlayerSpawn(playerid)
{
	if(gPlayerLogged[playerid] == 0) { SendClientMessage(playerid, COLOR_WHITE, "Необходимо авторизоваться!"); GKick(playerid); return true; }
	TogglePlayerControllable(playerid, true);
	if(IsPlayerConnected(playerid))
	{
		if(PlayerInfo[playerid][pAdmin] > 0 && dostup[playerid] == 0) {  ShowPlayerDialog(playerid,2934,DIALOG_STYLE_PASSWORD,"Админ авторизация","Введите пароль\n\nПароль должен состоять из латинских букв и цифр\nразмером от 4 до 15 символов","Вход","Скрыть"); }
		if(PlayerInfo[playerid][pWanted] > 6) PlayerInfo[playerid][pWanted] = 6;
		if(PlayerInfo[playerid][pChar] == 0) PlayerInfo[playerid][pChar] = 230;
		if(PlayerInfo[playerid][pModel] == 0) PlayerInfo[playerid][pModel] = 230;
		if(PlayerInfo[playerid][pLeader] == 1 && PlayerInfo[playerid][pRank] != 15) PlayerInfo[playerid][pRank] = 15;
