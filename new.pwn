CMD:raion(playerid, params[])
{
	new strings[30];
	GetPlayer2DZone(playerid, strings, 30);
	SendMes(playerid, -1, "Вы находитесь в районе: %s", strings);
	return true;
}
CMD:repair(playerid, params[])
{
	if(PlayerInfo[playerid][pJob] != 2) return SendClientMessage(playerid, -1, "Вы не механик!");
	new playa, money;
	if(sscanf(params, "dd", playa, money)) return	SendClientMessage(playerid, COLOR_GRAD2, " {FFA200}[Подсказка]: {FFFFFF} /repair [id] [цена]");
	if(money < 1 || money > 1000) { SendClientMessage(playerid, -1, "Нельзя меньше 1, и больше 1000!"); return true; }
	if(IsPlayerConnected(playa))
	{
		if(playa != INVALID_PLAYER_ID)
		{
			if(GetVehicleModel(GetPlayerVehicleID(playerid)) != 525) return   SendClientMessage(playerid, -1, "Вы не на эвакуаторе!");
			if(ProxDetectorS(8.0, playerid, playa)&& IsPlayerInAnyVehicle(playa))
			{
				if(playa == playerid) { SendClientMessage(playerid, -1, "Вы не можете чинить машину самому себе!"); return true; }
				format(stringer, sizeof(stringer), "Вы предложили %s отремонтировать его машину за %d вирт.", PlayerInfo[playa][pName],money);
				SendClientMessage(playerid, 0x6ab1ffaa, stringer);
				format(stringer, sizeof(stringer), "Механик %s предлагает отремонтировать ваш автомобиль за %d вирт.(Введите /accept repair),чтобы совершить починку.", PlayerInfo[playerid][pName],money);
				SendClientMessage(playa, 0x6ab1ffaa, stringer);
				RepairOffer[playa] = playerid;
				RepairPrice[playa] = money;
			}
			else { SendClientMessage(playerid, -1, "Он не в машине!"); }
		}
	}
	else { SendClientMessage(playerid, -1, "[Ошибка] Игрок не найден!"); }
	return true;
}
CMD:capture(playerid, params[])
{
	if(!IsAGang(playerid)) return SendClientMessage(playerid,-1, "Вам не доступна эта функция");
	if(PlayerInfo[playerid][pRank] < 7) return SendClientMessage(playerid, COLOR_GRAD1, "Вам нужен 7 ранг");
	if(FrakCD[PlayerInfo[playerid][pMember]] > 0) return SendClientMessage(playerid,-1,"Ваша банда уже воевала за территорию.");
	new captureghetto = 0;
	new t; gettime(t);
	if(t < 9 || t > 22 ) return SendClientMessage(playerid, 0xAFAFAFAA, "Использовать команду можно только с 9:00 до 23:00");
	for(new i = 0; i < sizeof(GZInfo); i++)
	{
		if(PlayerToKvadrat(playerid,GZInfo[i][gCoords][0], GZInfo[i][gCoords][1],GZInfo[i][gCoords][2],GZInfo[i][gCoords][3]) && GZInfo[i][ZoneOnBattle] == 0)
		{
			if(i == 34 || i == 46 || i == 93 || i == 98 || i == 4) return SendClientMessage(playerid, -1, "{ffffff}Данная территория прилегает к респавну, захват запрещен!");
			if(PlayerInfo[playerid][pMember] == GZInfo[i][gFrakVlad]) return SendClientMessage(playerid,-1,"Необходимо находится на территори которую хотите завоевать");
			if(FrakCD[GZInfo[i][gFrakVlad]] > 0) return SendClientMessage(playerid,-1,"Банда на которую вы хотите напасать уже воевала в этом часу");
			if(!IsPlayerInBandOnline(GZInfo[i][gFrakVlad])) return SendClientMessage(playerid,-1, "Банда на которую вы собираетесь напасть нет в сети!");
			captureghetto++;
			GZInfo[i][gTime] = 600;
			GetPlayer2DZone(playerid,GZInfo[i][GZName],30);
			GZInfo[i][gNapad] = PlayerInfo[playerid][pMember];
			format(stringer,112,"%s начали захват территории банды %s в районе %s",GFrac(PlayerInfo[playerid][pMember]),GFrac(GZInfo[i][gFrakVlad]),GZInfo[i][GZName]);
			SendBand(PlayerInfo[playerid][pMember],GZInfo[i][gFrakVlad],COLOR_ORANGE,stringer);
			GangZoneFlashForAll(GZInfo[i][gID],GetGangColor(GZInfo[i][gNapad]));
			GZInfo[i][ZoneOnBattle] = 1;
			FracCD(PlayerInfo[playerid][pMember],GZInfo[i][gFrakVlad],1);// капт в 1 час
			GZInfo[i][gzTimer] = SetTimerEx("GzCheck",1000,1,"iii",i,PlayerInfo[playerid][pMember],GZInfo[i][gFrakVlad]);
			break;
		}
	}
	if(captureghetto == 0) return SendClientMessage(playerid,-1,"Необходимо находится на территори которую хотите завоевать");
	return true;
}
CMD:snow(playerid, params[])
{
    if(GetPVarInt(playerid, "Snow_Xenus") == 0)
    {
        SendClientMessage(playerid, -1, "[2017] Вы включили снег. С НОВЫМ ГОДОМ!");
    	SetPVarInt(playerid, "Snow_Xenus", 1);
    	SetPlayerAttachedObject(playerid, 9, 18864, 1, -9.0, 0.0, 0.0, 0.0, 90.0, 0.0);
    	return 1;
    }
    SendClientMessage(playerid, -1, "[2017] Вы выключили снег. С НОВЫМ ГОДОМ!");
    DeletePVar(playerid, "Snow_Xenus");
    RemovePlayerAttachedObject(playerid, 9);
    return 1;
}
CMD:quitjob(playerid, params[])
{
	PlayerInfo[playerid][pJob] = 0;
	SendClientMessage(playerid,COLOR_ORANGE,"Вы успешно уволились с работы");
	return 1;
}
CMD:radio(playerid, params[])
{
	if(PlayerInfo[playerid][pMuted] == 1) return SendMes(playerid, COLOR_LIGHTRED, "У Вас заблокирован чат, Вы не можете разговаривать. До снятия: %d секунд", PlayerInfo[playerid][pMuteTime]);
	if(sscanf(params, "s[128]",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} (/r)adio [текст]");
	switch(PlayerInfo[playerid][pMember])
	{
	case 11,12,13,15,14,24,27:return true;
	case 17,18,0,5,6,9,16,20,23:return true;
	}
	format(stringer1, sizeof(stringer1), "%s | %s[%d]: %s", GetPlayerRank(playerid),PlayerInfo[playerid][pName], playerid, params[0]);
	SendRadioMessage(PlayerInfo[playerid][pMember], TEAM_BLUE_COLOR, stringer1);
	return true;
}
CMD:id(playerid, params[])
{
	new null = 0;
	if(sscanf(params, "s[32]",params[0])) return SendClientMessage(playerid, -1, "{FFA200}[Подсказка]: {FFFFFF} /id [ник]");
	PlayerForeach(i)
	{
		if(strfind(PlayerInfo[i][pName], params[0], true) != -1)
		{
			null++;
			new string[104];
			format(string, 104, "%i. %s [%i]\n", null, PlayerInfo[i][pName], i);
			SendClientMessage(playerid, -1, string);
		}
	}
	if(null == 0) return SendClientMessage(playerid, COLOR_GREY, "Игроки не найдены");
	return true;
}
CMD:family(playerid, params[])
{
	if(PlayerInfo[playerid][pMuted] == 1) return SendMes(playerid, COLOR_LIGHTRED, "У Вас заблокирован чат, Вы не можете разговаривать. До снятия: %d секунд", PlayerInfo[playerid][pMuteTime]);
	if(sscanf(params, "s[128]",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} (/f)amily [текст]");
	switch(PlayerInfo[playerid][pMember])
	{
	case 0..4,7,10,19,21,25,26: return true;
	}
	format(stringer1, sizeof(stringer1), "[F] %s %s[%d]: %s", GetPlayerRank(playerid),PlayerInfo[playerid][pName], playerid, params[0]);
	SendFamilyMessage(PlayerInfo[playerid][pMember], TEAM_AZTECAS_COLOR, stringer1);
	return true;
}
CMD:departments(playerid, params[])
{
	if(PlayerInfo[playerid][pMuted] == 1) return SendMes(playerid, COLOR_LIGHTRED, "У Вас заблокирован чат, Вы не можете разговаривать. До снятия: %d секунд", PlayerInfo[playerid][pMuteTime]);
	if(sscanf(params, "s[128]",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} (/d)epartments [текст]");
	switch(PlayerInfo[playerid][pMember])
	{
	case 12,13,15,14,24,27:return true;
	case 17,18,0,5,6,9,16,20,23:return true;
	}
	if(PlayerInfo[playerid][pRank] < 2) return SendClientMessage(playerid, COLOR_GRAD1, "Вы не уполномочены писать в депортамент!");
	format(stringer1, sizeof(stringer1), "%s %s | %s[%d]: %s", GetPlayerFracName(playerid),GetPlayerRank(playerid),PlayerInfo[playerid][pName], playerid, params[0]);
	SendTeamMessage(PlayerInfo[playerid][pMember], COLOR_ALLDEPT, stringer1);
	return true;
}
CMD:government(playerid,params[])
{
	if(gag[playerid] == 1) return SendClientMessage(playerid, COLOR_WHITE, "Ошибка: Вы не можете говорить. Для начала мафиози должен избавить вас от кляпа.");
	if(PlayerInfo[playerid][pMuted] != 0) return SendMes(playerid, COLOR_WHITE, "У Вас заблокирован чат, Вы не можете разговаривать. До снятия: %d секунд", PlayerInfo[playerid][pMuteTime]);
	if(government_mute) return SendClientMessage(playerid, 0xE63D00FF, "На данный момент запрещено отправлять сообщения в гос. новости");
	new memberrs = PlayerInfo[playerid][pMember];
	new rankk = PlayerInfo[playerid][pRank];
	if(memberrs == 1 && rankk >= 14 || memberrs == 3 && rankk >= 14 || memberrs == 10 && rankk >= 14 || memberrs == 19 && rankk >= 14 || memberrs == 21 && rankk >= 14 || memberrs == 2 && rankk >= 9 || memberrs == 26 && rankk >= 9 || memberrs == 4 && rankk >= 9 || memberrs == 11 && rankk >= 9
			|| memberrs == 25 && rankk >= 9 || memberrs == 7 && rankk >= 5)
	{
		if(sscanf(params,"s[128]",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /gov(ernment) [сообщение]");
		if(GetPVarInt(playerid,"GovChat") > gettime()) return SendClientMessage(playerid, -1, "Сообщение можно подать раз в 10 секунд.");
		SetPVarInt(playerid,"GovChat",gettime()+10);
		if(IsIpFound(params[0]))
		{
			PlayerInfo[playerid][pMuteTime] = 180;
			PlayerInfo[playerid][pMuted] = 1;
			format(stringer1, sizeof(stringer1), "%s: %s",PlayerInfo[playerid][pName],params[0]);
			ABroadCast(COLOR_LIGHTRED,stringer1,1);
			new ip[14];
			GetPlayerIp(playerid,ip,14);
			format(stringer1, sizeof(stringer1), "- ID: %d | IP: [%s]",playerid,ip);
			ABroadCast(COLOR_LIGHTRED,stringer1,1);
			SendMes(playerid, COLOR_LIGHTRED, "Сервер заблокировал Вам чат на 3 минуты ( /mm => Репорт )");
			return true;
		}
		format(stringer1, sizeof(stringer1),"[%s] %s %s[%d]: %s",GetPlayerFracName(playerid),GetPlayerRank(playerid),PlayerInfo[playerid][pName],playerid, params[0]);
		SendClientMessageToAll(0x6495EDFF,stringer1);
	}
	else return SendClientMessage(playerid,COLOR_GREY,"Вам не доступна данная команда");
	return true;
}
CMD:dice(playerid, params[])
{
	if(!ProxDetectorS(5.0, playerid, params[0])) SendClientMessage(playerid, COLOR_WHITE, "Игрок не рядом с вами!");
	if(!PlayerToPoint(30.0,playerid,1130.7448,-1.4491,1000.6797)) return SendClientMessage(playerid, COLOR_WHITE, "Вы должны находиться в казино!");
	if(sscanf(params, "ud", params[0],params[1])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /dice [id игрока] [ставка]");
	if(params[1] < 100000 || params[1] > 5000000) return SendClientMessage(playerid, COLOR_WHITE, "Минимальная ставка 100 000$ максимальная 5 000 000$");
	if(ZapretDice[params[0]] == 1) return SendClientMessage(playerid, COLOR_WHITE, "В данный момент игрок не может играть!");
	if(PlayerInfo[params[0]][pCash] < params[1]) return SendClientMessage(playerid, -1, "У этого игрока нет столько денег!");
	if(dicetime > gettime()) return SendClientMessage(playerid, COLOR_WHITE, "В данный момент вы можете играть");
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid, COLOR_WHITE, "Игрок оффлайн");
	if(!ProxDetectorS(6.0, playerid, params[0])) SendClientMessage(playerid, COLOR_WHITE, "Игрок не рядом с вами!");
	if(params[0] == playerid) return SendClientMessage(playerid, COLOR_WHITE, "Вы указали свой ID");
	SendMes(playerid, 0x269BD8FF, "Вы предложили {FFFFFF}%s {269BD8} бросить кости. Ставка: {FFFFFF}$%i",PlayerInfo[params[0]][pName],params[1]);
	SendMes(params[0], COLOR_WHITE, "%s {269BD8}предлагает бросить кости. Ставка: {FFFFFF}$%i. {269BD8}Чтобы подтвердить нажмите {33AA33}Y{269BD8}, иначе {"#cRED"}N",PlayerInfo[playerid][pName],params[1]);
	ZapretDice[playerid] = 1;
	SetPVarInt(params[0], "KostiName",playerid);
	SetPVarInt(params[0], "KostiMoney",params[1]);
	return true;
}
CMD:spy(playerid, params[])
{
	if(PlayerInfo[playerid][pMember] != 2) return SendClientMessage(playerid, COLOR_WHITE, "Вы не агент FBI");
	if(PlayerInfo[playerid][pMember] == 2 && PlayerInfo[playerid][pRank] >= 4)
	ShowPlayerDialog(playerid, 9746, DIALOG_STYLE_LIST, "Выберите фракцию", "Полиция\nАрмия\nМЧС\nМэрия\nАвтошкола\nNews\nLCN\nYAKUZA\nRUSSIAN MAFIA\nRIFA GANG\nGROVE STREET\nBALLAS\nVAGOS\nAZTECAS\nБайкеры\nСнять маскировку", "Выбрать", "Отмена");
	return true;
}
CMD:suspect(playerid, params[])
{
	if(sscanf(params, "ds[128]", params[0],params[1])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} (/su)spect [id] [преступление]");
	if(PlayerInfo[playerid][pMember] == 1 || PlayerInfo[playerid][pLeader] == 1 || PlayerInfo[playerid][pMember] == 2 || PlayerInfo[playerid][pLeader] == 2 || PlayerInfo[playerid][pMember] == 10 || PlayerInfo[playerid][pLeader] == 10 || PlayerInfo[playerid][pMember] == 21 || PlayerInfo[playerid][pLeader] == 21 || PlayerInfo[playerid][pMember] == 25 || PlayerInfo[playerid][pLeader] == 25)
	{
		if(!IsPlayerConnected(params[0])) return true;
		if(params[0] == INVALID_PLAYER_ID) return true;
		if(PlayerInfo[params[0]][pJailed] != 0) return true;
		if(PlayerInfo[params[0]][pWanted] >= 6) return    SendClientMessage(playerid, COLOR_GREY, "У данного игрока уже 6 уровней розыска!");
		if(IsACop(params[0])) return SendClientMessage(playerid, COLOR_GRAD2, "Вы не можете давать розыск законникам!");
		if(PlayerInfo[params[0]][pAdmin] > 0 && PlayerInfo[playerid][pAdmin] != 5) return SendClientMessage(playerid, COLOR_WHITE, "Администратор не может быть в розоске!");
		WantedPoints[params[0]]++;
		PlayerInfo[params[0]][pWanted]+= 1;
		SetPlayerExtra(params[0],playerid, params[1]);
		return true;
	}
	return true;
}
CMD:arrest(playerid, params[])
{
	if(!IsACop(playerid)) return true;
	if(PlayerToPoint(15.0, playerid, 268.3327,77.8972,1001.0391) || PlayerToPoint(6.0, playerid, 227.7436,114.5075,999.0156) || PlayerToPoint(6.0, playerid, 188.7124,157.6917,1003.0234)|| PlayerToPoint(6.0, playerid, 218.2263,114.9286,999.0156) || PlayerToPoint(6.0, playerid, 198.3940,157.9389,1003.0234))
	{
		if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /arrest [время]");
		if(params[0] < 1 || params[0] > 20) return SendClientMessage(playerid, COLOR_GREY, "От 1 минуты до 20");
		new suspect = GetClosestPlayer(playerid);
		if(!IsPlayerConnected(suspect)) return true;
		if(!ProxDetectorS(4.0, playerid, suspect)) return true;
		if(PlayerInfo[suspect][pWanted] < 1) return  SendClientMessage(playerid, COLOR_GREY, "Человек должен иметь хотя бы один уровень розыска!");
		format(stringer1, sizeof(stringer1), "Вы арестовали %s, штраф 5 вирт",PlayerInfo[suspect][pName]);
		SendClientMessage(playerid, COLOR_WHITE, stringer1);
		PlayerInfo[suspect][pCash]-= 5;
		PlayerInfo[playerid][pCash]+= 5;
		GameTextForPlayer(suspect,"~r~-5", 5000, 5);
		Delgun(suspect);
		switch(PlayerInfo[playerid][pMember])
		{
		case 1,10,21,25,2: { format(stringer1, sizeof(stringer1), "Police Deportament | %s арестовал(a) преступника %s ",PlayerInfo[playerid][pName],PlayerInfo[suspect][pName]); SendClientMessageToAll(COLOR_LIGHTRED, stringer1); }
		}
		if(PlayerToPoint(15.0, playerid, 268.3327,77.8972,1001.0391))
		{
			SetPlayerInterior(suspect, 6);
			PlayerInfo[suspect][pInt] = 6;
			SetPlayerPos(suspect,264.1425,77.4712,1001.0391);
			SetPlayerFacingAngle(suspect, 263.0160);
			PlayerInfo[suspect][pMestoJail] = 1;
		}
		else if(PlayerToPoint(6.0, playerid, 218.2263,114.9286,999.0156))
		{
			SetPlayerInterior(suspect, 10);
			PlayerInfo[suspect][pInt] = 10;
			SetPlayerPos(suspect,219.5400,109.9767,999.0156);
			SetPlayerFacingAngle(suspect, 1.0000);
			PlayerInfo[suspect][pMestoJail] = 2;
		}
		else if(PlayerToPoint(6.0, playerid, 198.3940,157.9389,1003.0234))
		{
			SetPlayerInterior(suspect, 3);
			PlayerInfo[suspect][pInt] = 3;
			SetPlayerPos(suspect,198.3642,161.8103,1003.0300);
			SetPlayerFacingAngle(suspect, 1.0000);
			PlayerInfo[suspect][pMestoJail] = 3;
		}
		SetPlayerWantedLevel(suspect, 0);
		PlayerInfo[suspect][pJailTime] = params[0]*60;
		WantedPoints[suspect] = 0;
		PlayerInfo[suspect][pWanted] = 0;
		PlayerInfo[suspect][pZakonp] -= 1;
		SetPlayerSpecialAction(suspect,SPECIAL_ACTION_NONE);
		RemovePlayerAttachedObject(suspect,0);
		TogglePlayerControllable(suspect, 1);
		PlayerInfo[suspect][pJailed] = 1;
		PlayerCuffed[suspect] = 0;
	}
	return true;
}
CMD:megaphone(playerid, params[])
{
	if(!IsPlayerConnected(playerid)) return true;
	if(sscanf(params, "s[128]",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} (/m)egaphone [текст ]");
	new vehicleid = GetPlayerVehicleID(playerid);
	switch(PlayerInfo[playerid][pMember])
	{
	case 3,19:
		{
			if(!Megaphone(vehicleid)) return SendClientMessage(playerid, COLOR_GRAD2, "Вы не в служебной машине!");
			format(stringer1, sizeof(stringer1), "{{ Армия %s: %s }}",PlayerInfo[playerid][pName],params[0]);
			ProxDetector(80.0, playerid, stringer1,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW);
		}
	case 1,10,21,25:
		{
			if(!Megaphone(vehicleid)) return SendClientMessage(playerid, COLOR_GRAD2, "Вы не в служебной машине!");
			format(stringer1, sizeof(stringer1), "{{ Офицер %s: %s }}",PlayerInfo[playerid][pName],params[0]);
			ProxDetector(80.0, playerid, stringer1,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW);
		}
	case 2:
		{
			if(!Megaphone(vehicleid)) return SendClientMessage(playerid, COLOR_GRAD2, "Вы не в служебной машине!");
			format(stringer1, sizeof(stringer1), "{{ Агент FBI %s: %s }}",PlayerInfo[playerid][pName],params[0]);
			ProxDetector(80.0, playerid, stringer1,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW);
		}
	}
	return true;
}
CMD:helpers(playerid, params[])
{
	new b=0,ttext[50];
	SendClientMessage(playerid, COLOR_ORANGE, "Агенты поддержки в сети:");
	PlayerForeach(i)
	{
		if(PlayerInfo[i][pHelper] > 0)
		{
			b++;
			switch(PlayerInfo[i][pHelper])
			{
			case 1: ttext = "{F6FF00}(Агент поддержки){FFFFFF}";
			case 2: ttext = "{F6FF00}(Агент поддержки){FFFFFF}";
			case 3: ttext = "{33CCFF}(Агент поддержки){FFFFFF}";
			case 4: ttext = "{33CCFF}(Агент поддержки){FFFFFF}";
			case 5: ttext = "{FF0000}(Главный хелпер){FFFFFF}";
			}
			SendMes(playerid,COLOR_GREY,"* %s %s[%d] [{32CD32}lvl:%d{FFFFFF}]",ttext,PlayerInfo[i][pName],i,PlayerInfo[i][pHelper]);
		}
	}
	if(b>0) SendMes(playerid,COLOR_GREY,"В сети всего %d хелперов.",b);
	else return SendMes(playerid,COLOR_GREY,"Нету никого из хелперов в сети.");
	return true;
}
CMD:admins(playerid, params[])
{
	new b=0,ttext[50];
    if(!PlayerInfo[playerid][pAdmin] && PlayerInfo[playerid][pDonateRank] != 1) return SendClientMessage(playerid, 0xAFAFAFAA, "[{C90000}Ошибка{AFAFAF}] Доступно только для VIP игроков!");
	SendClientMessage(playerid, COLOR_ORANGE, "Администрация проекта");
	PlayerForeach(i)
	{
		if(PlayerInfo[i][pAdmin] > 0)
		{
			b++;
			switch(PlayerInfo[i][pAdmin])
			{
			case 1: ttext = "{F6FF00}(Практикант){FFFFFF}";
			case 2: ttext = "{F6FF00}(Ст.Практикант){FFFFFF}";
			case 3: ttext = "{33CCFF}(Мл.Модератор){FFFFFF}";
			case 4: ttext = "{33CCFF}(Модератор){FFFFFF}";
			case 5: ttext = "{33CCFF}(Ст.Модератор){FFFFFF}";
			case 6: ttext = "{33CCFF}(Гл.Модератор){FFFFFF}";
			case 7: ttext = "{00E910}(Мл.Администратор){FFFFFF}";
			case 8: ttext = "{00E910}(Администратор){FFFFFF}";
			case 9: ttext = "{00E910}(Ст.Администратор){FFFFFF}";
			case 10: ttext = "{00E910}(Гл.Администратор){FFFFFF}";
			case 11: ttext = "{0000FF}(Спец.Администратор){FFFFFF}";
			case 12: ttext = "{FF0000}(Руководитель){FFFFFF}";
			}
			SendMes(playerid,COLOR_GREY,"* %s %s[%d] [{32CD32}lvl:%d{FFFFFF}]",ttext,PlayerInfo[i][pName],i,PlayerInfo[i][pAdmin]);
		}
	}
	if(b>0) SendMes(playerid,COLOR_GREY,"В сети всего %d администраторов.",b);
	else return SendMes(playerid,COLOR_GREY,"Нету никого из администрации в сети.");
	return true;
}
CMD:b(playerid, params[])
{
	if(PlayerInfo[playerid][pMuted] == 1) return SendMes(playerid, COLOR_LIGHTRED, "У Вас заблокирован чат, Вы не можете разговаривать. До снятия: %d секунд", PlayerInfo[playerid][pMuteTime]);
	if(sscanf(params, "s[128]",params[0])) return	SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /b [сообщение]");
	if(IsIpFound(params[0]))
	{
		PlayerInfo[playerid][pMuteTime] = 180;
		PlayerInfo[playerid][pMuted] = 1;
		format(stringer1, sizeof(stringer1), "%s: %s",PlayerInfo[playerid][pName],params[0]);
		ABroadCast(COLOR_LIGHTRED,stringer1,1);
		new ip[14];
		GetPlayerIp(playerid,ip,14);
		format(stringer1, sizeof(stringer1), "- ID: %d | IP: [%s]",playerid,ip);
		ABroadCast(COLOR_LIGHTRED,stringer1,1);
		SendMes(playerid, COLOR_LIGHTRED, "Сервер заблокировал Вам чат на 3 минуты ( /mm - Репорт )");
		return true;
	}
	format(stringer1, sizeof(stringer1), "%s: (( %s ))", PlayerInfo[playerid][pName], params[0]);
	ProxDetector(20.0, playerid, stringer1,COLOR_WHITE,COLOR_WHITE,COLOR_WHITE,COLOR_WHITE,COLOR_WHITE);
	return true;
}
