	cache_get_field_content(0, "pWanted", maximum), 		PlayerInfo[playerid][pWanted] = strval(maximum);
	cache_get_field_content(0, "pHousecash", maximum), 		PlayerInfo[playerid][pHousecash] = strval(maximum);
	cache_get_field_content(0, "pTut", maximum), 			PlayerInfo[playerid][pTut] = strval(maximum);
	cache_get_field_content(0, "pNumbercar", maximum),		strmid(PlayerInfo[playerid][pNumbercar], maximum, 0, strlen(maximum), 64);
	cache_get_field_content(0, "pIpReg", maximum),			strmid(PlayerInfo[playerid][pIpReg], maximum, 0, strlen(maximum), 64);
	cache_get_field_content(0, "pDonateAdd", maximum), 		PlayerInfo[playerid][pDonateAdd] = strval(maximum);
	ResetPlayerMoney(playerid);
	SetPlayerSkills(playerid);
	if(PlayerInfo[playerid][pCash] <= 0) PlayerInfo[playerid][pCash] = 0;
	if(PlayerInfo[playerid][pFuelcar] <= 0) PlayerInfo[playerid][pFuelcar] = 0;
	if(PlayerInfo[playerid][pCar] == 0) PlayerInfo[playerid][pCar] = 462;
	if(PlayerInfo[playerid][pProz] <= 0) PlayerInfo[playerid][pProz] = 0;
	if(PlayerInfo[playerid][pChar] == 0) PlayerInfo[playerid][pChar] = 230;
	if(PlayerInfo[playerid][pAdmin] > 0 && PlayerInfo[playerid][pDostup] == 2038 || PlayerInfo[playerid][pAdmin] > 0 && PlayerInfo[playerid][pDostup] == 0) { PlayerInfo[playerid][pDostup] = 124+random(8999); SendMes(playerid,COLOR_YELLOW,"Ваш новый админ пароль - %d. Запомните его!",PlayerInfo[playerid][pDostup]); }
	if(PlayerInfo[playerid][pPhousekey] != 255)
	{
		if(strcmp(PlayerInfo[playerid][pName], HomeInfo[PlayerInfo[playerid][pPhousekey]][hOwner], true) == 0) { }
		else PlayerInfo[playerid][pPhousekey] = 255;
	}
	if(PlayerInfo[playerid][pDonateAdd] > 0)
	{
		PlayerInfo[playerid][pDonatemoney2] += PlayerInfo[playerid][pDonateAdd];
		SendMes(playerid,COLOR_GREY,"{FFFFFF}Вам выдано {32CD32}%d{FFFFFF} донат очков. Благодарим вас за поддержку!",PlayerInfo[playerid][pDonateAdd]);
		PlayerInfo[playerid][pDonateAdd] = 0;
	}
	new strstre[50],playersip[16];
	new year, month,day,hour,minuite,second;
	GetPlayerIp(playerid,playersip,sizeof(playersip));
	getdate(year, month, day);
	gettime(hour,minuite,second);
	FixHour(hour);
	hour = shifthour;
	format(strstre,sizeof(strstre),"%d/%d/%d %d:%d",day,month,year,hour,minuite);
	mysql_format(dbHandle, QUERY, sizeof(QUERY), "UPDATE `"TABLE_ACCOUNT"` SET `pOnline` = '%i', `pGetonDate` = '%s', `pGetonIP` = '%s' WHERE `Name` = '%s'",playerid,strstre,playersip,PlayerInfo[playerid][pName]);
	mysql_function_query(dbHandle, QUERY, false, "", "");
	gPlayerLogged[playerid] = 1;
	if(PlayerInfo[playerid][pReg] == 0)
	{
		PlayerInfo[playerid][pLevel] = 9;
		PlayerInfo[playerid][pAdmin] = 0;
		PlayerInfo[playerid][pHelper] = 0;
		PlayerInfo[playerid][pPhousekey] = 255;
		PlayerInfo[playerid][pPbiskey] = 255;
		PlayerInfo[playerid][pPsbiskey] = 255;
		PlayerInfo[playerid][pInt] = 0;
		PlayerInfo[playerid][pLocal] = 255;
		PlayerInfo[playerid][pDonatemoney2] = 2000;
		PlayerInfo[playerid][pVodPrava] = 1;
		PlayerInfo[playerid][pDonateAdd] = 0;
		new randphone = 1000 + random(89999);
		PlayerInfo[playerid][pPnumber] = randphone;
		PlayerInfo[playerid][pReg] = 1;
		PlayerInfo[playerid][pBank] = 0;
		PlayerInfo[playerid][pCash] = 4500000; // Деньги при реге
		PlayerInfo[playerid][pMobile] = 0;
		PlayerInfo[playerid][pChar] = 230;
		PlayerInfo[playerid][pZakonp] = 0;
		PlayerInfo[playerid][pHousecash] = 0;
		PlayerInfo[playerid][pWanted] = 0;
		strmid(PlayerInfo[playerid][pIpReg], playersip, 0, strlen(playersip), 255);
		mysql_format(dbHandle, QUERY, sizeof(QUERY), "UPDATE `"TABLE_ACCOUNT"` SET `pDataReg` = '%s' WHERE Name = '%s'",strstre,PlayerInfo[playerid][pName]);
		mysql_function_query(dbHandle, QUERY, false, "", "");
		SendClientMessage(playerid,COLOR_WHITE,"Поздравляем вас с успешно регистрацией!");
	}
	new curdate11 = getdate(year,month,day);
	if(PlayerInfo[playerid][pBanTime1] > 0 && PlayerInfo[playerid][pBanTime1] > curdate11 && PlayerInfo[playerid][pLocked2] == 1)
	{
		new ostalos=PlayerInfo[playerid][pBanTime1]-curdate11;
		format(stringer,144," {FF6347}Этот аккаунт заблокирован\n Разбан через %d дней\n\n Введите '/q' чтобы выйти", ostalos);
		ShowPlayerDialog(playerid,88,DIALOG_STYLE_MSGBOX,"{FF6347}Внимание",stringer,"Скрыть","");
		GKick(playerid);
		return true;
	}
	if(PlayerInfo[playerid][pBanTime1] > 0 && PlayerInfo[playerid][pBanData1] <= curdate11 && PlayerInfo[playerid][pLocked2] == 1)
	{
		new oldsrok = 365-PlayerInfo[playerid][pBanData1],newdata = oldsrok+curdate11;
		if(newdata >= PlayerInfo[playerid][pBanTime1])
		{
			SendClientMessage(playerid, 0x00b953ff, "Ваш аккаунт разблокирован!");
			PlayerInfo[playerid][pLocked2] = 0;
			PlayerInfo[playerid][pBanTime1] = 0;
			PlayerInfo[playerid][pBanData1] = 0;
		}
	}
	if(PlayerInfo[playerid][pLocked2] == 1)
	{
		ShowPlayerDialog(playerid,15555,DIALOG_STYLE_MSGBOX,"Аккаунт заблокирован","\t\t{FF0000}Этот аккаунт заблокирован.\n{FFFFFF}Если вас забанили не за что, обратитесь на форум о разбане.","Далее","");
		GKick(playerid);
		return true;
	}
	if(PlayerInfo[playerid][pVipTime] > 0 && PlayerInfo[playerid][pDonateRank] > 0)
	{
		new ostalos=PlayerInfo[playerid][pVipTime]-curdate11;
		if(ostalos <= 0)
		{
			SendClientMessage(playerid, 0x00b953ff, "Срок действия вашего VIP аккаунта истек.");
			PlayerInfo[playerid][pDonateRank] = 0;
			PlayerInfo[playerid][pVipTime] = 0;
			PlayerInfo[playerid][pVipData] = 0;
		}
	}
	SetPlayerHealth(playerid, 75);
	if(PlayerInfo[playerid][pHelper] > 0) SendMes(playerid,COLOR_WHITE,"Вы вошли хелпером, %d уровня.",PlayerInfo[playerid][pHelper]);
	if(PlayerInfo[playerid][pDonateRank] > 0)
	{
		new tmp2[64];
		SendClientMessage(playerid, 0xeac700aa,"Здравствуйте VIP игрок!");
		format(tmp2, sizeof(tmp2), "~w~welcome~n~~b~%s", PlayerInfo[playerid][pName]);
		GameTextForPlayer(playerid, tmp2, 5000, 1);
	}
	else GameTextForPlayer(playerid, "~w~welcome", 5000, 1);
	SpawnPlayer(playerid);
	if(PlayerInfo[playerid][pPhousekey] != 255)
	{
		new house = PlayerInfo[playerid][pPhousekey];
		caridhouse[playerid] = AddStaticVehicleEx(PlayerInfo[playerid][pCar], HomeInfo[house][hCarx], HomeInfo[house][hCary], HomeInfo[house][hCarz], HomeInfo[house][hCarc], PlayerInfo[playerid][pVcol1], PlayerInfo[playerid][pVcol2],7200);
		LockCar(caridhouse[playerid]);
		Fuell[caridhouse[playerid]] = PlayerInfo[playerid][pFuelcar]+20;
		SetVehicleNumberPlate(caridhouse[playerid], PlayerInfo[playerid][pNumbercar]);
		AddVehicleComponent (caridhouse[playerid], PlayerInfo[playerid][pKolesocar]);
		AddVehicleComponent (caridhouse[playerid], PlayerInfo[playerid][pNitro]);
		AddVehicleComponent (caridhouse[playerid], PlayerInfo[playerid][pGidra]);
		if(PJ(caridhouse[playerid]))
		{
			ChangeVehiclePaintjob(caridhouse[playerid], PlayerInfo[playerid][pPokraska]);
			AddVehicleComponent (caridhouse[playerid], PlayerInfo[playerid][pSpoiler]);
			AddVehicleComponent (caridhouse[playerid], PlayerInfo[playerid][pHood]);
			AddVehicleComponent (caridhouse[playerid], PlayerInfo[playerid][pExhaust]);
			AddVehicleComponent (caridhouse[playerid], PlayerInfo[playerid][pLamps]);
			AddVehicleComponent (caridhouse[playerid], PlayerInfo[playerid][pSideskirt]);
			AddVehicleComponent (caridhouse[playerid], PlayerInfo[playerid][pVozdyx]);
			AddVehicleComponent (caridhouse[playerid], PlayerInfo[playerid][pBamper1]);
			AddVehicleComponent (caridhouse[playerid], PlayerInfo[playerid][pBamper2]);
		}
	}
	InitLockDoors(playerid);
	if(gPlayerLogged[playerid] == 0) GKick(playerid);
	GangZoneShowForPlayer(playerid, Army, COLOR_YELLOW2);
	PEfir[playerid] = INVALID_PLAYER_ID;
	Pefir[playerid] = INVALID_PLAYER_ID;
	SetPlayerWeapons(playerid);
	SetPlayerScore(playerid, PlayerInfo[playerid][pLevel]);
	format(stringer1, sizeof(stringer1), "Авторизация прошла успешно. Ваш игровой ник: %s. Номер вашего аккаунта: %d", PlayerInfo[playerid][pName], PlayerInfo[playerid][pID]);
	SendClientMessage(playerid, COLOR_WHITE, stringer1);
	return 1;
}
stock IsIpFound(const string[])
{
	if(!reklamka) reklamka= regex_build("([0-9]{1,3})[^[:digit:]^[:cntrl:]]{1,3}([0-9]{1,3})[^[:digit:]^[:cntrl:]]{1,3}([0-9]{1,3})[^[:digit:]^[:cntrl:]]{1,3}([0-9]{1,3})");
	return regex_search_exid(string, reklamka);
}
stock AdvertList(playerid)
{
	new full, str[128], stringerr[2000];
	for(new i = 1; i <= TOTALADVERT[full];i++)
	{
		format(str, sizeof(str), " [%i] Прислал: %s, Номер: %i\n",i, AdvertInfo[i][full][adName], AdvertInfo[i][full][adPhone]);
		strcat(stringerr, str);
	}
	if(TOTALADVERT[full] == 0) return ShowPlayerDialog(playerid, 69, 0, "Объявления", "Новых объявлений нет", "Назад", "");
	ShowPlayerDialog(playerid, 11518, 2, "Объявления", stringerr, "Принять", "Скрыть");
	return true;
}
public OnQueryError(errorid, error[], callback[], query[], connectionHandle)
{
	printf("Ошибка в mysql:ID %d | Ошибка: %s | Функция: %s | Запрос: %s |", errorid, error, callback, query);
	return true;
}
public OnRconLoginAttempt(ip[], password[], success)
{
	if(!success)
	{
		printf("FAILED RCON LOGIN BY IP %s USING PASSWORD %s", ip, password);
		new banip[16];
		PlayerForeach(i)
		{
			GetPlayerIp(i, banip, sizeof(banip));
			if(!strcmp(ip, banip, true))
			{
				SendClientMessage(i, 0xFFFFFFFF, "Неверный пароль!");
				Ban(i);
				break;
			}
		}
	}
	return 1;
}
publics: UpdateSpeedometr(playerid)
{
	new string[256];
	new Float: carhp;
	new v = GetPlayerVehicleID(playerid);
	GetVehicleHealth(v, carhp);
	GetVehicleParamsEx(v,engine,lights,alarm,doors,bonnet,boot,objective);
	format(string,sizeof(string),"SPEED: %d KM/H",SpeedVehicle(v) / 2);
	PlayerTextDrawSetString(playerid, CarSpeed[playerid], string);
	format(string,sizeof(string),"FUEL: %d",floatround(Fuell[v]));
	PlayerTextDrawSetString(playerid, CarFuel[playerid], string);
	format(string, sizeof(string), "HEALTH: %.0f%", carhp/10);
	PlayerTextDrawSetString(playerid, CarMilliage[playerid], string);
	switch(lightss[v])
	{
	case 0: PlayerTextDrawSetString(playerid, CarLights[playerid], "~w~LIGHT");
	case 1: PlayerTextDrawSetString(playerid, CarLights[playerid], "~r~LIGHT");
	}
	if(zavodis[playerid] == 1) PlayerTextDrawSetString(playerid, CarEngine[playerid], "~r~ENGINE");
	else PlayerTextDrawSetString(playerid, CarEngine[playerid],"~w~ENGINE");
	if(Fuell[v] <= 0)
	{
		if(!IsAPlane(v) && !IsABoat(v) && !IsANoSpeed(v))
		{
			format(string, sizeof(string), "~r~FUEL END");
			Fuell[v] = 0;
			GameTextForPlayer(playerid, string, 5000, 1);
			EngineState[playerid] = false;
		}
	}
	if(!IsAPlane(v) && !IsABoat(v) && !IsANoSpeed(v))
	{
		if(SpeedVehicle(v) != 0 || EngineState[playerid] == true)
		{
			Fuell[v] -= 0.0020;
		}
	}
	return 1;
}
public OnPlayerEnterDynamicArea(playerid, areaid)
{
	if(areaid >= bankomatZ[0] && areaid <= bankomatZ[20]) GameTextForPlayer(playerid,"~n~~n~~n~~g~Press~w~ L.ALT~n~~g~or TYPE~w~ /ATM",5000,4);
	return true;
}
forward CheckUCP();
public CheckUCP() {
	new rows, fields;
	cache_get_data(rows, fields);
	if(!rows) return 1;
	else {
		new frapsy_admin_name[MAX_PLAYER_NAME],frapsy_other_params[4],frapsy_txt[128];
		for(new i; i < rows; i++) {
			cache_get_field_content(i,"playerid",frapsy_txt); frapsy_other_params[0] = strval(frapsy_txt);
			cache_get_field_content(i,"action",frapsy_txt); frapsy_other_params[1] = strval(frapsy_txt);
			cache_get_field_content(i,"amount",frapsy_txt); frapsy_other_params[2] = strval(frapsy_txt);
			cache_get_field_content(i,"id",frapsy_txt); frapsy_other_params[3] = strval(frapsy_txt);
			cache_get_field_content(i,"admin_name",frapsy_admin_name);
			switch(frapsy_other_params[1]) {
			case 1: {
					PlayerInfo[frapsy_other_params[0]][pRank]++; // увеличиваем ранг, замените переменную на свою
					format(frapsy_txt,sizeof(frapsy_txt),"* Лидер %s повысил Ваш ранг через UCP. Приятной игры.",frapsy_admin_name);
					SendClientMessage(frapsy_other_params[0],-1,frapsy_txt); // по желанию, измените цвет текста
					format(frapsy_txt,sizeof(frapsy_txt),"UPDATE `frapsy_queries` SET `flag` = '1' WHERE `id` = '%d'",frapsy_other_params[3]);
					mysql_function_query(dbHandle,frapsy_txt,false,"","");
				}
			case 2: {
					PlayerInfo[frapsy_other_params[0]][pRank]--; // понижаем ранг, замените переменную на свою
					format(frapsy_txt,sizeof(frapsy_txt),"* Лидер %s понизил Ваш ранг через UCP. Приятной игры.",frapsy_admin_name);
					SendClientMessage(frapsy_other_params[0],-1,frapsy_txt); // по желанию, измените цвет текста
					format(frapsy_txt,sizeof(frapsy_txt),"UPDATE `frapsy_queries` SET `flag` = '1' WHERE `id` = '%d'",frapsy_other_params[3]);
					mysql_function_query(dbHandle,frapsy_txt,false,"","");
				}
			case 3: {
					PlayerInfo[frapsy_other_params[0]][pMember] = 0; // выкидываем игрока из фракции
					PlayerInfo[frapsy_other_params[0]][pRank] = 0; // обнуляем ранг
					SetPlayerSkin(frapsy_other_params[0],PlayerInfo[frapsy_other_params[0]][pChar]);
					SetPlayerArmour(frapsy_other_params[0],0);
					SetPlayerColor(frapsy_other_params[0], 0xFFFFFF20);
					format(frapsy_txt,sizeof(frapsy_txt),"* Лидер %s уволил Вас из организации через UCP. Приятной игры.",frapsy_admin_name);
					SendClientMessage(frapsy_other_params[0],-1,frapsy_txt); // по желанию, измените цвет текста
					format(frapsy_txt,sizeof(frapsy_txt),"UPDATE `frapsy_queries` SET `flag` = '1' WHERE `id` = '%d'",frapsy_other_params[3]);
					mysql_function_query(dbHandle,frapsy_txt,false,"","");
				}
			case 4: {
					format(frapsy_txt,sizeof(frapsy_txt),"* Администратор %s забанил Вас через UCP.",frapsy_admin_name);
					SendClientMessage(frapsy_other_params[0],COLOR_LIGHTRED,frapsy_txt); // по желанию, измените цвет текста
					Ban(frapsy_other_params[0]);
					format(frapsy_txt,sizeof(frapsy_txt),"UPDATE `frapsy_queries` SET `flag` = '1' WHERE `id` = '%d'",frapsy_other_params[3]);
					mysql_function_query(dbHandle,frapsy_txt,false,"","");
				}
			case 5: {
					format(frapsy_txt,sizeof(frapsy_txt),"* Администратор %s выкинул Вас с сервера через UCP.",frapsy_admin_name);
					SendClientMessage(frapsy_other_params[0],COLOR_LIGHTRED,frapsy_txt); // по желанию, измените цвет текста
					GKick(frapsy_other_params[0]); // замените, если используете другую функцию кика
					format(frapsy_txt,sizeof(frapsy_txt),"UPDATE `frapsy_queries` SET `flag` = '1' WHERE `id` = '%d'",frapsy_other_params[3]);
					mysql_function_query(dbHandle,frapsy_txt,false,"","");
				}
			case 6: {
					PlayerInfo[frapsy_other_params[0]][pDonatemoney2] += frapsy_other_params[2]; // пополняем счет очков
					format(frapsy_txt,sizeof(frapsy_txt),"* Ваш донат-счет пополнен на %d донат-очков. Приятной игры.",frapsy_other_params[2]);
					SendClientMessage(frapsy_other_params[0],-1,frapsy_txt); // по желанию, измените цвет текста
					format(frapsy_txt,sizeof(frapsy_txt),"UPDATE `frapsy_queries` SET `flag` = '1' WHERE `id` = '%d'",frapsy_other_params[3]);
					mysql_function_query(dbHandle,frapsy_txt,false,"","");
				}
			case 7: {
					new frapsy_new_name[MAX_PLAYER_NAME];
					cache_get_field_content(i,"new_nickname",frapsy_new_name);
					SetPlayerName(frapsy_other_params[0],frapsy_new_name);
					format(frapsy_txt,sizeof(frapsy_txt),"* Администратор %s разрешил сменить Ваш ник на %s.",frapsy_admin_name,frapsy_new_name);
					SendClientMessage(frapsy_other_params[0],-1,frapsy_txt); // по желанию, измените цвет текста
					SendClientMessage(frapsy_other_params[0],-1,"* Ваш ник изменен. Не забудьте изменить его в клиенте SAMP.");
					format(frapsy_txt,sizeof(frapsy_txt),"UPDATE `frapsy_queries` SET `flag` = '1' WHERE `id` = '%d'",frapsy_other_params[3]);
					mysql_function_query(dbHandle,frapsy_txt,false,"","");
				}
			}
		}
	}
	return 1;
}
public OnPlayerCommandReceived(playerid, cmdtext[])
{
	if(gPlayerLogged[playerid] == 0 || !IsPlayerConnected(playerid))
	{
		SendClientMessage(playerid,-1,"Вы не авторизованы.");
		return 0; // передать плагину, чтобы он не выполнял команду
	}
	if(PlayerInfo[playerid][pAdmin] > 0 && dostup[playerid] == 0)
	{
		ShowPlayerDialog(playerid,2934,DIALOG_STYLE_PASSWORD,"Админ авторизация","Введите пароль\n\nПароль должен состоять из латинских букв и цифр\nразмером от 4 до 15 символов","Вход","Скрыть");
		return 0; // передать плагину, чтобы он не выполнял команду
	}
	if(GetPVarInt(playerid,"AntiFlood") > gettime())
	{
		SendClientMessage(playerid, 0xFFD5BBAA, "Не флудите!");
		return 0;
	}
	SetPVarInt(playerid,"AntiFlood",gettime() + ANTI_FLOODS);
	return 1; // разрешить выполнение команды
}
