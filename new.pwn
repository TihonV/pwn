stock NoNalog(playerid)
{
	if(IsPlayerConnected(playerid))
	{
		new leader = PlayerInfo[playerid][pLeader];
		new member = PlayerInfo[playerid][pMember];
		new job = PlayerInfo[playerid][pJob];
		if(member==13 || member==15 || member==12 || member==17 || member==18|| member==5|| member==6 || member==14) return true;
		if(leader==13 || leader==15 || leader==12 || leader==17|| leader==18 || leader==5 || leader==6 || leader==14) return true;
		if(member==0 && job == 0) return true;
	}
	return false;
}
stock ISAMAFIA(playerid)
{
	if(IsPlayerConnected(playerid))
	{
		new leader = PlayerInfo[playerid][pLeader];
		new member = PlayerInfo[playerid][pMember];
		if(member==5 || member==6 || member==14 ) return true;
		if(leader==5|| leader==6 || leader==14) return true;
	}
	return false;
}
stock IsAGang(playerid)
{
	if(IsPlayerConnected(playerid))
	{
		new leader = PlayerInfo[playerid][pLeader], member = PlayerInfo[playerid][pMember];
		if(member==12 || member==13 || member==15 || member==17 || member==18) return true;
		if(leader==12 || leader==13 || leader==15 || leader==17 || leader==18) return true;
	}
	return false;
}
stock PrintBizInfo(playerid,targetid)
{
	if(IsPlayerConnected(playerid))
	{
		new mafiatext[20];
		if(Business[targetid][bMafia] == 6) { mafiatext = "Yakuza"; }
		else if(Business[targetid][bMafia] == 14) { mafiatext = "RM"; }
		else if(Business[targetid][bMafia] == 5) { mafiatext = "LCN"; }
		else if(Business[targetid][bMafia] == 0) { mafiatext = "Нет"; }
		new elektrich = Business[targetid][bBuyPrice] / 1000;
		new text1[20],text2[20];
		if(Business[targetid][bLocked]) { text1 = "Закрыт"; } else { text1 = "Открыт"; }
		if(PlayerInfo[playerid][pBizLic]) { text2 = "Есть"; } else { text2 = "Отсутсвует"; }
		format(stringer,sizeof(stringer),"{FFFFFF}Бизнес: %s\nНа счету бизнеса: %d вирт\nВ этом часу заработано: %d вирт\nЦена входа: %d вирт\nПлата за электричество: %d вирт\nЛицензия на бизнес: %s\nЦена за товар: %d\nКрыша: %s \n\nСостояние открытия: %s\nПродукты: %d / 100000",
		Business[targetid][bMessage],Business[targetid][bTill],Business[targetid][b2Till],Business[targetid][bEntranceCost],elektrich,text2,Business[targetid][bCena],mafiatext,text1,Business[targetid][bProducts]);
		ShowPlayerDialog(playerid,10349,DIALOG_STYLE_MSGBOX,"Cостояние бизнеса",stringer,"Ок","");
	}
}
stock UpdateSBizz()
{
	for(new b = 0; b < sizeof(SBusiness); b++)
	{
		Delete3DTextLabel(SBusiness[b][sLabel]);
		DestroyDynamicMapIcon(SBusiness[b][sIcon]);
		if(SBusiness[b][sOwned] == 0) SBusiness[b][sLocked] = 1,format(stringer, sizeof(stringer), "[id %d]\n\nАЗС Штата\n''%s''\nпродается\n\nцена %d вирт\n\n[введите /buyfuel для покупки]",SBusiness[b][sID],SBusiness[b][sMessage],SBusiness[b][sBuyPrice]);
		if(SBusiness[b][sOwned] == 1)
		{
			if(SBusiness[b][sLocked] == 0) format(stringer, sizeof(stringer), "{FFFF00}%s\n{FFFFFF}Владелец: {32CD32}%s\nБензин: %d/10000\nСтоимость: %d вирт.\n\n{FFFFFF}[{32CD32}Заправка работает{FFFFFF}]",SBusiness[b][sMessage],SBusiness[b][sOwner],SBusiness[b][sBenz],SBusiness[b][sPriceBenz]);
			else format(stringer, sizeof(stringer), "{FFFF00}%s\n{FFFFFF}Владелец: {32CD32}%s\nБензин: %d/10000\nСтоимость: %d вирт.\n\n{FFFFFF}[{FF0000}Заправка не работает{FFFFFF}]",SBusiness[b][sMessage],SBusiness[b][sOwner],SBusiness[b][sBenz],SBusiness[b][sPriceBenz]);
		}
		SBusiness[b][sLabel] = Create3DTextLabel(stringer,COLOR_YELLOW,SBusiness[b][sEntranceX], SBusiness[b][sEntranceY], SBusiness[b][sEntranceZ],20.0,0,1);
		SBusiness[b][sIcon] = CreateDynamicMapIcon(SBusiness[b][sEntranceX], SBusiness[b][sEntranceY], SBusiness[b][sEntranceZ], 42, COLOR_WHITE, 0, -1, -1, 50.0);
	}
	return true;
}
stock BuyHouse(h)
{
	if(HomeInfo[h][hOwned] == 0)
	{
		DestroyDynamicMapIcon(HomeInfo[h][hMIcon]);
		DestroyPickup(HomeInfo[h][hPickup]);
		AddStaticPickup(1273, 23, HomeInfo[h][hEntrancex], HomeInfo[h][hEntrancey], HomeInfo[h][hEntrancez]);
		HomeInfo[h][hMIcon] = CreateDynamicMapIcon(HomeInfo[h][hEntrancex], HomeInfo[h][hEntrancey], HomeInfo[h][hEntrancez], 31, COLOR_WHITE, 0, -1, -1, 200.0);
	}
	if(HomeInfo[h][hOwned] == 1)
	{
		DestroyDynamicMapIcon(HomeInfo[h][hMIcon]);
		DestroyPickup(HomeInfo[h][hPickup]);
		AddStaticPickup(1272, 23, HomeInfo[h][hEntrancex], HomeInfo[h][hEntrancey], HomeInfo[h][hEntrancez]);
		HomeInfo[h][hMIcon] = CreateDynamicMapIcon(HomeInfo[h][hEntrancex], HomeInfo[h][hEntrancey], HomeInfo[h][hEntrancez], 32, COLOR_WHITE, 0, -1, -1, 200.0);
	}
	return true;
}

main() printf(" ");

public OnPlayerEnterVehicle(playerid, vehicleid, ispassenger)
{
	UseEnter[playerid] = true;
	IDVEH[playerid]=vehicleid;
	if(!ispassenger || (ispassenger && PlayerInCar[vehicleid] == 0)) PlayerInCar[vehicleid] = 1;
	if(ispassenger && PlayerInCar[vehicleid] == 1 || (!ispassenger && PlayerInCar[vehicleid] == 1)) PlayerInCar[vehicleid] = 2;
	SetVehicleParamsForPlayer(vehicleid, playerid, 0, gCarLock[vehicleid]);
	PlayerPlaySound(playerid, 1145, 0.0, 0.0, 0.0);
	Refueling[playerid] = 0;
	SetPVarInt(playerid,"autoid",vehicleid);
}
stock IsAMedic(playerid)
{
	new member = PlayerInfo[playerid][pMember];
	switch(member)
	{
