	return true;
}
public OnPlayerConnect(playerid)
{
	checkautoaim[playerid]     = 9999;
	pressingaimtick[playerid]  = -1;
	autoaim[playerid]          = false;
	keyfire[playerid]          = false;
	ispressingaimkey[playerid] = false;
	CheckNextAim[playerid]     = false;
	///////////////////////////////////////////
	GameTextForPlayer(playerid,"~w~Welcome to ~n~~r~WHISPER - ROLEPLAY",4000,4);
	//
	tChainSaw[playerid] = -1;
	activemusic[playerid] = false;
	FirstKick{playerid}=0;
	ZapretDice[playerid] = 0;
	SetPVarInt(playerid,"autoid",-1);
	if(tChainSaw[playerid] != -1) KillTimer(tChainSaw[playerid]), tChainSaw[playerid] = -1;
	//
	CreateTextDraw(playerid);
	NewTextDrawsLoad(playerid);
	for(new i = 0; i < 3; i++)
	{
		GangZoneShowForPlayer(playerid, ZonsWar[i], 16711888);
	}
	for(new i = 0; i <13; i++ ) pAmmo[playerid][i] = 0;
	
	for(new i = 0; i < 2; i++)
    {
        TextDrawShowForPlayer(playerid, Whisper[i]);
    }
    

	SetTimerEx("UpdateFPS", 1000, 1, "i", playerid);
	
	FPStext[0] = CreatePlayerTextDraw(playerid, 73.500000, 320.822296, "150");
	PlayerTextDrawLetterSize(playerid, FPStext[0], 0.321500, 1.301332);
	PlayerTextDrawAlignment(playerid, FPStext[0], 1);
	PlayerTextDrawColor(playerid, FPStext[0], -1);
	PlayerTextDrawSetShadow(playerid, FPStext[0], 1);
	PlayerTextDrawSetOutline(playerid, FPStext[0], 0);
	PlayerTextDrawBackgroundColor(playerid, FPStext[0], 51);
	PlayerTextDrawFont(playerid, FPStext[0], 1);
	PlayerTextDrawSetProportional(playerid, FPStext[0], 1);

	FPStext[1] = CreatePlayerTextDraw(playerid, 97.500000, 321.200073, "GOOD");
