}
public OnPlayerPickUpPickup(playerid, pickupid)
{
	for(new h = 0; h < sizeof(HomeInfo); h++)
	{
		if(pickupid == HomeInfo[h][hPickup])
		{
			if(HomeInfo[h][hOwned] == 1)
			{
				new ttextt[32];
				if(IsPlayerConnected(GetPlayerID(HomeInfo[h][hOwner]))) { ttextt = "{11FF00}ONLINE"; }
				else if(!IsPlayerConnected(GetPlayerID(HomeInfo[h][hOwner]))) { ttextt = "{ff0000}OFFLINE"; }
				if(HomeInfo[h][hKlass] == 0)format(stringer1, sizeof(stringer1), "{ffffff}Владелец: {ff0000}%s\tСтатус: %s\n{ffffff}Класс: {ff0000}Низкий\n{ffffff}Номер дома: {ff0000}%d",HomeInfo[h][hOwner],ttextt,h);
				else if(HomeInfo[h][hKlass] == 1) format(stringer1, sizeof(stringer1), "{ffffff}Владелец: {ff0000}%s\tСтатус: %s\n{ffffff}Класс: {ff0000}Чистый\n{ffffff}Номер дома: {ff0000}%d",HomeInfo[h][hOwner],ttextt,h);
				else if(HomeInfo[h][hKlass] == 2) format(stringer1, sizeof(stringer1), "{ffffff}Владелец: {ff0000}%s\tСтатус: %s\n{ffffff}Класс: {ff0000}Средний\n{ffffff}Номер дома: {ff0000}%d",HomeInfo[h][hOwner],ttextt,h);
				else if(HomeInfo[h][hKlass] == 3) format(stringer1, sizeof(stringer1), "{ffffff}Владелец: {ff0000}%s\tСтатус: %s\n{ffffff}Класс: {ff0000}Выше среднего\n{ffffff}Номер дома: {ff0000}%d",HomeInfo[h][hOwner],ttextt,h);
				else if(HomeInfo[h][hKlass] == 4) format(stringer1, sizeof(stringer1), "{ffffff}Владелец: {ff0000}%s\tСтатус: %s\n{ffffff}Класс: {ff0000}Высший\n{ffffff}Номер дома: {ff0000}%d",HomeInfo[h][hOwner],ttextt,h);
				else if(HomeInfo[h][hKlass] == 5) format(stringer1, sizeof(stringer1), "{ffffff}Владелец: {ff0000}%s\tСтатус: %s\n{ffffff}Класс: {ff0000}Люкс\n{ffffff}Номер дома: {ff0000}%d",HomeInfo[h][hOwner],ttextt,h);
				ShowPlayerDialog(playerid,10075,DIALOG_STYLE_MSGBOX,"{ffe650}Дом",stringer1,"Войти","Скрыть");
			}
			else
			{
				if(HomeInfo[h][hKlass] == 0) format(stringer1, sizeof(stringer1), "{ffffff}Цена: {ff0000}%d$\n{ffffff}Класс: {ff0000}Низкий\n{ffffff}Номер дома: {ff0000}%d",HomeInfo[h][hValue],h);
				else if(HomeInfo[h][hKlass] == 1) format(stringer1, sizeof(stringer1), "{ffffff}Цена: {ff0000}%d$\n{ffffff}Класс: {ff0000}Чистый\n{ffffff}Номер дома: {ff0000}%d",HomeInfo[h][hValue],h);
				else if(HomeInfo[h][hKlass] == 2) format(stringer1, sizeof(stringer1), "{ffffff}Цена: {ff0000}%d$\n{ffffff}Класс: {ff0000}Средний\n{ffffff}Номер дома: {ff0000}%d",HomeInfo[h][hValue],h);
				else if(HomeInfo[h][hKlass] == 3) format(stringer1, sizeof(stringer1), "{ffffff}Цена: {ff0000}%d$\n{ffffff}Класс: {ff0000}Выше среднего\n{ffffff}Номер дома: {ff0000}%d",HomeInfo[h][hValue],h);
				else if(HomeInfo[h][hKlass] == 4) format(stringer1, sizeof(stringer1), "{ffffff}Цена: {ff0000}%d$\n{ffffff}Класс: {ff0000}Высший\n{ffffff}Номер дома: {ff0000}%d",HomeInfo[h][hValue],h);
				else if(HomeInfo[h][hKlass] == 5) format(stringer1, sizeof(stringer1), "{ffffff}Цена: {ff0000}%d$\n{ffffff}Класс: {ff0000}Люкс\n{ffffff}Номер дома: {ff0000}%d",HomeInfo[h][hValue],h);
				ShowPlayerDialog(playerid,10026,DIALOG_STYLE_MSGBOX,"{ffe650}Дом",stringer1,"Купить","Скрыть");
			}
		}
	}
	if(pickupid == weaponpaintball[0] && StartPaintBall == 2 && TeamPain[playerid] != 0) return GivePlayerWeapon(playerid, 24, 49);//Выдачу оружий ставим свою
	else if(pickupid == weaponpaintball[1] && StartPaintBall == 2 && TeamPain[playerid] != 0) return GivePlayerWeapon(playerid, 25, 25);
	else if(pickupid == weaponpaintball[2] && StartPaintBall == 2 && TeamPain[playerid] != 0) return GivePlayerWeapon(playerid, 34, 10);
	else if(pickupid == weaponpaintball[3] && StartPaintBall == 2 && TeamPain[playerid] != 0) return GivePlayerWeapon(playerid, 29, 90);
	else if(pickupid == paintball)
	{
		if(StartPaintBall != 1) return SendClientMessage(playerid, COLOR_WHITE,"Регистрация закрыта!");
		else if(TeamPain[playerid] != 0) return SendClientMessage(playerid, COLOR_WHITE,"Вы уже зарегистрированны!");
		else if(RedPlayer > 14 && BluePlayer > 14) return SendClientMessage(playerid, COLOR_GREY,"Все места заняты.");
		else if(RedPlayer == 0 && BluePlayer == 0 || BluePlayer < RedPlayer || RedPlayer == BluePlayer)
		{
			SendClientMessage(playerid, -1,"Вы зарегестрированы на матч. Вы играете за команду {33AAFF}синих{FFFFFF}!");
			BluePlayer ++;
			TeamPain[playerid] = 1;
			KillPain[playerid] = 0;
			DeathPain[playerid] = 0;
			return true;
		}
		else if(BluePlayer > RedPlayer)
		{
			SendClientMessage(playerid, -1,"Вы зарегистрированы на матч. Вы играете за команду {FF0000}красных{FFFFFF}!");
			RedPlayer ++;
			TeamPain[playerid] = 2;
			KillPain[playerid] = 0;
			DeathPain[playerid] = 0;
			return true;
		}
		return true;
	}
	else if(pickupid == fight)
	{
		ShowPlayerDialog(playerid,9979,DIALOG_STYLE_MSGBOX,"Боксёр","Вы хотите устроится на работу боксёра?","Устроится","Скрыть");
		return true;
	}
	else if(pickupid == sportzal[0])
	{
		if(PlayerInfo[playerid][pJob] == 6 && PlayerInfo[playerid][pMember] == 0) SetPlayerSkin(playerid, 49);
		SetPlayerInterior(playerid,5);
		PlayerInfo[playerid][pInt] = 5;
		ResetPlayerWeapons(playerid);
		SetPlayerPos(playerid,771.4412,-2.7885,1000.7279);
		SetPlayerFacingAngle(playerid, 21.2131);
	}
	else if(pickupid == sportzal[1])
	{
		SetPlayerInterior(playerid,0);
		PlayerInfo[playerid][pInt] = 0;
		SetPlayerPos(playerid,2227.1162,-1723.1353,13.5533);
		SetPlayerFacingAngle(playerid, 130.5909);
		SetPlayerFightingStyle (playerid, FIGHT_STYLE_NORMAL);
		if(PlayerInfo[playerid][pMember] >=1) {	SetPlayerSkin(playerid,PlayerInfo[playerid][pModel]);}
		if(PlayerInfo[playerid][pMember] ==0) {	SetPlayerSkin(playerid,PlayerInfo[playerid][pChar]);}
	}
	else if(pickupid == jobspickup[0])
	{
		ShowPlayerDialog(playerid,1775,DIALOG_STYLE_MSGBOX,"Работа автоугонщика","Вы уверены, что хотите устроиться на работу автоугонщика?","Да","Нет");
	}
