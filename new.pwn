	TimerPaintBall = REGISTER_PAINTBALL;
	StartPaintBall = 1;
	RedScore = 0, BlueScore = 0;
	RedPlayer = 0, BluePlayer = 0;
	SendClientMessageToAll(COLOR_YELLOW3,"SMS от СМИ: Начало пейнтбола через 5 минут. Желающим прибыть на стадион Лос Сантос");
	PlayerForeach(i)
	{
		if(TeamPain[i] != 0 && gPlayerLogged[i] == 1) TeamPain[i] = 0;
	}
	return true;
}
