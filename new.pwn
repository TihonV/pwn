CMD:makeleader(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] > 10)
	{
		if(AntiBan[playerid] >= 60) { SendClientMessage(playerid,COLOR_GREY,"[Анти-перебан] Ваши адм действия заблокированы на 3 минуты."); AntiBan[playerid] = 180; return true; }
		if(sscanf(params, "dd",params[0], params[1])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /makeleader [id] [фракция]");
		if(params[1] > 27 || params[1] < 1) return SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 или больше 27!");
		if(PlayerInfo[params[0]][pAdmin] > 0 && PlayerInfo[playerid][pAdmin] != 12) return SendClientMessage(playerid, COLOR_WHITE, "Администратор не может быть лидером только во фракции");
		if(PlayerInfo[params[0]][pWarns] >= 1) return SendClientMessage(playerid, COLOR_GRAD1,"У игрока Warn.");
		PlayerInfo[params[0]][pLeader] = params[1];
		PlayerInfo[params[0]][pMember] = params[1];
		PlayerInfo[params[0]][pJob] = 0;
		format(stringer1, sizeof(stringer1), "Администратор %s назначил Вас контролировать данную организацию", PlayerInfo[playerid][pName]);
		SendClientMessage(params[0], 0xFFA200FF, stringer1);
		format(stringer1, sizeof(stringer1), "[A] %s назначил %s контролировать фракцию номер: %d.",PlayerInfo[playerid][pName], PlayerInfo[params[0]][pName],params[1]);
		ABroadCast(0x6495EDFF,stringer1,1);
		format(stringer1, sizeof(stringer1), "Вы назначили %s контролировать организацию номер %d.", PlayerInfo[params[0]][pName],params[1]);
		SendClientMessage(playerid, 0x6ab1ffaa, stringer1);
		SendClientMessage(params[0], 0xbc2c2caa, "Используйте клавишу 'Быстрый бег' (пробел по умолчанию)");
		SendClientMessage(params[0], 0xbc2c2caa, "Используйте клавишу 'Вверх,вниз' (W,S по умолчанию)");
		SendClientMessage(params[0], COLOR_WHITE, "- Заполните заявку на модерацию вашего раздела, на форуме: {FF0000}whisper-game.ru/forum");
		SendClientMessage(params[0], COLOR_GRAD1, "Если Вы случайно нажали 'Enter' и меню пропало, нажмите 'Enter' еще раз");
		OldSkin[playerid] = GetPlayerSkin(playerid);
		switch(params[1])
		{
		case 1: { PlayerInfo[params[0]][pRank] = 15; InviteSkin[params[0]] = 280; }
		case 2: { PlayerInfo[params[0]][pRank] = 10; InviteSkin[params[0]] = 286; }
		case 3,19: { PlayerInfo[params[0]][pRank] = 15; InviteSkin[params[0]] = 287; }
		case 4: { PlayerInfo[params[0]][pRank] = 10; InviteSkin[params[0]] = 70; }
		case 5: { PlayerInfo[params[0]][pRank] = 10; InviteSkin[params[0]] = 223; }
		case 6: { PlayerInfo[params[0]][pRank] = 10; InviteSkin[params[0]] = 120; }
		case 7: { PlayerInfo[params[0]][pRank] = 6; InviteSkin[params[0]] = 57; }
		case 10: { PlayerInfo[params[0]][pRank] = 15; InviteSkin[params[0]] = 281; }
		case 11: { PlayerInfo[params[0]][pRank] = 10; InviteSkin[params[0]] = 59; }
		case 12: { PlayerInfo[params[0]][pRank] = 10; InviteSkin[params[0]] = 102; }
		case 13: { PlayerInfo[params[0]][pRank] = 10; InviteSkin[params[0]] = 108; }
		case 14: { PlayerInfo[params[0]][pRank] = 10; InviteSkin[params[0]] = 111; }
		case 15: { PlayerInfo[params[0]][pRank] = 10; InviteSkin[params[0]] = 106; }
		case 16: { PlayerInfo[params[0]][pRank] = 13; InviteSkin[params[0]] = 261; }
		case 17: { PlayerInfo[params[0]][pRank] = 10; InviteSkin[params[0]] = 115; }
		case 18: { PlayerInfo[params[0]][pRank] = 10; InviteSkin[params[0]] = 174; }
		case 21: { PlayerInfo[params[0]][pRank] = 15; InviteSkin[params[0]] = 281; }
		case 23: { PlayerInfo[params[0]][pRank] = 12; InviteSkin[params[0]] = 30; }
		case 24: { PlayerInfo[params[0]][pRank] = 10; InviteSkin[params[0]] = 184; }
		case 26: { PlayerInfo[params[0]][pRank] = 10; InviteSkin[params[0]] = 295; }
		default: SendClientMessage(playerid, COLOR_WHITE, " Данная фракция была удалена. | Пропишите /llist");
		}
		AntiBan[playerid] += 30;
		SetPlayerInterior(params[0],5);
		PlayerInfo[params[0]][pInt] = 5;
		SetPlayerVirtualWorld(params[0],1);
		ShowMenuForPlayer(ChoseSkin,params[0]);
		new rand = random(sizeof(gInviteSpawns));
		SetPlayerPos(params[0], gInviteSpawns[rand][0], gInviteSpawns[rand][1], gInviteSpawns[rand][2]); // Warp the player
		SetPlayerFacingAngle(params[0], gInviteSpawns[rand][3]);
		SetPlayerCameraPos(params[0],gInviteSpawns[rand][0] + 3, gInviteSpawns[rand][1], gInviteSpawns[rand][2]);
		SetPlayerCameraLookAt(params[0],gInviteSpawns[rand][0], gInviteSpawns[rand][1], gInviteSpawns[rand][2]);
		TogglePlayerControllable(params[0], 0);
		SelectChar[params[0]] = INVALID_PLAYER_ID;
		SelectCharID[params[0]] = PlayerInfo[params[0]][pMember];
		SelectCharPlace[params[0]] = 1;
		PlayerInfo[params[0]][pModel] = InviteSkin[params[0]];
		SetPlayerArmour(params[0],0);
		SetPlayerHealth(params[0],100);
		SetPlayerSkin(params[0], InviteSkin[params[0]]);
		OnPlayerUpdateRL(playerid);
		return true;
	}
	return true;
}
CMD:agivevip(playerid, params[])
{
	new year, month, day;
	if(PlayerInfo[playerid][pAdmin] != 12) return true;
	if(sscanf(params, "ddd",params[0], params[1], params[2])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /agivevip [id] [уровень вип] [кол-во дней]");
	if(IsPlayerConnected(params[0]))
	{
		if(params[0] != INVALID_PLAYER_ID)
		{
			switch(params[1])
			{
			case 1: SendClientMessage(params[0], COLOR_WHITE, "Поздравляем, вы получили от администрации {FFA500}Bronze VIP");
			case 2: SendClientMessage(params[0], COLOR_WHITE, "Поздравляем, вы получили от администрации {FFA500}Silver VIP");
			case 3: SendClientMessage(params[0], COLOR_WHITE, "Поздравляем, вы получили от администрации {FFA500}Gold VIP");
			default: SendClientMessage(params[0], COLOR_WHITE, "Администратор забрал у вас VIP Аккаунт");
			}
			if(params[2] == 0)
			{
				PlayerInfo[params[0]][pDonateRank] = 0;
				PlayerInfo[params[0]][pVipTime] = 0;
				PlayerInfo[params[0]][pVipData] = 0;
				SendClientMessage(playerid, COLOR_WHITE, "- Вы забрали у игрока VIP Статус.");
			}
			else
			{
				getdate(year, month, day);
				new curdate = getdate(year,month,day);
				PlayerInfo[params[0]][pDonateRank] = params[1];
				PlayerInfo[params[0]][pVipTime] = curdate+params[2];
				PlayerInfo[params[0]][pVipData] = curdate;
				SendClientMessage(playerid, COLOR_WHITE, "- Вы выдали игроку VIP Статус.");
			}
		}
	}
	return true;
}
