public OnPlayerCommandText(playerid, cmdtext[])
{
	new cmd[144];
	new idx;
	cmd = strcharsplit(cmdtext, idx);
	if(gPlayerLogged[playerid] == 0 || !IsPlayerConnected(playerid)) return SendClientMessage(playerid,COLOR_GREY,"Вы не авторизованы.");
	if(PlayerInfo[playerid][pAdmin] > 0 && dostup[playerid] == 0) return ShowPlayerDialog(playerid,2934,DIALOG_STYLE_PASSWORD,"Админ авторизация","Введите пароль\n\nПароль должен состоять из латинских букв и цифр\nразмером от 4 до 15 символов","Вход","Скрыть");
	return true;
}
public ProxDetector(Float:radi, playerid, string[],col1,col2,col3,col4,col5)
{
	if(IsPlayerConnected(playerid))
	{
		new Float:posx, Float:posy, Float:posz;
		new Float:oldposx, Float:oldposy, Float:oldposz;
		new Float:tempposx, Float:tempposy, Float:tempposz;
		GetPlayerPos(playerid, oldposx, oldposy, oldposz);
		PlayerForeach(i)
		{
			if(IsPlayerConnected(i))
			{
				if(!BigEar[i])
				{
					if(GetPlayerVirtualWorld(playerid) == GetPlayerVirtualWorld(i))
					{
						GetPlayerPos(i, posx, posy, posz);
						tempposx = (oldposx -posx);
						tempposy = (oldposy -posy);
						tempposz = (oldposz -posz);
						if(((tempposx < radi/16) && (tempposx > -radi/16)) && ((tempposy < radi/16) && (tempposy > -radi/16)) && ((tempposz < radi/16) && (tempposz > -radi/16))) SendClientMessage(i, col1, string);
						else if(((tempposx < radi/8) && (tempposx > -radi/8)) && ((tempposy < radi/8) && (tempposy > -radi/8)) && ((tempposz < radi/8) && (tempposz > -radi/8))) SendClientMessage(i, col2, string);
						else if(((tempposx < radi/4) && (tempposx > -radi/4)) && ((tempposy < radi/4) && (tempposy > -radi/4)) && ((tempposz < radi/4) && (tempposz > -radi/4))) SendClientMessage(i, col3, string);
						else if(((tempposx < radi/2) && (tempposx > -radi/2)) && ((tempposy < radi/2) && (tempposy > -radi/2)) && ((tempposz < radi/2) && (tempposz > -radi/2))) SendClientMessage(i, col4, string);
						else if(((tempposx < radi) && (tempposx > -radi)) && ((tempposy < radi) && (tempposy > -radi)) && ((tempposz < radi) && (tempposz > -radi))) SendClientMessage(i, col5, string);
					}
				}
				else SendClientMessage(i, col1, string);
			}
		}
	}
	return true;
}

stock strcharsplit(const string[], &index, seperator=' ')
{
	new result[20], i = 0;
	if(index != 0 && string[index] != '\0') index++;
	while (string[index] && string[index] != seperator && string[index] != '\r' && string[index] != '\n')
	{
		result[i++] = string[index++];
	}
	return result;
}
public ProxDetectorS(Float:radi, playerid, targetid)
{
	if(IsPlayerConnected(playerid)&&IsPlayerConnected(targetid))
	{
		new Float:posx, Float:posy, Float:posz;
		new Float:oldposx, Float:oldposy, Float:oldposz;
		new Float:tempposx, Float:tempposy, Float:tempposz;
		GetPlayerPos(playerid, oldposx, oldposy, oldposz);
		//radi = 2.0; //Trigger Radius
		GetPlayerPos(targetid, posx, posy, posz);
		tempposx = (oldposx -posx);
		tempposy = (oldposy -posy);
		tempposz = (oldposz -posz);
		//printf("DEBUG: X:%f Y:%f Z:%f",posx,posy,posz);
		if(((tempposx < radi) && (tempposx > -radi)) && ((tempposy < radi) && (tempposy > -radi)) && ((tempposz < radi) && (tempposz > -radi))) { return true; }
	}
	return false;
}
public OnPlayerText(playerid, text[])
{
	if(gPlayerLogged[playerid] == 0) return false;
	if(PlayerInfo[playerid][pTut] == 0) return false;
	if(GetPVarInt(playerid,"Antisbiv") == 1) return 0;
	new ip[15];
	GetPlayerIp(playerid,ip,sizeof(ip));
	if(IsIpFound(text))
	{
		PlayerInfo[playerid][pMuteTime] = 180;
		PlayerInfo[playerid][pMuted] = 1;
		format(stringer1, sizeof(stringer1), "%s: %s",PlayerInfo[playerid][pName],text);
		ABroadCast(COLOR_LIGHTRED,stringer1,1);
		format(stringer1, sizeof(stringer1), "- ID: %d | IP: [%s]",playerid,ip);
		ABroadCast(COLOR_LIGHTRED,stringer1,1);
		format(stringer1,sizeof(stringer1),"Сервер заблокировал Вам чат на 3 минуты ( /mm => Репорт )");
		SendClientMessage(playerid, COLOR_LIGHTRED, stringer1);
		return false;
	}
	if(strfind(text,"админ",true) != -1 || strfind(text,"afk",true) != -1 ||  strfind(text,"афк",true) != -1\
			|| strfind(text,"gta",true) != -1  || strfind(text,"samp",true) != -1 || strfind(text,"читер",true) != -1 || strfind(text,"/",true) != -1\
