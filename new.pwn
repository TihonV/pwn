publics: OffLeader(playerid,tmp[])
{
	new rows, fields;
	cache_get_data(rows, fields);
	if(!rows) return SendMes(playerid, COLOR_GREY, "MySql: Аккаунт %s не найден в базе данных.",tmp);
	mysql_format(dbHandle, QUERY, sizeof(QUERY), "UPDATE `"TABLE_ACCOUNT"` SET `pLeader` = '0', `pMember` = '0', `pRank` = '0' WHERE `Name` = '%s'", tmp);
	mysql_function_query(dbHandle, QUERY, false, "", "");
	format(stringer1, 100, "[A][OFF] Администратор: %s снял лидерство с %s.",PlayerInfo[playerid][pName],tmp);
	ABroadCast(COLOR_LIGHTRED,stringer1,1);
	return true;
