					{
						if(!strlen(inputtext))
						{
							format(stringer,sizeof(stringer),"Пополнение банковского счета банды");
							ShowPlayerDialog(playerid,22250,DIALOG_STYLE_INPUT,"Введите сумму платежа",stringer,"Далее","Скрыть");
						}
						new dengi;
						dengi = strval(inputtext);
