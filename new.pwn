stock Float:GetDistanceBetweenPoints(Float:X, Float:Y, Float:Z, Float:PointX, Float:PointY, Float:PointZ)
{
	new Float:Distance;Distance = floatabs(floatsub(X, PointX)) + floatabs(floatsub(Y, PointY)) + floatabs(floatsub(Z, PointZ));
	return Distance;
}
public OnDialogResponse(playerid, dialogid, response, listitem, inputtext[])
{
	PlayerPlaySound(playerid, 1136, 0.0, 0.0, 0.0);
	strreplace(inputtext, '%', '#');
	if(strlen(inputtext) && (strfind(inputtext,"`") != -1 ||
				strfind(inputtext,"'") != -1 )) return SendClientMessage(playerid, COLOR_GREY, "В тексте были обнаружены запрещенные символы.");
	new gun,ammo, money;
	new gunname[32];
	switch(dialogid)
	{
	case dBuyInt:
		{
			if(response)
			{
				switch(listitem)
				{
				case 0:
					{
						new house = PlayerInfo[playerid][pPhousekey];
						HomeInfo[house][hInt] = 10;
						HomeInfo[house][hExitx] = 24.3769;
						HomeInfo[house][hExity] = 1341.1829;
						HomeInfo[house][hExitz] = 1084.3750;
						PlayerInfo[playerid][pCash] -= 50000;
						SendClientMessage(playerid, COLOR_GREEN, "Поздравляю! Вы сделали ремонт за 50.000$.");
						SaveHouse(house);
						SpawnPlayer(playerid);
						return true;
					}
				case 1:
					{
						new house = PlayerInfo[playerid][pPhousekey];
						HomeInfo[house][hInt] = 5;
						HomeInfo[house][hExitx] = 227.2413;
						HomeInfo[house][hExity] = 1114.3289;
						HomeInfo[house][hExitz] = 1080.9978;
						PlayerInfo[playerid][pCash] -= 110000;
						SendClientMessage(playerid, COLOR_GREEN, "Поздравляю! Вы сделали ремонт за 110.000$.");
						SaveHouse(house);
						SpawnPlayer(playerid);
						return true;
					}
				case 2:
					{
						new house = PlayerInfo[playerid][pPhousekey];
						HomeInfo[house][hInt] = 10;
						HomeInfo[house][hExitx] = 2269.4436;
						HomeInfo[house][hExity] = -1210.5802;
						HomeInfo[house][hExitz] = 1047.5625;
						PlayerInfo[playerid][pCash] -= 200000;
						SendClientMessage(playerid, COLOR_GREEN, "Поздравляю! Вы сделали ремонт за 200.000$.");
						SaveHouse(house);
						SpawnPlayer(playerid);
						return true;
					}
				case 3:
					{
						new house = PlayerInfo[playerid][pPhousekey];
						HomeInfo[house][hInt] = 12;
						HomeInfo[house][hExitx] = 2324.3752;
						HomeInfo[house][hExity] = -1148.3384;
						HomeInfo[house][hExitz] = 1050.7101;
						PlayerInfo[playerid][pCash] -= 300000;
						SendClientMessage(playerid, COLOR_GREEN, "Поздравляю! Вы сделали ремонт за 300.000$.");
						SaveHouse(house);
						SpawnPlayer(playerid);
						return true;
					}
				case 4:
					{
						new house = PlayerInfo[playerid][pPhousekey];
						HomeInfo[house][hInt] = 7;
						HomeInfo[house][hExitx] = 225.6309;
						HomeInfo[house][hExity] = 1022.4799;
						HomeInfo[house][hExitz] = 1084.0146;
						PlayerInfo[playerid][pCash] -= 500000;
						SendClientMessage(playerid, COLOR_GREEN, "Поздравляю! Вы сделали ремонт за 500.000$.");
						SaveHouse(house);
						SpawnPlayer(playerid);
						return true;
					}
				case 5:
					{
						new house = PlayerInfo[playerid][pPhousekey];
						HomeInfo[house][hInt] = 5;
						HomeInfo[house][hExitx] = 1299.3610;
						HomeInfo[house][hExity] = -795.7043;
						HomeInfo[house][hExitz] = 1084.0078;
						PlayerInfo[playerid][pCash] -= 1000000;
						SendClientMessage(playerid, COLOR_GREEN, "Поздравляю! Вы сделали ремонт за 1.000.000$.");
						SaveHouse(house);
						SpawnPlayer(playerid);
						return true;
					}
				}
			}
			else return true;
		}
	case dTeleport:
		{
			if(!response) return true;
			SetPlayerPos(playerid, TPCords[listitem][0],TPCords[listitem][1],TPCords[listitem][2]);
			SetPlayerFacingAngle(playerid, TPCords[listitem][3]);
			SetCameraBehindPlayer(playerid);
			SetPlayerInterior(playerid,0);
			SetPlayerVirtualWorld(playerid,0);
		}
	case dBankomat:
		{
			if(response)
			{
				switch(listitem)
				{
				case 0:
					{
						format(stringer,sizeof(stringer), "Баланс вашего счёта: %d вирт", PlayerInfo[playerid][pBank]);
