	return 1;
}
stock NewTextDrawsLoad(i)
{

	Capture[i][0] = CreatePlayerTextDraw(i, 151.000000, 254.122222, "usebox"); // box
	PlayerTextDrawLetterSize(i, Capture[i][0], 0.000000, 1.135183);
	PlayerTextDrawTextSize(i, Capture[i][0], 1.000000, 0.000000);
	PlayerTextDrawAlignment(i, Capture[i][0], 1);
	PlayerTextDrawColor(i, Capture[i][0], 0);
	PlayerTextDrawUseBox(i, Capture[i][0], true);
	PlayerTextDrawBoxColor(i, Capture[i][0], -5963521);
	PlayerTextDrawSetShadow(i, Capture[i][0], 0);
	PlayerTextDrawSetOutline(i, Capture[i][0], 0);
	PlayerTextDrawFont(i, Capture[i][0], 1);

	Capture[i][1] = CreatePlayerTextDraw(i, 151.000000, 271.544464, "usebox");
	PlayerTextDrawLetterSize(i, Capture[i][1], 0.000000, 1.104321);
	PlayerTextDrawTextSize(i, Capture[i][1], 1.000000, 0.000000);
	PlayerTextDrawAlignment(i, Capture[i][1], 1);
	PlayerTextDrawColor(i, Capture[i][1], 0);
	PlayerTextDrawUseBox(i, Capture[i][1], true);
	PlayerTextDrawBoxColor(i, Capture[i][1], 50529738);
	PlayerTextDrawSetShadow(i, Capture[i][1], 0);
