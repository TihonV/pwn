		case 7: { lvpdmats = params[1]; format(stringer1, sizeof(stringer1), "Маты LVPD изменены на: %d", params[1]); }
		case 8: { yakuzamats = params[1]; format(stringer1, sizeof(stringer1), "Маты Якудза изменены на: %d", params[1]); }
		case 9: { lcnmats = params[1]; format(stringer1, sizeof(stringer1), "Маты ЛКН изменены на: %d", params[1]); }
		case 10: { rmmats = params[1]; format(stringer1, sizeof(stringer1), "Маты РМ изменены на: %d", params[1]); }
		case 11:
			{
				armmatbi = params[1];
				armmatsf = params[1];
				rifamatbi = params[1];
				ballasmatbi = params[1];
				aztekmatbi = params[1];
				vagosmatbi = params[1];
				groovmatbi = params[1];
				lspdmatbi = params[1];
				fbimats = params[1];
				yakuzamats = params[1];
