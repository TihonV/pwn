CMD:newsbank(playerid, params[])
{
	switch(PlayerInfo[playerid][pMember])
	{
	case 16: return SendMes(playerid, 0x6ab1ffaa, "В банке SAN NEWS: %d вирт", FracBank[0][fLsnews]);
	}
	return true;
}
CMD:newswithdraw(playerid, params[])
{
	if(PlayerInfo[playerid][pLeader] == 9 || PlayerInfo[playerid][pLeader] == 16)
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /newswithdraw [количество]");
	if(PlayerInfo[playerid][pMember] == 16 && PlayerInfo[playerid][pRank] == 13)
	{
		if(FracBank[0][fLsnews] == 0) return SendClientMessage(playerid, COLOR_GREY, "В банке SAN NEWS нет денег");
		if(FracBank[0][fLsnews] < params[0]) return SendClientMessage(playerid, COLOR_GREY, "В банке SAN NEWS нет столько денег");
		if(params[0] < 1 || params[0] > 100000000) return SendClientMessage(playerid, COLOR_GREY, "Неправильный количество денег!");
		FracBank[0][fLsnews] -= params[0];
		PlayerInfo[playerid][pCash] +=params[0];
		SendMes(playerid, 0x6ab1ffaa, "Вы сняли с банка SAN NEWS: %d вирт", params[0]);
		SetOtherInt("FracBank[0][fLsnews]", FracBank[0][fLsnews]);
	}
	return true;
}
CMD:getweapon(playerid, params[])
{
	switch(PlayerInfo[playerid][pMember])
	{
	case 6:
		{
			if(PlayerToPoint(4.0,playerid,1257.1469,-792.7399,1084.2344))//яки getgun
			{
				if(PlayerInfo[playerid][pRank] <= 2)return SendClientMessage(playerid,COLOR_GRAD1,"Оружие можно взять с 3 ранга!");
				ShowPlayerDialog(playerid, 2013, DIALOG_STYLE_LIST, "Взять оружие со склада Yakuza", "- Deagle [70 матов/50 патронов]\n- Shotgun [50 матов/15 патронов]\n- Rifle [100 матов/10 патронов]\n- M4 [500 матов/100 патронов]\n- AK-47 [500 матов/100 патронов]\n- Mp5 [400 матов/200 патронов]\n- Sdpistol [100 матов/100 патронов])", "Далее", "Скрыть");
			}
		}
	case 5:
		{
			if(PlayerToPoint(4.0,playerid,1257.1469,-792.7399,1084.2344))//lcn getgun
			{
				if(PlayerInfo[playerid][pRank] <= 2)return SendClientMessage(playerid,COLOR_GRAD1,"Оружие можно взять с 3 ранга!");
				ShowPlayerDialog(playerid, 2014, DIALOG_STYLE_LIST, "Взять оружие со склада LCN", "- Deagle [70 матов/50 патронов]\n- Shotgun [50 матов/15 патронов]\n- Rifle [100 матов/10 патронов]\n- M4 [500 матов/100 патронов]\n- AK-47 [500 матов/100 патронов]\n- Mp5 [400 матов/200 патронов]\n- Sdpistol [100 матов/100 патронов])", "Далее", "Скрыть");
			}
		}
	case 14:
		{
			if(PlayerToPoint(4.0,playerid,1257.1469,-792.7399,1084.2344))//рм getgun
			{
				if(PlayerInfo[playerid][pRank] <= 2)return SendClientMessage(playerid,COLOR_GRAD1,"Оружие можно взять с 3 ранга!");
				ShowPlayerDialog(playerid, 2015, DIALOG_STYLE_LIST, "Взять оружие со склада Русской Мафии", "- Deagle [70 матов/50 патронов]\n- Shotgun [50 матов/15 патронов]\n- Rifle [100 матов/10 патронов]\n- M4 [500 матов/100 патронов]\n- AK-47 [500 матов/100 патронов]\n- Mp5 [400 матов/200 патронов]\n- Sdpistol [100 матов/100 патронов])", "Далее", "Скрыть");
			}
