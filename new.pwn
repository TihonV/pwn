public LockCar(carid)
{
	PlayerForeach(i)
	{
		if(IsPlayerConnected(i)) { SetVehicleParamsForPlayer(carid,i,0,1); gCarLock[carid] = 1; }
	}
}
public InitLockDoors(playerid)
{
	if(IsPlayerConnected(playerid))
	{
		for(new c = 0; c < 265; c++)
		{
			if(gCarLock[c] == 1) SetVehicleParamsForPlayer(c,playerid,0,1);
		}
	}
	return true;
}
public OnPlayerExitVehicle(playerid, vehicleid)
{
	new Veh = GetPlayerVehicleID(playerid);
	ResetCarInfo(playerid);
	if(PEfir[playerid] != INVALID_PLAYER_ID)
	{
		SendMes(playerid,COLOR_WHITE, "Вы вышли из прямого эфира");
		PEfir[playerid] = INVALID_PLAYER_ID;
	}
	if(Pefir[playerid] == 1 || Pefir[playerid] == 2)
	{
		Pefir[playerid] = 0;
		PEfir[playerid] = INVALID_PLAYER_ID;
		SendMes(playerid,COLOR_WHITE, "Вы вышли из прямого эфира");
	}
	if(TransportDuty[playerid] > 0)
	{
		if(TransportDuty[playerid] == 1) TaxiDrivers -= 1;
		Delete3DTextLabel(taxi3d[Veh]);
	}
	return true;
}
public OnPlayerRequestClass(playerid, classid)
{
	if(gov[playerid] > 3) return true;
	new Float:pHealth;
	GetPlayerHealth(playerid, pHealth);
	if(pHealth) ClearAnimations(playerid, 1);
	SetPlayerInterior(playerid,0);
	PlayerInfo[playerid][pInt] = 0;
 	InterpolateCameraPos(playerid, 1604.906616, -1986.163452, 50.145294, 1848.423950, -1840.502441, 40.976726, 20000);
	InterpolateCameraLookAt(playerid, 1609.136718, -1983.563598, 49.555946, 1844.970336, -1843.971801, 39.958724, 20000);
	TogglePlayerControllable(playerid,0);
	gov[playerid]++;
	SetPVarInt(playerid, "AIRAS", 500);
	return true;
}
stock SetPlayerExtra(playerid,declare,reason[])
{
	if(IsPlayerConnected(playerid))
	{
		new turner[MAX_PLAYER_NAME];
		new pizdezturned[MAX_PLAYER_NAME];
		GetPlayerName(playerid, pizdezturned, sizeof(pizdezturned));
		strmid(PlayerCrime[playerid][pAccusedof], reason, 0, strlen(reason), 255);
		if(declare == 255)
		{
			format(turner, sizeof(turner), "Неизвестный");
			strmid(PlayerCrime[playerid][pVictim], PlayerInfo[playerid][pName], 0, strlen(turner), 255);
		}
		else
		{
			if(IsPlayerConnected(declare))
			{
				GetPlayerName(declare, turner, sizeof(turner));
				strmid(PlayerCrime[playerid][pVictim], turner, 0, strlen(turner), 255);
				strmid(PlayerCrime[declare][pBplayer], pizdezturned, 0, strlen(pizdezturned), 255);
				strmid(PlayerCrime[declare][pAccusing], reason, 0, strlen(reason), 255);
			}
		}
		SendMes(playerid,COLOR_LIGHTRED,"Вы совершили преступление: [%s]. Сообщил: %s.",reason,turner);
		if(PlayerInfo[playerid][pWanted] > 0)
		{
			new yesno;
			if(PlayerInfo[playerid][pWanted] != 0) { if(gTeam[playerid] == 3) gTeam[playerid] = 4; yesno = 1; }
			if(yesno)
			{
				SendMes(playerid,COLOR_YELLOW,"Текущий уровень розыска: %d", PlayerInfo[playerid][pWanted]);
				SetPlayerWantedLevel(playerid, PlayerInfo[playerid][pWanted]);
				PlayerForeach(i)
				{
					if(IsPlayerConnected(i)) { if(IsACop(i)) SendMes(i,0xFEBC41AA,"Рация: Cообщает: %s. Преступление: %s. Подозреваемый: %s",turner,reason,pizdezturned); }
				}
			}
		}
	}
}
public OtherTimer()
{
	GetMoney();
	PlayerForeach(i)
	{
		if(IsPlayerConnected(i))
		{
			if(CellTime[i] > 0)
			{
				if(CellTime[i] == cchargetime)
				{
					CellTime[i] = 1;
					if(Mobile[Mobile[i]] == i) CallCost[i] = CallCost[i]+callcost;
				}
				CellTime[i] = CellTime[i] +1;
				if(Mobile[Mobile[i]] == -1 && CellTime[i] == 5)
				{
					if(IsPlayerConnected(Mobile[i]))
					{
						format(stringer1, sizeof(stringer1), "У %s звонит мобильник", PlayerInfo[Mobile[i]][pName]);
						ProxDetector(30.0, Mobile[i], stringer1, COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW);
					}
				}
			}
			if(CellTime[i] == 0 && CallCost[i] > 0)
			{
				format(stringer1, sizeof(stringer1), "~w~Phone~n~~r~%d",CallCost[i]);
				PlayerInfo[i][pCash] -=-CallCost[i];
				GameTextForPlayer(i, stringer1, 5000, 1);
				CallCost[i] = 0;
			}
		}
	}
	return true;
}

stock Fresh()
{
	if(adverttime > 0) adverttime--;
	mysql_function_query(dbHandle,"SELECT * FROM `frapsy_queries` WHERE `flag` = '0'",true,"CheckUCP","");
	new hour, minute, second;
	gettime(hour, minute, second);
	new tmphour;
	new tmpminute;
	new tmpsecond;
	gettime(tmphour, tmpminute, tmpsecond);
	FixHour(tmphour);
	tmphour = shifthour;
	if(hitmansgatetime > 0)
	{
		hitmansgatetime--;
		if(hitmansgatetime == 0) MoveObject (hitmansgate, -1195.4439697,-1038.7869873,130.9980011, 2);
	}
	if(BizWarTime > 0)
	{
		BizWarTime--;
		new kv1,kv2;
		PlayerForeach(playerid)
		{
			if(playerid == -1) continue;
			if(PlayerInfo[playerid][ppkz2] == true && !ISAMAFIA(playerid)) EndBizwar(playerid);
			if(MZInfo[bFrakVlad]!=PlayerInfo[playerid][pMember] && MZInfo[bNapad]!=PlayerInfo[playerid][pMember]) continue;
			switch(MZInfo[bMesto])
			{
			case 1:
				if(PlayerToKvadrat(playerid,300.755706, 2402.644531, 468.755706, 2580.644531))
				{
					if(MZInfo[bFrakVlad]==PlayerInfo[playerid][pMember])
					kv1++;
					else
					kv2++;
				}
			case 2:
				if(PlayerToKvadrat(playerid,-855.6808,1891.0676,-519.0121,2128.4995))
				{
					if(MZInfo[bFrakVlad]==PlayerInfo[playerid][pMember])
					kv1++;
					else
					kv2++;
				}
			case 3:
				if(PlayerToKvadrat(playerid,275.881378, 797.211608, 443.881378, 973.211608))
				{
					if(MZInfo[bFrakVlad]==PlayerInfo[playerid][pMember])
					kv1++;
					else
					kv2++;
				}
			}
		}
		PlayerForeach(m)
		{
			if(m == -1) continue;
			if(PlayerInfo[m][ppkz2] == true && !ISAMAFIA(m)) EndBizwar(m);
			if(MZInfo[bFrakVlad]!=PlayerInfo[m][pMember] && MZInfo[bNapad]!=PlayerInfo[m][pMember]) continue;
			if(PlayerInfo[m][ppkz2] == false)
			{
				GangZoneFlashForPlayer(m,ZonsWar[MZInfo[bMesto]-1],GetColor(MZInfo[bNapad]));
				PlayerTextDrawShow(m, Bizwar[m][0]);
				format(stringer,50,"~w~Time: ~g~%s",TimeConverter(BizWarTime));
				PlayerTextDrawSetString(m,Bizwar[m][0],stringer);
				format(stringer,50,"~w~%s ~g~0 ~w~Kill: ~g~0",GetMN(MZInfo[bFrakVlad]));
				PlayerTextDrawSetString(m,Bizwar[m][1],stringer);
				PlayerTextDrawShow(m, Bizwar[m][1]);
				format(stringer,50,"~w~%s ~g~0 ~w~Kill: ~g~0",GetMN(MZInfo[bNapad]));
				PlayerTextDrawSetString(m,Bizwar[m][2],stringer);
				PlayerTextDrawShow(m, Bizwar[m][2]);
				PlayerInfo[m][ppkz2] = true;
			}
			else
			{
				format(stringer,50,"~w~Time: ~g~%s",TimeConverter(BizWarTime));
				PlayerTextDrawSetString(m,Bizwar[m][0],stringer);
				format(stringer,50,"~w~%s ~g~%d ~w~Kill: ~g~%d",GetMN(MZInfo[bFrakVlad]),kv1,MZInfo[bCountDead][MZInfo[bFrakVlad]]);
				PlayerTextDrawSetString(m,Bizwar[m][1],stringer);
				format(stringer,50,"~w~%s ~g~%d ~w~Kill: ~g~%d",GetMN(MZInfo[bNapad]),kv2,MZInfo[bCountDead][MZInfo[bNapad]]);
				PlayerTextDrawSetString(m,Bizwar[m][2],stringer);
			}
		}
		if(BizWarTime <= 0)
		{
			new mafianame[24];
			switch(MZInfo[bNapad])
			{
			case 6: mafianame = "Yakuza";
			case 14: mafianame = "Russian Mafia";
			case 5: mafianame = "LCN";
			}
			new mafianamev[24];
