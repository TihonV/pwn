stock SetPlayerSkills(playerid)
{
	if(PlayerInfo[playerid][pSDPistol] >= 100) SetPlayerSkillLevel(playerid, WEAPONSKILL_PISTOL_SILENCED, 1000); else SetPlayerSkillLevel(playerid, WEAPONSKILL_PISTOL_SILENCED, 0);
	if(PlayerInfo[playerid][pDesertEagle] >= 100) SetPlayerSkillLevel(playerid, WEAPONSKILL_DESERT_EAGLE, 1000); else SetPlayerSkillLevel(playerid, WEAPONSKILL_DESERT_EAGLE, 0);
	if(PlayerInfo[playerid][pShotGun] >= 100) SetPlayerSkillLevel(playerid, WEAPONSKILL_SHOTGUN, 1000); else SetPlayerSkillLevel(playerid, WEAPONSKILL_SHOTGUN, 0);
	if(PlayerInfo[playerid][pMP5] >= 100) SetPlayerSkillLevel(playerid, WEAPONSKILL_MP5, 1000); else SetPlayerSkillLevel(playerid, WEAPONSKILL_MP5, 0);
	if(PlayerInfo[playerid][pAK47] >= 100) SetPlayerSkillLevel(playerid, WEAPONSKILL_AK47, 1000); else SetPlayerSkillLevel(playerid, WEAPONSKILL_AK47, 0);
	if(PlayerInfo[playerid][pM4] >= 100) SetPlayerSkillLevel(playerid, WEAPONSKILL_M4, 1000); else SetPlayerSkillLevel(playerid, WEAPONSKILL_M4, 0);
	return true;
}
stock OnPlayerAmmoChange(playerid, newammo, oldammo)
{
	if(newammo < oldammo)
	{
		Shot[playerid]++;
		switch(GetPlayerWeapon(playerid))
		{
		case 24: if(Shot[playerid] >= 25 && PlayerInfo[playerid][pDesertEagle] < 100) PlayerInfo[playerid][pDesertEagle]++, Shot[playerid] = 0;
		case 23: if(Shot[playerid] >= 25 && PlayerInfo[playerid][pSDPistol] < 100) PlayerInfo[playerid][pSDPistol]++, Shot[playerid] = 0;
		case 25: if(Shot[playerid] >= 50 && PlayerInfo[playerid][pShotGun] < 100) PlayerInfo[playerid][pShotGun]++, Shot[playerid] = 0;
		case 29: if(Shot[playerid] >= 50 && PlayerInfo[playerid][pMP5] < 100) PlayerInfo[playerid][pMP5]++, Shot[playerid] = 0;
		case 30: if(Shot[playerid] >= 50 && PlayerInfo[playerid][pAK47] < 100) PlayerInfo[playerid][pAK47]++, Shot[playerid] = 0;
		case 31: if(Shot[playerid] >= 50 && PlayerInfo[playerid][pM4] < 100) PlayerInfo[playerid][pM4]++, Shot[playerid] = 0;
		}
	}
	return true;
}
stock GetPlayerID(string[])
{
	PlayerForeach(i)
	{
		if(IsPlayerConnected(i) == 1)
		{
			if(strcmp(PlayerInfo[i][pName], string, true, strlen(string)) == 0) { return i; }
		}
	}
	return INVALID_PLAYER_ID;
}
stock SCMAH(color, string[])
{
	PlayerForeach(i)
	{
		if(!IsPlayerConnected(i) || gPlayerLogged[i] == 0) continue;
		if(PlayerInfo[i][pAdmin] > 0 || PlayerInfo[i][pHelper] > 0) SendClientMessage(i, color, string);
	}
	return true;
}
public OnPlayerTakeDamage(playerid, issuerid, Float:amount, weaponid, bodypart)
{
	format(stringer1, sizeof(stringer1), "{FF0000}- {D3D3D3}%.0f",amount);
	SetPlayerChatBubble(playerid, stringer1, 0x6ab1ffaa, 20.0, 10000);
	PlayerPlaySound(playerid,1150,0.0,0.0,0.0);
	return true;
}
SetPosInFrontOfPlayer(playerid,giveplayerid,Float:distance)
{
	new Float:x,Float:y,Float:z,Float:a;
	GetPlayerPos(playerid, x, y,z);GetPlayerFacingAngle(playerid, a);
	x += (distance * floatsin(-a, degrees));
	y += (distance * floatcos(-a, degrees));
	SetPlayerPos(giveplayerid,x,y,z);SetPlayerFacingAngle(giveplayerid,a);
}
stock IsAnyPlayerInVehicle(vehicleid,seat)
{
	PlayerForeach(i)
	{
		if(IsPlayerInVehicle(i, vehicleid) && GetPlayerVehicleSeat(i) == seat) return true;
	}
	return false;
}
public OnPlayerClickMap(playerid, Float:fX, Float:fY, Float:fZ)
{
	if(PlayerInfo[playerid][pAdmin] >=5)
	{
		if(!IsPlayerInAnyVehicle(playerid))
		{
			SetPlayerPos(playerid,fX,fY,fZ); SendClientMessage(playerid,COLOR_GREY,"Инфо: Вы успешно телепортировались");//Меняем позицию игрока на координаты метки и выводим ему сообщение
			SetPlayerInterior(playerid,0); PlayerInfo[playerid][pInt] = 0; SetPlayerVirtualWorld(playerid,0);//Виртуальный мир и инт ставим на 0
		}
	}
	return true;
}
public OnUnoccupiedVehicleUpdate(vehicleid, playerid, passenger_seat) return true;

stock acc_int_strcat(query[], len, name[], number)
{
	new string[64];
	format(string, sizeof(string), "`%s` = '%d',",name, number);
	strcat(query, string, len);
	return true;
}
stock acc_float_strcat(query[], len, name[], Float:number)
{
	new string[64];
	format(string, sizeof(string), "`%s` = '%f',", name, number);
	strcat(query, string, len);
	return true;
}
stock acc_str_strcat(query[], len, name[], str[])
{
	new string[64];
	format(string, sizeof(string), "`%s` = '%s',",name, str);
	strcat(query, string, len);
	return true;
}
public GMTest(playerid)
{
	new string[128], Float:nowhealth[MAX_PLAYERS];
	if(autoaim[GetPVarInt(playerid,"AdmGMID")] == true)
	{

	}
	if(GetPVarInt(GetPVarInt(playerid,"AdmGMID"), "AdmGM") == 1)
	{
		GetPlayerHealth(GetPVarInt(playerid,"AdmGMID"),nowhealth[GetPVarInt(playerid,"AdmGMID")]);
	}
	if((AdmGMHP[GetPVarInt(playerid,"AdmGMID")]-nowhealth[GetPVarInt(playerid,"AdmGMID")]) > 0)
	{
		format(string, sizeof(string), "До: \t\t\t\t%.0f.0 HP\nПосле: \t\t\t%.0f.0 HP\nHP уменьшилось на: \t\t%.0f.0\n\n{7FB151}ГМ не обнаружено. HP игрока восстановлено.",AdmGMHP[GetPVarInt(playerid,"AdmGMID")],nowhealth[GetPVarInt(playerid,"AdmGMID")],(AdmGMHP[GetPVarInt(playerid,"AdmGMID")]-nowhealth[GetPVarInt(playerid,"AdmGMID")]));
		ShowPlayerDialog(playerid,888,DIALOG_STYLE_MSGBOX  , "Проверка на God Mode",string, "Закрыть", "");
		SetPlayerHealth(GetPVarInt(playerid,"AdmGMID"), AdmGMHP[GetPVarInt(playerid,"AdmGMID")]);
		SetPlayerArmour(GetPVarInt(playerid,"AdmGMID"), AdmGMArm[playerid]);
		AdmGMArm[playerid] = 0;
		SetPlayerHealth(GetPVarInt(playerid,"AdmGMID"), AdmGMHP[GetPVarInt(playerid,"AdmGMID")]);
		SetPVarInt(GetPVarInt(playerid,"AdmGMID"), "AdmGM", 0);
		AdmGMHP[GetPVarInt(playerid,"AdmGMID")] = 0;
		SetPVarInt(playerid, "AdmGMID", INVALID_PLAYER_ID);
	}
	else if((AdmGMHP[GetPVarInt(playerid,"AdmGMID")]-nowhealth[GetPVarInt(playerid,"AdmGMID")]) == 0)
	{
		format(string, sizeof(string), "До: \t\t\t%.0f.0 HP\nПосле: \t\t%.0f.0 HP\nHP не уменьшилось\n\n{CD5A5A}Возможно этот игрок использует ГМ.",AdmGMHP[GetPVarInt(playerid,"AdmGMID")],nowhealth[GetPVarInt(playerid,"AdmGMID")]);
		ShowPlayerDialog(playerid,888,DIALOG_STYLE_MSGBOX  , "Проверка God Mode",string, "Закрыть", "");
		SetPVarInt(GetPVarInt(playerid,"AdmGMID"), "AdmGM", 0);
		AdmGMArm[playerid] = 0;
		AdmGMHP[GetPVarInt(playerid,"AdmGMID")] = 0;
		SetPVarInt(playerid, "AdmGMID", INVALID_PLAYER_ID);
	}
	KillTimer(GMTestTimer[playerid]);
	return true;
}
public OnVehicleSpawn(vehicleid)
{
	PlayerInCar[vehicleid] = 0;
	Fuell[vehicleid] = 50;
	PlayerForeach(i)
	{
		if(vehicleid == caridhouse[i])
		{
			AddVehicleComponent (caridhouse[i], PlayerInfo[i][pKolesocar]);
			AddVehicleComponent (caridhouse[i], PlayerInfo[i][pNitro]);
			AddVehicleComponent (caridhouse[i], PlayerInfo[i][pGidra]);
			if(PJ(caridhouse[i]))
			{
				ChangeVehiclePaintjob(caridhouse[i], PlayerInfo[i][pPokraska]);
				AddVehicleComponent (caridhouse[i], PlayerInfo[i][pSpoiler]);
				AddVehicleComponent (caridhouse[i], PlayerInfo[i][pHood]);
				AddVehicleComponent (caridhouse[i], PlayerInfo[i][pExhaust]);
				AddVehicleComponent (caridhouse[i], PlayerInfo[i][pLamps]);
				AddVehicleComponent (caridhouse[i], PlayerInfo[i][pSideskirt]);
				AddVehicleComponent (caridhouse[i], PlayerInfo[i][pVozdyx]);
				AddVehicleComponent (caridhouse[i], PlayerInfo[i][pBamper1]);
				AddVehicleComponent (caridhouse[i], PlayerInfo[i][pBamper2]);
			}
		}
	}
	return true;
}
publics: OnPlayerRegCheck(playerid)
{
	new rows, fields,bac[512];
	SetPlayerFacingAngle(playerid, 180.7816);
	SetPlayerPos(playerid, 1609.1125,-1903.1948,19.3657);
	InterpolateCameraPos(playerid, 1604.906616, -1986.163452, 50.145294, 1848.423950, -1840.502441, 40.976726, 20000);
	InterpolateCameraLookAt(playerid, 1609.136718, -1983.563598, 49.555946, 1844.970336, -1843.971801, 39.958724, 20000);
	cache_get_data(rows, fields);
	if(rows)
	{
		format(bac, sizeof(bac), AutorizeAccount, PlayerInfo[playerid][pName]);
		ShowPlayerDialog(playerid, dAutorizePlayer, DIALOG_STYLE_PASSWORD,"Авторизация",bac,"Вход","");
	}
	else
	{
		format(bac, sizeof(bac), RegAccount, PlayerInfo[playerid][pName]);
		ShowPlayerDialog(playerid, dRegPlayer, DIALOG_STYLE_INPUT,"Регистрация",bac,"Далее","Скрыть");
	}
	return true;
}

stock OnPlayerRegister(playerid, password[])
{
	new bac[512];
	mysql_format(dbHandle,QUERY,sizeof(QUERY),"INSERT INTO `"TABLE_ACCOUNT"` (`Name`, `pKey`) VALUES ('%s', '%e')", PlayerInfo[playerid][pName], password);
	mysql_function_query(dbHandle, QUERY, false, "","");
	format(bac, sizeof(bac), AutorizeAccount, PlayerInfo[playerid][pName]);
	ShowPlayerDialog(playerid, dAutorizePlayer, DIALOG_STYLE_PASSWORD, "Авторизация", bac, "Вход", "");
	return true;
}

stock OnPlayerUpdateRL(playerid)
{
	if(gPlayerLogged[playerid] == 1 && IsPlayerConnected(playerid))
	{
		if(saveplayer[playerid] != 0) return true;
		saveplayer[playerid] = 5;
		new sendername[24];
		GetPlayerName(playerid,sendername,24);
		new str[2048];
		format(str,sizeof(str),"UPDATE `"TABLE_ACCOUNT"` SET `pLevel` = '%d',`pPhousekey` = '%d',`pPbiskey` = '%d',`pPsbiskey` = '%d',`pAdmin` = '%d',`pFuelcar` = '%f',`pHeadValue` = '%d',`pContract` = '%d',`pCar` = '%d',`pHelper` = '%d', ",
		PlayerInfo[playerid][pLevel],
		PlayerInfo[playerid][pPhousekey],PlayerInfo[playerid][pPbiskey],
		PlayerInfo[playerid][pPsbiskey],PlayerInfo[playerid][pAdmin],
		PlayerInfo[playerid][pFuelcar],
		PlayerInfo[playerid][pHeadValue],PlayerInfo[playerid][pContract],
		PlayerInfo[playerid][pCar], PlayerInfo[playerid][pHelper]);

		format(str,sizeof(str),"%s `pDonatemoney2` = '%d', `pDonateAdd` = '%d', `pPodarok` = '%d', `pDonateRank` = '%d',`pDonateRankTime` = '%d',`pReg` = '%d',`pSex` = '%d',`pMuted` = '%d',`pExp` = '%d',`pCash` = '%d',`pJailed` = '%d',`pJailTime` = '%d',`pMats` = '%d',`pDrugs` = '%d',`pLeader` = '%d',`pMember` = '%d', ",str,
		PlayerInfo[playerid][pDonatemoney2],PlayerInfo[playerid][pDonateAdd], PlayerInfo[playerid][pPodarok],
		PlayerInfo[playerid][pDonateRank],PlayerInfo[playerid][pDonateRankTime],
		PlayerInfo[playerid][pReg],PlayerInfo[playerid][pSex],
		PlayerInfo[playerid][pMuted],PlayerInfo[playerid][pExp],
		PlayerInfo[playerid][pCash],
		PlayerInfo[playerid][pJailed],PlayerInfo[playerid][pJailTime],
		PlayerInfo[playerid][pMats],PlayerInfo[playerid][pDrugs],
		PlayerInfo[playerid][pLeader],PlayerInfo[playerid][pMember]);

		format(str,sizeof(str),"%s `pRank` = '%d',`pJob` = '%d',`pVodPrava` = '%d',`pBizLic` = '%d',`pFlyLic` = '%d',`pBoatLic` = '%d',`pFishLic` = '%d',`pGunLic` = '%d', ",str,
		PlayerInfo[playerid][pRank],PlayerInfo[playerid][pJob],
		PlayerInfo[playerid][pVodPrava],PlayerInfo[playerid][pBizLic],
		PlayerInfo[playerid][pFlyLic],PlayerInfo[playerid][pBoatLic],
		PlayerInfo[playerid][pFishLic],PlayerInfo[playerid][pGunLic]);

		format(str,sizeof(str),"%s `pSDPistol` = '%d',`pDesertEagle` = '%d',`pShotGun` = '%d',`pMP5` = '%d',`pAK47` = '%d',`pM4` = '%d',`pChar` = '%d',`pModel` = '%d', `pBankPass` = '%d', `pBankKart` = '%d', ",str,
		PlayerInfo[playerid][pSDPistol],
		PlayerInfo[playerid][pDesertEagle],PlayerInfo[playerid][pShotGun],
		PlayerInfo[playerid][pMP5],PlayerInfo[playerid][pAK47],
		PlayerInfo[playerid][pM4],PlayerInfo[playerid][pChar],
		PlayerInfo[playerid][pModel], PlayerInfo[playerid][pBankPass], PlayerInfo[playerid][pBankKart]);

		format(str,sizeof(str),"%s `pPnumber` = '%d',`pPayDayHad` = '%d',`pWarns` = '%d',`punWarns` = '%d',`punWarnstime` = '%d',`pFuel` = '%d',`pRobTime` = '%d',`pExitTied` = '%d',`pExitTiedNomer` = '%d',`pGrabSkill` = '%d',`pGrabTime` = '%d',`pReportTime` = '%d',`pVerevka` = '%d',`pOtmbI4ka` = '%d',`pAutoTime` = '%d', ",str,
		PlayerInfo[playerid][pPnumber],PlayerInfo[playerid][pPayDayHad],
		PlayerInfo[playerid][pWarns],PlayerInfo[playerid][punWarns],
		PlayerInfo[playerid][punWarnstime],PlayerInfo[playerid][pFuel],
		PlayerInfo[playerid][pRobTime],PlayerInfo[playerid][pExitTied],
		PlayerInfo[playerid][pExitTiedNomer],PlayerInfo[playerid][pGrabSkill],
		PlayerInfo[playerid][pGrabTime],PlayerInfo[playerid][pReportTime],
		PlayerInfo[playerid][pVerevka],
		PlayerInfo[playerid][pOtmbI4ka],PlayerInfo[playerid][pAutoTime]);

		format(str,sizeof(str),"%s `pAutoSkill` = '%d',`pMarried` = '%d',`pMuteTime` = '%d',`pMobile` = '%d',`pBank` = '%d',`pLocked2` = '%d',`pBoxSkill` = '%d',`pKongfuSkill` = '%d',`pKickboxSkill` = '%d',`pFightSkill` = '%d',`pFightSkil` = '%d',`pFightTime` = '%d',`pHospital` = '%d' = '%d',`pDostup` = '%d',`pZakonp` = '%d', ",str,
		PlayerInfo[playerid][pAutoSkill],PlayerInfo[playerid][pMarried],
		PlayerInfo[playerid][pMuteTime],PlayerInfo[playerid][pMobile],
		PlayerInfo[playerid][pBank],PlayerInfo[playerid][pLocked2],
		PlayerInfo[playerid][pBoxSkill],PlayerInfo[playerid][pKongfuSkill],
		PlayerInfo[playerid][pKickboxSkill],PlayerInfo[playerid][pFightSkill],
		PlayerInfo[playerid][pFightSkil],PlayerInfo[playerid][pFightTime],
		PlayerInfo[playerid][pDostup],PlayerInfo[playerid][pZakonp]);

		format(str,sizeof(str),"%s `pBanTime1` = '%d',`pBanData1` = '%d',`pVipTime` = '%d',`pHouse` = '%d',`pVipData` = '%d',`pBanKol` = '%d',`pNarcoLomka` = '%d',`pProz` = '%d',`pKolesocar` = '%d',`pPokraska` = '%d',`pSpoiler` = '%d',`pHood` = '%d',`pExhaust` = '%d',`pLamps` = '%d',`pSideskirt` = '%d',`pVozdyx` = '%d',`pVcol1` = '%d',`pVcol2` = '%d',`pBamper1` = '%d',`pBamper2` = '%d', ",str,
		PlayerInfo[playerid][pBanTime1],PlayerInfo[playerid][pBanData1],
		PlayerInfo[playerid][pVipTime],PlayerInfo[playerid][pHouse],
		PlayerInfo[playerid][pVipData],PlayerInfo[playerid][pBanKol],
		PlayerInfo[playerid][pNarcoLomka],PlayerInfo[playerid][pProz],
		PlayerInfo[playerid][pKolesocar],PlayerInfo[playerid][pPokraska],
		PlayerInfo[playerid][pSpoiler],PlayerInfo[playerid][pHood],
		PlayerInfo[playerid][pExhaust],PlayerInfo[playerid][pLamps],
		PlayerInfo[playerid][pSideskirt],PlayerInfo[playerid][pVozdyx],
		PlayerInfo[playerid][pVcol1],PlayerInfo[playerid][pVcol2],
		PlayerInfo[playerid][pBamper1],PlayerInfo[playerid][pBamper2]);

		format(str,sizeof(str),"%s `pNitro` = '%d',`pGidra` = '%d',`pMestoJail` = '%d',`pWanted` = '%d',`pHousecash` = '%d',`pTut` = '%d',`pNumbercar` = '%s',`pIpReg` = '%s' WHERE `Name` = '%s'",str,
		PlayerInfo[playerid][pNitro],PlayerInfo[playerid][pGidra],PlayerInfo[playerid][pMestoJail],
		PlayerInfo[playerid][pWanted],PlayerInfo[playerid][pHousecash],
		PlayerInfo[playerid][pTut],PlayerInfo[playerid][pNumbercar],
		PlayerInfo[playerid][pIpReg],sendername);
		mysql_function_query(dbHandle, str, false, "", "");
		printf("Аккаунт %s был успешно сохранён.(%d)",sendername,strlen(str));
	}
	else printf("[ERROR] Ошибка сохранёния.");
	return 1;
}

stock OnPlayerLogin(playerid, password[])
{
	new sendername[24];
	GetPlayerName(playerid,sendername,24);
	mysql_format(dbHandle,QUERY,sizeof(QUERY),"SELECT * FROM `"TABLE_ACCOUNT"` WHERE `Name` = '%s' AND `pKey` = '%e'", sendername, password);
	mysql_function_query(dbHandle, QUERY, true, "LoginCallback","ds", playerid, password);
	return true;
}
publics: OffWarn(playerid,tmp[])
{
	new rows, fields;
	cache_get_data(rows, fields);
	if(!rows) return SendMes(playerid, COLOR_GREY, "[ MySql ] Аккаунт %s не найден в базе данных.",tmp);
	mysql_format(dbHandle, QUERY, sizeof(QUERY), "UPDATE `"TABLE_ACCOUNT"` SET `pWarns` = '1', `pLeader` = '0', `pMember` = '0', `pRank` = '0' WHERE `Name` = '%s'", tmp);
	mysql_function_query(dbHandle, QUERY, false, "", "");
	format(stringer1, sizeof(stringer1), "OffWarn [заварнил: %s] [заварнен: %s]",PlayerInfo[playerid][pName],tmp);
	SendAdminMessage(COLOR_LIGHTRED,stringer1);
	return true;
}
publics: OnLeaderPanel(playerid)
{
	new rows, fields;
	cache_get_data(rows, fields);
	if(rows)
	{
		new string[1000],Names[MAX_PLAYER_NAME],str[24],full;
		while(--rows >= 0)
		{
			cache_get_field_content(rows,"Name",Names);
			if(cache_get_field_content_int(rows, "pOnline", dbHandle) == 1001) format(str,sizeof(str),"%s\n",Names), strcat(string,str), full++;
		}
		if(full == 0) SendClientMessage(playerid,-1,"Не найдено совпадений!");
		else ShowPlayerDialog(playerid,9485,DIALOG_STYLE_LIST,"Меню лидера",string,"OK","");
	}
	return true;
}
publics: Delete(playerid,tmp[])
{
	new rows, fields,strban[144],mysql_querka[128];
	cache_get_data(rows, fields);
	if(!rows) return SendMes(playerid, COLOR_GREY, "[ MySql ] Аккаунт %s не найден в Базе данных.",tmp);
	if(IsPlayerConnected(GetPlayerID(tmp)))
	{
		SendClientMessage(GetPlayerID(tmp), COLOR_LIGHTRED,"Ваш аккаунт был удален за нарушение правил сервера!");
		GKick(GetPlayerID(tmp));
	}
	mysql_format(dbHandle, mysql_querka,sizeof(mysql_querka),"DELETE FROM `"TABLE_ACCOUNT"` WHERE `Name` = '%s'",tmp);
	mysql_function_query(dbHandle, mysql_querka, false, "", "");
	format(strban, sizeof(strban), "[DELETE] Администратор %s удалил аккаунт %s.",PlayerInfo[playerid][pName], tmp);
	SendAdminMessage(COLOR_LIGHTRED, strban);
	return true;
}
publics: UnBan(playerid,tmp[])
{
	new rows, fields,tmp1[2];
	cache_get_data(rows, fields);
	if(!rows) return SendMes(playerid, COLOR_GREY, "MySql: Аккаунт %s не найден в базе данных.",tmp);
	cache_get_field_content(0, "pBanKol", tmp1);
	mysql_format(dbHandle, QUERY, sizeof(QUERY), "UPDATE `"TABLE_ACCOUNT"` SET `pLocked2` = '0',`pBanData1` = '0', `pBanTime1` = '0', `pBanKol` = '%d' WHERE `Name` = '%s'",strval(tmp)-1,tmp);
	mysql_function_query(dbHandle, QUERY, false, "", "");
	format(stringer1, sizeof(stringer1), "[UNBAN] {FFFFFF}Администратор {FF6347}%s {FFFFFF}разбанил {FF6347}%s.",PlayerInfo[playerid][pName],tmp);
	SendAdminMessage(COLOR_LIGHTRED,stringer1);
	return true;
}
publics: OffAdmin(playerid,tmp[])
{
	new rows, fields;
	cache_get_data(rows, fields);
	if(!rows) return SendMes(playerid, COLOR_GREY, "MySql: Аккаунт %s не найден в базе данных.",tmp);
	mysql_format(dbHandle, QUERY, sizeof(QUERY), "UPDATE `"TABLE_ACCOUNT"` SET `pAdmin` = '0' WHERE `Name` = '%s'", tmp);
	mysql_function_query(dbHandle, QUERY, false, "", "");
	SendMes(playerid, COLOR_GREY, "MySql: Аккаунт %s был снят с поста администратора.", tmp);
	return true;
}
