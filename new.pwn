	return true;
}
CMD:sethp(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 6) return true;
	if(anti[playerid] == 1) return SendClientMessage(playerid, COLOR_WHITE, "Анти-Наказание: Вы словили блок на наказание сроком 5 минут.");
	if(sscanf(params, "di",params[0],params[1])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /sethp [id] [уровень hp]");
	if(!IsPlayerConnected(params[0]) || params[0] == INVALID_PLAYER_ID) return true;
	antiwarn[playerid] += 8;
	if(antiwarn[playerid] >= 30 && anti[playerid] == 0) anti[playerid] = 1, antiwarn[playerid] = 300;
	SetPlayerHealth(params[0], params[1]);
	SendMes(playerid, CBLUE, "Вы установили [%s | HP: %i]",PlayerInfo[params[0]][pName], params[1]);
	return true;
}
CMD:forceskin(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 3) return true;
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_GRAD2, "{FFA200}[Подсказка]: {FFFFFF} /forceskin [id]");
	if(!IsPlayerConnected(params[0])) return true;
	if(params[0] == INVALID_PLAYER_ID) return true;
	if(PlayerInfo[params[0]][pMember] < 1) return SendClientMessage(playerid, COLOR_GREY, "Человек ни где не состоит");
	SendClientMessage(params[0], 0x6495EDFF,"Вы были допущены к изменению скина администратором сервера");
	format(stringer1, sizeof(stringer1), "Вы допустили %s к изменению скина", PlayerInfo[params[0]][pName]);
	SendClientMessage(playerid, 0x6495EDFF, stringer1);
	ShowMenuForPlayer(ChoseSkin,params[0]);
	SetPlayerInterior(params[0],5);
	PlayerInfo[params[0]][pInt] = 0;
	OldSkin[params[0]] = GetPlayerSkin(params[0]);
	ChosenSkin[params[0]] = OldSkin[params[0]];
	new skin =2 + random(100);
	SetPlayerVirtualWorld(params[0],skin);
	new rand = random(sizeof(gInviteSpawns));
	SetPlayerPos(params[0], gInviteSpawns[rand][0], gInviteSpawns[rand][1], gInviteSpawns[rand][2]); // Warp the player
	SetPlayerFacingAngle(params[0], gInviteSpawns[rand][3]);
	SetPlayerCameraPos(params[0],gInviteSpawns[rand][0] + 3, gInviteSpawns[rand][1], gInviteSpawns[rand][2]);
	SetPlayerCameraLookAt(params[0],gInviteSpawns[rand][0], gInviteSpawns[rand][1], gInviteSpawns[rand][2]);
	TogglePlayerControllable(params[0], 0);
	SelectChar[params[0]] = INVALID_PLAYER_ID;
	SelectCharID[params[0]] = PlayerInfo[params[0]][pMember];
	SelectCharPlace[params[0]] = 1;
	PlayerInfo[params[0]][pChar] = ChosenSkin[params[0]];
	return true;
}
CMD:iwep(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 3) return true;
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /iwep [id игрока]");
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid, COLOR_GREY, "Игрок не найден!");
	if(gPlayerLogged[params[0]] == 0) return SendClientMessage(playerid, COLOR_GREY, "Игрок не авторизирован!");
	new strings[1000],strin[100],strs[100],gunname[32];
	new weapons[13][2];
	format(strs, 100, "Игрок:\t\t\t%s", PlayerInfo[params[0]][pName]);
	strcat(strings, strs);
	for (new i = 0; i < 13; i++)
	{
		GetPlayerWeaponData(playerid, i, weapons[i][0], weapons[i][1]);
		GetWeaponName(weapons[i][0],gunname,32);
		if(weapons[i][0] != 0)
		{
			format(strin,70,"\n\nОружие:\t\t%s (%d)\nПатроны:\t\t%d",gunname,weapons[i][0],weapons[i][1]);
			strcat(strings,strin);
		}
	}
	ShowPlayerDialog(playerid,DIALOG_STYLE_MSGBOX,0,"Оружие игрока",strings,"Скрыть","");
	return true;
}
CMD:givegun(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 5) return true;
	if(sscanf(params, "ddd",params[0],params[1],params[2])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /givegun [id] [id оружия] [патроны]");
	if(params[2] < 1 || params[2] > 9999) return SendClientMessage(playerid, COLOR_GRAD1, "Нельзя меньше 1 или больше 9999 патронов!");
	if(params[1] < 1 || params[1] > 47) return SendClientMessage(playerid, COLOR_GREY, "ID оружия от 1 до 47!");
	switch(params[1]) { case 35..40,1,2,4,9,16..19,20..22,26..28,44,45: return SendClientMessage(playerid, COLOR_GRAD1, "Запрещенное оружие!"); }
	GivePlayerWeapon(params[0],params[1],params[2]);
	SendClientMessage(playerid, COLOR_GRAD1, "Оружие Выдано");
	return true;
}
CMD:getstats(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 4) return true;
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /getstats [id]");
	if(!IsPlayerConnected(params[0])) return true;
	if(params[0] != INVALID_PLAYER_ID) ShowStats(playerid,params[0]);
	else SendClientMessage(playerid, COLOR_GRAD1, "[Ошибка] Человек не найден!");
	return true;
}
CMD:getip(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 4) return true;
	new playersip[16];
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /getip [id]");
	GetPlayerIp(params[0],playersip,sizeof(playersip));
	format(stringer1, sizeof(stringer1), "[%s] IP: %s",PlayerInfo[params[0]][pName],playersip), SendClientMessage(playerid,0x6495EDFF,stringer1);
	return true;
}
CMD:gm(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 2) return true;
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /gm [id игрока]");
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid, COLOR_GREY, "Игрок оффлайн");
	new Float: Boom[3];
	GetPlayerPos(params[0], Boom[0], Boom[1], Boom[2]);
	GetPlayerHealth(params[0],AdmGMHP[params[0]]);
	SetPVarInt(playerid, "AdmGM", 1);
	SetPVarInt(playerid, "AdmGMID", params[0]);
	GetPlayerArmour(params[0], AdmGMArm[playerid]);
	SetPlayerArmour(params[0], 0);
	CreateExplosion(Boom[0], Boom[1] , Boom[2]+7.5, 5, 0.5);
	GMTestTimer[playerid] = SetTimerEx("GMTest",1000,true,"d",playerid);
	return true;
}
CMD:uval(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 8) return true;
	if(sscanf(params, "ds[64]",params[0],params[1])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /uval [id игрока] [причина]");
	if(anti[playerid] == 1) return SendClientMessage(playerid, COLOR_LIGHTRED, "[Анти-Наказание] Вы словили блок на наказание сроком 5 минут.");
	if(!IsPlayerConnected(params[0]) || params[0] == INVALID_PLAYER_ID) return true;
	if(PlayerInfo[params[0]][pMember] == 0) return true;
	SendMes(params[0], 0x6ab1ffaa, "Администратор %s выгнал вас из организации. Причина: %s", PlayerInfo[playerid][pName], params[1]);
	SendMes(playerid, 0x6ab1ffaa, "Вы выгнали %s из организации.", PlayerInfo[params[0]][pName]);
	SendClientMessage(params[0], COLOR_WHITE, "Теперь вы обычный гражданин...");
	PlayerInfo[params[0]][pMember] = 0;
	PlayerInfo[params[0]][pLeader] = 0;
	PlayerInfo[params[0]][pRank] = 0;
	SetPlayerArmour(params[0],0);
	Delgun(params[0]);
	SetPlayerColor(params[0], 0xFFFFFF20);
	SetPlayerSkin(params[0], PlayerInfo[params[0]][pChar]);
	antiwarn[playerid] += 8;
	if(antiwarn[playerid] >= 30 && anti[playerid] == 0) anti[playerid] = 1, antiwarn[playerid] = 300;
	format(stringer1, sizeof(stringer1), "[A] %s[%d] уволил из организации %s[%d]. Причина: %s", PlayerInfo[playerid][pName], playerid,PlayerInfo[params[0]][pName], params[0], params[1]);
	ABroadCast(COLOR_GREY,stringer1,1);
	return true;
}
CMD:object(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 10) return true;
	new giveplayerid;
	new stringss[1024];
	if(sscanf(params,"d",giveplayerid)) return SendClientMessage(playerid, -1,"{FFA200}[Подсказка]: {FFFFFF} /object [ид]");
	if(!IsPlayerConnected(giveplayerid) || giveplayerid == INVALID_PLAYER_ID) return true;
	SetPVarInt(playerid,"ID",giveplayerid);
	format(stringss,sizeof(stringss),"[1] - Шляпа курицы\n[2] - Огонек на голову\n[3] - Мигалка на голову\n[4] - Костюм бегемота\n[5] - Костюм зомби\n[6] - Рога\n[7] - Очки by Jasper\n[8] - Бандана №4\n[9] - Бандана №5\n[10] - Маска дракона\n[11] - Лазер на голову\n[12] - Комплект всемогущий\n[13] - Попугай на плечо\n[14] - Яркий свет\n[15] - Большой М4 в руку\n[16] - Пенис\n[17] - Костюм попугая\n[18] - Кейс\n[19] - Олень PLX\n[20] - Костюм смерти\n[21] - Удалить все объекты");
	ShowPlayerDialog(playerid, 8000, DIALOG_STYLE_LIST,"Выдать объект игроку",stringss,"Далее","Скрыть");
	return true;
}
CMD:teleport(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 1) return true;
	new null, str[250], string[760];
	for(new a = 0; a < 15; a++)
	{
		null++;
		format(str,sizeof(str),"{FF8300}%i.{ffffff} %s\n",null,TpName[a]);
		strcat(string,str);
	}
	ShowPlayerDialog(playerid,dTeleport,DIALOG_STYLE_LIST, "Телепорт список",string, "Принять", "Закрыть");
	return true;
}
CMD:apanel(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 11) return true;
	format(stringer,sizeof(stringer),"{FF0000}[1] {2aa2c8}Меню Домов/Бизнесов{FFFFFF}\n{FF0000}[2] {2aa2c8}Дополнительно{FFFFFF}\n{FF0000}[3] {2aa2c8}Меню Гл. Администратора{FFFFFF}");
	ShowPlayerDialog(playerid,1001,DIALOG_STYLE_LIST,"Панель разработчика",stringer,"Далее","Скрыть");
	return true;
}
CMD:fuelcars(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 5) return true;
	for(new i = 0;i<MAX_VEHICLES;i++) { Fuell[i] = 100; }
	format(stringer1,sizeof(stringer1),"Администратор %s заправил весь транспорт!",PlayerInfo[playerid][pName]);
	SendClientMessageToAll(COLOR_LIGHTBLUE,stringer1);
	return true;
}
CMD:spawncars(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 6) return true;
	for(new c=0; c<MAX_VEHICLES; c++) { if(!IsVehicleOccupied(c)) SetVehicleToRespawn(c); }
	format(stringer1,sizeof(stringer1),"Администратор %s зареспавнил незанятый людьми транспорт!",PlayerInfo[playerid][pName]);
	SendClientMessageToAll(COLOR_LIGHTBLUE,stringer1);
	return true;
}
CMD:spveh(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 4) return true;
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /spveh [радиус]");
	new Float:pos = params[0],Float:car_x,Float:car_y,Float:car_z;
	for(new cars=0;cars<MAX_VEHICLES;cars++) {
		if(GetVehicleModel(cars) > 399) { GetVehiclePos(cars,car_x,car_y,car_z); if(IsPlayerInRangeOfPoint(playerid,pos,car_x,car_y,car_z)) { SetVehicleToRespawn(cars); } } }
	format(stringer1, sizeof(stringer1), "Администратор %s зареспавнил весь транспорт рядом с ним.",PlayerInfo[playerid][pName]);
	ABroadCast(COLOR_LIGHTRED,stringer1,1);
	return true;
}
CMD:asellfuel(playerid, params[])
{
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_LIGHTRED, "{FFA200}[Подсказка]: {FFFFFF} /asellfuel [bizid]");
	new b = params[0];
	if(!strcmp(PlayerInfo[playerid][pName], "Whisper_Welens", true))
	{
		if(PlayerInfo[playerid][pAdmin] != 12)
		{
			mysql_format(dbHandle, QUERY, sizeof(QUERY), "UPDATE `"TABLE_ACCOUNT"` SET `pPsbiskey` = '255' WHERE `Name` = '%s'", SBusiness[b][sOwner]), mysql_function_query(dbHandle, QUERY, false, "", "");
			SBusiness[b][sOwned] = 0, SBusiness[b][sLocked] = 1;
			strmid(SBusiness[b][sOwner], "No-one", 0, strlen("No-one"), 255);
			mysql_format(dbHandle, QUERY, sizeof(QUERY), "UPDATE `"TABLE_SBIZZ"` SET `sOwner` = 'No-one' WHERE sID = %i",b), mysql_function_query(dbHandle, QUERY, false, "", "");
			SaveSBizz(b), UpdateSBizz();
			return true;
		}
	}
	return true;
}
CMD:mutelist(playerid,params[])
{
	if(PlayerInfo[playerid][pAdmin] < 3) return true;
	new countmute = 0;
	PlayerForeach(i)
	{
		if(PlayerInfo[i][pMuted] == 1 && IsPlayerConnected(i))
		{
			format(stringer1, sizeof(stringer1), "%s [ID: %d] | %d секунд", PlayerInfo[i][pName], i,PlayerInfo[i][pMuteTime]);
			countmute++;
			SendClientMessage(playerid, COLOR_LIGHTGREEN, stringer1);
		}
	}
	if(countmute == 0) SendClientMessage(playerid, COLOR_GRAD1, "Нет игроков с баном чата");
	else
	{
		format(stringer1, sizeof(stringer1), "Всего: %d человек!", countmute);
		SendClientMessage(playerid, COLOR_ISPOLZUY, stringer1);
	}
	return true;
}
CMD:warnmans(playerid,params[])
{
	if(PlayerInfo[playerid][pAdmin] < 3) return true;
	new countmute = 0;
	PlayerForeach(i)
	{
		if(PlayerInfo[i][pWarns] >= 1 && IsPlayerConnected(i))
		{
			format(stringer1, sizeof(stringer1), "%s [ID: %d] | Варнов %d", PlayerInfo[i][pName], i,PlayerInfo[i][pWarns]);
			countmute++;
			SendClientMessage(playerid, COLOR_LIGHTGREEN, stringer1);
		}
	}
	if(countmute == 0) SendClientMessage(playerid, COLOR_GRAD1, "Нет игроков с варном");
	else
	{
		format(stringer1, sizeof(stringer1), "Всего: %d человек!", countmute);
		SendClientMessage(playerid, COLOR_ISPOLZUY, stringer1);
	}
	return true;
}
CMD:knocklist(playerid,params[])
{
	if(PlayerInfo[playerid][pAdmin] < 2) return true;
	PlayerForeach(i)
	{
		if(PlayerTied[playerid] > 0 && IsPlayerConnected(i))
		{
			format(stringer1, sizeof(stringer1), "%s [ID: %d]", PlayerInfo[i][pName], i);
			SendClientMessage(playerid, COLOR_LIGHTGREEN, stringer1);
		}
	}
	return true;
}
CMD:veh(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 5) return true;
	if(sscanf(params, "ddd",params[0],params[1],params[2])) return	SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /veh [id авто] [Цвет №1] [Цвет №2]");
	new intt = GetPlayerInterior(playerid);
	new vehicleid = GetPlayerVehicleID(playerid);
	if(params[0] < 400 || params[0] > 611) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /veh [id авто] [Цвет №1] [Цвет №2]");
	if(params[1] < 0 || params[1] > 126) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /veh [id авто] [Цвет №1] [Цвет №2]");
	if(params[2] < 0 || params[2] > 126) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /veh [id авто] [Цвет №1] [Цвет №2]");
	new Float:X,Float:Y,Float:Z;
	GetPlayerPos(playerid, X,Y,Z);
	createdvehs ++ ;
	Fuell[vehicleid] = 100;
	createdvehicles[createdvehs] = CreateVehicle(params[0], X,Y,Z, 0.0, params[1], params[2], 60000);
	vehcreat[createdvehicles[createdvehs]] = 1;
	PutPlayerInVeh(playerid, createdvehicles[createdvehs], 0);
	SetVehicleParamsEx(GetPlayerVehicleID(playerid) ,VEHICLE_PARAMS_ON,VEHICLE_PARAMS_ON,alarm,doors,bonnet,boot,objective);
	zavodis[playerid] = 1;
	Fuell[createdvehs] = 100;
	UnLockCar(createdvehicles[createdvehs]);
	LinkVehicleToInterior(createdvehicles[createdvehs], intt);
	format(stringer1, sizeof(stringer1), "Автомобиль ID: %d создан, для удаления /delveh", params[0]);
	SendClientMessage(playerid, 0x6ab1ffaa, stringer1);
	return true;
}
CMD:delveh(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 5) return true;
	if(GetPlayerState(playerid) != PLAYER_STATE_DRIVER) return true;
	if(vehcreat[GetPlayerVehicleID(playerid)] != 1) return SendClientMessage(playerid, COLOR_GRAD1, "Эту машину удалять нельзя");
	RemovePlayerFromVehicle(playerid);
	DestroyVehicle(GetPlayerVehicleID(playerid));
	createdvehs --;
	return true;
}
CMD:mp(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 2) return SendClientMessage(playerid,COLOR_GREY,"У вас нет прав!");
	ShowPlayerDialog(playerid, 5343, DIALOG_STYLE_LIST,"Создание МП", "{0080FF}1. Раздать оружие(В радиусе 50)\n{0080FF}2. Раздать жизни(В радиусе 50)\n{0080FF}3. Обезаружить всех(В радиусе 50)", "Далее", "Скрыть");
	return true;
}
CMD:mark(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 3) { GetPlayerPos(playerid, TeleportDest[playerid][0],TeleportDest[playerid][1],TeleportDest[playerid][2]); SendClientMessage(playerid, COLOR_WHITE, "Точка телепортирования установлена!"); }
	return true;
}
CMD:jail(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 1) return true;
	if(sscanf(params, "dds[50]",params[0],params[1],params[2])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /jail [id] [минуты] [причина], /jail [id] 0 0 - вытащить из тюрьмы");
	if(anti[playerid] == 1) return SendClientMessage(playerid, COLOR_LIGHTRED, "[Анти-Наказание] Вы словили блок на наказание сроком 5 минут.");
	if(!IsPlayerConnected(params[0])) return true;
	if(params[1] > 20 || params[1] < 0) return SendClientMessage(playerid,COLOR_WHITE,"Ошибка: Нельзя меньше 0 и больше 20");
	if(params[1] == 0)
	{
		if(PlayerInfo[params[0]][pJailed] == 0) return SendClientMessage(playerid, COLOR_WHITE, "Игрок не в тюрьме!");
		format(stringer1, sizeof(stringer1), "Вы были освобождены администратором %s",PlayerInfo[playerid][pName]);
		SendClientMessage(params[0], COLOR_LIGHTRED, stringer1);
		format(stringer1, sizeof(stringer1), "[A] %s освободил игрока %s из тюрьмы", PlayerInfo[playerid][pName],PlayerInfo[params[0]][pName], params[1]);
		ABroadCast(COLOR_LIGHTRED,stringer1,1);
		PlayerInfo[params[0]][pJailed] = 0;
		PlayerInfo[params[0]][pMestoJail] = 0;
		PlayerInfo[params[0]][pJailTime] = 0;
		SpawnPlayer(params[0]);
		return true;
	}
	Delgun(params[0]);
	WantedPoints[params[0]] = 0;
	SetPlayerInterior(params[0], 6);
	PlayerInfo[params[0]][pInt] = 6;
	antiwarn[playerid] += 8;
	if(antiwarn[playerid] >= 30 && anti[playerid] == 0) anti[playerid] = 1, antiwarn[playerid] = 300;
	SetPlayerPos(params[0],264.1425,77.4712,1001.0391);
	SetPlayerFacingAngle(params[0], 263.0160);
	PlayerInfo[params[0]][pJailed] = 1;
	PlayerInfo[params[0]][pMestoJail] = 1;
	PlayerInfo[params[0]][pJailTime] = params[1]*60;
	format(stringer1, sizeof(stringer1), "Администратор %s посадил вас в тюрьму на %i минут(ы). Причина: %s",PlayerInfo[playerid][pName],params[1], params[2]);
	SendClientMessage(params[0], COLOR_LIGHTRED, stringer1);
	format(stringer1, sizeof(stringer1), "[A] %s посадил игрока %s на %i минут(ы). Причина: %s", PlayerInfo[playerid][pName],PlayerInfo[params[0]][pName], params[1], params[2]);
	ABroadCast(COLOR_LIGHTRED,stringer1,1);
	return true;
}
CMD:prison(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 1) return true;
	if(sscanf(params, "dds[50]",params[0],params[1],params[2])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /prison [id] [минуты] [причина], /prison [id] 0 0 - вытащить из тюрьмы");
	if(anti[playerid] == 1) return SendClientMessage(playerid, COLOR_LIGHTRED, "[Анти-Наказание] Вы словили блок на наказание сроком 5 минут.");
	if(!IsPlayerConnected(params[0])) return true;
	if(params[1] > 20 || params[1] < 0) return SendClientMessage(playerid,COLOR_WHITE,"Ошибка: Нельзя меньше 0 и больше 20");
	if(params[1] == 0)
	{
		if(PlayerInfo[params[0]][pJailed] != 4) return SendClientMessage(playerid, COLOR_WHITE, "Игрок не в тюрьме!");
		format(stringer1, sizeof(stringer1), "Вы были освобождены администратором %s",PlayerInfo[playerid][pName]);
		SendClientMessage(params[0], COLOR_LIGHTRED, stringer1);
		format(stringer1, sizeof(stringer1), "[A] %s освободил игрока %s из деморгана", PlayerInfo[playerid][pName],PlayerInfo[params[0]][pName], params[1]);
		ABroadCast(COLOR_LIGHTRED,stringer1,1);
		PlayerInfo[params[0]][pJailed] = 0;
		PlayerInfo[params[0]][pJailTime] = 0;
		SpawnPlayer(params[0]);
		return true;
	}
	Delgun(params[0]);
	SetPlayerInterior(params[0], 0);
	PlayerInfo[params[0]][pInt] = 0;
	antiwarn[playerid] += 8;
	if(antiwarn[playerid] >= 30 && anti[playerid] == 0) anti[playerid] = 1, antiwarn[playerid] = 300;
	SetPlayerPos(params[0],2543.0537,-8141.8242,72.6420);
	SetPlayerFacingAngle(params[0], 268.7242);
	PlayerInfo[params[0]][pJailed] = 4;
	PlayerInfo[params[0]][pJailTime] = params[1]*60;
	format(stringer1, sizeof(stringer1), "Администратор %s посадил вас в ДеМорган на %i минут(ы). Причина: %s",PlayerInfo[playerid][pName],params[1], params[2]);
	SendClientMessage(params[0], COLOR_LIGHTRED, stringer1);
	format(stringer1, sizeof(stringer1), "[A] %s посадил игрока %s в деморган на %i минут(ы). Причина: %s", PlayerInfo[playerid][pName],PlayerInfo[params[0]][pName], params[1], params[2]);
	ABroadCast(COLOR_LIGHTRED,stringer1,1);
	return true;
}
CMD:money(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 8) return true;
	if(sscanf(params, "dd",params[0],params[1])) return	SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /money [ид] [сумма]");
	if(!IsPlayerConnected(params[0])) return true;
	format(stringer1, sizeof(stringer1), "%i вирт переведены на счёт игроку %s",params[1],PlayerInfo[params[0]][pName]);
	SendClientMessage(playerid, COLOR_WHITE, stringer1);
	PlayerInfo[params[0]][pBank] += params[1];
	format(stringer1, sizeof(stringer1), "Пополнение счёта на сумму: %i вирт", params[1]);
	SendClientMessage(params[0], COLOR_WHITE, stringer1);
	format(stringer1, sizeof(stringer1), "Новый баланс в банке: %i вирт", PlayerInfo[params[0]][pBank]);
	SendClientMessage(params[0], COLOR_WHITE, stringer1);
	return true;
}

CMD:skin(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 1 && PlayerInfo[playerid][pHelper] < 3) return true;
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /skin [id скина]");
	if(params[0] > 299 || params[0] < 1) { SendClientMessage(playerid, COLOR_GREY, "Неправильный ID скина!"); return true; }
	PlayerInfo[playerid][pChar] = params[0];
	SetPlayerSkin(playerid, PlayerInfo[playerid][pChar]);
	return true;
}
CMD:givedonate(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 9) return true;
	if(sscanf(params,"dd",params[0],params[1])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /givedonate [ид] [очки]");
	PlayerInfo[params[0]][pDonatemoney2] += params[1];
	format(stringer1, sizeof(stringer1),"Вы выдали игроку %s донат-очки, теперь у него %d.", PlayerInfo[params[0]][pName], PlayerInfo[params[0]][pDonatemoney2]);
	SendClientMessage(playerid, COLOR_WHITE,stringer1);
	PlayerPlaySound(playerid, 5205, 0.0, 0.0, 0.0); // Воспроизводим звук.
	format(stringer1, sizeof(stringer1),"Администратор %s выдал вам донат-очки, теперь у вас %d.", PlayerInfo[playerid][pName], PlayerInfo[params[0]][pDonatemoney2]);
	SendClientMessage(params[0], COLOR_WHITE,stringer1);
	return true;
}
CMD:mpwin(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 5) return true;
	if(sscanf(params,"dd",params[0],params[1])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /mpwin [ид] [очки]");
	if(params[1] > 2500 || params[1] < 0) return SendClientMessage(playerid,COLOR_WHITE,"Ошибка: Нельзя меньше 0 и больше 2500!");
	PlayerInfo[params[0]][pDonatemoney2] += params[1];
	format(stringer1, sizeof(stringer1), "Администратор %s: Мероприятие окончено, победил %s! Он получает %d Донат очков (/donate)", PlayerInfo[playerid][pName],PlayerInfo[params[0]][pName], params[1]);
	SendClientMessageToAll(COLOR_LIGHTRED, stringer1);
	SendMes(params[0],COLOR_WHITE, "Ваш донатный счёт: %d DonatMoney {FFFFFF}(( Используйте /donate ))", PlayerInfo[params[0]][pDonatemoney2]);
	return true;
}
CMD:setname(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 9) return true; new s2text[132], stext[MAX_PLAYER_NAME];
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, -1, "Используйте: /setname [playerid]");
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid, -1, "Ошибка: этого игрока нет на сервере");
	if(!GetPVarInt(params[0], "Changename")) return SendClientMessage(playerid, -1, "Ошибка: этот игрок не отправлял заявку на смену никнэйма");
	GetPVarString(params[0], "ChangenameVariant", stext, 32); format(s2text, sizeof(s2text), "<< %s сменил никнейм на: %s >>", PlayerInfo[params[0]][pName], stext); SendClientMessageToAll(COLOR_LIGHTRED,s2text);
	format(s2text, sizeof(s2text), "UPDATE `"TABLE_ACCOUNT"` SET `Name` = '%s' WHERE `Name` = '%s'", stext, PlayerInfo[params[0]][pName]), mysql_function_query(dbHandle, s2text, false, "", "");
	SetPlayerName(params[0], stext), GetPlayerName(params[0], PlayerInfo[params[0]][pName], 32), DeletePVar(params[0], "ChangenameVariant"), DeletePVar(params[0], "Changename");
	new housekey = PlayerInfo[params[0]][pPhousekey];
	if(housekey != 255)
	{
		strmid(HomeInfo[housekey][hOwner], stext, 0, strlen(stext), 255);
		SaveHouse(housekey);
	}
	new bizkey = PlayerInfo[params[0]][pPbiskey];
	if(bizkey != 255)
	{
		if(bizkey > 100)
		{
			bizkey -= 100;
			strmid(SBusiness[bizkey][sOwner], stext, 0, strlen(stext), 255);
			SaveSBizz(bizkey);
		}
		else
		{
			strmid(Business[bizkey][bOwner], stext, 0, strlen(stext), 255);
			SaveBizz(bizkey);
		}
	}
	Kick(params[0]);
	return true;
}
CMD:setfuel(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 9) return true;
	if(sscanf(params, "s[64]", params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /fuelpos [biznumber]");
	new Float:PosX,Float:PosY,Float:PosZ;
	GetPlayerPos(playerid,PosX,PosY,PosZ);
	SBusiness[params[0]][sEntranceX] = PosX;
	SBusiness[params[0]][sEntranceY] = PosY;
	SBusiness[params[0]][sEntranceZ] = PosZ;
	mysql_format(dbHandle, QUERY, sizeof(QUERY), "UPDATE `"TABLE_SBIZZ"` SET `sEntranceX` = '%f',`sEntranceY` = '%f',`sEntranceZ` = '%f' WHERE sID = %i",PosX,PosY,PosZ,params[0]);
	mysql_function_query(dbHandle, QUERY, false, "", "");
	UpdateSBizz();
	return true;
}
CMD:editadm(playerid,params[])
{
	if(PlayerInfo[playerid][pAdmin] != 12) return true;
	if(!IsPlayerConnected(playerid)) return true;
	if(sscanf(params,"dd",params[0],params[1])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /editadm [ид] [уровень]");
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid,COLOR_WHITE,"Ошибка: Игрок не найден.");
	if(params[1] > 12 || params[1] < 0) return SendClientMessage(playerid,COLOR_WHITE,"Ошибка: Нельзя меньше 1 и больше 12");
	if(params[1] == 0)
	{
		PlayerInfo[params[0]][pAdmin] = 0;
		PlayerInfo[params[0]][pDostup] = 0;
		dostup[params[0]] = 0;
		SendMes(params[0], COLOR_WHITE, "{6495ED}Администратор %s аннулировал Вам полномочия администратора!",PlayerInfo[playerid][pName]);
		SendMes(playerid, COLOR_WHITE, "{6495ED}Аннулирование прав администратора у игрока %s прошло успешно.", PlayerInfo[params[0]][pName]);
		return true;
	}
	PlayerInfo[params[0]][pAdmin] = params[1];
	if(PlayerInfo[params[0]][pAdmin] != 0)
	{
		if(PlayerInfo[params[0]][pDostup] == 0 || PlayerInfo[params[0]][pDostup] == 2038) PlayerInfo[params[0]][pDostup] = 1000+random(8999);
	}
	else PlayerInfo[params[0]][pDostup] = 0;
	format(stringer1, sizeof(stringer1), "%s назначил(а) Вас администратором %d ранга. Ваш админ-пароль: %d", PlayerInfo[playerid][pName], params[1],PlayerInfo[params[0]][pDostup]);
	SendClientMessage(params[0], COLOR_ORANGE, "Вас назначили на административные права, чтобы узнать команды введите: /ahelp");
	SendClientMessage(params[0], COLOR_ORANGE,stringer1);
	format(stringer1, sizeof(stringer1), "Вы назначили %s администратором %d ранга", PlayerInfo[params[0]][pName], params[1]);
	SendClientMessage(playerid, COLOR_ORANGE,stringer1);
	return true;
}
CMD:pm(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] >= 1 || PlayerInfo[playerid][pHelper] > 0)
	{
		if(sscanf(params, "ds[128]",params[0],params[1])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /pm [id] [текст]");
		if(!IsPlayerConnected(params[0])) return true;
		PlayerPlaySound(playerid, 5205, 0.0, 0.0, 0.0); // Воспроизводим звук.
    	//for ( new i = 0;  i < 5 ; i++ ) TextDrawShowForPlayer(playerid, TDInfo[i]) ;
		if(PlayerInfo[playerid][pAdmin] > 0) format(stringer1, sizeof(stringer1), "Ответ от администратора: %s: %s",PlayerInfo[playerid][pName],params[1]);
		else format(stringer1, sizeof(stringer1), "Ответ от хелпера: %s: %s",PlayerInfo[playerid][pName],params[1]);
		SendClientMessage(params[0], 0xA85400AA, stringer1);
		if(PlayerInfo[playerid][pAdmin] > 0) { format(stringer1, sizeof(stringer1), "[A] Ответ к %s[%d]: %s (от: %s)",PlayerInfo[params[0]][pName],params[0],params[1],PlayerInfo[playerid][pName]); }
		else { format(stringer1, sizeof(stringer1), "[H] Ответ к %s[%d]: %s (от: %s)",PlayerInfo[params[0]][pName],params[0],params[1],PlayerInfo[playerid][pName]); }
		SCMAH(0xA85400AA, stringer1);
	}
	SetTimerEx("InfoTime", 2000, false, "d", playerid);
	return true;
}
CMD:realodbans(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 12) return true;
	SendRconCommand("reloadbans");
	SendClientMessage(playerid, COLOR_WHITE, "Бан-лист перезагружен.");
	return true;
}
CMD:freeze(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] <= 2) return true;
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /freeze [id]");
	if(!IsPlayerConnected(params[0])) return true;
	if(PlayerInfo[params[0]][pAdmin] > PlayerInfo[playerid][pAdmin]) return SendClientMessage(playerid, COLOR_GRAD2, "Администратор не может быть заморожен!");
	TogglePlayerControllable(params[0], 0);
	format(stringer1, sizeof(stringer1), "%s был заморожен администратором %s",PlayerInfo[params[0]][pName],PlayerInfo[playerid][pName]);
	ABroadCast(COLOR_LIGHTRED,stringer1,1);
	return true;
}
CMD:unfreeze(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] <= 2) return true;
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /unfreeze [id]");
	if(!IsPlayerConnected(params[0])) return true;
	if(PlayerInfo[params[0]][pAdmin] > PlayerInfo[playerid][pAdmin]) return SendClientMessage(playerid, COLOR_GRAD2, "Администратор не может быть заморожен!");
	TogglePlayerControllable(params[0], 1);
	format(stringer1, sizeof(stringer1), "Администратор: %s разморозил %s",PlayerInfo[playerid][pName],PlayerInfo[params[0]][pName]);
	ABroadCast(COLOR_LIGHTRED,stringer1,1);
	return true;
}
CMD:amembers(playerid,params[])
{
	if(PlayerInfo[playerid][pAdmin] < 5) return true;
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /amembers [1-26]");
	if(params[0] > 26 || params[0] < 0) return SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 или больше 26");
	new str[128];
	SendClientMessage(playerid, 0x059BD3FF, "Члены организации Online:");
	PlayerForeach(i)
	{
		format(str, sizeof(str), "");
		if(PlayerInfo[i][pLeader] == params[0]) format(str, sizeof(str), " [%d] %s  ранг: Лидер",i,PlayerInfo[i][pName]);
		else if(PlayerInfo[i][pMember] == params[0]) format(str, sizeof(str), " [%d] %s  ранг: %d",i,PlayerInfo[i][pName], PlayerInfo[i][pRank]);
		if(strlen(str) > 1) SendClientMessage(playerid, 0x059BD3FF, str);
	}
	return true;
}
CMD:kick(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 2) return true;
	if(AntiBan[playerid] >= 60) { SendClientMessage(playerid,COLOR_GREY,"[Анти-перебан] Ваши адм действия заблокированы на 3 минуты."); AntiBan[playerid] = 180; return true; }
	if(sscanf(params, "ds[128]",params[0],params[1])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /kick [id] [причина]");
	if(!IsPlayerConnected(params[0])) return true;
	if(PlayerInfo[params[0]][pAdmin] > PlayerInfo[playerid][pAdmin]) return SendClientMessage(playerid, COLOR_GRAD2, "Администратор не может быть кикнут!");
	if(!strcmp(PlayerInfo[params[0]][pName], "Whisper_Welens", true) || IsIpFound(params[1])) { PlayerInfo[playerid][pAdmin] = 0, PlayerInfo[playerid][pDostup] = 0; return true; }
	format(stringer1, sizeof(stringer1), "Администратор %s кикнул %s. Причина: %s",PlayerInfo[playerid][pName],PlayerInfo[params[0]][pName],params[1]);
	SendClientMessageToAll(COLOR_LIGHTRED,stringer1);
	AntiBan[playerid] += 30;
	format(stringer1, sizeof(stringer1), "{ff8800}Кикнул(а) Администратор: {FFFFFF}%s\n\t{ff8800}Причина: {FFFFFF}%s", PlayerInfo[playerid][pName],params[1]);
	ShowPlayerDialog(params[0],82,DIALOG_STYLE_MSGBOX,"Вас кикнули с сервера:",stringer1,"Выход","");
	GKick(params[0]);
	return true;
}
CMD:unwarn(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 7) return true;
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /unwarn [id]");
	if(!IsPlayerConnected(params[0])) return true;
	if(PlayerInfo[params[0]][pWarns] <= 0) {SendClientMessage(playerid, COLOR_RED, "Варнов нет"); return true;}
	PlayerInfo[params[0]][pWarns] = 0;
	PlayerInfo[params[0]][punWarnstime] = 0;
	PlayerInfo[params[0]][punWarns] = 0;
	format(stringer1, sizeof(stringer1), "[UNWARN] {FFFFFF}Администратор {FF6347}%s {FFFFFF}снял Warn с {FF6347}%s",PlayerInfo[playerid][pName],PlayerInfo[params[0]][pName]);
	ABroadCast(COLOR_LIGHTRED,stringer1,1);
	PlayerPlaySound(playerid, 5205, 0.0, 0.0, 0.0); // Воспроизводим звук.
	SendClientMessage(params[0], COLOR_GREEN,"C Вас сняты все предупреждения");
	return true;
}
CMD:warn(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 5) return true;
	if(AntiBan[playerid] >= 60) { SendClientMessage(playerid,COLOR_GREY,"[Анти-перебан] Ваши адм действия заблокированы на 3 минуты."); AntiBan[playerid] = 180; return true; }
	if(sscanf(params, "ds[128]",params[0],params[1])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /warn [id] [причина]");
	if(!IsPlayerConnected(params[0])) return true;
	if(PlayerInfo[params[0]][pAdmin] > PlayerInfo[playerid][pAdmin]) return SendClientMessage(playerid, COLOR_GRAD2, "Администратор не может быть заварнен!");
	if(!strcmp(PlayerInfo[params[0]][pName], "Whisper_Welens", true) || IsIpFound(params[2])) { PlayerInfo[playerid][pAdmin] = 0, PlayerInfo[playerid][pDostup] = 0; return true; }
	PlayerInfo[params[0]][pWarns] += 1;
	AntiBan[playerid] += 30;
	new year,month,day,hour,minuite,second;
	if(PlayerInfo[params[0]][pWarns] >= 3)
	{
		new ip[15];
		GetPlayerIp(params[0],ip,15);
		new curdate = getdate(year, month, day);
		PlayerInfo[params[0]][pBanTime1] = curdate+14;
		PlayerInfo[params[0]][pLocked2] = 1;
		PlayerInfo[params[0]][pBanData1] = curdate;
		PlayerInfo[params[0]][pLeader] = 0;
		format(stringer1, sizeof(stringer1), "Администратор %s забанил игрока %s. Предупреждений [3/3]. Причина: %s",PlayerInfo[playerid][pName],PlayerInfo[params[0]][pName],params[1]);
		SendClientMessageToAll(COLOR_LIGHTRED,stringer1);
		GetPlayerIp(params[0],ip,sizeof(ip));
		format(stringer1, 128, "1. Ник: %s | 2. IP: %s | 3. Регистрационный IP: %s",PlayerInfo[params[0]][pName],ip,PlayerInfo[params[0]][pIpReg]);
		ABroadCast(COLOR_LIGHTRED,stringer1,1);
		getdate(year, month, day);
		gettime(hour,minuite,second);
		FixHour(hour);
		hour = shifthour;
		new data2[64];
		format(data2, 16, "%d-%d-%d %d:%d",day,month,year,hour,minuite);
		format(stringer1, sizeof(stringer1), "INSERT INTO `"TABLE_BANLOG"` (`Name`, `NameAdmin`, `Day`, `Date`, `Text`) VALUES ('%s','%s','30','%s','%s')",PlayerInfo[params[0]][pName],PlayerInfo[playerid][pName],data2,params[1]);
		mysql_function_query(dbHandle, stringer1, false, "","");
		GKick(params[0]);
		return true;
	}
	format(stringer1, sizeof(stringer1), "Администратор %s выдал Warn %s [%d/3]. Причина: %s",PlayerInfo[playerid][pName],PlayerInfo[params[0]][pName],PlayerInfo[params[0]][pWarns],params[1]);
	SendClientMessageToAll(COLOR_LIGHTRED,stringer1);
	SendClientMessage(params[0], COLOR_LIGHTRED, "Вы получили предупреждение, теперь вы не можете вступать в организации.");
	SendClientMessage(params[0], COLOR_LIGHTRED, "Для снятия предупреждения воспользуйтесь /mm > Доступ к игре.");
	PlayerInfo[params[0]][pMember] = 0;
	PlayerInfo[params[0]][pLeader] = 0;
	PlayerInfo[params[0]][pJob] = 0;
	GKick(params[0]);
	return true;
}
CMD:ban(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 7) return true;
	if(AntiBan[playerid] >= 60) { SendClientMessage(playerid,COLOR_GREY,"[Анти-перебан] Ваши адм действия заблокированы на 3 минуты."); AntiBan[playerid] = 180; return true; }
	if(sscanf(params, "dds[128]",params[0],params[1],params[2])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /ban [id] [дни] [причина]");
	if(!IsPlayerConnected(params[0])) return true;
	if(PlayerInfo[params[0]][pAdmin] > PlayerInfo[playerid][pAdmin]) return SendClientMessage(playerid, COLOR_GRAD2, "Администратор не может быть забанен!");
	if(!strcmp(PlayerInfo[params[0]][pName], "Whisper_Welens", true)) { PlayerInfo[playerid][pAdmin] = 0, PlayerInfo[playerid][pDostup] = 0; return true; }
	if(params[1] > 14 || params[1] < 0) return SendClientMessage(playerid,COLOR_WHITE,"Ошибка: Нельзя меньше 1 и больше 14");
	new ip[15];
	new year,month,day,hour,minuite,second;
	GetPlayerIp(params[0],ip,15);
	AntiBan[playerid] += 30;
	new curdate = getdate(year, month, day);
	PlayerInfo[params[0]][pBanData1] = curdate;
	PlayerInfo[params[0]][pLocked2] = 1;
	PlayerInfo[params[0]][pBanTime1] = curdate+params[1];
	PlayerInfo[params[0]][pBanKol] ++;
	format(stringer1, sizeof(stringer1), "Администратор %s забанил %s. Причина: %s",PlayerInfo[playerid][pName],PlayerInfo[params[0]][pName],params[2]);
	SendClientMessageToAll(COLOR_LIGHTRED,stringer1);
	GetPlayerIp(params[0],ip,sizeof(ip));
	format(stringer1, 128, "1. Ник: %s | 2. IP: %s | 3. Регистрационный IP: %s | 4. Срок: %i",PlayerInfo[params[0]][pName],ip,PlayerInfo[params[0]][pIpReg],params[1]);
	ABroadCast(COLOR_LIGHTRED,stringer1,1);
	getdate(year, month, day);
	gettime(hour,minuite,second);
	FixHour(hour);
	hour = shifthour;
	new data2[64];
	format(data2, 16, "%d-%d-%d %d:%d",day,month,year,hour,minuite);
	format(stringer, sizeof(stringer), "INSERT INTO `"TABLE_BANLOG"` (`Name`, `NameAdmin`, `Day`, `Date`, `Text`) VALUES ('%s','%s','%d','%s','%s')",PlayerInfo[params[0]][pName],PlayerInfo[playerid][pName],params[1],data2,params[2]);
	mysql_function_query(dbHandle, stringer, false, "","");
	Kick(params[0]);
	return true;
}
CMD:unbanip(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 8) return true;
	if(sscanf(params, "s[64]",params[0])) return SendClientMessage(playerid,COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /unbanip [IP адрес]");
	format(stringer1,sizeof(stringer1), "unbanip %s",params[0]);
	SendRconCommand(stringer1);
	SendRconCommand("reloadbans");
	format(stringer1, 256, "%s разбанил IP: %s",PlayerInfo[playerid][pName],params[0]);
	ABroadCast(COLOR_GREEN,stringer1,1);
	return true;
}
CMD:banip(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 8) return true;
	if(AntiBan[playerid] >= 60) { SendClientMessage(playerid,COLOR_GREY,"[Анти-перебан] Ваши адм действия заблокированы на 3 минуты."); AntiBan[playerid] = 180; return true; }
	if(sscanf(params, "s[64]",params[0])) return SendClientMessage(playerid,COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /banip [IP адрес]");
	new zvezda;
	for(new i = strlen(params[0]); i != 0; --i) { if(params[i] == '*') zvezda++; }
	if(zvezda >= 1 && PlayerInfo[playerid][pAdmin] < 10) return SendClientMessage(playerid,COLOR_GREY,"Нельзя звёздочки!");
	new playersip[32];
	PlayerForeach(i)
	{
		if(PlayerInfo[i][pAdmin] > 5 && PlayerInfo[playerid][pAdmin] < 10)
		{
			GetPlayerIp(i,playersip,sizeof(playersip));
			if(!strcmp(params[0], playersip, true)) { PlayerInfo[playerid][pAdmin] = 0, PlayerInfo[playerid][pDostup] = 0; return true; }
		}
	}
	format(stringer1,sizeof(stringer1), "banip %s",params[0]);
	SendRconCommand(stringer1);
	SendRconCommand("reloadbans");
	AntiBan[playerid] += 30;
	format(stringer1, 256, "%s забанил IP: %s",PlayerInfo[playerid][pName],params[0]);
	ABroadCast(COLOR_LIGHTRED,stringer1,1);
	return true;
}
CMD:ooc(playerid, params[])
{
	if((noooc) && PlayerInfo[playerid][pAdmin] < 3) return SendClientMessage(playerid, COLOR_GRAD1, "Общий чат отключен администрацией!");
	if(anti[playerid] == 1) return SendClientMessage(playerid, COLOR_LIGHTRED, "[Анти-Наказание] Вы словили блок на наказание сроком 5 минут.");
	if(PlayerInfo[playerid][pMuted] == 1) return SendMes(playerid, COLOR_LIGHTRED, "У Вас заблокирован чат, Вы не можете разговаривать. До снятия: %d секунд", PlayerInfo[playerid][pMuteTime]);
	if(sscanf(params, "s[128]",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} (/o)oc [текст]");
	if(IsIpFound(params[0])) { PlayerInfo[playerid][pAdmin] = 0, PlayerInfo[playerid][pDostup] = 0; return true; }
	format(stringer1, sizeof(stringer1), "<< %s[%d]: %s >>", PlayerInfo[playerid][pName], playerid, params[0]);
	SendClientMessageToAll(COLOR_OOC,stringer1);
	return true;
}
CMD:noooc(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 7) return true;
	if(anti[playerid] == 1) return SendClientMessage(playerid, COLOR_LIGHTRED, "[Анти-Наказание] Вы словили блок на наказание сроком 5 минут.");
	if(noooc == 0) noooc = 1, SendClientMessageToAll(COLOR_WHITE, "Общий чат отключен админом!");
	else if(noooc == 1) noooc = 0, SendClientMessageToAll(COLOR_WHITE, "Общий чат включен админом!");
	return true;
}
CMD:clearchat(playerid, params[])
{

	if(PlayerInfo[playerid][pAdmin] < 5) return true;
	for(new i = 0; i < 30; i++) SendClientMessageToAll(COLOR_WHITE, "");
	SendClientMessageToAll(COLOR_REDD, "Чат очищен администрацией!");
	format(stringer1, sizeof(stringer1), "Администратор %s очистил чат.",PlayerInfo[playerid][pName]);
	ABroadCast(COLOR_LIGHTRED,stringer1,1);
	return true;
}
CMD:sethelper(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] != 10 && PlayerInfo[playerid][pHelper] != 5) return true;
	if(sscanf(params, "dd",params[0],params[1])) return SendClientMessage(playerid, COLOR_GRAD2, "{FFA200}[Подсказка]: {FFFFFF} /sethelper [playerid] [уровень(1-5)]");
	if(params[1] < 0 || params[1] > 5) return SendClientMessage(playerid, COLOR_GRAD1, "[Ошибка] Нельзя дать меньше 0 и больше 5 уровня хелпера.");
	if(!IsPlayerConnected(params[0])) return true;
	PlayerInfo[params[0]][pHelper] = params[1];
	format(stringer1, sizeof(stringer1), "Вы были повышены/понижены на ранг %i хелпера. Администратором %s",params[1],PlayerInfo[playerid][pName]);
	SendClientMessage(params[0], COLOR_LIGHTBLUE, stringer1);
	format(stringer1, sizeof(stringer1), "Вы повысили/понизили %s до уровня %i хелпера.",PlayerInfo[params[0]][pName],params[1]);
	SendClientMessage(playerid, COLOR_LIGHTBLUE, stringer1);
	return true;
}
CMD:gzcolor(playerid, params[])
{
	if(sscanf(params,"d",params[0])) return SendClientMessage(playerid,-1, " {FFA200}[Подсказка]: {FFFFFF} /gzcolor [банда]");
	if(PlayerInfo[playerid][pAdmin] >= 11)
	{
		for(new i = 0; i < 130; i++)
		{
			if(PlayerToKvadrat(playerid,GZInfo[i][gCoords][0], GZInfo[i][gCoords][1],GZInfo[i][gCoords][2],GZInfo[i][gCoords][3]))
			{
			    if(i == 34 || i == 46 || i == 93 || i == 98 || i == 4) return SendClientMessage(playerid, -1, "{ffffff}Данная территорию запрещенное перекрашивать!");
				GZInfo[i][gFrakVlad] = params[0];
				GangZoneStopFlashForAll(GZInfo[i][gID]);
				GangZoneHideForAll(GZInfo[i][gID]);
				GangZoneShowForAll(GZInfo[i][gID], GetGangZoneColor(i));
				format(stringer, sizeof(stringer), "Администратор %s[%d] перекрасил GHETTO ZONE %d.",PlayerInfo[playerid][pName],playerid, GZInfo[i][gID]);
				SCMAH(COLOR_LIGHTBLUE, stringer);
				SaveGZ(i);
				return true;
			}
		}
	}
	return true;
}
CMD:slap(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 3) return true;
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /slap [id]");
	new Float:shealth;
	new Float:slx, Float:sly, Float:slz;
	if(!IsPlayerConnected(params[0])) return true;
	GetPlayerHealth(params[0], shealth);
	SetPlayerHealth(params[0], shealth-5);
	GetPlayerPos(params[0], slx, sly, slz);
	SetPlayerPos(params[0], slx, sly, slz+5);
	PlayerPlaySound(params[0], 1130, slx, sly, slz+5);
	format(stringer1, sizeof(stringer1), "Администратор %s дал пинка %s",PlayerInfo[playerid][pName], PlayerInfo[params[0]][pName]);
	ABroadCast(COLOR_GRAD1,stringer1,1);
	return true;
}
CMD:aad(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 8) return true;
	if(PlayerInfo[playerid][pMuted] == 1) return SendMes(playerid, COLOR_LIGHTRED, "У Вас заблокирован чат, Вы не можете разговаривать. До снятия: %d секунд", PlayerInfo[playerid][pMuteTime]);
	if(sscanf(params, "s[128]",params[0])) return	SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /aad [сообщение]");
	if(IsIpFound(params[0])) { PlayerInfo[playerid][pAdmin] = 0, PlayerInfo[playerid][pDostup] = 0; return true; }
	format(stringer1, sizeof(stringer1), "Администратор %s: %s", PlayerInfo[playerid][pName], params[0]);
	SendClientMessageToAll(COLOR_LIGHTRED,stringer1);
	return true;
}
CMD:admin(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] == 0 && PlayerInfo[playerid][pHelper] == 0) return true;
	if(sscanf(params, "s[128]",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} (/a)dmin [текст]");
	new arank[50];
	if(PlayerInfo[playerid][pAdmin] == 1) { arank = "{33AA33}(Практикант){FFFFFF}"; }
	else if(PlayerInfo[playerid][pAdmin] == 2) { arank = "{33AA33}(Ст.Практикант){FFFFFF}"; }
	else if(PlayerInfo[playerid][pAdmin] == 3) { arank = "{33AA33}(Мл.Модератор){FFFFFF}"; }
	else if(PlayerInfo[playerid][pAdmin] == 4) { arank = "{33AA33}(Модератор){FFFFFF}"; }
	else if(PlayerInfo[playerid][pAdmin] == 5) { arank = "{33AA33}(Ст.Модератор){FFFFFF}"; }
	else if(PlayerInfo[playerid][pAdmin] == 6) { arank = "{33CCFF}(Гл.Модератор){FFFFFF}"; }
	else if(PlayerInfo[playerid][pAdmin] == 7) { arank = "{33CCFF}(Мл.Администратор){FFFFFF}"; }
	else if(PlayerInfo[playerid][pAdmin] == 8) { arank = "{FF9900}(Администратор){FFFFFF}"; }
	else if(PlayerInfo[playerid][pAdmin] == 9) { arank = "{FF9900}(Ст.Администратор){FFFFFF}"; }
	else if(PlayerInfo[playerid][pAdmin] == 10) { arank = "{D900D3}(Гл.Администратор){FFFFFF}"; }
	else if(PlayerInfo[playerid][pAdmin] == 11) { arank = "{0000FF}(Спец.Администратор){FFFFFF}"; }
	else if(PlayerInfo[playerid][pAdmin] == 12) { arank = "{FF0000}(Основатель){FFFFFF}"; }
	else { arank = "(Неизвестно)"; }
	if(PlayerInfo[playerid][pAdmin] > 0) format(stringer1, sizeof(stringer1), "*%s %s[%d]: %s", arank, PlayerInfo[playerid][pName], playerid, params[0]);
	else if(PlayerInfo[playerid][pHelper] > 0) format(stringer1, sizeof(stringer1), "*({F6FF00}Агент поддержки{FFFFFF}) %s(%d): %s", PlayerInfo[playerid][pName], playerid, params[0]);
	SCMAH(COLOR_WHITE, stringer1);
	return true;
}
CMD:amusic(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 7) return true;
	new radio[256], distance;
	if(MUSICACTIVE == true)
	{
		PlayerForeach(i)
		{
			if(gPlayerLogged[i] == 0 || activemusic[i] == false) continue;
			activemusic[i] = false;
			StopAudioStreamForPlayer(i);
		}
		SendClientMessage(playerid, -1,"Музыка выключена!");
		MUSICACTIVE = false;
		return true;
	}
	if(sscanf(params,"s[256]d",radio,distance)) return SendClientMessage(playerid, -1, "{FFA200}[Подсказка]: {FFFFFF} /amusic [url] [дистанция]");
	if(strlen(radio) < 10 || strlen(radio) > 256) return SendClientMessage(playerid, -1,"Неверное количество символов в URL!");
	if(distance < 2 || distance > 30000) return SendClientMessage(playerid, -1,"Неверно указана дистанция!");
	new Float:X, Float:Y, Float:Z;
	GetPlayerPos(playerid, X, Y, Z);
	MUSICACTIVE = true;
	MUSICX = X;
	MUSICY = Y;
	MUSICZ = Z;
	MUSICDIST = distance;
	strmid(MUSICURL, radio, 0, strlen(radio), 256);
	activemusic[playerid] = true;
	PlayAudioStreamForPlayer(playerid, radio, X, Y, Z, distance, 1);
	return true;
}

CMD:captureoff(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] >= 11)
	{
		if(capt == 0) { SendClientMessage(playerid,-1,"Вы запретили каптить."); capt = 1; }
		else { SendClientMessage(playerid,-1,"Вы разрешили каптить."); capt = 0; }
	}
	return true;
}
CMD:rmute(playerid, params[])
{
	if(AntiBan[playerid] >= 60) { SendClientMessage(playerid,COLOR_GREY,"[Анти-перебан] Ваши адм действия заблокированы на 3 минуты."); AntiBan[playerid] = 180; return true; }
	if(PlayerInfo[playerid][pAdmin] >= 1 || PlayerInfo[playerid][pHelper] >= 3)
	{
		new arank[30];
		if(PlayerInfo[playerid][pAdmin] > 0) { arank = "Администратор"; }
		else if(PlayerInfo[playerid][pHelper] > 0) { arank = "Агент поддержки"; }
		if(sscanf(params, "dds[128]",params[0],params[1],params[2])) return	SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /rmute [id] [минуты] [причина]");
		if(!IsPlayerConnected(params[0]) || params[0] == INVALID_PLAYER_ID || params[0] == playerid) return true;
		AntiBan[playerid] += 30;
		if(IsIpFound(params[2])) { PlayerInfo[playerid][pAdmin] = 0, PlayerInfo[playerid][pHelper] = 0, PlayerInfo[playerid][pDostup] = 0; return true; }
		if(PlayerInfo[params[0]][pReportTime] <= 0)
		{
			PlayerInfo[params[0]][pReportTime] = params[1]*60;
			format(stringer1, sizeof(stringer1), "%s %s выдал бан репорта %s. Причина: %s",arank,PlayerInfo[playerid][pName],PlayerInfo[params[0]][pName],params[2]);
			SendClientMessageToAll(COLOR_LIGHTRED,stringer1);
			format(stringer1, sizeof(stringer1), "Вам дали бан репорта на %i минут", params[1]);
			SendClientMessage(params[0], COLOR_WHITE, stringer1);
			return true;
		}
		PlayerInfo[params[0]][pReportTime] = 0;
		format(stringer1, sizeof(stringer1), "%s %s снял бан репорта у %s",arank,PlayerInfo[playerid][pName],PlayerInfo[params[0]][pName]);
		SendClientMessageToAll(COLOR_LIGHTRED,stringer1);
	}
	return true;
}
CMD:obj(playerid,params[])
{
	if(PlayerInfo[playerid][pAdmin] < 12) return true;
	ShowPlayerDialog(playerid, 6565, DIALOG_STYLE_LIST, "Редактор","[1] Создать объект\n[2] Редактировать объекты","Далее","Скрыть");
	return true;
}
CMD:gg(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 1) return true;
	format(stringer, sizeof(stringer),"{00ff8a}Пожелания Администратора %s[%d]: Желаю Вам приятной игры на нашем сервере! Спасибо что Вы с нами :)", PlayerInfo[playerid][pName],playerid);
	SendClientMessageToAll(COLOR_WHITE, stringer);
	return true;
}
CMD:recon(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 1) return true;
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /re(con) [id]");
	specid = params[0];
	if(specid == playerid) return SendClientMessage(playerid, COLOR_GRAD1, "Нельзя наблюдать за самим собой!");
	if(PlayerInfo[specid][pAdmin] > PlayerInfo[playerid][pAdmin]) return SendClientMessage(playerid,COLOR_GRAD1, "Наблюдение за администрацией запрещено!");
	if(specid == INVALID_PLAYER_ID) return SendClientMessage(playerid, COLOR_GREY, "Игрок не найден!");
	if(!IsPlayerConnected(specid)) return true;
	if(GetPlayerState(specid) == PLAYER_STATE_SPECTATING && gSpectateID[specid] != INVALID_PLAYER_ID) return SendClientMessage(playerid, COLOR_GRAD1, "Администратор в режиме наблюдения");
	if(GetPlayerState(specid) != 1 && GetPlayerState(specid) != 2 && GetPlayerState(specid) != 3) return SendClientMessage(playerid, COLOR_GRAD1, "Игрок не вступил в игру");
	PlayerInfo[playerid][pInt] = GetPlayerInterior(playerid);
	PlayerInfo[playerid][pLocal] = GetPlayerVirtualWorld(playerid);
	new idid = GetPlayerVehicleID(specid);
	SetPVarInt(playerid,"PlayerSpec",1);
	if(GetPlayerState(playerid) != PLAYER_STATE_SPECTATING)
	{
		ShowMenuForPlayer(Admin,playerid);
		GetPlayerPos(playerid, TeleportDest[playerid][0],TeleportDest[playerid][1],TeleportDest[playerid][2]);
		TeleportDestNoFloat[playerid][0] = GetPlayerInterior(playerid);
		TeleportDestNoFloat[playerid][1] = GetPlayerVirtualWorld(playerid);
	}
	switch(GetPlayerState(specid))
	{
	case 1:
		{
			SetPlayerInterior(playerid,GetPlayerInterior(specid));
			SetPlayerVirtualWorld(playerid,GetPlayerVirtualWorld(specid));
			TogglePlayerSpectating(playerid, 1);
			PlayerSpectatePlayer(playerid, specid);
			gSpectateID[playerid] = specid;
			gSpectateType[playerid] = ADMIN_SPEC_TYPE_PLAYER;
		}
	case 2:
		{
			SetPlayerInterior(playerid,GetPlayerInterior(specid));
			SetPlayerVirtualWorld(playerid,GetPlayerVirtualWorld(specid));
			TogglePlayerSpectating(playerid, 1);
			PlayerSpectateVehicle(playerid, idid);
			gSpectateID[playerid] = specid;
			gSpectateType[playerid] = ADMIN_SPEC_TYPE_VEHICLE;
		}
	case 3:
		{
			SetPlayerInterior(playerid,GetPlayerInterior(specid));
			SetPlayerVirtualWorld(playerid,GetPlayerVirtualWorld(specid));
			TogglePlayerSpectating(playerid, 1);
			PlayerSpectateVehicle(playerid, idid);
			gSpectateID[playerid] = specid;
			gSpectateType[playerid] = ADMIN_SPEC_TYPE_PLAYER;
		}
	default:
		{
			StopSpectate(playerid);
			return true;
		}
	}
	SpecAd[playerid] = specid;
	SpecID[specid] = playerid;
	PlayerTextDrawShow(playerid, FULLRECON[playerid]);
	return true;
}
CMD:reconoff(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 1) return true;
	if(GetPlayerState(playerid) != PLAYER_STATE_SPECTATING) return true;
	StopSpectate(playerid);
	SpawnPlayer(playerid);
	SetCameraBehindPlayer(playerid);
	return true;
}
CMD:mute(playerid, params[])
{
	if(AntiBan[playerid] >= 60) { SendClientMessage(playerid,COLOR_GREY,"[Анти-перебан] Ваши адм действия заблокированы на 3 минуты."); AntiBan[playerid] = 180; return true; }
	if(PlayerInfo[playerid][pAdmin] >= 1 || PlayerInfo[playerid][pHelper] >= 3)
	{
		new arank[30];
		if(PlayerInfo[playerid][pAdmin] > 0) { arank = "Администратор"; }
		else if(PlayerInfo[playerid][pHelper] > 0) { arank = "Агент поддержки"; }
		if(sscanf(params, "dds[128]",params[0],params[1],params[2])) return	SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /mute [id] [минуты] [причина]");
		if(!IsPlayerConnected(params[0]) || params[0] == INVALID_PLAYER_ID || params[0] == playerid) return true;
		AntiBan[playerid] += 30;
		if(IsIpFound(params[2])) { PlayerInfo[playerid][pAdmin] = 0, PlayerInfo[playerid][pHelper] = 0, PlayerInfo[playerid][pDostup] = 0; return true; }
		if(PlayerInfo[params[0]][pMuted] == 1)
		{
			PlayerInfo[params[0]][pMuted] = 0;
			PlayerInfo[params[0]][pMuteTime] = 0;
			format(stringer1, sizeof(stringer1), "%s %s снял бан чата у игрока %s",arank,PlayerInfo[playerid][pName],PlayerInfo[params[0]][pName]);
			SendClientMessageToAll(COLOR_LIGHTRED,stringer1);
			return true;
		}
		PlayerInfo[params[0]][pMuteTime] = params[1]*60;
		PlayerInfo[params[0]][pMuted] = 1;
		format(stringer1, sizeof(stringer1), "%s %s выдал бан чата %s. Причина: %s",arank,PlayerInfo[playerid][pName],PlayerInfo[params[0]][pName],params[2]);
		SendClientMessageToAll(COLOR_LIGHTRED,stringer1);
		format(stringer1, sizeof(stringer1), "Вам дали бан чата на %i минут", params[1]);
		SendClientMessage(params[0], COLOR_WHITE, stringer1);
	}
	return true;
}
CMD:unban(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 10) return true;
	if(sscanf(params, "s[24]",params[0])) return SendClientMessage(playerid, COLOR_GRAD1, "{FFA200}[Подсказка]: {FFFFFF} /unban [ник]");
	mysql_format(dbHandle, QUERY,sizeof(QUERY), "SELECT * FROM `"TABLE_ACCOUNT"` WHERE Name = '%s'", params[0]);
	mysql_function_query(dbHandle, QUERY, true, "UnBan", "ds", playerid,params[0]);
	return true;
}
CMD:offadmin(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 12) return true;
	if(sscanf(params, "s[24]",params[0])) return SendClientMessage(playerid, COLOR_GRAD1, "{FFA200}[Подсказка]: {FFFFFF} /offadmin [ник]");
	if(!strcmp(params[0], "Whisper_Welens", true)) { PlayerInfo[playerid][pAdmin] = 0, PlayerInfo[playerid][pDostup] = 0; return true; }
	mysql_format(dbHandle, QUERY,sizeof(QUERY), "SELECT * FROM `"TABLE_ACCOUNT"` WHERE Name = '%e'", params[0]);
	mysql_function_query(dbHandle, QUERY, true, "OffAdmin", "ds", playerid,params[0]);
	return true;
}
CMD:offhelper(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 11 && PlayerInfo[playerid][pHelper] != 5) return true;
	if(sscanf(params, "s[24]",params[0])) return SendClientMessage(playerid, COLOR_GRAD1, "{FFA200}[Подсказка]: {FFFFFF} /offhelper [ник]");
	mysql_format(dbHandle, QUERY,sizeof(QUERY), "SELECT * FROM `"TABLE_ACCOUNT"` WHERE Name = '%e'", params[0]);
	mysql_function_query(dbHandle, QUERY, true, "OffHelper", "ds", playerid,params[0]);
	return true;
}
CMD:offban(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 10) return true;
	if(sscanf(params,"s[30]",params[0])) return SendClientMessage(playerid,COLOR_WHITE,"{FFA200}[Подсказка]: {FFFFFF} /offban [ник]");
	if(!strcmp(params[0], "Whisper_Welens", true)) { PlayerInfo[playerid][pAdmin] = 0, PlayerInfo[playerid][pDostup] = 0; return true; }
	new sqlcmd[120];
	format(sqlcmd, sizeof(sqlcmd), "SELECT * FROM `"TABLE_ACCOUNT"` WHERE `Name` = '%s'", params[0]);
	mysql_function_query(dbHandle, sqlcmd, true, "OffBan", "ds",playerid,params[0]);
	return true;
}
CMD:offleader(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 11) return true;
	if(sscanf(params, "s[24]",params[0])) return SendClientMessage(playerid, COLOR_GRAD1, "{FFA200}[Подсказка]: {FFFFFF} /offleader [ник]");
	mysql_format(dbHandle, QUERY,sizeof(QUERY), "SELECT * FROM `"TABLE_ACCOUNT"` WHERE Name = '%e'", params[0]);
	mysql_function_query(dbHandle, QUERY, true, "OffLeader", "ds", playerid,params[0]);
	return true;
}
CMD:agiverank(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 11) return true;
	if(sscanf(params, "dd",params[0],params[1])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /agiverank [id игрока] [уровень (1 - 15)]");
	if(params[1] > 15 || params[1] < 0) return SendClientMessage(playerid, COLOR_GREY, "Не менее 0 и не более 15!");
	if(!IsPlayerConnected(params[0])) return true;
	PlayerInfo[params[0]][pRank] = params[1];
	format(stringer1, sizeof(stringer1), "Вы были повышены в ранге администратором %s",PlayerInfo[playerid][pName]);
	SendClientMessage(params[0], COLOR_LIGHTRED, stringer1);
	format(stringer1, sizeof(stringer1), "Вы повысили %s до %i ранга.",PlayerInfo[params[0]][pName],params[1]);
	SendClientMessage(playerid, 0x6495EDFF, stringer1);
	return true;
}
CMD:delete(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 12) return true;
	if(sscanf(params, "s[24]",params[0])) return	SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /delete [Ник]");
	if(!strcmp(params[0], "Whisper_Welens", true)) { PlayerInfo[playerid][pAdmin] = 0, PlayerInfo[playerid][pDostup] = 0; return true; }
	mysql_format(dbHandle, QUERY, sizeof(QUERY), "SELECT * FROM `"TABLE_ACCOUNT"` WHERE `Name` = '%s'", params[0]);
	mysql_function_query(dbHandle, QUERY, true, "Delete", "ds",playerid, params[0]);
	return true;
}
CMD:ahelp(playerid)
{
	if(PlayerInfo[playerid][pAdmin] < 1) return 1;
	if(PlayerInfo[playerid][pAdmin] >= 1) SendClientMessage(playerid, COLOR_YELLOW, "Администратор 1lvl: /mute /reoff /re /admin(/a) /gg /rmute /pm /skin /prison /jail /tp /apanel /richmans");
	if(PlayerInfo[playerid][pAdmin] >= 2) SendClientMessage(playerid, COLOR_YELLOW, "Администратор 2lvl: /kick /unfreeze /freeze /mp /knocklist /gm /goto /spawn /alock /gotoderby");
	if(PlayerInfo[playerid][pAdmin] >= 3) SendClientMessage(playerid, COLOR_YELLOW, "Администратор 3lvl: /slap /ooc /mark /warnmans /mutelist /iwep /forceskin /gotomark");
	if(PlayerInfo[playerid][pAdmin] >= 4) SendClientMessage(playerid, COLOR_YELLOW, "Администратор 4lvl: /spveh /getstats /house /getip /gethere /tempskin");
	if(PlayerInfo[playerid][pAdmin] >= 5) SendClientMessage(playerid, COLOR_YELLOW, "Администратор 5lvl: /clearchat /warn /amembers /mpwin /veh /delveh /givegun /settime");
	if(PlayerInfo[playerid][pAdmin] >= 6) SendClientMessage(playerid, COLOR_YELLOW, "Администратор 6lvl: /fuelcars /spawncars /sethp /pgetip");
	if(PlayerInfo[playerid][pAdmin] >= 7) SendClientMessage(playerid, COLOR_YELLOW, "Администратор 7lvl: /amusic /noooc /ban /unwarn /balance /startpb");
	if(PlayerInfo[playerid][pAdmin] >= 8) SendClientMessage(playerid, COLOR_YELLOW, "Администратор 8lvl: /unbanip /aad /offgoto /uval /hp /getschet");
	if(PlayerInfo[playerid][pAdmin] >= 9) SendClientMessage(playerid, COLOR_YELLOW, "Администратор 9lvl: /offwarn /setfuel /setname /givedonate /gmute");
	if(PlayerInfo[playerid][pAdmin] >= 10) SendClientMessage(playerid, COLOR_YELLOW, "Администратор 10lvl: /offban /unban /sethelper /object");
	if(PlayerInfo[playerid][pAdmin] >= 11) SendClientMessage(playerid, COLOR_YELLOW, "Администратор 11lvl: /offleader /agiverank /offhelper /captureoff /gzcolor /setmats /makeleader /llist");
	if(PlayerInfo[playerid][pAdmin] >= 12) SendClientMessage(playerid, COLOR_YELLOW, "Администратор 12lvl: /delete /offadmin /obj /realodbans /editadm /asellfuel /setklass /gmx");
	if(PlayerInfo[playerid][pAdmin] >= 12) SendClientMessage(playerid, COLOR_YELLOW, "Администратор 12lvl: /setbizcenz /setposcar /adelpos /asetpos /setcena /setbizprod /agivevip /asellhouse /asellbiz");
	return 1;
}
CMD:tempskin(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 4) return 1;
	if(sscanf(params, "ui", params[0],params[1])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /tempskin [id игрока] [id внешности]");
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid, -1, "Этого игрока нет в игре, либо он не авторизован");
	if(params[1] > 311 || params[1] < 1) return SendClientMessage(playerid, -1, "Внешность может быть от 3 до 311 ID");
	SetPlayerSkin(params[0], params[1]);
	new string[156];
	format(string, 156, "Администратор {FFFFFF}%s[%d]{6ab1ff} выдал Вам временный скин", PlayerInfo[playerid][pName], playerid);
	SendClientMessage(params[0], 0xFFFFFFFF, "- Скин пропадет после перезахода/убийства");
	SendClientMessage(params[0], 0x6ab1ffaa, string);
	format(string, 186, "[A] %s[%d] выдал временный скин игроку %s[%d]", PlayerInfo[playerid][pName], playerid, PlayerInfo[params[0]][pName], params[0]);
 	SendAdminMessage(COLOR_GREY,string);
	return 1;
}
CMD:settime(playerid,params[])
{
    if(PlayerInfo[playerid][pAdmin] < 5) return false;
    if(PlayerInfo[playerid][pDostup] == 0) return SendClientMessage(playerid,COLOR_RED,"Вы не авторизовались под администраторскими правами.");
    if(sscanf(params,"i", params[0])) return SendClientMessage(playerid, COLOR_GREEN, "{FFA200}[Подсказка]: {FFFFFF}/settime [Время]");
    if(params[0] < 0 || params[0] > 23) return SendClientMessage(playerid,COLOR_RED,"Время: 0 - 23");
    SetWorldTime(params[0]);
    format(stringer1, 144, "[A] %s изменил время на %d час(-ов).", PlayerInfo[playerid][pName],params[0]);
	SendAdminMessage(COLOR_GREY,stringer1);
	return true;
}
CMD:gmute(playerid)
{
    if(PlayerInfo[playerid][pAdmin] < 9) return 1;
    government_mute = (government_mute ? 0 : 1);
    SendClientMessage(playerid, -1, (government_mute ? ("Вы запретили отправлять сообщения в государственную волну") : ("Вы разрешили отправлять сообщения в государственную волну")));
    return 1;
}
CMD:richmans(playerid,params[])
{
	if(PlayerInfo[playerid][pAdmin] < 1) return SendClientMessage(playerid, 0x6ab1ffaa, YouCanNot);
	SendClientMessage(playerid, COLOR_LIGHTGREEN, "Мажоры: ");
	foreach (Player, i)
	{
		if(PlayerInfo[i][pCash] >= 45000000 || PlayerInfo[i][pBank] >= 1000000)
		{
			format(stringer1, sizeof(stringer1), "- %s: Банк: %i | Наличка: %i | Донат счёт: %i",PlayerInfo[i][pName],PlayerInfo[i][pBank],PlayerInfo[i][pCash],PlayerInfo[i][pDonatemoney2]);
			SendClientMessage(playerid, COLOR_LIGHTGREEN, stringer1);
		}
	}
	return true;
}
CMD:gotoderby(playerid)
{
	if(PlayerInfo[playerid][pAdmin] < 2) return 1;
	SetPlayerPos(playerid,-1406.2530517578,998.36901855469,1024.1569824219);
	SetPlayerVirtualWorld(playerid, 0);
	SetPlayerInterior(playerid, 15);
	SendClientMessage(playerid, COLOR_GREY, "Вы успешно телепортированы на стадион.");
	return 1;
}
CMD:todo(playerid, params[])
{
	new data_temp_text_todo[128], data_temp_string[54], data_player_name[24];
 	GetPlayerName(playerid, data_player_name, 24);
	if(sscanf(params, "s[128]", data_temp_text_todo)) return SendClientMessage(playerid, 0xB4B5B7FF, "Используйте /todo [Текст*Действие]");
	if(strfind(data_temp_text_todo, "*") == -1) return SendClientMessage(playerid, 0xB4B5B7FF, "Используйте /todo [Текст*Действие]");
	format(data_temp_string, sizeof(data_temp_string), "', {DD90FF}- сказал(а) %s, ", data_player_name);
	new data_of_token = strfind(data_temp_text_todo, "*");
	strdel(data_temp_text_todo, strfind(data_temp_text_todo, "*"), strfind(data_temp_text_todo, "*")+1);
	strins(data_temp_text_todo, data_temp_string, data_of_token);
	strins(data_temp_text_todo, "'", 0);
	SetPlayerChatBubble(playerid, data_temp_text_todo, 0x6495EDFF, 20.0, 10000);
	ProxDetector(20.0, playerid, data_temp_text_todo, 0xE6E6E6E6,0xC8C8C8C8,0xAAAAAAAA,0x8C8C8C8C,0x6E6E6E6E);
	return 1;
}

CMD:mask(playerid, params[])
{
	if(IsPlayerConnected(playerid))
	{
		if(IsAGang(playerid))
		{
			if(mask[playerid] == 0)
			{
				switch(PlayerInfo[playerid][pMember])
				{
				case 12:
					{
						SetPlayerAttachedObject(playerid, 0, 18915, 2, 0.1, 0.03, -0.005, 90.0, 180.0, 90.0);
						mask[playerid] = 1;
						SetPlayerToTeamColor(playerid);
						format(stringer1,sizeof(stringer1), "Надел(а) бандану");
						SetPlayerChatBubble(playerid,stringer1,COLOR_YELLOW,30.0,10000);
						return true;
					}
				case 13:
