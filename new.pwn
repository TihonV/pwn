			{
				HomeInfo[he][hPickup] = CreatePickup(1273, 23, HomeInfo[he][hEntrancex], HomeInfo[he][hEntrancey], HomeInfo[he][hEntrancez],-1);
				HomeInfo[he][hMIcon] = CreateDynamicMapIcon(HomeInfo[he][hEntrancex], HomeInfo[he][hEntrancey], HomeInfo[he][hEntrancez], 31, COLOR_WHITE, 0, -1, -1, 200.0);
			}
			if(HomeInfo[he][hOwned] == 1)
			{
