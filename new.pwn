public OnVehicleMod(playerid,vehicleid,componentid)
{
	if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER && vehicleid == PlayerInfo[playerid][pCar])
	{
		PlayerInfo[playerid][pSpoiler] = GetVehicleComponentInSlot(vehicleid, CARMODTYPE_SPOILER);
		PlayerInfo[playerid][pHood] = GetVehicleComponentInSlot(vehicleid, CARMODTYPE_HOOD);
		PlayerInfo[playerid][pBamper1]  = GetVehicleComponentInSlot(vehicleid, CARMODTYPE_FRONT_BUMPER);
		PlayerInfo[playerid][pBamper2] = GetVehicleComponentInSlot(vehicleid, CARMODTYPE_REAR_BUMPER);
		PlayerInfo[playerid][pGidra] = GetVehicleComponentInSlot(vehicleid, CARMODTYPE_HYDRAULICS);
		PlayerInfo[playerid][pNitro] = GetVehicleComponentInSlot(vehicleid, CARMODTYPE_NITRO);
		PlayerInfo[playerid][pExhaust] = GetVehicleComponentInSlot(vehicleid, CARMODTYPE_EXHAUST);
		PlayerInfo[playerid][pLamps] = GetVehicleComponentInSlot(vehicleid, CARMODTYPE_LAMPS);
		PlayerInfo[playerid][pVozdyx] = GetVehicleComponentInSlot(vehicleid, CARMODTYPE_ROOF);
		PlayerInfo[playerid][pKolesocar] = GetVehicleComponentInSlot(vehicleid, CARMODTYPE_WHEELS);
		PlayerInfo[playerid][pSideskirt] = GetVehicleComponentInSlot(vehicleid, CARMODTYPE_SIDESKIRT);
	}
	return true;
}

public OnVehiclePaintjob(playerid, vehicleid, paintjobid)
{
	if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER && vehicleid == PlayerInfo[playerid][pCar]) PlayerInfo[playerid][pPokraska] = paintjobid;
	return true;
}

public OnVehicleRespray(playerid, vehicleid, color1, color2)
{
	if(PlayerToPoint(30.0,playerid,1024.8700,-1023.9111,31.8337)) return true;
	return true;
}
stock skladband(){
	new faasst = FracBank[0][fBallasn]; new aast = FracBank[0][fAztekn]; new vast = FracBank[0][fVagosn];
	new gast = FracBank[0][fGroven]; new fast = FracBank[0][fRifan];
	format(stringer,sizeof(stringer),"{ffff00}Шкаф\n\n{ffffff}Деньги:{42aaff} %d из 10.000.000$\n{ffffff}Материалы:{42aaff} %d из 300000 кг\n{ffffff}Наркотики:{42aaff} %d из 10000 г",FracBank[0][fBallas],ballasmatbi,faasst); UpdateDynamic3DTextLabelText(SkladB,  Cvet_4, stringer);
	format(stringer,sizeof(stringer),"{ffff00}Шкаф\n\n{ffffff}Деньги:{42aaff} %d из 10.000.000$\n{ffffff}Материалы:{42aaff} %d из 300000 кг\n{ffffff}Наркотики:{42aaff} %d из 10000 г",FracBank[0][fVagos],vagosmatbi,vast); UpdateDynamic3DTextLabelText(SkladV,  Cvet_4, stringer);
	format(stringer,sizeof(stringer),"{ffff00}Шкаф\n\n{ffffff}Деньги:{42aaff} %d из 10.000.000$\n{ffffff}Материалы:{42aaff} %d из 300000 кг\n{ffffff}Наркотики:{42aaff} %d из 10000 г",FracBank[0][fGrove],groovmatbi,gast); UpdateDynamic3DTextLabelText(SkladG,  Cvet_4, stringer);
	format(stringer,sizeof(stringer),"{ffff00}Шкаф\n\n{ffffff}Деньги:{42aaff} %d из 10.000.000$\n{ffffff}Материалы:{42aaff} %d из 300000 кг\n{ffffff}Наркотики:{42aaff} %d из 10000 г",FracBank[0][fRifa],rifamatbi,fast); UpdateDynamic3DTextLabelText(SkladR,  Cvet_4, stringer);
	format(stringer,sizeof(stringer),"{ffff00}Шкаф\n\n{ffffff}Деньги:{42aaff} %d из 10.000.000$\n{ffffff}Материалы:{42aaff} %d из 300000 кг\n{ffffff}Наркотики:{42aaff} %d из 10000 г",FracBank[0][fAztek],aztekmatbi,aast); UpdateDynamic3DTextLabelText(SkladA,  Cvet_4, stringer);}
stock PlayerToKvadrat(playerid,Float:min_x,Float:min_y,Float:max_x,Float:max_y)
{
	new Float:xxp,Float:yyp,Float:zzp;
	GetPlayerPos(playerid, xxp, yyp, zzp);
	if((xxp <= max_x && xxp >= min_x) && (yyp <= max_y && yyp >= min_y)) return true;
	return false;
}
stock CheckPlayerDistanceToVehicle(Float:radi, playerid, vehicleid)
{
	if(IsPlayerConnected(playerid))
	{
		new Float:PX,Float:PY,Float:PZ,Float:X,Float:Y,Float:Z;
		GetPlayerPos(playerid,PX,PY,PZ);
		GetVehiclePos(vehicleid, X,Y,Z);
		new Float:Distance = (X-PX)*(X-PX)+(Y-PY)*(Y-PY)+(Z-PZ)*(Z-PZ);
		if(Distance <= radi*radi) return true;
	}
	return false;
}
//========================================================[ цвета гангзон]===================================================================//
stock GetGangZoneColor(gangzonex)
{
	new zx;
	switch(GZInfo[gangzonex][gFrakVlad])
	{
	case 12: zx = 0xED00B6AA;
	case 18: zx = 0x4D9AFFAA;
	case 13: zx = 0xFFEE00AA;
	case 15: zx = 0x00E300AA;
	case 17: zx = 0x00EEFFAA;
	default: zx = 0xF7F7F7AA;
	}
	return zx;
}
stock GetGangColor(g)
{
	new zx;
	switch(g)
	{
	case 15: zx = 0x00E300AA;
	case 12: zx = 0xED00B6AA;
	case 18: zx = 0x4D9AFFAA;
	case 17: zx = 0x00EEFFAA;
	case 13: zx = 0xFFEE00AA;
	default: zx = 0xC0C0C0AA;
	}
	return zx;
}
stock GetNearestVehicle(playerid)
{
	new Float:X,Float:Y,Float:Z;
	for(new i=0; i<MAX_VEHICLES; i++)
	{
		if(GetVehicleModel(i))
		{
			GetVehiclePos(i,X,Y,Z);
			if(PlayerToPoint(6.0, playerid, X, Y, Z)) return i;
		}
	}
	return -1;
}
stock IsPlayerInBandOnline(bandid)
{
	new np;
	PlayerForeach(i)
	{
		if(!IsPlayerConnected(i)) continue;
		if(PlayerInfo[i][pMember] == bandid || PlayerInfo[i][pLeader] == bandid)
		{
			np++;
		}
	}
	return np;
}
stock PlayerToPoint(Float:radi, playerid, Float:x, Float:y, Float:z)
{
	if(IsPlayerConnected(playerid))
	{
		new Float:oldposx, Float:oldposy, Float:oldposz;
		new Float:tempposx, Float:tempposy, Float:tempposz;
		GetPlayerPos(playerid, oldposx, oldposy, oldposz);
		tempposx = (oldposx -x);
		tempposy = (oldposy -y);
		tempposz = (oldposz -z);
		if(((tempposx < radi) && (tempposx > -radi)) && ((tempposy < radi) && (tempposy > -radi)) && ((tempposz < radi) && (tempposz > -radi))) { return true; }
	}
	return false;
}
stock GetGangName(fnumbwer)
{
	new string[20];
	switch(fnumbwer)
	{
	case 12: format(string,sizeof(string), "Ballas");
	case 13: format(string,sizeof(string), "Vagos");
	case 15: format(string,sizeof(string), "Grove Street");
	case 17: format(string,sizeof(string), "Aztecas");
	case 18: format(string,sizeof(string), "Rifa");
	}
	return string;
}
