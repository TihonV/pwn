}
CMD:shield(playerid, params[])
{
	if(TeamPain[playerid] != 0 && StartPaintBall == 2) return SendClientMessage(playerid,COLOR_GREY,"Использовать щит на PaintBall запрещено.");
	if(IsACop(playerid) || IsAArm(playerid))
	{
		if(shield[playerid] == 0)
		{
			SetPlayerAttachedObject(playerid, 1, 18637, 14, 0.0, 0.0, 0.0, 0.0, 180.0, 180.0), SetPlayerHealth(playerid, 999), shield[playerid] = 1;
		}
		else { RemovePlayerAttachedObject(playerid, 1), SetPlayerHealth(playerid, 50), shield[playerid] = 0; }
	}
	else return SendClientMessage(playerid, COLOR_GREY, "Вы не Полицейский/Военный/ФБР");
	return true;
}
CMD:live(playerid, params[])
{
	if(PlayerInfo[playerid][pMuted] == 1) return SendMes(playerid, TEAM_CYAN_COLOR, "У Вас заблокирован чат, Вы не можете разговаривать. До снятия: %d секунд", PlayerInfo[playerid][pMuteTime]);
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /live [id/name]");
	if(params[0] == playerid) { SendClientMessage(playerid, COLOR_GREY, "Вы не можете брать интервью у себя!"); return true; }
	if(ProxDetectorS(5.0, playerid, params[0])){} else { SendClientMessage(playerid, COLOR_GREY, "Человек далеко от вас!"); return true; }
	if(params[0] == INVALID_PLAYER_ID) { SendClientMessage(playerid, COLOR_GREY, "[Ошибка] Человек не найден!"); return true; }
	new newcar = GetPlayerVehicleID(playerid);
	switch(PlayerInfo[playerid][pMember])
	{
	case 16:
		{
			if(newcar >= lsnewscar[0] && newcar <= lsnewscar[1] || PlayerToPoint(30.0,playerid,363.1062,270.4055,1008.6729)) { } else { SendClientMessage(playerid, COLOR_GREY, "Вы не в репортёрской машине / вертолёте / офисе!"); return true;}
			if(TalkingLivels[playerid] != 255)
			{
				SendClientMessage(playerid, 0x6495EDFF, "Прямой эфир завершён");
				SendClientMessage(TalkingLivels[playerid], 0x6495EDFF, "Прямой эфир завершён");
				TogglePlayerControllable(playerid, 1);
				TogglePlayerControllable(TalkingLivels[playerid], 1);
				TalkingLivels[TalkingLivels[playerid]] = 255;
				TalkingLivels[playerid] = 255;
				return true;
			}
			format(stringer1, sizeof(stringer1), "Вы предложили %s снять интервью",PlayerInfo[params[0]][pName]);
			SendClientMessage(playerid, 0x6495EDFF, stringer1);
			format(stringer1, sizeof(stringer1), "%s предлагает вам снять интервью",PlayerInfo[playerid][pName]);
			SendClientMessage(params[0], 0x6495EDFF, stringer1);
			SendClientMessage(params[0], COLOR_WHITE, "Введите /accept livels, чтобы согласиться");
			LiveOfferls[params[0]] = playerid;
		}
	}
	return true;
}
CMD:npanel(playerid, params[])
{
	if(GetVehicleModel(GetPlayerVehicleID(playerid)) == 582 || GetVehicleModel(GetPlayerVehicleID(playerid)) == 488 || PlayerToPoint(15.0,playerid,662.8426,-1359.6340,13.6099)) {
		if(PlayerInfo[playerid][pMember] == 16) ShowPlayerDialog(playerid,2224, DIALOG_STYLE_LIST, "[ NEWS MENU ]", " [ 1 ] Прямой эфир\n [ 2 ] Выйти из прямого эфира\n [ 3 ] Начать принимать звонки / смс\n [ 4 ] Завершить принимать звонки / смс\n [ 5 ] Установить цену за звонки и смс\n [ 6 ] Установить цену за объявления\n [ 7 ] Обьявления", "Принять", "Скрыть"); }
	else return SendClientMessage(playerid, COLOR_GREY, "Вы не в служебном транспорте/офисе!");
	return true;
}
CMD:sellbiz(playerid, params[])
{
	if(PlayerInfo[playerid][pPbiskey] != 255)
	{
		new bouse = PlayerInfo[playerid][pPbiskey];
		if(PlayerToPoint(3, playerid,Business[bouse][bEntranceX], Business[bouse][bEntranceY], Business[bouse][bEntranceZ])) SellBizz(playerid);
	}
	else return SendClientMessage(playerid,COLOR_GREY,"У вас нету бизнеса.");
	return true;
}
CMD:advertise(playerid, params[])
{
	if(sscanf(params, "s[128]",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} (/ad)vertise [текст]");
	if(PlayerInfo[playerid][pMuted] == 1) return SendMes(playerid, TEAM_CYAN_COLOR, "У Вас заблокирован чат, Вы не можете разговаривать. До снятия: %d секунд", PlayerInfo[playerid][pMuteTime]);
	if(adverttime > 0) return SendClientMessage(playerid,COLOR_WHITE,"Попробуйте попозже!");
	if(IsIpFound(params[0]))
	{
		PlayerInfo[playerid][pMuteTime] = 180;
		PlayerInfo[playerid][pMuted] = 1;
		format(stringer1, sizeof(stringer1), "%s: %s",PlayerInfo[playerid][pName],params[0]);
		ABroadCast(COLOR_LIGHTRED,stringer1,1);
		new ip[14];
		GetPlayerIp(playerid,ip,14);
		format(stringer1, sizeof(stringer1), "- ID: %d | IP: [%s]",playerid,ip);
		ABroadCast(COLOR_LIGHTRED,stringer1,1);
		SendMes(playerid, COLOR_LIGHTRED, "Сервер заблокировал Вам чат на 3 минуты ( /mm => Репорт )");
		return true;
	}
	strmid (ReportQ[playerid],params[0], 0, strlen(params[0]), 255);
	format(stringer,sizeof(stringer),"{9ACD32}Вы собираетесь отправить объявление:\n               {9ACD32}%s\n\n{9ACD32}Стоимость:{FFFFFF} %i вирт\n\n\n{9ACD32}Объявление будет подано после того когда вы нажмёте `Отправить`!\nСпасибо что воспользовались услугами Select San Andreas News",params[0],strlen(params[0])*addd);
	ShowPlayerDialog(playerid,8454,DIALOG_STYLE_MSGBOX,"{FFFFFF}Проверка",stringer,"Отправить","Скрыть");
	return true;
}
CMD:vipad(playerid, params[])
{
	if(sscanf(params, "s[128]",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /v(ip)ad [текст]");
	if(PlayerInfo[playerid][pMuted] == 1) return SendMes(playerid, TEAM_CYAN_COLOR, "У Вас заблокирован чат, Вы не можете разговаривать. До снятия: %d секунд", PlayerInfo[playerid][pMuteTime]);
	if(adverttime > 0) return SendClientMessage(playerid,COLOR_WHITE,"Попробуйте попозже!");
	if(PlayerInfo[playerid][pDonateRank] != 3) return SendClientMessage(playerid,COLOR_WHITE,"Нужен GOLD VIP аккаунт!");
	if(IsIpFound(params[0]))
	{
		PlayerInfo[playerid][pMuteTime] = 180;
		PlayerInfo[playerid][pMuted] = 1;
		format(stringer1, sizeof(stringer1), "%s: %s",PlayerInfo[playerid][pName],params[0]);
		ABroadCast(COLOR_LIGHTRED,stringer1,1);
		new ip[14];
		GetPlayerIp(playerid,ip,14);
		format(stringer1, sizeof(stringer1), "- ID: %d | IP: [%s]",playerid,ip);
		ABroadCast(COLOR_LIGHTRED,stringer1,1);
		SendMes(playerid, COLOR_LIGHTRED, "Сервер заблокировал Вам чат на 3 минуты ( /mm - Репорт )");
		return true;
	}
	format(stringer,sizeof(stringer),"{FFD700}« VIP Radio » %s. Прислал: %s[%d]. Телефон: %d",params[0],PlayerInfo[playerid][pName],playerid,PlayerInfo[playerid][pPnumber]);
	SendClientMessageToAll(COLOR_WHITE,stringer);
	FracBank[0][fLsnews] += strlen(params[0])*addd;
	PlayerInfo[playerid][pCash] -= strlen(params[0])*addd;
	format(stringer,sizeof(stringer), "~r~-$%d", strlen(params[0])*addd);
	GameTextForPlayer(playerid, stringer, 5000, 1);
	adverttime = 20;
	return true;
}
CMD:viphelp(playerid, params[])
{
	SendClientMessage(playerid, 0xCD7F32FF, "Bronze VIP :: /admins");
	SendClientMessage(playerid, 0xC0C0C0FF, "Silver VIP :: /togphone - Выключить телефон");
	SendClientMessage(playerid, 0xFFD700FF, "Gold VIP :: /fstyle - стиль боя, /leave - уволится из фракции, /v(ip)ad - VIP обьявление");
	return true;
}
CMD:pay(playerid, params[])
{
	if(sscanf(params,"dd",params[0],params[1])) return SendClientMessage(playerid, COLOR_GREY, "/pay [ID игрока] [сумма]");
	if(!IsPlayerConnected(params[0]) || playerid == params[0]) return SendClientMessage(playerid, COLOR_GREY, "Неверный ID игрока");
	if(!ProxDetectorS(8.0, playerid, params[0]) || GetPlayerVirtualWorld(playerid) != GetPlayerVirtualWorld(params[0])) return SendClientMessage(playerid,COLOR_WHITE,"Вы далеко друг от друга");
	if(PlayerInfo[playerid][pPayDayHad] < 4) return SendClientMessage(playerid, COLOR_GREY, "Вы должны пробыть в игре ещё 3 часа.");
	if(params[1] < 1 || params[1] > 100000) return SendClientMessage(playerid, COLOR_GREY, "Можно передавать от 1 до 100000$");
	if(GetPlayerMoney(playerid) < params[1]) return SendClientMessage(playerid, COLOR_GREY, "У Вас недостаточно денег");
	format(stringer1,sizeof(stringer1),"%s | передал Вам | %d вирт",PlayerInfo[playerid][pName],params[1]);
	SendClientMessage(params[0], -1, stringer1);
	format(stringer1,sizeof(stringer1),"Вы передали %s | %d вирт",PlayerInfo[params[0]][pName],params[1]);
	SendClientMessage(playerid, -1, stringer1);
	format(stringer1,sizeof(stringer1),"достал деньги и передал их %s",PlayerInfo[params[0]][pName]);
	MeAction(playerid,stringer1);
	ApplyAnimation(playerid, "INT_SHOP", "shop_pay", 4.1, 0, 0, 0, 0,0,1);
	PlayerInfo[playerid][pCash] -= params[1];
	PlayerInfo[params[0]][pCash] += params[1];
	return true;
}
CMD:selldrugs(playerid, params[])
{
	if(IsAGang(playerid))
	{
		if(PlayerInfo[playerid][pRank] < 3) return SendClientMessage(playerid, COLOR_GREY, "Функция доступна с 3 ранга и выше!");
		new full = 0;
		for(new i =0;i<sizeof(GZInfo);i++)
		{
			if(PlayerToKvadrat(playerid,GZInfo[i][gCoords][0], GZInfo[i][gCoords][1],GZInfo[i][gCoords][2],GZInfo[i][gCoords][3]))
			{
				if(GZInfo[i][gFrak] != PlayerInfo[playerid][pMember]) return SendClientMessage(playerid, COLOR_GREY, "Продавать наркотики можно только на своих зонах!");
				if(sscanf(params, "dii", params[0], params[1], params[2])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /selldrugs [id игрока] [грамм] [цена]");
				if(gPlayerLogged[params[0]] == 0 || !IsPlayerConnected(params[0])) return SendClientMessage(playerid,COLOR_GREY,"Игрок не авторизирован.");
				if(!ProxDetectorS(8.0, playerid, params[0])) return SendClientMessage(playerid, COLOR_GREY, "Игрок слишком далеко!");
				if(params[1] < 1 || params[1] > 100) return SendClientMessage(playerid, COLOR_GREY, "Кол-во грамм от 1 до 100!");
				if(params[2] < 1 || params[2] > 20000) return SendClientMessage(playerid, COLOR_GREY, "Цена от 1 до 20000 доллара(ов)!");
				if(PlayerInfo[playerid][pDrugs] < params[1]) return SendClientMessage(playerid, COLOR_GREY, "Недостаточно кол-во наркотиков!");
				format(stringer1,144,"Вы предложили %s'у купить наркотики (Грамм: %i). Цена: %i вирт", PlayerInfo[params[0]][pName],params[1], params[2]), SendClientMessage(playerid,0x6495EDFF, stringer1);
				format(stringer1, 144, "%s предложил вам купить наркотики (Грамм: %i). Цена: %i вирт", PlayerInfo[playerid][pName],params[1], params[2]);
				ShowPlayerDialog(params[0], 1006, 0, "Наркотики", stringer1, "Да", "Нет");
				SetPVarInt(params[0], "PlayerDrugs", playerid);
				SetPVarInt(params[0], "PlayerDrugsKG", params[1]);
				SetPVarInt(params[0], "DrugsPrice", params[2]);
				full++;
				break;
			}
		}
		if(full == 0) SendClientMessage(playerid, COLOR_GREY, "Продавать наркотики можно только в гетто!");
	}
	else SendClientMessage(playerid, COLOR_GREY, YouCanNot);
	return true;
}
CMD:sellgun(playerid, params[])
{
	if(IsAGang(playerid))
	{
		if(PlayerInfo[playerid][pRank] < 2) return SendClientMessage(playerid, COLOR_GREY, "Функция доступна с 3 ранга и выше!");
		new full = 0;
		for(new i =0;i<sizeof(GZInfo);i++)
		{
			if(PlayerToKvadrat(playerid,GZInfo[i][gCoords][0], GZInfo[i][gCoords][1],GZInfo[i][gCoords][2],GZInfo[i][gCoords][3]))
			{
				if(GZInfo[i][gFrak] != PlayerInfo[playerid][pMember]) return SendClientMessage(playerid, COLOR_GREY, "Продавать оружие можно только на своих зонах!");
				if(sscanf(params, "diii", params[0], params[1], params[2], params[3])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /sellgun [id игрока] [id оружия] [патроны] [цена]");
				if(gPlayerLogged[params[0]] == 0 || !IsPlayerConnected(params[0])) return SendClientMessage(playerid,COLOR_GREY,"Игрок не авторизирован.");
				if(params[1] == 24 || params[1] == 25 || params[1] == 29 || params[1] == 23 || params[1] == 30 || params[1] == 31 || params[1] == 33)
				{
					if(params[2] < 1 || params[2] > 350) return SendClientMessage(playerid, COLOR_GREY, "Кол-во патронов от 1 до 350!");
					if(params[3] < 1 || params[3] > 20000) return SendClientMessage(playerid, COLOR_GREY, "Цена от 1 до 20000 доллара(ов)!");
					if(!ProxDetectorS(8.0, playerid, params[0])) return SendClientMessage(playerid, COLOR_GREY, "Игрок слишком далеко!");
					if(PlayerInfo[playerid][pMats] < params[2]) return SendClientMessage(playerid, COLOR_GREY, "У вас недостаточно материалов!");
					format(stringer1,128,"Вы предложили %s'у купить оружие %s (%i) с %i патронами. Цена: %i вирт", PlayerInfo[params[0]][pName], WeaponNames[params[1]], params[1], params[2], params[3]), SendClientMessage(playerid,0x6495EDFF, stringer1);
					format(stringer1, 127, "%s предложил вам купить оружие %s (%i) с %i патронами. Цена: %i вирт\n\nВы согласны?", PlayerInfo[playerid][pName],WeaponNames[params[1]], params[1], params[2], params[3]);
					ShowPlayerDialog(params[0], 1007, 0, "Оружие", stringer1, "Да", "Нет");
					SetPVarInt(params[0], "PlayerGun", playerid);
					SetPVarInt(params[0], "PlayerGun_", params[1]);
					SetPVarInt(params[0], "PlayerGAmmo", params[2]);
					SetPVarInt(params[0], "PlayerGPrice", params[3]);
					full++;
					break;
				}
				else return SendClientMessage(playerid, COLOR_GREY, "Неверный ID оружия! ID оружия: 23, 24, 25, 29, 30, 31, 33");
			}
		}
		if(full == 0) SendClientMessage(playerid, COLOR_GREY, "Продавать оружие можно только в гетто!");
	}
	return true;
}
CMD:mxpell(playerid, params[])
{
	if(PlayerInfo[playerid][pMember] != 7) return SendClientMessage(playerid,COLOR_WHITE,"Вы не сотрудник мэрии!");
	if(sscanf(params, "ds[128]",params[0],params[1])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /mxpell [id] [причина]");
	if(!ProxDetectorS(15.0, playerid, params[0])) return SendClientMessage(playerid, COLOR_GREY, "Игрок слишком далеко!");
	if(IsACop(params[0]) || IsAArm(params[0]) || PlayerInfo[params[0]][pMember] == 4 || PlayerInfo[params[0]][pMember] == 7) return SendClientMessage(playerid, COLOR_RED, "Вы не можете выгнать Госсударственного работника!");
	if(PlayerToPoint(60.0,playerid,360.8623,173.5765,1009.1094))
	{
		SetPlayerInterior(params[0],0);
		SetPlayerPos(params[0],1480.8832,-1769.0471,18.7958);
		SetPlayerFacingAngle(params[0], 0.3133);
		DisablePlayerCheckpoint(params[0]);
		CP[params[0]] = 0;
		SetPVarInt(params[0],"MerEnter",gettime()+300);
		format(stringer1,100,"Сотрудник: %s выставил Вас за дверь Мэрии. Причина: %s",PlayerInfo[playerid][pName],params[1]);
		SendClientMessage(params[0],COLOR_WHITE,stringer1);
		format(stringer1,100,"Вы выстовили %s за дверь.",PlayerInfo[params[0]][pName]);
		SendClientMessage(playerid,COLOR_WHITE,stringer1);
	}
	return true;
}
CMD:axpell(playerid, params[])
{
	if(PlayerInfo[playerid][pMember] != 11) return SendClientMessage(playerid,COLOR_WHITE,"Вы не сотрудник мэрии!");
	if(sscanf(params, "ds[128]",params[0],params[1])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /axpell [id] [причина]");
	if(!ProxDetectorS(15.0, playerid, params[0])) return SendClientMessage(playerid, COLOR_GREY, "Игрок слишком далеко!");
	if(IsACop(params[0]) || IsAArm(params[0]) || PlayerInfo[params[0]][pMember] == 4 || PlayerInfo[params[0]][pMember] == 7) return SendClientMessage(playerid, COLOR_RED, "Вы не можете выгнать Госсударственного работника!");
	if(PlayerToPoint(30.0,playerid,-2028.7372,-116.0282,1035.1719))
	{
		PlayerInfo[params[0]][pInt] = 0;
		SetPlayerInterior(params[0],0);
		SetPlayerVirtualWorld(params[0], 0);
		SetPlayerPos(params[0],-2026.9436,-99.6266,35.1641);
		SetPlayerFacingAngle(params[0], 355.8038);
		DisablePlayerCheckpoint(params[0]);
		SetPVarInt(params[0],"AvtoEnter",gettime()+300);
		format(stringer1,100,"Сотрудник: %s выставил Вас за дверь Автошколы. Причина: %s",PlayerInfo[playerid][pName],params[1]);
		SendClientMessage(params[0],COLOR_WHITE,stringer1);
		format(stringer1,100,"Вы выстовили %s за дверь.",PlayerInfo[params[0]][pName]);
		SendClientMessage(playerid,COLOR_WHITE,stringer1);
	}
	return true;
}
CMD:giverank(playerid, params[])
{
	if(!IsAbleToGiveSkin(playerid)) return SendClientMessage(playerid,COLOR_WHITE,"Ваш ранг недостаточен");
	if(sscanf(params, "dd",params[0],params[1])) return    SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /giverank [id] [ранг]");
	switch(PlayerInfo[playerid][pMember])
	{
	case 1,10,3,19,21: if(params[1] > 14 || params[1] < 1) return SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 и больше 14!");
	case 2,26,4,5,6,11,12,13,14,15,17,18,22,24,25: if(params[1] > 9 || params[1] < 1) return SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 и больше 9!");
	case 7: if(params[1] > 5 || params[1] < 1) return SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 и больше 5!");
	case 27: if(params[1] > 4 || params[1] < 1) return SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 и больше 4!");
	case 16: if(params[1] > 12 || params[1] < 1) return SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 и больше 12!");
	case 23: if(params[1] > 11 || params[1] < 1) return SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 и больше 11!");
	}
	if(!IsPlayerConnected(params[0]) || params[0] == INVALID_PLAYER_ID || params[0] == playerid) return true;
	if(PlayerInfo[params[0]][pLeader] >= 1) return SendClientMessage(playerid, COLOR_GREY, "[Ошибка] Вы указали ID лидера");
	if(PlayerInfo[playerid][pMember] != PlayerInfo[params[0]][pMember]) return SendClientMessage(playerid, COLOR_GREY, "Данный игрок не в вашей фракции!");
	if(PlayerInfo[playerid][pMember] > 0 && PlayerInfo[playerid][pRank] <= params[1]) return SendClientMessage(playerid,COLOR_GREY,"Ошибка");
	if(PlayerInfo[playerid][pLeader] <= 0 && PlayerInfo[playerid][pRank] <=  PlayerInfo[params[0]][pRank]) return SendClientMessage(playerid, COLOR_GREY, "Ошибка");
	format(stringer1, sizeof(stringer1), "Вас повысил/понизил до %d ранга %s",params[1], PlayerInfo[playerid][pName]);
	SendClientMessage(params[0], 0x6BB3FFAA, stringer1);
	format(stringer1, sizeof(stringer1), "Вы повысили %s до %d ранга.", PlayerInfo[params[0]][pName],params[1]);
	SendClientMessage(playerid, 0x6BB3FFAA, stringer1);
	PlayerInfo[params[0]][pRank] = params[1];
	return true;
}
CMD:uninvite(playerid, params[])
{
	if(!IsPlayerConnected(playerid)) return true;
	if(sscanf(params, "ds[64]",params[0],params[1])) return SendClientMessage(playerid, COLOR_GRAD2, " Используйте: /uninvite [id] [причина]");
	if(PlayerInfo[playerid][pRank] == PlayerInfo[params[0]][pRank]) return SendClientMessage(playerid, COLOR_GREY, "[Ошибка] Вы не можете уволить этого игрока");
	if(params[0] == playerid) return SendClientMessage(playerid,-1,"Себя невозможно уволить");
	if(PlayerInfo[params[0]][pMember] == PlayerInfo[playerid][pLeader] || PlayerInfo[params[0]][pMember] == PlayerInfo[playerid][pMember])
	{
		if(!IsPlayerConnected(params[0])) return true;
		if(!CanUninvitePlayer(playerid,params[0])) return true;
		if(PlayerInfo[params[0]][pMember] <= 0) return true;
		format(stringer1, sizeof(stringer1), "%s выгнал вас из организации. Причина: %s",PlayerInfo[playerid][pName],params[1]);
		SendClientMessage(params[0], 0x6495EDFF, stringer1);
		format(stringer1, sizeof(stringer1), "Вы выгнали %s из организации с причиной: %s",PlayerInfo[params[0]][pName],params[1]);
		SendClientMessage(playerid, 0x6495EDFF, stringer1);
		PlayerInfo[params[0]][pMember] = 0;
		PlayerInfo[params[0]][pLeader] = 0;
		PlayerInfo[params[0]][pRank] = 0;
		SetPlayerArmour(params[0],0);
		Delgun(params[0]);
		SetPlayerColor(params[0], 0xFFFFFF20);
		SetPlayerSkin(params[0], PlayerInfo[params[0]][pChar]);
		format(stringer1, sizeof(stringer1), "[Лидер/Заместитель] %s[%d] уволил из организации %s[%d]. Причина: %s", PlayerInfo[playerid][pName], playerid,PlayerInfo[params[0]][pName], params[0], params[1]);
		ABroadCast(COLOR_GREY,stringer1,1);
	}
	return true;
}
CMD:sms(playerid, params[])
{
	if(PlayerInfo[playerid][pPayDayHad] < 2) return SendClientMessage(playerid, COLOR_GREY, "Вы должны пробыть в игре ещё 2 часа.");
	if(sscanf(params, "ds[128]",params[0],params[1])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /sms [id] [текст]");
	if(gag[playerid] == 1) return SendClientMessage(playerid, COLOR_WHITE, "Ошибка: У вас стоит кляп");
	if(PlayerInfo[playerid][pMuted] == 1) return SendMes(playerid, COLOR_LIGHTRED, "У Вас заблокирован чат, Вы не можете разговаривать. До снятия: %d секунд", PlayerInfo[playerid][pMuteTime]);
	if(takephone[playerid] == 1) return SendClientMessage(playerid, COLOR_LIGHTRED, "У Вас нет телефона");
	if(IsIpFound(params[1]))
	{
		PlayerInfo[playerid][pMuteTime] = 180;
		PlayerInfo[playerid][pMuted] = 1;
		format(stringer1, sizeof(stringer1), "%s: %s",PlayerInfo[playerid][pName],params[1]);
		ABroadCast(COLOR_LIGHTRED,stringer1,1);
		new ip[14];
		GetPlayerIp(playerid,ip,14);
		format(stringer1, sizeof(stringer1), "- ID: %d | IP: [%s]",playerid,ip);
		ABroadCast(COLOR_LIGHTRED,stringer1,1);
		SendMes(playerid, COLOR_LIGHTRED, "Сервер заблокировал Вам чат на 3 минуты ( /mm - Репорт )");
		return true;
	}
	switch (params[0])
	{
	case 11888:
		{
			if(smsls == 0) return SendClientMessage(playerid, COLOR_GREY, "Приём SMS отключен");
			if(PlayerInfo[playerid][pBank] <= 0)
			{
				format(stringer1, sizeof(stringer1), "[Исходящее SMS]: %s | Получатель: San Andreas News",params[1]);
				SendClientMessage(playerid,  COLOR_YELLOW, stringer1);
				SendClientMessage(playerid,  COLOR_GRAD1, "Сообщение не доставлено, не достаточно средств");
				format(stringer1, sizeof(stringer1), "%s достаёт мобильник", PlayerInfo[playerid][pName]);
				SetPlayerChatBubble(playerid,stringer1,COLOR_YELLOW,5.0,10000);
				return true;
			}
			format(stringer1, sizeof(stringer1), "[Эфир] %s. Отправитель: %s[%i]",params[1],PlayerInfo[playerid][pName], playerid);
			SendFamilyMessage(16, COLOR_YELLOW, stringer1);
			format(stringer1, sizeof(stringer1), "[Исходящее SMS]: %s | Получатель: San Andreas News",params[1]);
			SendClientMessage(playerid,  COLOR_YELLOW, stringer1);
			PlayerInfo[playerid][pMobile] -= smspricels;
			FracBank[0][fLsnews] += smspricels;
		}
	}
	if(IsPlayerConnected(params[0]))
	{
		if(params[0] != INVALID_PLAYER_ID)
		{
			if(PhoneOnline[params[0]] > 0)
			{
				SendClientMessage(playerid, COLOR_GREY, "Телефон абонента выключен...");
				format(stringer1, sizeof(stringer1), "%s достаёт мобильник", PlayerInfo[playerid][pName]);
				SetPlayerChatBubble(playerid,stringer1,COLOR_YELLOW,5.0,10000);
				return true;
			}
			PlayerInfo[playerid][pBank] -=20;
			format(stringer1, sizeof(stringer1), "[Входящее SMS]: %s | Отправитель: %s[%d]",params[1],PlayerInfo[playerid][pName], playerid);
			SendClientMessage(params[0], COLOR_YELLOW, stringer1);
			PlayerForeach(i)
			{
				if(BigEarSms[i] != 0)
				{
					format(stringer1, sizeof(stringer1), "» Входящее к %s[%d]: %s. Отправитель: %s[%d].",PlayerInfo[params[0]][pName],params[0],params[1],PlayerInfo[playerid][pName],playerid);
					SendClientMessage(i, COLOR_YELLOW, stringer1);
				}
			}
			PlayerPlaySound(params[0], 1052, 0.0, 0.0, 0.0);
			PlayerPlaySound(playerid, 1052, 0.0, 0.0, 0.0);
			format(stringer1, sizeof(stringer1), "[Исходящее SMS]: %s | Получатель: %s[%d]",params[1], PlayerInfo[params[0]][pName], params[0]);
			SendClientMessage(playerid,  COLOR_YELLOW, stringer1);
			format(stringer1, sizeof(stringer1), "%s отправил(а) смс сообщение", PlayerInfo[playerid][pName]);
			SetPlayerChatBubble(playerid,stringer1,COLOR_YELLOW,5.0,10000);
			return true;
		}
	}
	return true;
}
CMD:tazer(playerid, params[])
{
	if(IsACop(playerid) || PlayerInfo[playerid][pMember] == 7 && PlayerInfo[playerid][pRank] == 3 && PlayerInfo[playerid][pRank] == 4 || PlayerInfo[playerid][pMember] == 11 || PlayerInfo[playerid][pMember] == 8 && PlayerInfo[playerid][pRank] == 2)
	{
		if(IsPlayerInAnyVehicle(playerid)) return SendClientMessage(playerid, COLOR_GREY, "Невозможно использовать в машине!");
		if(Tazer[playerid] == 1) return  SendClientMessage(playerid, COLOR_GREY, "Перезарядка тайзера ещё не прошла!");
		new suspect = GetClosestPlayer(playerid);
		if(GetDistanceBetweenPlayers(playerid,suspect) < 5)
		{
			if(IsPlayerInAnyVehicle(suspect)) return SendClientMessage(playerid, COLOR_GREY, "Человек в машине");
			if(PlayerTied[playerid] > 0)  return SendClientMessage(playerid, COLOR_GREY, "Вы связаны!");
			if(PlayerCuffed[suspect] >= 1) return SendClientMessage(playerid, COLOR_RED, "Игрок уже оглушён!");
			if(IsACop(suspect) || IsAArm(suspect) || PlayerInfo[suspect][pMember] == 4 || PlayerInfo[suspect][pMember] == 7) return SendClientMessage(playerid, COLOR_RED, "Вы не можете ударить электрошокером Госсударственного работника!");
			format(stringer1, sizeof(stringer1), "Вас обездвижил электрошокером %s на 15 секунд",PlayerInfo[playerid][pName]);
			SendClientMessage(suspect, 0x6495EDFF, stringer1);
			format(stringer1, sizeof(stringer1), "Вы обездвижили электрошокером %s на 15 секунд",PlayerInfo[suspect][pName]);
			SendClientMessage(playerid, 0x6495EDFF, stringer1);
			format(stringer1, sizeof(stringer1), "%s проводит задержание %s", PlayerInfo[playerid][pName],PlayerInfo[suspect][pName]);
			ProxDetector(25.0, playerid, stringer1, COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW);
			SetPlayerSpecialAction(suspect,SPECIAL_ACTION_HANDSUP);
			TogglePlayerControllable(suspect, 0);
			PlayerCuffed[suspect] = 1; PlayerCuffedTime[suspect] = 15;  Tazer[playerid] = 1; TazerTime[playerid] = 15;
		}
		else return SendClientMessage(playerid, COLOR_GREY, "Рядом с тобой никого нет");
	}
	return true;
}
CMD:ftazer(playerid, params[])
{
	if(PlayerInfo[playerid][pMember] != 2 || PlayerInfo[playerid][pLeader] != 2 || !IsACop(playerid)) return true;
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid,COLOR_WHITE,"{FFA200}[Подсказка]: {FFFFFF} /ftazer [1/2/3]");
	switch(params[0])
	{
	case 1:
		{
			format(stringer1, sizeof(stringer1), "Агент FBI %s оглушил всех",PlayerInfo[playerid][pName]);
			ProxDetector(20.0, playerid, stringer1, COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW);
			PlayerForeach(i)
			{
				new Float:X,Float:Y,Float:Z;
				GetPlayerPos(playerid,X,Y,Z);
				if(IsPlayerInRangeOfPoint(i,20,X,Y,Z) && i != playerid)
				{
					SendClientMessage(i,-1,"Вы заморожены на 15 секунд");
					ApplyAnimation(i,"PED","handsup",4.1,0,1,1,1,0,0);
					PlayerCuffed[i] = 1;
					PlayerCuffedTime[i] = 15;
				}
			}
		}
	case 2:
		{
			format(stringer1, sizeof(stringer1), "Агент FBI %s оглушил всех рядомстоящих законников",PlayerInfo[playerid][pName]);
			ProxDetector(20.0, playerid, stringer1, COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW);
			PlayerForeach(i)
			{
				new Float:X,Float:Y,Float:Z;
				GetPlayerPos(playerid,X,Y,Z);
				if(IsPlayerInRangeOfPoint(i,20,X,Y,Z) && i != playerid)
				{
					if(IsAArm(i) || IsACop(i) || IsAMedic(i))
					{
						SendClientMessage(i,-1,"Вы заморожены на 15 секунд");
						ApplyAnimation(i,"PED","handsup",4.1,0,1,1,1,0,0);
						PlayerCuffed[i] = 1;
						PlayerCuffedTime[i] = 15;
					}
				}
			}
		}
	case 3:
		{
			format(stringer1, sizeof(stringer1), "Агент FBI %s оглушил всех рядомстоящих жителей", PlayerInfo[playerid][pName]);
			ProxDetector(20.0, playerid, stringer1, COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW);
			PlayerForeach(i)
			{
				new Float:X,Float:Y,Float:Z;
				GetPlayerPos(playerid,X,Y,Z);
				if(IsPlayerInRangeOfPoint(i,20,X,Y,Z) && i != playerid)
				{
					if(PlayerInfo[i][pMember] == 0 || IsAGang(i) || ISAMAFIA(i))
					{
						SendClientMessage(i,-1,"Вы заморожены на 15 секунд");
						ApplyAnimation(i,"PED","handsup",4.1,0,1,1,1,0,0);
						PlayerCuffed[i] = 1;
						PlayerCuffedTime[i] = 15;
					}
				}
			}
		}
	}
	return true;
}
CMD:duty(playerid, params[])
{
	if(PlayerInfo[playerid][pMember] != 11 && PlayerInfo[playerid][pMember] != 27) return SendClientMessage(playerid, COLOR_GRAD1, "Вы не состоите в автошколе или казино!");
	if(PlayerInfo[playerid][pMember] == 11)
	{
		if(!IsPlayerInRangeOfPoint(playerid,25,1195.9542,1339.5466,1501.6549)) return SendClientMessage(playerid, COLOR_GRAD1, "Вы не в автошколе!");
		if(GetPVarInt(playerid,"DutyAsh") == 0) format(stringer1, sizeof(stringer1), "Инструктор %s приступил(а) к работе",PlayerInfo[playerid][pName]), SetPVarInt(playerid,"DutyAsh",1);
		else format(stringer1, sizeof(stringer1), "Инструктор %s завершил(а) рабочий день",PlayerInfo[playerid][pName]), SetPVarInt(playerid,"DutyAsh",0);
		ProxDetector(25.0, playerid, stringer1, COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW);
	}
	return true;
}
CMD:kiss(playerid,params[])
{
	if(PlayerInfo[playerid][pJailTime] > 0) return SendClientMessage(playerid, COLOR_GREY, "Нельзя использовать эту команду в тюрьме.");
	if(GetPlayerState(playerid)!=PLAYER_STATE_ONFOOT) return true;
	params[0]= GetClosestPlayer(playerid);
	if(PlayerInfo[params[0]][pSex] == PlayerInfo[playerid][pSex]) return SendClientMessage(playerid, COLOR_GREY, "Вы не можете его поцеловать.");
	if(!ProxDetectorS(4.0, playerid, params[0])) return SendClientMessage(playerid, COLOR_GREY, "Нет ни кого рядом");
	SetPosInFrontOfPlayer(playerid,params[0],1);
	new Float:a;GetPlayerFacingAngle(playerid,a);
	SetPlayerFacingAngle(params[0],180+a);
	ApplyAnimation(params[0],"BD_FIRE","GRLFRD_KISS_03",4.0,0,0,0,0,0,1);
	ApplyAnimation(playerid,"BD_FIRE","PLAYA_KISS_03",4.0,0,0,0,0,0,1);
	return true;
}
CMD:minet(playerid, params[])
{
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /minet [id]");
	if(!IsPlayerConnected(params[0]) || params[0] == INVALID_PLAYER_ID || playerid == params[0]) return true;
	if(!ProxDetectorS(4.0, playerid, params[0])) return true;
	if(GetPVarInt(playerid,"MinetTime") > gettime()) return SendClientMessage(playerid, -1, "Можно использовать раз в 30 секунд.");
	SetPVarInt(playerid,"MinetTime",gettime()+30);
	ApplyAnimation(params[0],"BLOWJOBZ","BJ_COUCH_END_P",4.1,0,1,1,1,5,1);
	ApplyAnimation(playerid,"BLOWJOBZ","BJ_COUCH_END_W",4.1,0,1,1,1,5,1);
	SendClientMessage(playerid,COLOR_GREEN,"Вы сделали минет");
	SendClientMessage(params[0],COLOR_INDIGO,"Вам сделали минет");
	return true;
}
CMD:iznas(playerid, params[])
{
	if(sscanf(params, "d",params[0])) return	SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /iznas [ID]");
	if(!IsPlayerConnected(params[0]) || params[0] == INVALID_PLAYER_ID || playerid == params[0]) return true;
	if(GetDistanceBetweenPlayers(playerid, params[0]) < 2)
	{
		if(GetPVarInt(playerid,"IznasTime") > gettime()) return SendClientMessage(playerid, -1, "Можно использовать раз в 30 секунд.");
		SetPVarInt(playerid,"IznasTime",gettime()+30);
		SendClientMessage(playerid,0xFF0000AA,"Вы изнасиловали игрока!");
		SendClientMessage(params[0],0x00FF00AA,"Вас изнасиловали!");
		ApplyAnimation(params[0],"SNM","SPANKINGW",4.1,0,1,1,1,1);
		ApplyAnimation(playerid,"SNM","SPANKEDW",4.1,0,1,1,1,1);
	}
	else SendClientMessage(playerid,COLOR_WHITE,"Вы слишком далеко!");
	return 1;
}
CMD:myskill(playerid,params[])
{
	if(sscanf(params,"d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, "/myskill [id]");
	new sendername2[MAX_PLAYER_NAME];
	if(IsPlayerConnected(params[0]))
	{
		if(ProxDetectorS(8.0, playerid, params[0]))
		{
			new Stringm[1100];
			new points[6],rang1[25],rang2[25],rang3[25],rang4[25],rang5[25],rang6[25];
			if(PlayerInfo[playerid][pSDPistol])
			{ format(rang1,sizeof(rang1),"%d%",PlayerInfo[playerid][pSDPistol]); }
			else { format(rang1,sizeof(rang1),"0%"); }
			if(PlayerInfo[playerid][pDesertEagle])
			{ format(rang2,sizeof(rang2),"%d%",PlayerInfo[playerid][pDesertEagle]); }
			else { format(rang2,sizeof(rang2),"0%"); }
			if(PlayerInfo[playerid][pShotGun])
			{ format(rang3,sizeof(rang3),"%d%",PlayerInfo[playerid][pShotGun]); }
			else { format(rang3,sizeof(rang3),"0%"); }
			if(PlayerInfo[playerid][pMP5])
			{ format(rang4,sizeof(rang4),"%d%",PlayerInfo[playerid][pMP5]); }
			else { format(rang4,sizeof(rang4),"0%"); }
			if(PlayerInfo[playerid][pM4])
			{ format(rang5,sizeof(rang5),"%d%",PlayerInfo[playerid][pM4]); }
			else { format(rang5,sizeof(rang5),"0%"); }
			if(PlayerInfo[playerid][pAK47])
			{ format(rang6,sizeof(rang6),"%d%",PlayerInfo[playerid][pAK47]); }
			else { format(rang6,sizeof(rang6),"0%"); }
			points[0] = 100 - PlayerInfo[playerid][pSDPistol];
			points[1] = 100 - PlayerInfo[playerid][pDesertEagle];
			points[2] = 100 - PlayerInfo[playerid][pShotGun];
			points[3] = 100 - PlayerInfo[playerid][pMP5];
			points[4] = 100 - PlayerInfo[playerid][pAK47];
			points[5] = 100 - PlayerInfo[playerid][pM4];
			format(Stringm,1000,"\
		{ffffff}SD Pistol\t%s %s%\n\
		{ffffff}Desert Eagle\t%s %s%\n\
		{ffffff}ShotGun\t%s %s%\n\
		{ffffff}MP5\t\t%s %s%\n\
		{ffffff}AK47\t\t%s %s%\n\
		{ffffff}M4\t\t%s %s%\n",
			ToDevelopSkills(PlayerInfo[playerid][pSDPistol]),rang1,
			ToDevelopSkills(PlayerInfo[playerid][pDesertEagle]),rang2,
			ToDevelopSkills(PlayerInfo[playerid][pShotGun]),rang3,
			ToDevelopSkills(PlayerInfo[playerid][pMP5]),rang4,
			ToDevelopSkills(PlayerInfo[playerid][pAK47]),rang5,
			ToDevelopSkills(PlayerInfo[playerid][pM4]),rang6);
			ShowPlayerDialog(params[0],43,DIALOG_STYLE_MSGBOX,"Выписка из тира",Stringm,"Скрыть","");
			MeAction(playerid,"показывает(а) навыки владения оружием");
			GetPlayerName(playerid, sendername2, sizeof(sendername2));
			format(Stringm, sizeof(Stringm), "%s показывает свои навыки владения оружием", sendername2);
			ProxDetector(10.0, playerid, Stringm, 0xE75480FF,0xE75480FF,0xE75480FF,0xE75480FF,0xE75480FF);
			return true;
		}
	}
	return 1;
}
CMD:fpanel(playerid,params[])
{
	if(PlayerInfo[playerid][pPsbiskey] == 255) return SendClientMessage(playerid,COLOR_GREY,"У вас нету заправки.");
	ShowPlayerDialog(playerid,1523,DIALOG_STYLE_LIST,"Управление заправкой","[1] {32CD32}Открыть{FFFFFF}/{FF0000}Закрыть{FFFFFF} заправку\n[2] Поменять название заправки\n[3] Управление счетом заправки\n[4] Информация о заправке\n\n[5] Изменить цену за единицу продукта\n[6] Изменить цену за единицу бензина\n[7] {FF0000}Продать заправку","Далее","Скрыть");
	return true;
}
CMD:buyfuel(playerid,params[])
{
	if(PlayerInfo[playerid][pPayDayHad] < 4) return SendClientMessage(playerid, COLOR_GREY, "Вы должны пробыть в игре ещё 3 часа.");
	if(PlayerInfo[playerid][pPbiskey] != 255 || PlayerInfo[playerid][pPsbiskey] != 255)  return SendClientMessage(playerid, COLOR_WHITE, "У вас уже есть бизнесс, введите /sellbiz чтобы его продать.");
	if(PlayerInfo[playerid][pBizLic] == 0)  return	SendClientMessage(playerid, COLOR_WHITE, "У Вас нет лицензии на бизнес");
	for(new b = 0; b < sizeof(SBusiness); b++)
	{
		if(PlayerToPoint(10.0, playerid, SBusiness[b][sEntranceX], SBusiness[b][sEntranceY], SBusiness[b][sEntranceZ]) && SBusiness[b][sOwned] == 0)
		{
			if(PlayerInfo[playerid][pBank] < SBusiness[b][sBuyPrice]) return SendClientMessage(playerid,COLOR_GREY,"У вас недостаточно денег в банке.");
			PlayerInfo[playerid][pPsbiskey] = b;
			PlayerInfo[playerid][pJob] = 0;
			PlayerInfo[playerid][pBank] -= SBusiness[b][sBuyPrice];
			SBusiness[b][sOwned] = 1;
			SBusiness[b][sTill] = 100;
			SBusiness[b][sLocked] = 0;
			SBusiness[b][sPriceBenz] = 100;
			strmid(SBusiness[b][sOwner], PlayerInfo[playerid][pName], 0, strlen(PlayerInfo[playerid][pName]), 255);
			SendClientMessage(playerid, COLOR_GREEN, "Поздравляем, вы купили заправку.");
			SendClientMessage(playerid, COLOR_GREEN, "Для уравления заправкой используйте команду /fpanel");
			mysql_format(dbHandle, QUERY, sizeof(QUERY), "UPDATE `"TABLE_SBIZZ"` SET `sOwner` = '%s', `sOwned` = '1' WHERE sID = '%i'",PlayerInfo[playerid][pName],b);
			mysql_function_query(dbHandle, QUERY, false, "", "");
			OnPlayerUpdateRL(playerid);
			SaveSBizz(b);
			UpdateSBizz();
			return true;
		}
	}
	return true;
}
CMD:leave(playerid, params[])
{
	if(PlayerInfo[playerid][pCash] < 200000) return SendClientMessage(playerid, 0x6495EDFF, "Вам необходимо 200.000 вирт для увольнения");
	if(PlayerInfo[playerid][pMember]== 0) return SendClientMessage(playerid,COLOR_WHITE,"Вы не состоите в организации!");
	if(PlayerInfo[playerid][pLeader] > 0) return SendClientMessage(playerid, COLOR_BLUE, "Вы руководитель фракции,поэтому уволится не получится!");
	ShowPlayerDialog(playerid,1119, DIALOG_STYLE_MSGBOX, "Увольнение","Вы действительно хотите покинуть данную организацию за 200000$ ?", "Да", "Нет");
	return true;
}
CMD:offmembers(playerid, params[])
{
	if(PlayerInfo[playerid][pMember] < 1) return SendClientMessage(playerid,-1,"Только для лидеров!");
	mysql_format(dbHandle, QUERY,sizeof(QUERY), "SELECT * FROM `"TABLE_ACCOUNT"` WHERE pMember = '%i'",PlayerInfo[playerid][pLeader]);
	mysql_function_query(dbHandle, QUERY, true, "OnLeaderPanel", "d", playerid);
	return true;
}
CMD:en(playerid, params[])
{
	new carid = GetPlayerVehicleID(playerid);
	if(GetPlayerVehicleID(playerid) == INVALID_VEHICLE_ID) return true;
	if(GetPlayerState(playerid) != PLAYER_STATE_DRIVER) return true;
	if(!IsPlayerInAnyVehicle(playerid)) return SendClientMessage(playerid, COLOR_GREY, "Вы не в машине!");
	new dvig[15],far[15],dver[25],kap[15],bag[15];
	GetVehicleParamsEx(carid,engine,lights,alarm,doors,bonnet,boot,objective);
	if(engine == 1) dvig = "{32CD32}ON";
	else dvig = "{FF0000}OFF";
	if(lights == 1) far = "{32CD32}ON";
	else far = "{FF0000}OFF";
	if(bonnet == 1) kap = "{32CD32}ON";
	else kap = "{FF0000}OFF";
	if(boot == 1) bag = "{32CD32}ON";
	else bag = "{FF0000}OFF";
	if(gCarLock[carid] == 0) dver = "{FF0000}Closed";
	else dver = "{32CD32}Open";
	format(stringer,sizeof(stringer),"[1] » [%s{FFFFFF}] Двигатель\n[2] » [%s{FFFFFF}] Фары\n[3] » [%s{FFFFFF}] Двери\n[4] » [%s{FFFFFF}] Капот\n[5] » [%s{FFFFFF}] Багажник\n[6] » Заправить [канистр: %d]\n[7] » Информация",zavodis,far,dver,kap,bag,PlayerInfo[playerid][pFuel]);
	ShowPlayerDialog(playerid, 8023, DIALOG_STYLE_LIST, "Управление транспортом", stringer, "Далее", "Скрыть");
	return true;
}
CMD:trailer(playerid, params[])
{
	if(PlayerInfo[playerid][pMember] == 1 || PlayerInfo[playerid][pJob] == 2)
	{
		if(!IsPlayerInAnyVehicle(playerid)) return SendClientMessage(playerid, COLOR_GREY, "Вам нужно быть в автомобиле!");
		if(GetVehicleModel(GetPlayerVehicleID(playerid)) != 525) return SendClientMessage(playerid, COLOR_GREY, "Вам нужно быть в эвакуаторе!");
		if(GetPlayerState(playerid)!=2)return SendClientMessage(playerid, COLOR_GREY, "Вам нужно быть за рулём!");
		new Float:pX,Float:pY,Float:pZ;
		new Float:vX,Float:vY,Float:vZ;
		new Found=0,  vid=0;
		GetPlayerPos(playerid,pX,pY,pZ);
		while((vid<MAX_VEHICLES)&&(!Found))
		{
			vid++;
			GetVehiclePos(vid,vX,vY,vZ);
			if((floatabs(pX-vX)<7.0)&&(floatabs(pY-vY)<7.0)&&(floatabs(pZ-vZ)<7.0)&&(vid!=GetPlayerVehicleID(playerid)))
			{
				Found=1;
				if(IsTrailerAttachedToVehicle(GetPlayerVehicleID(playerid))) DetachTrailerFromVehicle(GetPlayerVehicleID(playerid));
				else AttachTrailerToVehicle(vid,GetPlayerVehicleID(playerid));
			}
		}
		if(!Found) SendClientMessage(playerid,0xFFFF00AA,"Рядом нет автомобиля");
	}
	return true;
}
CMD:untrailer(playerid, params[])
{
	new vehplid=GetPlayerVehicleID(playerid);
	DetachTrailerFromVehicle(vehplid);
	SendClientMessage(playerid, 0x6ab1ffaa, "Вы отцепили автомобиль");
	return true;
}
CMD:bizwar(playerid, params[])
{
	new t; gettime(t);
	if(t < 13 || t > 22 ) return SendClientMessage(playerid, 0xAFAFAFAA, "Использовать команду можно только с 13:00 до 23:00");
	if(!ISAMAFIA(playerid)) return SendClientMessage(playerid,COLOR_WHITE,"Вам не доступна данная команда.");
	if(BizWarTime != 0) return SendClientMessage(playerid,COLOR_WHITE,"Война за бизнес уже идет.");
	if(BizHourTime>0) return SendClientMessage(playerid,COLOR_WHITE,"Стрелы за бизнес проходят раз в два часа");
	if(PlayerInfo[playerid][pMember] == 5 && PlayerInfo[playerid][pRank] < 7 || PlayerInfo[playerid][pMember] == 6 && PlayerInfo[playerid][pRank] < 7 || PlayerInfo[playerid][pMember] == 14 && PlayerInfo[playerid][pRank] < 7) return SendClientMessage(playerid,COLOR_WHITE,"Вам не доступна данная команда.");
	if(sscanf(params,"i",params[0])) return SendClientMessage(playerid,COLOR_WHITE,"Введите /bizwar [1-3]");
	if(params[0] < 1 || params[0] > 3) return SendClientMessage(playerid,COLOR_WHITE,"Введите /bizwar [1-3]");
	for(new h = 1; h < sizeof(Business); h++)
	{
		if(IsPlayerInRangeOfPoint(playerid, 5,Business[h][bEntranceX], Business[h][bEntranceY], Business[h][bEntranceZ]))
		{
			if(Business[h][bMafia] == PlayerInfo[playerid][pMember] && Business[h][bMafia] != 0) return SendClientMessage(playerid,COLOR_GREY,"Нельзя напасть на бизнес, который уже под вашим контролем.");
			if(Business[h][bMafia] <= 0)
			{
				Business[h][bMafia] = PlayerInfo[playerid][pMember];
				SendClientMessage(playerid, COLOR_WHITE, "Бизнес взят под контроль");
				return 1;
			}
			new mestoz[21];
			switch(params[0])
			{
			case 1: mestoz = "Заброшенный аэропорт";
			case 2: mestoz = "Дамба";
			case 3: mestoz = "Карьер";
			}
			GangZoneFlashForAll(ZonsWar[params[0]-1],GetColor(MZInfo[bNapad]));
			format(stringer1,200, "%s{FFFFFF} забила вам стрелу, цена которой является бизнес {4169E1}%s{FFFFFF}. Место встречи: %s.", GetMN(PlayerInfo[playerid][pMember]),Business[h][bMessage],mestoz);
			SendFamilyMessage(Business[h][bMafia],COLOR_WHITE,stringer1);
			format(stringer1,200, "Вы забили стрелу мафии {4169E1}%s{FFFFFF} за бизнес {4169E1}%s{FFFFFF}. Место встречи: %s.", GetMN(Business[h][bMafia]),Business[h][bMessage],mestoz);
			SendFamilyMessage(PlayerInfo[playerid][pMember],COLOR_WHITE,stringer1);
			BizWarTime = 600;
			MZInfo[bNapad] = PlayerInfo[playerid][pMember];
			MZInfo[bFrakVlad] = Business[h][bMafia];
			MZInfo[bBiz] = h;
			MZInfo[bType] = 1;
			MZInfo[bMesto] = params[0];
			MZInfo[bCountDead][MZInfo[bNapad]] = 0;
			MZInfo[bCountDead][MZInfo[bFrakVlad]] = 0;
			return 1;
		}
	}
	for(new h = 0; h < sizeof(SBusiness); h++)
	{
		if(IsPlayerInRangeOfPoint(playerid, 3,SBusiness[h][sEntranceX], SBusiness[h][sEntranceY], SBusiness[h][sEntranceZ]) || SBusiness[h][sbMafia] == PlayerInfo[playerid][pMember]) continue;
		if(SBusiness[h][sbMafia] <= 0)
		{
			SBusiness[h][sbMafia] = PlayerInfo[playerid][pMember];
			SendClientMessage(playerid, COLOR_WHITE, "Бизнес взят под контроль");
			return 1;
		}
		new mestoz[21];
		switch(params[0])
		{
		case 1: mestoz = "Заброшенный аэропорт";
		case 2: mestoz = "Дамба";
		case 3: mestoz = "Карьер";
		}
		GangZoneFlashForAll(ZonsWar[params[0]-1],GetColor(MZInfo[bNapad]));
		format(stringer1,200, "%s{FFFFFF} забила вам стрелу, цена которой является бизнес {4169E1}%s{FFFFFF}. Место встречи: %s.", GetMN(PlayerInfo[playerid][pMember]),SBusiness[h][sMessage],mestoz);
		SendFamilyMessage(SBusiness[h][sbMafia],COLOR_WHITE,stringer1);
		format(stringer1,200, "Вы забили стрелу мафии {4169E1}%s{FFFFFF} за бизнес {4169E1}%s{FFFFFF}. Место встречи: %s.", GetMN(SBusiness[h][sbMafia]),SBusiness[h][sMessage],mestoz);
		SendFamilyMessage(PlayerInfo[playerid][pMember],COLOR_WHITE,stringer1);
		BizWarTime = 600;
		MZInfo[bNapad] = PlayerInfo[playerid][pMember];
		MZInfo[bFrakVlad] = SBusiness[h][sbMafia];
		MZInfo[bBiz] = h;
		MZInfo[bType] = 2;
		MZInfo[bMesto] = params[0];
		MZInfo[bCountDead][MZInfo[bNapad]] = 0;
		MZInfo[bCountDead][MZInfo[bFrakVlad]] = 0;
		return 1;
	}
	SendClientMessage(playerid, COLOR_GREY, "Вы должны находится возле бизнеса или заправки.");
	return 1;
}
CMD:bizlist(playerid, params[])
{
	if(!ISAMAFIA(playerid)) return true;
	new stringmafia[712];
	for(new i = 0; i < sizeof(Business); i++)
	{
		if(Business[i][bMafia] != PlayerInfo[playerid][pMember]) continue;
		format(stringmafia, sizeof(stringmafia), "{ffffff}%s%i. %s\n", stringmafia, i, Business[i][bMessage]);
	}
	ShowPlayerDialog(playerid, 0000, DIALOG_STYLE_MSGBOX, "Бизнесы под контролем", stringmafia, "Скрыть", "");
	return true;
}
CMD:bizfee(playerid, params[])
{
	new bouse = PlayerInfo[playerid][pPbiskey];
	if(bouse == 255) return SendClientMessage(playerid, COLOR_GRAD2, "У вас нет бизнеса!");
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_LIGHTRED, "{FFA200}[Подсказка]: {FFFFFF} /bizfee [цена входа/бензина]");
	if(params[0] < 100 || params[0] > 9999)  return SendClientMessage(playerid, COLOR_GREY, "Минимальная цена 100, максимальная 9999 вирт");
	if(bouse != 255)
	{
		Business[bouse][bEntranceCost] = params[0];
		format(stringer1,sizeof(stringer1), "%s\nВладелец:\n %s\nДля входа нажмите клавишу\nL.ALT", Business[bouse][bMessage], Business[bouse][bOwner]);
		Update3DTextLabelText(Business[bouse][bLabel], TEAM_GROVE_COLOR, stringer1);
		format(stringer1, sizeof(stringer1), "Плата за вход %d вирт.", Business[bouse][bEntranceCost]);
		SaveBizz(bouse);
	}
	SendClientMessage(playerid, COLOR_WHITE, stringer1);
	return true;
}
CMD:getbizstats(playerid, params[])
{
	for(new h = 0; h < sizeof(Business); h++) { if(PlayerToPoint(10, playerid,Business[h][bEntranceX], Business[h][bEntranceY], Business[h][bEntranceZ])) {     PrintBizInfo(playerid,h); } }
	return true;
}
CMD:ticket(playerid, params[])
{
	if(!IsACop(playerid)) return SendClientMessage(playerid, COLOR_GREY, "Вы не полицейский!");
	if(sscanf(params, "dds[128]",params[0],params[1],params[2])) return	SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /ticket [id] [цена] [причина]");
	if(params[1] < 1 || params[1] > 10000) { SendClientMessage(playerid, COLOR_GREY, "Штраф не должен привышать 10000 и не должен быть меньше 0 вирт!"); return true; }
	if(!IsPlayerConnected(params[0])) return true;
	if(!ProxDetectorS(8.0, playerid, params[0])) return true;
	if(GetSRVMoney(params[0]) < params[1]) 	return 	SendClientMessage(playerid, COLOR_GRAD1, "У этого  нет столько денег!");
	if(params[0] == playerid) { SendClientMessage(playerid, COLOR_GREY, "[Ошибка] Вы указали свой ID"); return true; }
	format(stringer1, sizeof(stringer1), "Вы выписали штраф в размере %i вирт %s. Причина: %s",params[1],PlayerInfo[params[0]][pName],params[2]);
	SendClientMessage(playerid, COLOR_BLUE, stringer1);
	format(stringer1, sizeof(stringer1), "Офицер %s выписал вам штраф в размере %i вирт. Причина: %s",PlayerInfo[playerid][pName],params[1],params[2]);
	SendClientMessage(params[0], COLOR_BLUE, stringer1);
	SendClientMessage(params[0], COLOR_WHITE, "(( {FFA200}[Подсказка]: {FFFFFF} /accept ticket, чтобы оплатить штраф ))");
	TicketOffer[params[0]] = playerid;
	TicketMoney[params[0]] = params[1];
	return true;
}
CMD:drugs(playerid, params[])
{
	if(sscanf(params, "d", params[0])) return	SendClientMessage(playerid, COLOR_GREY, "{FFA200}[Подсказка]: {FFFFFF} /drugs [количество]");
	new Float:health;
	if(health > 160) return SendClientMessage(playerid, COLOR_GREY, "Вы слишком много употребили");
	if(TeamPain[playerid] != 0 && StartPaintBall == 2) return SendClientMessage(playerid,COLOR_GREY,"Использовать наркотики на PaintBall запрещено.");
	if(PlayerInfo[playerid][pDrugtime] > 0) return  SendClientMessage(playerid,COLOR_GRAD1,"Нельзя слишком часто употреблять наркотик!");
	if(PlayerInfo[playerid][pNarcoLomka] < 3000) { if(params[0] > 3 || params[0] < 1) return SendClientMessage(playerid, COLOR_GRAD1, "Нельзя меньше 1 грамма и больше 3 грамм!"); }
	else if(PlayerInfo[playerid][pNarcoLomka] >= 3000 && PlayerInfo[playerid][pNarcoLomka] < 5000) { if(params[0] > 12 || params[0] < 1) return SendClientMessage(playerid, COLOR_GRAD1, "Нельзя меньше 1 грамма и больше 12 грамм!"); }
	else if(PlayerInfo[playerid][pNarcoLomka] >= 5000) { if(params[0] > 15 || params[0] < 1) return SendClientMessage(playerid, COLOR_GRAD1, "Нельзя меньше 1 грамма и больше 15 грамм!"); }
	if(PlayerInfo[playerid][pDrugs] <= 0) return SendClientMessage(playerid, COLOR_GRAD1, "Недостаточно наркотиков");
	PlayerInfo[playerid][pDrugtime] = 10;
	if(PlayerInfo[playerid][pDrugs] >= params[0])
	{
		if(PlayerInfo[playerid][pNarcoLomka] <= 4000) { SetPlayerTime(playerid,17,0); PlayerStoned[playerid] = 0; }
		if(GetPlayerState(playerid) == PLAYER_STATE_ONFOOT) {    PlayerStoned[playerid] += 1; if(PlayerCuffed[playerid] == 0) { ApplyAnimation(playerid,"SMOKING","M_smk_drag",4.1,0,0,0,0,0,1);    } }
		if(params[0] == 1) { GetPlayerHealth(playerid, health); SetPlayerHealth(playerid, health + 10.0); }
		if(params[0] == 2) { GetPlayerHealth(playerid, health); SetPlayerHealth(playerid, health + 20.0); }
		if(params[0] == 3) { GetPlayerHealth(playerid, health); SetPlayerHealth(playerid, health + 30.0); }
		if(params[0] == 4) { GetPlayerHealth(playerid, health); SetPlayerHealth(playerid, health + 40.0); }
		if(params[0] == 5) { GetPlayerHealth(playerid, health); SetPlayerHealth(playerid, health + 50.0); }
		if(params[0] == 6) { GetPlayerHealth(playerid, health); SetPlayerHealth(playerid, health + 60.0); }
		if(params[0] == 7) { GetPlayerHealth(playerid, health); SetPlayerHealth(playerid, health + 70.0); }
		if(params[0] == 8) { GetPlayerHealth(playerid, health); SetPlayerHealth(playerid, health + 80.0); }
		if(params[0] == 9) { GetPlayerHealth(playerid, health); SetPlayerHealth(playerid, health + 90.0); }
		if(params[0] == 10) { GetPlayerHealth(playerid, health); SetPlayerHealth(playerid, health + 100.0); }
		if(params[0] == 11) { GetPlayerHealth(playerid, health); SetPlayerHealth(playerid, health + 110.0); }
		if(params[0] == 12) { GetPlayerHealth(playerid, health); SetPlayerHealth(playerid, health + 120.0); }
		if(params[0] == 13) { GetPlayerHealth(playerid, health); SetPlayerHealth(playerid, health + 130.0); }
		if(params[0] == 14) { GetPlayerHealth(playerid, health); SetPlayerHealth(playerid, health + 140.0); }
		if(params[0] == 15) { GetPlayerHealth(playerid, health); SetPlayerHealth(playerid, health + 150.0); }
		if(PlayerInfo[playerid][pNarcoLomka] < 2000) {	GetPlayerHealth(playerid, health); SetPlayerHealth(playerid, 120.0); }
		if(PlayerInfo[playerid][pNarcoLomka] >= 2000 && PlayerInfo[playerid][pNarcoLomka] <= 2999) {	GetPlayerHealth(playerid, health); SetPlayerHealth(playerid, 130.0);      }
		if(PlayerInfo[playerid][pNarcoLomka] >= 3000 && PlayerInfo[playerid][pNarcoLomka] <= 3999) {    GetPlayerHealth(playerid, health); SetPlayerHealth(playerid, 140.0);     }
		if(PlayerInfo[playerid][pNarcoLomka] >= 4000 && PlayerInfo[playerid][pNarcoLomka] <= 4999) {    GetPlayerHealth(playerid, health); SetPlayerHealth(playerid, 150.0);     }
		if(PlayerInfo[playerid][pNarcoLomka] >= 5000) SetPlayerHealth(playerid, 160.0);
		PlayerInfo[playerid][pDrugs] -= params[0];
		PlayerInfo[playerid][pNarcoLomka] += params[0]*2;
		usegrugss[playerid] = 1;
		MeAction(playerid,"употребил наркотики");
		narkotimer = SetTimerEx( "NarkoTimer", 10000 , false, "i", playerid);
		if(startnarko[playerid] == 1)
		{
			startnarko[playerid] = 0;
			if(PlayerCuffed[playerid] == 0) {      ApplyAnimation(playerid,"SMOKING","M_smk_drag",4.1,0,0,0,0,0,1); }
			send[playerid] = 0;
		}
	}
	SetPVarInt(playerid,"Antisbiv",1);
	return true;
}
CMD:mafiabalance(playerid, params[])
{
	switch(PlayerInfo[playerid][pMember])
	{
	case 6: return SendMes(playerid, 0x6ab1ffaa, "В банке мафии Yakuza: %d вирт", MafiaBank[0][nYakuza]);
	case 14: return SendMes(playerid, 0x6ab1ffaa, "В банке Русской мафии: %d вирт", MafiaBank[0][nRm]);
	case 5: return SendMes(playerid, 0x6ab1ffaa, "В банке мафии LCN: %d вирт", MafiaBank[0][nLcn]);
	}
	return true;
}
CMD:mafiawithdraw(playerid, params[])
{
	if(PlayerInfo[playerid][pLeader] == 6 || PlayerInfo[playerid][pLeader] == 14 || PlayerInfo[playerid][pLeader] == 5)
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /mafiawithdraw [количество]");
	if(params[0] < 1) { SendClientMessage(playerid, COLOR_GREY, "Неправильный количество денег!"); return true; }
	if(PlayerInfo[playerid][pMember] == 6 && PlayerInfo[playerid][pRank] >= 10)
	{
		if(MafiaBank[0][nYakuza] <= 0) { SendClientMessage(playerid, COLOR_GREY, "В банке мафии Yakuza нет денег"); return true; }
		if(MafiaBank[0][nYakuza] < params[0]) { SendClientMessage(playerid, COLOR_GREY, "В банке мафии Yakuza нет столько денег"); return true; }
		MafiaBank[0][nYakuza] -= params[0];
		PlayerInfo[playerid][pCash] +=params[0];
		format(stringer1, sizeof(stringer1), "Вы сняли с банка мафии Yakuza: %i вирт", params[0]);
		SendClientMessage(playerid, 0x6495EDFF, stringer1);
	}
	else if(PlayerInfo[playerid][pMember] == 14 && PlayerInfo[playerid][pRank] >= 8)
	{
		if(MafiaBank[0][nRm] <= 0) { SendClientMessage(playerid, COLOR_GREY, "В банке Русской мафии нет денег"); return true; }
		if(MafiaBank[0][nRm] < params[0]) { SendClientMessage(playerid, COLOR_GREY, "В банке Русской мафии нет столько денег"); return true; }
		MafiaBank[0][nRm] -= params[0];
		PlayerInfo[playerid][pCash] +=params[0];
		format(stringer1, sizeof(stringer1), "Вы сняли с банка Русской мафии: %i вирт", params[0]);
		SendClientMessage(playerid, 0x6495EDFF, stringer1);
	}
	else if(PlayerInfo[playerid][pMember] == 5 && PlayerInfo[playerid][pRank] >= 10)
	{
		if(MafiaBank[0][nLcn] <= 0) { SendClientMessage(playerid, COLOR_GREY, "В банке мафии LCN нет денег"); return true; }
		if(MafiaBank[0][nLcn] < params[0]) { SendClientMessage(playerid, COLOR_GREY, "В банке мафии LCN нет столько денег"); return true; }
		MafiaBank[0][nLcn] -= params[0];
		PlayerInfo[playerid][pCash] +=params[0];
		format(stringer1, sizeof(stringer1), "Вы сняли с банка мафии LCN: %i вирт", params[0]);
		SendClientMessage(playerid, 0x6495EDFF, stringer1);
	}
	return true;
}
CMD:mafiabankput(playerid, params[])
{
	if(PlayerInfo[playerid][pLeader] == 6 || PlayerInfo[playerid][pLeader] == 14 || PlayerInfo[playerid][pLeader] == 5)
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_WHITE, "{FFA200}[Подсказка]: {FFFFFF} /mafiawithdraw [количество]");
	if(params[0] < 1 || PlayerInfo[playerid][pCash] < params[0]) { SendClientMessage(playerid, COLOR_GREY, "Неправильный количество денег!"); return true; }
	if(PlayerInfo[playerid][pMember] == 6 && PlayerInfo[playerid][pRank] >= 10)
	{
		MafiaBank[0][nYakuza] += params[0];
		PlayerInfo[playerid][pCash] -=params[0];
		format(stringer1, sizeof(stringer1), "Вы положили в банк мафии Yakuza: %i вирт", params[0]);
		SendClientMessage(playerid, 0x6495EDFF, stringer1);
	}
	else if(PlayerInfo[playerid][pMember] == 14 && PlayerInfo[playerid][pRank] >= 8)
	{
		MafiaBank[0][nRm] += params[0];
		PlayerInfo[playerid][pCash] -=params[0];
		format(stringer1, sizeof(stringer1), "Вы положили в банк Русской мафии: %i вирт", params[0]);
		SendClientMessage(playerid, 0x6495EDFF, stringer1);
	}
	else if(PlayerInfo[playerid][pMember] == 5 && PlayerInfo[playerid][pRank] >= 10)
	{
		MafiaBank[0][nLcn] += params[0];
		PlayerInfo[playerid][pCash] -=params[0];
		format(stringer1, sizeof(stringer1), "Вы положили в банк мафии LCN: %i вирт", params[0]);
		SendClientMessage(playerid, 0x6495EDFF, stringer1);
	}
	return true;
