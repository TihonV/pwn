{
	if(IsPlayerConnected(playerid))
	{
		if(PlayerInfo[playerid][pLeader] == 23 || PlayerInfo[playerid][pMember] == 23)
		ShowPlayerDialog(playerid,7763,DIALOG_STYLE_LIST,"Портативный компьютер","{FF0000}\
		[00] Доступные Контракты\n\
		[01] Проверить контракт\n\
