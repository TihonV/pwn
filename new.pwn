CMD:usekey(playerid, params[])
{
	if(IsAGang(playerid))
	{
		if(PlayerInfo[playerid][pJailed] != 1) return SendClientMessage(playerid, COLOR_GRAD1, "Вы не в тюрьме!");
		if(keys[playerid] <=0) return  SendClientMessage(playerid, COLOR_GRAD1, "У Вас нет ключа от тюрьмы!");
		keys[playerid] -=1;
		SetPlayerInterior(playerid, 0);
		PlayerInfo[playerid][pInt] = 0;
		SetPlayerPos(playerid,1553.4962,-1675.2714,16.1953);
		SetPlayerFacingAngle(playerid, 95.0636);
		SendClientMessage(playerid, COLOR_YELLOW, "Вы совершили побег из тюрьмы");
	}
	else return true;
	return true;
}
CMD:heal(playerid, params[])
{
	if(!ProxDetectorS(5.0, playerid, params[0])) SendClientMessage(playerid, COLOR_WHITE, "Игрок не рядом с вами!");
	if(PlayerInfo[playerid][pMember] == 4)
	{
		if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /heal [id]");
		if(params[0] != INVALID_PLAYER_ID)
		{
			if(params[0] == playerid) return	SendClientMessage(playerid, COLOR_GRAD1, "Вы не можете вылечить себя!");
			if(PlayerInfo[playerid][pMember] == 4)
			{
				format(stringer1, sizeof(stringer1), "Вы предложили вылечить %s за %d вирт.",PlayerInfo[params[0]][pName],healpric);
				SendClientMessage(playerid, 0x6ab1ffaa, stringer1);
				new healdialog[40];
				format(healdialog,sizeof(healdialog), "Желаете вылечиться за %d вирт?",healpric);
				ShowPlayerDialog(params[0],5522,DIALOG_STYLE_MSGBOX,"Лечение", healdialog, "Да", "Нет");
				HealOffer[params[0]] = playerid;
				HealPrice[params[0]] = healpric;
			}
			else return SendClientMessage(playerid, COLOR_GRAD1, "Вы не медик!");
		}
	}
	return true;
}
CMD:fare(playerid, params[])
{
	new Veh = GetPlayerVehicleID(playerid);
	if(PlayerInfo[playerid][pJob] == 4)
	{
		if(TransportDuty[playerid] > 0)
		{
			if(TransportDuty[playerid] == 1)
			{
				TaxiDrivers -= 1;
			}
			new moneyyys = 32 + random(2);
			Delete3DTextLabel(taxi3d[Veh]);
			TransportDuty[playerid] = 0;
			SendMes(playerid, 0x6495EDFF, "Вы закончили рабочий день, ваш бонус: %d", moneyyys);
			PlayerInfo[playerid][pCash] +=TransportMoney[playerid];
			TransportValue[playerid] = 0; TransportMoney[playerid] = 0;
			return true;
		}
		if(Veh >= taxicar[0] && Veh <= taxicar[1])
		{
			if(GetPlayerState(playerid) == 2)
			{
				if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " {FFA200}[Подсказка]: {FFFFFF} /fare [тариф]");
				if(params[0] < 1 || params[0] > 1000) { SendClientMessage(playerid, COLOR_GREY, "Не меньше 1 и не больше $1000"); return true; }
				TaxiDrivers += 1;
				TransportDuty[playerid] = 1;
				TransportValue[playerid] = params[0];

				if(Veh >= taxicar[0] && Veh <= taxicar[1])
				{
					format(stringer1, sizeof(stringer1), "{3399ff}Такси\n{ffff00}Тариф: %d$", TransportValue[playerid]);
					taxi3d[Veh] = Create3DTextLabel(stringer1, COLOR_YELLOW, 9999.0, 9999.0, 9999.0, 30.0, 0, 1);
					Attach3DTextLabelToVehicle(taxi3d[Veh], Veh, 0, 0, 1.5);
				}
			}
			else return SendClientMessage(playerid, COLOR_GREY, "{F36223}[!]{ADAEAD}Вы не таксист или вы не в машине.");
		}
		else { SendClientMessage(playerid, COLOR_GREY, "{F36223}[!]{ADAEAD}Вы не начали рабочий день"); }
	}
	else return SendClientMessage(playerid, COLOR_GREY, "{F36223}[!]{ADAEAD}Вы не таксист или вы не в машине.");
	return true;
}
CMD:tune(playerid, params[])
{
	if(!IsATune(playerid)) return SendClientMessage(playerid, COLOR_GREY, "Вы не в автомастерской!");
	{
		if(GetPlayerVehicleID(playerid) != caridhouse[playerid]) return SendClientMessage(playerid, COLOR_GREY, "Вы не за рулём своего транспортного средства!");
		{
			TuneDialog(playerid);
		}
	}
	return true;
}
CMD:carmat(playerid, params[])
{
	switch(PlayerInfo[playerid][pMember])
	{
	case 3:
		{
			if(GetVehicleModel(GetPlayerVehicleID(playerid)) != 548) return  SendClientMessage(playerid,COLOR_GREY,"Вы не в загрузочном вертолёте!");
			SetPlayerCheckpoint(playerid,-1420.4194,1485.6796,11.8084,14.0);
			SendClientMessage(playerid,COLOR_WHITE,"Отправляйтесь на корабль, для загрузки Оружия");
			VertMats[playerid]=1;
		}
	}
	return true;
}
CMD:wantedlist(playerid, params[])
{
	if(PlayerInfo[playerid][pAdmin] < 1) { SendClientMessage(playerid, COLOR_RED, "Вы не уполномочены использовать эту команду!"); return true; }
	PlayerForeach(i)
	{
		if(PlayerInfo[i][pWanted] > 0 && IsPlayerConnected(i))
		{
			format(stringer1, sizeof(stringer1), "%s [ID: %d] | Звезд: %d", PlayerInfo[i][pName], i, PlayerInfo[i][pWanted]);
			SendClientMessage(playerid, COLOR_LIGHTGREEN, stringer1);
		}
	}
	return true;
}
CMD:unfuel(playerid, params[])
{
	new tmpcar = GetPlayerVehicleID(playerid);
	if(PlayerInfo[playerid][pJob] == 5 && PlayerInfo[playerid][pMember] == 0)
	{
		if(GetVehicleModel(GetPlayerVehicleID(playerid)) != 403) return SendClientMessage(playerid,COLOR_GREY,"Вы не в машине!");
		if(PlayersHaul[tmpcar-benzovoz[0]][sLoad] == 0) return SendClientMessage(playerid,COLOR_GREY,"Нет бензина!");
		for(new i = 0; i < sizeof(SBusiness); i++)
		{
			if(PlayerToPoint(15, playerid,SBusiness[i][sEntranceX], SBusiness[i][sEntranceY], SBusiness[i][sEntranceZ]))
			{
				if(SBusiness[i][sLocked] == 1) return SendClientMessage(playerid,COLOR_GREY,"Заправка не работает.");
				if(SBusiness[i][sBenz] == 10000) return SendClientMessage(playerid,COLOR_GREY,"Заправка не требует пополнения скважены.");
				new benz = 10000 - SBusiness[i][sBenz];
				if(PlayersHaul[tmpcar-benzovoz[0]][sLoad] > benz)
				{
					SBusiness[i][sBenz] += benz;
					PlayerInfo[playerid][pCash] += SBusiness[i][sPrice]*benz;
					SendClientMessage(playerid, COLOR_YELLOW2, ":Доставка:");
					SendMes(playerid, COLOR_WHITE, "- Бензин успешно залит в скважену. Зарплата: %d вирт",SBusiness[i][sPrice]*benz);
					SendClientMessage(playerid, COLOR_YELLOW2, ":Доставка:");
					PlayersHaul[tmpcar-benzovoz[0]][sLoad] -= benz;
				}
				else
				{
					SBusiness[i][sBenz] += PlayersHaul[tmpcar-benzovoz[0]][sLoad];
					PlayerInfo[playerid][pCash] += SBusiness[i][sPrice]*PlayersHaul[tmpcar-benzovoz[0]][sLoad];
					SendClientMessage(playerid, COLOR_YELLOW2, ":Доставка:");
					SendMes(playerid, COLOR_WHITE, "- Бензин успешно залит в скважену. Зарплата: %d вирт",SBusiness[i][sPrice]*PlayersHaul[tmpcar-benzovoz[0]][sLoad]);
					SendClientMessage(playerid, COLOR_YELLOW2, ":Доставка:");
					PlayersHaul[tmpcar-benzovoz[0]][sLoad] = 0;
				}
				format(stringer1, sizeof(stringer1), "{FFFF00}%s\n{FFFFFF}Владелец: {32CD32}%s\nБензин: %d/10000\nСтоимость: %d вирт.\n\n{FFFFFF}[{32CD32}Заправка работает{FFFFFF}]",SBusiness[i][sMessage],SBusiness[i][sOwner],SBusiness[i][sBenz],SBusiness[i][sPriceBenz]);
				Update3DTextLabelText(SBusiness[i][sLabel], TEAM_GROVE_COLOR, stringer1);
				SaveSBizz(i);
				return true;
			}
		}
	}
	return true;
}
CMD:sellprodbiz(playerid, params[])
{
	new tmpcar = GetPlayerVehicleID(playerid);
	if(PlayerInfo[playerid][pJob] == 5 && PlayerInfo[playerid][pMember] == 0)
	{
		if(GetVehicleModel(GetPlayerVehicleID(playerid)) != 440) return SendClientMessage(playerid,COLOR_GREY,"Вы не в машине!");
		if(PlayerHaul[tmpcar-comptruck[0]][pLoad] == 0) return SendClientMessage(playerid,COLOR_GREY,"Нет продуктов в машине!");
		for(new i = 0; i < sizeof(Business); i++)
		{
			if(PlayerToPoint(15, playerid,Business[i][bEntranceX], Business[i][bEntranceY], Business[i][bEntranceZ]))
			{
				Business[i][bProducts] += PlayerHaul[tmpcar-comptruck[0]][pLoad];
				PlayerHaul[tmpcar-comptruck[0]][pLoad] = 0;
				SendClientMessage(playerid, COLOR_YELLOW2, ":Доставка:");
				SendClientMessage(playerid, COLOR_WHITE, "- Продукты успешно доставлены");
				SendClientMessage(playerid, COLOR_YELLOW2, ":Доставка:");
				SendClientMessage(Business[i][bOwner], COLOR_YELLOW2, ":Доставка продуктов:");
				SendClientMessage(Business[i][bOwner], COLOR_WHITE, "- Продукты доставлены");
				SendClientMessage(Business[i][bOwner], COLOR_YELLOW2, ":Расчётка:");
				SaveBizz(i);
				return true;
			}
		}
	}
	return true;
}
CMD:lock(playerid, params[])
{
	new carid;
	if(PlayerInfo[playerid][pPhousekey] == 255)
	{
		if(GetPlayerVehicleID(playerid) != caridhouse[playerid]) return SendClientMessage(playerid,COLOR_GREY,"Вы не в своей машине.");
		if(caridhouse[playerid] == 0) return SendClientMessage(playerid, COLOR_GRAD1, " У вас нет машины!");
	}
	carid = PlayerInfo[playerid][pPhousekey]+1;
	if(caridhouse[playerid] != 299) carid = caridhouse[playerid];
	new lockstatus = gCarLock[carid];
	new Float:cx,Float:cy,Float:cz;
	GetVehiclePos(carid, cx, cy, cz);
	switch (lockstatus)
	{
	case 0:
		{
			if(PlayerToPoint(4.0, playerid, cx, cy, cz) )
			{
				if(caridhouse[playerid] == 0 && PlayerInfo[playerid][pPhousekey] == 255) return SendClientMessage(playerid, COLOR_GRAD1, " У вас нет машины!");
				if(caridhouse[playerid] == carid)
				{
					GameTextForPlayer(playerid,"~r~locked",3000,3);
					PlayerPlaySound(playerid, 1145, 0.0, 0.0, 0.0);
					LockCar(carid);
					IsLocked[caridhouse[playerid]] = 1;
				}
			}
		}
	case 1:
		{
			if(PlayerToPoint(4.0, playerid, cx, cy, cz) )
			{
				if(caridhouse[playerid] == 0 && PlayerInfo[playerid][pPhousekey] == 255) return SendClientMessage(playerid, COLOR_GRAD1, "У вас нет машины!");
				if(caridhouse[playerid] == carid)
				{
					GameTextForPlayer(playerid,"~g~unlocked",3000,3);
					PlayerPlaySound(playerid, 1145, 0.0, 0.0, 0.0);
					gCarLock[caridhouse[playerid]] = 0;
					UnLockCar(caridhouse[playerid]);
					IsLocked[caridhouse[playerid]] = 0;
				}
			}
		}
	default: SendClientMessage(playerid, COLOR_RED, "Ошибка!");
	}
	if(carid == 256) SendClientMessage(playerid, COLOR_GRAD1, " Вы не имеете машины!");
	return true;
}
CMD:anim(playerid, params[])
{
	if(PlayerCuffed[playerid] == 0)
	{
		new stringiser[1720];
		new Animser[][] = {
			{"1. Танец - 1\n2. Танец - 2\n3. Танец - 3\n4. Танец - 4\n5. Стойка дилера\n6. Передал что-то\n7. Съел что-то\n8. Справить нужду\n9. Медитация\n10. Сидеть раненым\n11. Спать на боку\n12. Лечь на спину\n13. Шлепнуть рукой\n14. Наносить граффити 1\n15. Наносить граффити 2\n16. Курение\n17. Ограбление\n18. Одеть маску\n19. Руки в верх\n20. Позвать кого-то\n21. Поднять руки\n22. Болельщик 1\n23. Болельщик 2\n24. Болельщик 3\n"},
			{"25. Показать средний палец\n26. Выпить что-то\n27. Махать руками\n28. Мужское курение\n29. Прилечь 1\n30. Прилечь 2\n31. Прилечь 3\n32. Прилечь 4\n33. Присесть на пол\n34. Читать реп 1\n35. Читать реп 2\n36. Читать реп 3\n37. Читать реп 4\n38. Набивать мяч\n39. Кинуть мяч\n40. Поднять мяч\n41. Позвать\n42. Чинить авто\n43. Прислониться к авто\n44. Сложить руки вместе\n"},
			{"45. Держать биту 1\n46. Держать биту 2\n47. Гангстерский жест 1\n48. Гангстерский жест 2\n49. Гангстерский жест 3\n50. Гангстерский жест 4\n51. Гангстерский жест 5\n52. Гангстерский жест 6\n53. Гангстерский жест 7\n54. Гангстерский жест 8\n55. Плакать\n56. Присесть 1\n57. Присесть 2\n58. Присесть облокотившись\n59. Женское курение\n60. Искусственное дыхание\n61. Облокотится\n62. Облокотится 2\n63. Facepalm\n64. Чесаться\n65. Отключить анимацию"}
		};
		stringiser = "";
		format(stringiser, sizeof(stringiser), "%s%s%s", Animser[0], Animser[1], Animser[2]);
		ShowPlayerDialog(playerid, 1994, DIALOG_STYLE_LIST, "Список анимаций", stringiser, "Выбрать", "Отмена");
		return true;
	}
	return true;
}
CMD:rb(playerid, params[])
{
	if(PlayerInfo[playerid][pMember] == 1 && PlayerInfo[playerid][pRank] > 2 || PlayerInfo[playerid][pMember] == 10  && PlayerInfo[playerid][pRank] > 2 || PlayerInfo[playerid][pMember] == 21  && PlayerInfo[playerid][pRank] > 2)
	{
		if(RB[playerid] == 255)
		{
			new Float:X,Float:Y,Float:Z,Float:A;
			GetPlayerPos(playerid,X,Y,Z);
			GetPlayerFacingAngle(playerid, A);
			BlockPost[block] = CreateDynamicObject(981,X,Y,Z-0.2,0.00,0.00,A+180);
			format(stringer1,sizeof(stringer1),"Блок пост №%d\n{FF0000}Установил %s.",block,PlayerInfo[playerid][pName]);
			Block3D[block] = CreateDynamic3DTextLabel(stringer1,COLOR_YELLOW,X,Y,Z,20.0,INVALID_PLAYER_ID,INVALID_PLAYER_ID,0,-1,-1,-1,100.0);
			RB[playerid] = block;
			block++;
			new ftext[5];
			switch(PlayerInfo[playerid][pMember])
			{
			case 1: ftext = "LSPD";
			case 10: ftext = "SFPD";
			case 21: ftext = "LVPD";
			}
			rbtime[playerid] = 600;
			format(stringer1,sizeof(stringer1),"Сотрудник %s %s установил дорожное загрождение.",ftext,PlayerInfo[playerid][pName],RB[playerid]);
			SendTeamMessage(1, 0x4169E1FF, stringer1);
			SetPlayerPos(playerid,X,Y,Z+1);
		}
		else
		{
			DestroyDynamicObject(BlockPost[RB[playerid]]);
			DestroyDynamic3DTextLabel(Block3D[RB[playerid]]);
			RB[playerid] = 255;
			rbtime[playerid] = 0;
		}
	}
	return true;
}
CMD:rbinfo(playerid, params[])
{
	if(PlayerInfo[playerid][pMember] == 1 && PlayerInfo[playerid][pRank] > 12 || PlayerInfo[playerid][pMember] == 10  && PlayerInfo[playerid][pRank] > 12 || PlayerInfo[playerid][pMember] == 21  && PlayerInfo[playerid][pRank] > 12)
	{
		PlayerForeach(i)
		{
			if(rbtime[i] > 0) SendMes(playerid,COLOR_GREY,"[{FFFFFF}№%d{AFAFAF}] Установил {FF0000}%s, будет убран через %d секунд",RB[i],PlayerInfo[i][pName],rbtime[i]);
		}
	}
	return true;
}
CMD:hmenu(playerid, params[])
{
	new bouse = PlayerInfo[playerid][pPhousekey];
	if(bouse != 255 && strcmp(PlayerInfo[playerid][pName], HomeInfo[PlayerInfo[playerid][pPhousekey]][hOwner], true) == 0)
	{
		if(PlayerToPoint(10, playerid,HomeInfo[bouse][hExitx], HomeInfo[bouse][hExity], HomeInfo[bouse][hExitz]))
		{
			format(stringer1, sizeof(stringer1), "[0] Ремонт в доме\n[1] Домашний сейф\n[2] Открыть / Закрыть квартиру\n[3] Продать квартиру\n[4] На счету квартиры: %d вирт\n[5] Аптечек [%d]", HomeInfo[bouse][hTakings], HomeInfo[bouse][hHel]);
			ShowPlayerDialog(playerid, 5300, DIALOG_STYLE_LIST, "Информация о доме", stringer1, "Далее", "Скрыть");
			return true;
		}
		else return SendClientMessage(playerid, COLOR_GREY, "Вы не у себя в квартире!");
	}
	return true;
}
CMD:sellhouse(playerid, params[])
{
	new bouse = PlayerInfo[playerid][pPhousekey];
	if(bouse != INVALID_PLAYER_ID && strcmp(PlayerInfo[playerid][pName], HomeInfo[PlayerInfo[playerid][pPhousekey]][hOwner], true) == 0)
	{
		if(PlayerToPoint(5, playerid,HomeInfo[bouse][hExitx], HomeInfo[bouse][hExity], HomeInfo[bouse][hExitz])) ShowPlayerDialog(playerid, 5033, DIALOG_STYLE_MSGBOX, "Продажа имущества", "Вы действительно хотите продать дом государству?", "Да", "Нет");
		else return SendClientMessage(playerid, COLOR_GREY, "Вы не у себя дома");
	}
	else return SendClientMessage(playerid, COLOR_GREY, "Вы не владелец дома");
	return true;
}
CMD:healme(playerid, params[])
{
	for(new i = 0; i < sizeof(HomeInfo); i++)
	{
		if(PlayerToPoint(5, playerid,HomeInfo[i][hExitx], HomeInfo[i][hExity], HomeInfo[i][hExitz]))
		{
			if(GetPlayerVirtualWorld(playerid) == i+50)
			{
				if(HomeInfo[i][hHel] == 0)return SendClientMessage(playerid, COLOR_GREY, "В этом месте нет аптечек");
				SendClientMessage(playerid, COLOR_WHITE, "Вы были вылечены до 100 процентов");
				format(stringer1, sizeof(stringer1), "Осталось %d аптечек", HomeInfo[i][hHel]);
				SendClientMessage(playerid, 0x6495EDFF, stringer1);
				HomeInfo[i][hHel] -= 1;
				SetPlayerHealth(playerid, 100);
				SetPlayerChatBubble(playerid, "использовал аптечку", COLOR_YELLOW, 30.0, 10000);
				return true;
			}
		}
	}
	return true;
}
CMD:fixcar(playerid, params[])
{
	if(PlayerInfo[playerid][pCash] < 1000) return SendClientMessage(playerid, COLOR_RED, "Не достаточно денег!");
	if(IsVehicleOccupied(caridhouse[playerid])) return SendClientMessage(playerid,COLOR_GREY,"Транспорт занят игроком");
	if(PlayerInfo[playerid][pPhousekey] != 255)
	{
		new house = PlayerInfo[playerid][pPhousekey];
		if(caridhouse[playerid] != 0)
		{
			DestroyVehicle(caridhouse[playerid]);
			caridhouse[playerid] = 0;
		}
		caridhouse[playerid] = CreateVehicle(PlayerInfo[playerid][pCar], HomeInfo[house][hCarx], HomeInfo[house][hCary], HomeInfo[house][hCarz], HomeInfo[house][hCarc], PlayerInfo[playerid][pVcol1], PlayerInfo[playerid][pVcol2], 7200);
		LockCar(caridhouse[playerid]);
		Fuell[caridhouse[playerid]] = 50;
		GameTextForPlayer(playerid, "~r~$-1000", 5000, 1);
		PlayerInfo[playerid][pCash] -= 1000;
		PlayerPlaySound(playerid, 1052, 0.0, 0.0, 0.0);
		SetVehicleNumberPlate(caridhouse[playerid], PlayerInfo[playerid][pNumbercar]);
		AddVehicleComponent (caridhouse[playerid], PlayerInfo[playerid][pKolesocar]);
		AddVehicleComponent (caridhouse[playerid], PlayerInfo[playerid][pNitro]);
		AddVehicleComponent (caridhouse[playerid], PlayerInfo[playerid][pGidra]);
		if(PJ(caridhouse[playerid]))
		{
			ChangeVehiclePaintjob(caridhouse[playerid],PlayerInfo[playerid][pPokraska]);
			AddVehicleComponent(caridhouse[playerid],PlayerInfo[playerid][pSpoiler]);
			AddVehicleComponent(caridhouse[playerid],PlayerInfo[playerid][pHood]);
			AddVehicleComponent(caridhouse[playerid],PlayerInfo[playerid][pExhaust]);
			AddVehicleComponent(caridhouse[playerid],PlayerInfo[playerid][pLamps]);
			AddVehicleComponent(caridhouse[playerid],PlayerInfo[playerid][pSideskirt]);
			AddVehicleComponent(caridhouse[playerid],PlayerInfo[playerid][pVozdyx]);
			AddVehicleComponent(caridhouse[playerid],PlayerInfo[playerid][pBamper1]);
			AddVehicleComponent(caridhouse[playerid],PlayerInfo[playerid][pBamper2]);
		}
	}
	return true;
}
CMD:carpass(playerid, params[])
{
	if(!IsPlayerInAnyVehicle(playerid)) return   SendClientMessage(playerid, COLOR_GRAD2, "Вы не в машине!");
	if(GetPlayerVehicleID(playerid) == caridhouse[playerid])
	{
		new house = PlayerInfo[playerid][pPhousekey];
		SendClientMessage(playerid,0x0AA8DAFF,"-------========[ Тех. Паспорт ]========-------");
		SendMes(playerid,0xC0E1EEFF, "Модель: %s",VehicleNameS[GetVehicleModel(GetPlayerVehicleID(playerid))-400]);
		SendMes(playerid,0xC0E1EEFF, "Владелец: %s",HomeInfo[house][hOwner]);
		SendMes(playerid,0xC0E1EEFF, "Состояние: %d",PlayerInfo[playerid][pProz]);
		SendClientMessage(playerid,0x0AA8DAFF,"-------========[ Тех. Паспорт ]========-------");
		format(stringer1,sizeof(stringer1), "достал(а) документы из бардачка",PlayerInfo[playerid][pName]);
		SetPlayerChatBubble(playerid,stringer1,COLOR_YELLOW,30.0,10000);
		return true;
	}
	return true;
}
