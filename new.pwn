					SendFamilyMessage(MZInfo[bNapad], COLOR_WHITE, stringer);
					Business[MZInfo[bBiz]][bMafia] = 0;
				}
				else
				{
					format(stringer,sizeof(stringer), "{FFFFFF}[Стрела] Стрела за бизнес {4169E1}%s{FFFFFF} закончилась ничьей. {8B0000}Бизнес потерян.",SBusiness[MZInfo[bBiz]][sMessage]);
					SendFamilyMessage(MZInfo[bFrakVlad], COLOR_WHITE, stringer);
					format(stringer,sizeof(stringer), "{FFFFFF}[Стрела] Стрела за бизнес {4169E1}%s{FFFFFF} закончилась ничьей. {32CD32}Бизнес оставлен.",SBusiness[MZInfo[bBiz]][sMessage]);
					SendFamilyMessage(MZInfo[bNapad], COLOR_WHITE, stringer);
					SBusiness[MZInfo[bBiz]][sbMafia] = 0;
				}
			}
			else
			{
				if(MZInfo[bType]==1)
				{
					format(stringer,sizeof(stringer), "{FFFFFF}[Стрела] Мафия {4169E1}%s{FFFFFF} забрала у вас контроль над бизнесом {4169E1}%s{FFFFFF}. {8B0000}Бизнес потерян.",GetMN(MZInfo[bNapad]),Business[MZInfo[bBiz]][bMessage]);
					SendFamilyMessage(MZInfo[bFrakVlad], COLOR_WHITE, stringer);
					format(stringer,sizeof(stringer), "{FFFFFF}[Стрела] Вы отобрали контроль над бизнесом {4169E1}%s{FFFFFF} у мафии {4169E1}%s{FFFFFF}. {32CD32}Бизнес захвачен.",GetMN(MZInfo[bFrakVlad]),Business[MZInfo[bBiz]][bMessage]);
					SendFamilyMessage(MZInfo[bNapad], COLOR_WHITE, stringer);
					Business[MZInfo[bBiz]][bMafia] = MZInfo[bNapad];
				}
				else
				{
					format(stringer,sizeof(stringer), "{FFFFFF}[Стрела] Мафия {4169E1}%s{FFFFFF} забрала у вас контроль над бизнесом {4169E1}%s{FFFFFF}. {8B0000}Бизнес потерян.",GetMN(MZInfo[bNapad]),SBusiness[MZInfo[bBiz]][sMessage]);
					SendFamilyMessage(MZInfo[bFrakVlad], COLOR_WHITE, stringer);
					format(stringer,sizeof(stringer), "{FFFFFF}[Стрела] Вы отобрали контроль над бизнесом {4169E1}%s{FFFFFF} у мафии {4169E1}%s{FFFFFF}. {32CD32}Бизнес захвачен.",GetMN(MZInfo[bFrakVlad]),SBusiness[MZInfo[bBiz]][sMessage]);
					SendFamilyMessage(MZInfo[bNapad], COLOR_WHITE, stringer);
					SBusiness[MZInfo[bBiz]][sbMafia] = MZInfo[bNapad];
				}
			}
			PlayerForeach(m)
			{
				if(m == -1) continue;
				if(MZInfo[bFrakVlad]!=PlayerInfo[m][pMember] && MZInfo[bNapad]!=PlayerInfo[m][pMember]) continue;
				EndBizwar(m);
			}
			MZInfo[bFrakVlad] = 0;
			MZInfo[bNapad] = 0;
			MZInfo[bBiz] = 255;
			GangZoneStopFlashForAll(ZonsWar[MZInfo[bMesto]-1]);
			GangZoneHideForAll(ZonsWar[MZInfo[bMesto]]);
			GangZoneShowForAll(ZonsWar[MZInfo[bMesto]], 16711888);
			BizWarTime = 0;
			BizHourTime =2;
			MZInfo[bMesto]=0;
			MZInfo[bCountDead][MZInfo[bNapad]] = 0;
			MZInfo[bCountDead][MZInfo[bFrakVlad]] = 0;
			MZInfo[bType]=0;
		}
	}
	PlayerForeach(i)
	{
		new var = GetPlayerTargetPlayer(i);
		if(var != INVALID_PLAYER_ID)
		{
			CheckNextAim[i] = true;
		}
		if(checkautoaim[i] <= 10)
		{
			if(var != INVALID_PLAYER_ID)
			{
				checkautoaim[i] = 9999;
			}
			checkautoaim[i]++;
			if(checkautoaim[i] == 11)
			{
				autoaim[i] = true;
				CallRemoteFunction("OnPlayerDetectedAutoaim", "d", i);
			}
		}
		for (new cmdid; cmdid < MAX_CMDS; cmdid++) if(AntiFlood [i] [cmdid] > 0) AntiFlood [i] [cmdid] --;
	}
	if(TimerPaintBall && (StartPaintBall == 1 || StartPaintBall == 2)) TimerPaintBall--;
	if(!TimerPaintBall && StartPaintBall == 1)
	{
		StartPaintBall = 2;
		TimerPaintBall = TIME_PAINTBALL;
		SendClientMessageToAll(COLOR_YELLOW3, "SMS от СМИ: Матч по пейнтболу начался, продолжительность 10 минут.");
		PlayerForeach(i)
		{
			if(TeamPain[i] != 0) GameTextForPlayer(i,"~y~[START]", 2000, 4);
		}
	}
	if(TimerPaintBall == 5 && StartPaintBall == 1)
	{
		if(RedPlayer == 0 || BluePlayer == 0)
		{
			PlayerForeach(i)
			{
				if(TeamPain[i] != 0) TeamPain[i] = 0;
			}
			SendClientMessageToAll(COLOR_YELLOW3, "SMS от СМИ: Матч по пейнтболу отменен из за недостатка участников.");
			RedPlayer = 0, BluePlayer = 0;
			StartPaintBall = 0;
		}
		else
		{
			PlayerForeach(i)
			{
				if(TeamPain[i] == 0 || !gPlayerLogged[i]) continue;
				new str[28];
				format(str,sizeof(str),"~r~TEAM RED: ~w~%d",RedScore);
				TextDrawSetString(RedTeam, str);
				TextDrawShowForPlayer(i, RedTeam);
				format(str,sizeof(str),"~b~TEAM BLUE: ~w~%d",BlueScore);
				TextDrawSetString(BlueTeam, str);
				TextDrawShowForPlayer(i, BlueTeam);
				TogglePlayerControllable(i, 0);
				SetPVarInt(i,"DMWarning",5);
				ResetPlayerWeapons(i);
				SetPlayerInterior(i, 0);
				SetPlayerArmour(i, 0);
				SetPlayerHealth(i, 100);
				new spawn = random(6);
				if(TeamPain[i] == 1)
				{
					SetPlayerPos(i, SpawnBlueTeam[spawn][0],SpawnBlueTeam[spawn][1],SpawnBlueTeam[spawn][2]);
					if(PlayerInfo[i][pSex] == 1) SetPlayerSkin(i, 21);
					if(PlayerInfo[i][pSex] == 2)  SetPlayerSkin(i, 41);
					SetPlayerColor(i, COLOR_BLUE);
				}
				if(TeamPain[i] == 2)
				{
					SetPlayerPos(i, SpawnRedTeam[spawn][0],SpawnRedTeam[spawn][1],SpawnRedTeam[spawn][2]);
					if(PlayerInfo[i][pSex] == 1) SetPlayerSkin(i, 19);
					if(PlayerInfo[i][pSex] == 2)  SetPlayerSkin(i, 40);
					SetPlayerColor(i, COLOR_RED);
				}
			}
		}
	}
	if(StartPaintBall == 2 && !TimerPaintBall)
	{
		SendClientMessageToAll(COLOR_YELLOW3, "SMS от СМИ: Матч по пейнтболу завершен.");
		StartPaintBall = 0;
		new string[128], number = 0;
		format(string,sizeof(string),"{33AAFF}Team Blue[%d] {FFFFFF}|| {FF0000}Team Red[%d]\n\n",BlueScore, RedScore);
		strcat(strpaintball,string);
		PlayerForeach(i)
		{
			if(TeamPain[i] == 0) continue;
			SetPlayerPos(i, -2128.3118,-441.9403,35.5313);
			if(PlayerInfo[i][pMember] != 0) SetPlayerSkin(i, PlayerInfo[i][pModel]);
			else SetPlayerSkin(i, PlayerInfo[i][pChar]);
			ResetPlayerWeapons(i);
			SetPlayerHealth(i,100);
			SetPlayerToTeamColor(i);
			TextDrawHideForPlayer(i, BlueTeam);
			TextDrawHideForPlayer(i, RedTeam);
			number++;
			if(TeamPain[i] == 1)
			{
				if(BlueScore > RedScore)
				{
					SendClientMessage(i, COLOR_GREEN,"Ваша команда победила! Ваш приз составил: 50 DonateMoney");
					PlayerInfo[i][pDonatemoney2] += 50;
				}
				format(string,sizeof(string),"{33AAFF}%s | Kill: %d | Death: %d \n",PlayerInfo[i][pName], KillPain[i], DeathPain[i]);
				strcat(strpaintball,string);
			}
			if(TeamPain[i] == 2)
			{
				if(BlueScore < RedScore)
				{
					SendClientMessage(i, COLOR_GREEN,"Ваша команда победила! Ваш приз составил: 50 DonateMoney");
					PlayerInfo[i][pDonatemoney2] += 50;
				}
				format(string,sizeof(string),"{FF0000}%s | Kill: %d | Death: %d \n",PlayerInfo[i][pName], KillPain[i], DeathPain[i]);
				strcat(strpaintball,string);
			}
			TeamPain[i] = 0;
			KillPain[i] = 0;
			DeathPain[i] = 0;
		}
	}
	new Float:hp;
	PlayerForeach(i)
	{
		if(!IsPlayerConnected(i)) continue;
		iNewPlayerAmmo[i] = GetPlayerAmmo(i);
		if(iNewPlayerAmmo[i] != iPlayerAmmo[i])
		{
			OnPlayerAmmoChange(i, iNewPlayerAmmo[i], iPlayerAmmo[i]);
			iPlayerAmmo[i] = iNewPlayerAmmo[i];
		}
		AntiCheat(i);
		GetVehicleHealth(GetPlayerVehicleID(i), hp);
		if(IsPlayerConnected(i) && gPlayerLogged[i] == 1)
		{
			if(GetPlayerState(i) == PLAYER_STATE_DRIVER)
			{
				if(hp < 100)
				{
					zavodis[i] = 0;
					GetVehicleParamsEx(GetPlayerVehicleID(i),engine,lights,alarm,doors,bonnet,boot,objective);
					SetVehicleParamsEx(GetPlayerVehicleID(i),0,0,alarm,doors,bonnet,boot,objective);
				}
			}
		}
		if(AntiBan[i] > 0) AntiBan[i]--;
		if(!PlayerToPoint(40.0,i,264.1425,77.4712,1001.0391) && PlayerInfo[i][pJailed] == 1 || PlayerInfo[i][pJailed] == 2 || PlayerInfo[i][pJailed] == 3)
		{
			SetPlayerInterior(i, 6);
			PlayerInfo[i][pInt] = 6;
			SetPlayerPos(i,264.1425,77.4712,1001.0391);
			SetPlayerFacingAngle(i, 263.0160);
			PlayerInfo[i][pJailed] = 1;
			PlayerInfo[i][pMestoJail] = 1;
			SendClientMessage(i,COLOR_GREY,"За повторную попытку сбежать из тюрьмы вы можете получить бан.");
		}
		if(!PlayerToPoint(20.0,i,2543.0537,-8141.8242,72.6420) && PlayerInfo[i][pJailed] == 4)
		{
			SetPlayerInterior(i, 0);
			PlayerInfo[i][pInt] = 0;
			SetPlayerPos(i,2543.0537,-8141.8242,72.6420);
			SetPlayerFacingAngle(i, 268.7242);
			PlayerInfo[i][pJailed] = 4;
			SendClientMessage(i,COLOR_GREY,"За повторную попытку сбежать из тюрьмы вы можете получить бан.");
		}
		if(TimeBox[i] > 0)
		{
			TimeBox[i]--;
			format(stringer1, sizeof(stringer1), "~g~%d",TimeBox[i]);
			GameTextForPlayer(i, stringer1, 3000, 6);
			if(TimeBox[i] == 0)
			{
				GameTextForPlayer(i, "~r~Fight!", 3000, 6);
				TogglePlayerControllable(i, 1);
			}
		}
		if(TimeBoxAll[i] > 0)
		{
			TimeBoxAll[i]--;
			if(TimeBoxAll[i] == 0)
			{
				ring = 0;
				boy[i] = 0;
				boy[fightid[i]] = 0;
				SetPlayerPos(i,770.7656,3.9569,1000.7176);
				SetPlayerFacingAngle(i, 90.0);
				SetPlayerPos(fightid[i],770.7488,6.9432,1000.7118);
				SetPlayerFacingAngle(fightid[i], 90.0);
				PlayerInfo[i][pFightTime]= 600;
				PlayerInfo[fightid[i]][pFightTime]= 600;
				fightid[i] = INVALID_PLAYER_ID;
				fightid[fightid[i]] = INVALID_PLAYER_ID;
				TogglePlayerControllable(fightid[i], 0);
			}
		}
		if(startnarko[i] == 1)
		{
			if(PlayerInfo[i][pNarcoLomka] >=3000)
			{
				if(send[i] == 0)
				{
					SendClientMessage(i, COLOR_RED, "~~~~~~~~ У вас началась ломка ~~~~~~~~");
					SendClientMessage(i, COLOR_WHITE, "(( Вызвать медика - /call => [2] Скорая помощь    ||    Принять наркотик - /drugs ))");
					send[i] = 1;
				}
				if(GetPlayerState(i) == PLAYER_STATE_ONFOOT) ApplyAnimation(i, "CRACK", "CRCKDETH1", 4.0, 1, 1, 1, 1, 0),send[i] = 1;
			}
		}
		if(SwatDoor[0][i] > 0)
		{
			SwatDoor[0][i]--;
			if(SwatDoor[0][i] == 1) MoveObject(gatevorota,777.56915283,-1384.85498047,14.39731598, 3.0);
		}
		if(SwatDoor[1][i] > 0)
		{
			SwatDoor[1][i]--;
			if(SwatDoor[1][i] == 1) MoveObject(gatevorota2,781.87298584,-1330.21044922,12.70648003, 3.0);
		}
		if(GetPVarInt(i,"DMWarning") > 0)
		{
			SetPVarInt(i,"DMWarning",GetPVarInt(i,"DMWarning")-1);
			if(GetPVarInt(i,"DMWarning") <= 0) TogglePlayerControllable(i, 1);
		}
		if(antiwarn[i] > 0)
		{
			antiwarn[i]--;
			if(antiwarn[i] == 1) anti[i] = 0, antiwarn[i] = 0;
		}
		//
		if(GetPVarInt(i,"AntiDM") > 0)
		{
			new anim = GetPlayerAnimationIndex(i);
			if(anim != 471) ApplyAnimation(i, "FAT", "IDLE_tired",4.0,1,0,0,0,0,1);
			SetPVarInt(i,"AntiDM",GetPVarInt(i,"AntiDM")-1);
			if(GetPVarInt(i,"AntiDM") == 0) ClearAnimations(i);
		}
		//
		if(rbtime[i] > 0)
		{
			rbtime[i] --;
			if(rbtime[i] == 1 && RB[i] != 255)
			{
				DestroyDynamicObject(BlockPost[RB[i]]);
				DestroyDynamic3DTextLabel(Block3D[RB[i]]);
				rbtime[i] = 0;
				RB[i] = 255;
			}
		}
		if(krematory[i] > 0) krematory[i]--;
		if(gov[i] > 0) gov[i]--;
		if(PlayerInfo[i][pContract] > 0) PlayerInfo[i][pContract]--;
		if(PlayerInfo[i][pGunfbiTime] > 0) PlayerInfo[i][pGunfbiTime]--;
		if(PlayerInfo[i][pGun51Time] > 0) PlayerInfo[i][pGun51Time]--;
		if(PlayerInfo[i][pGunlspdTime] > 0) PlayerInfo[i][pGunlspdTime]--;
		if(PlayerInfo[i][pGunaviaTime] > 0) PlayerInfo[i][pGunaviaTime]--;
		if(saveplayer[i]) saveplayer[i]--;
		if(jackcar[i] > 0)
		{
			jackcar[i] -=1;
			if(jackcar[i] == 1)
			{
				jackcar[i] = 0;
				new nearveh = GetNearestVehicle(i);
				new carid = nearveh;
				new Float:cx,Float:cy,Float:cz;
				GetVehiclePos(carid, cx, cy, cz);
				new randd = random(12);
				if(PlayerToPoint(4.0, i, cx, cy, cz))
				{
					switch(randd)
					{
					case 0..4:
						{
							UnLockCar(carid);
							IsLocked[carid] = 0;
							TogglePlayerControllable(i, 1);
							GameTextForPlayer(i, "~g~Un Locked", 5000, 6);
							if(IsACop(i)) format(stringer1, sizeof(stringer1), "Законник %s успешно взламывает замок транспорта", PlayerInfo[i][pName]);
							else format(stringer1, sizeof(stringer1), "Незнакомец успешно взламывает замок транспорта");
							ProxDetector(30.0, i, stringer1, COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW);
						}
					default:
						{
							TogglePlayerControllable(i, 1);
							PlayerInfo[i][pOtmbI4ka]--;
							if(IsACop(i)) format(stringer1, sizeof(stringer1), "Законник %s не смог взломать замок транспорта", PlayerInfo[i][pName]);
							else format(stringer1, sizeof(stringer1), "Незнакомец не смог взломать замок транспорта");
							ProxDetector(30.0, i, stringer1, COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW,COLOR_YELLOW);
						}
					}
				}
			}
		}
		if(crashcuff[i] > 0) crashcuff[i]--;
		if(Flood[i] > 0) Flood[i] -=1;
		if(hour >= 12 && minute == 10 && second == 0) startnarko[i] = 1;
		DeletePVar(i,"NoAB");
		if(PlayerInfo[i][pDrugtime] > 0) PlayerInfo[i][pDrugtime]--;
		if(PlayerInfo[i][pRobTime] > 0) PlayerInfo[i][pRobTime]--;
		if(PlayerInfo[i][pGrabTime] > 0) PlayerInfo[i][pGrabTime]--;
		if(PlayerInfo[i][pReportTime] > 0) PlayerInfo[i][pReportTime]--;
		if(PlayerInfo[i][pAutoTime] > 0) PlayerInfo[i][pAutoTime]--;
		if(clearanim[i] > 0)
		{
			clearanim[i] --;
			if(clearanim[i] == 0) ApplyAnimation(i,"CARRY","crry_prtial",4.0,0,0,0,0,0,1);
		}
		if(PlayerInfo[i][pMuteTime] > 0 && PlayerInfo[i][pMuted] == 1)
		{
			PlayerInfo[i][pMuteTime] -=1;
			if(PlayerInfo[i][pMuteTime] == 1)
			{
				PlayerInfo[i][pMuted] = 0;
				PlayerInfo[i][pMuteTime] = 0;
				SendClientMessage(i,COLOR_WHITE,"Вам включили чат. Пожалуйста больше не нарушайте правила");
			}
		}
		if(IsPlayerInAnyVehicle(i) && GetPlayerState(i) == PLAYER_STATE_DRIVER) UpdateSpeedometr(i);
		if(IsPlayerConnected(i))
		{
			if(PlayerInfo[i][pJailed] > 0)
			{
				if(PlayerInfo[i][pJailTime] > 0) PlayerInfo[i][pJailTime]--;
				if(PlayerInfo[i][pJailTime] <= 0)
				{
					if(PlayerInfo[i][pJailed] == 1)
					{
						if(PlayerInfo[i][pMestoJail] == 1)
						{
							SetPlayerInterior(i, 0);
							PlayerInfo[i][pInt] = 0;
							SetPlayerPos(i,1547.11,-1675.76,13.94);//Тюрьма
							SetPlayerFacingAngle(i, 95.0636);
						}
						if(PlayerInfo[i][pMestoJail] == 2)
						{
							SetPlayerInterior(i, 0);
							PlayerInfo[i][pInt] = 0;
							SetPlayerPos(i,-1607.1873,721.3649,12.2721);//Тюрьма
							SetPlayerFacingAngle(i, 2.3026);
						}
						if(PlayerInfo[i][pMestoJail] == 3)
						{
							SetPlayerInterior(i, 0);
							PlayerInfo[i][pInt] = 0;
							SetPlayerPos(i,2334.8467,2454.9456,14.9688);//Тюрьма
							SetPlayerFacingAngle(i, 115.7874);
						}
					}
					else if(PlayerInfo[i][pJailed] == 4)
					{
						SetPlayerInterior(i, 0);
						PlayerInfo[i][pInt] = 0;
						SetPlayerPos(i,1547.11,-1675.76,13.94);//Тюрьма
						SetPlayerFacingAngle(i, 95.0636);
					}
					PlayerInfo[i][pJailTime] = 0;
					PlayerInfo[i][pJailed] = 0;
					SendClientMessage(i, COLOR_ISPOLZUY,"Вы заплатили свой долг обществу, теперь вы свободны!");
					PlayerInfo[i][pMestoJail] = 0;
					WantedLevel[i] = 0;
					PlayerInfo[i][pWanted] = 0;
					WantedPoints[i] = 0;
					SetPlayerWantedLevel(i, 0);
					SetPlayerVirtualWorld(i, 0);
					GameTextForPlayer(i, "~g~Freedom", 5000, 1);
					SetPlayerToTeamColor(i);
				}
			}
			if(JobCarTime[i] <= 16 && JobCarTime[i] >= 1)
			{
				JobCarTime[i]--;
				format(stringer1,sizeof(stringer1),"~r~%d",JobCarTime[i] - 1);
				GameTextForPlayer(i, stringer1, 2000, 6);
			}
			if(Tazer[i] == 1)
			{
				if(TazerTime[i] <= 0) Tazer[i] = 0;
				else TazerTime[i] -= 1;
			}
			if(TieTime[i] > 0)
			{
				TieTime[i]--;
				if(TieTime[i] == 0) gag[i] = 0,SendClientMessage(i, COLOR_GREY, "Кляп стал мокрым и выпал, вы снова можете говорить!");
			}
			if(PlayerCuffed[i] == 1)
			{
				if(PlayerCuffedTime[i] <= 0)
				{
					TogglePlayerControllable(i, 1);
					PlayerCuffed[i] = 0;
					PlayerCuffedTime[i] = 0;
				}
				else PlayerCuffedTime[i] -= 1;
			}
			if(PlayerCuffed[i] == 2)
			{
				if(PlayerCuffedTime[i] <= 0)
				{
					TogglePlayerControllable(i, 1);
					PlayerCuffed[i] = 0;
					PlayerCuffedTime[i] = 0;
				}
				else PlayerCuffedTime[i] -= 1;
			}
			new GetTime = gettime();
			if(Timer[7] <= GetTime && Timer[7] != 0)
			{
				Timer[7] = GetTime+1;
			}
		}
	}
	if(hour == 00 || hour == 03 || hour == 06 || hour == 09 || hour == 12 || hour == 15 || hour == 18 || hour == 21)
	{
		if(minute == 32 && second == 00)
		{
			for(new h = 0; h < sizeof(HomeInfo); h++)
			{
				if(HomeInfo[h][hKlass] == 0 && HomeInfo[h][hOwned] == 1)//Классы домов
				{
					HomeInfo[h][hTakings] -=300; kazna += 300;
					if(HomeInfo[h][hTakings] > 16800) HomeInfo[h][hTakings] = 16800;
				}
				if(HomeInfo[h][hKlass] == 1 && HomeInfo[h][hOwned] == 1)//Классы домов
				{
					HomeInfo[h][hTakings] -=600; kazna += 600;
					if(HomeInfo[h][hTakings] > 33600) HomeInfo[h][hTakings] = 33600;
				}
				if(HomeInfo[h][hKlass] == 2 && HomeInfo[h][hOwned] == 1)//Классы домов
				{
					HomeInfo[h][hTakings] -=900; kazna += 900;
					if(HomeInfo[h][hTakings] > 50400) HomeInfo[h][hTakings] = 50400;
				}
				if(HomeInfo[h][hKlass] == 3 && HomeInfo[h][hOwned] == 1)//Классы домов
				{
					HomeInfo[h][hTakings] -=1200; kazna += 1200;
					if(HomeInfo[h][hTakings] > 67200) HomeInfo[h][hTakings] = 67200;
				}
				if(HomeInfo[h][hKlass] == 4 && HomeInfo[h][hOwned] == 1)//Классы домов
				{
					HomeInfo[h][hTakings] -=1500; kazna += 1500;
					if(HomeInfo[h][hTakings] > 84000) HomeInfo[h][hTakings] = 84000;
				}
				if(HomeInfo[h][hTakings] <= 0 && HomeInfo[h][hOwned] == 1)
				{
					new housecash = HomeInfo[h][hValue];
					new playeridd = GetPlayerID(HomeInfo[h][hOwner]);
					if(IsPlayerConnected(playeridd))
					{
						PlayerInfo[playeridd][pPhousekey] = 255;
						if(caridhouse[playeridd] != 0)
						{
							DestroyVehicle(caridhouse[playeridd]);
							caridhouse[playeridd] = 0;
						}
						SendClientMessage(playeridd, COLOR_LIGHTRED, "Ваш дом был продан за неуплату государтсву.");
					}
					else if(!IsPlayerConnected(playeridd))
					{
						new mysql_query_[128];
						format(mysql_query_, sizeof(mysql_query_), "UPDATE `"TABLE_ACCOUNT"` SET `pPhousekey` = '255', `pHousecash` = '%d' WHERE `Name` = '%s'",housecash, HomeInfo[h][hOwner]);
						mysql_function_query(dbHandle, mysql_query_, false, "", "");
					}
					HomeInfo[h][hHel] = 0;
					HomeInfo[h][hLock] = 1;
					HomeInfo[h][hOwned] = 0;
					strmid(HomeInfo[h][hOwner], "The State", 0, strlen("The State"), 255);
					SaveHouse(h);
				}
				if(HomeInfo[h][hOwned] == 0)
				{
					DestroyDynamicMapIcon(HomeInfo[h][hMIcon]);
					DestroyPickup(HomeInfo[h][hPickup]);
					AddStaticPickup(1273, 23, HomeInfo[h][hEntrancex], HomeInfo[h][hEntrancey], HomeInfo[h][hEntrancez]);
					HomeInfo[h][hMIcon] = CreateDynamicMapIcon(HomeInfo[h][hEntrancex], HomeInfo[h][hEntrancey], HomeInfo[h][hEntrancez], 31, COLOR_WHITE, 0, -1, -1, 200.0);
				}
				if(HomeInfo[h][hOwned] == 1)
				{
					DestroyDynamicMapIcon(HomeInfo[h][hMIcon]);
					DestroyPickup(HomeInfo[h][hPickup]);
					AddStaticPickup(1272, 23, HomeInfo[h][hEntrancex], HomeInfo[h][hEntrancey], HomeInfo[h][hEntrancez]);
					HomeInfo[h][hMIcon] = CreateDynamicMapIcon(HomeInfo[h][hEntrancex], HomeInfo[h][hEntrancey], HomeInfo[h][hEntrancez], 32, COLOR_WHITE, 0, -1, -1, 200.0);
				}
			}
		}
	}
	if(hour == 04 && minute == 55 && second == 00)
	{
		SendClientMessageToAll(-1,"");
		SendClientMessageToAll(-1,"Внимание! Перезагрузка игрового режима через 5 минут.");
		SendClientMessageToAll(-1,"");
		SaveAccounts(); SaveOther(); SaveHousee();
	}
	if(hour == 05 && minute == 00 && second == 00)
	{
		SendClientMessageToAll(-1,"Происходит рестарт сервера, приносим свои извинения за предоставленные неудобства");
		SendClientMessageToAll(-1,"С Уважением, администрация сервера");
		PlayerForeach(i) GameTextForPlayer(i, "~r~RESTART~n~~w~PLEASE, RECONNECT", 5000, 4);
		SendRconCommand("gmx");
	}
	return true;
}
stock ShowStats(playerid,targetid)
{
	if(IsPlayerConnected(playerid)&&IsPlayerConnected(targetid))
	{
		new atext[20];
		if(PlayerInfo[targetid][pSex] == 1) { atext = "Мужской"; }
		else if(PlayerInfo[targetid][pSex] == 2) { atext = "Женский"; }
		new jtext[25];
		switch(PlayerInfo[targetid][pJob])
		{
		case 2: { jtext = "[Механик]"; }
		case 3: { jtext = "[Продавец ХотДогов]"; }
		case 4: { jtext = "[Таксист]"; }
		case 5: { jtext = "[Развозчик продуктов]"; }
		case 6: { jtext = "[Тренер]"; }
		case 7: { jtext = "[Неизвестно]"; }
		case 8: { jtext = "[Инкасатор]"; }
		case 9: { jtext = "[Неизвестно]"; }
		case 10: { jtext = "[Мусоровоз]"; }
		case 13: { jtext = "[Автоугонщик]"; }
		case 14: { jtext = "[Боксёр]"; }
		default: { jtext = "[Безработный]"; }
		}
		new drank[20];
		if(PlayerInfo[targetid][pDonateRank] == 1) { drank = "Bronze VIP"; }
		else if(PlayerInfo[targetid][pDonateRank] == 2) { drank = "Silver VIP"; }
		else if(PlayerInfo[targetid][pDonateRank] == 3) { drank = "Gold VIP"; }
		else { drank = "Обычный"; }
		new prank[23];
		switch(PlayerInfo[targetid][pLevel])
		{
		case 1..3: { prank = "Новичок"; }
		case 4..6: { prank = "Начинающий"; }
		case 7..9: { prank = "Уверенный"; }
		case 10..14: { prank = "Постоянный игрок"; }
		case 15..19: { prank = "Освоившийся"; }
		case 20..24: { prank = "Освоившийся"; }
		case 25..49: { prank = "Дед"; }
		}
		new wanted = PlayerInfo[targetid][pWanted];
		new zavisimostitext[20];
		if(PlayerInfo[targetid][pNarcoLomka] == 0) { zavisimostitext = "Стадия отсутствует"; }
		else if(PlayerInfo[targetid][pNarcoLomka] >= 1 && PlayerInfo[targetid][pNarcoLomka] < 3000) { zavisimostitext = "1 стадия"; }
		else if(PlayerInfo[targetid][pNarcoLomka] >= 3000 && PlayerInfo[targetid][pNarcoLomka] < 5000) { zavisimostitext = "2 стадия"; }
		else if(PlayerInfo[targetid][pNarcoLomka] >= 5000) { zavisimostitext = "3 стадия"; }
		new nxtlevel = PlayerInfo[targetid][pLevel]+1;
		new tiee = PlayerInfo[targetid][pVerevka];
		new otmi = PlayerInfo[targetid][pOtmbI4ka];
		new expamount = nxtlevel*levelexp;
		new PayDayHad = PlayerInfo[targetid][pPayDayHad];
		new str[166],sctring[1450];
		format(str,sizeof(str),"{9ACD32}_______________________________________________________________\n\n");
		strcat(sctring,str);
		format(str,sizeof(str),"\t{ffffff}Имя: \t\t\t\t\t{9ACD32}%s \n\n",PlayerInfo[targetid][pName]);
		strcat(sctring,str);
		format(str,sizeof(str),"\t{ffffff}Уровень: \t\t\t\t{ffffff}%d (%d/%d) \n",PlayerInfo[targetid][pLevel],PlayerInfo[targetid][pExp],expamount);
		strcat(sctring,str);
		format(str,sizeof(str),"\t{ffffff}Пол: \t\t\t\t\t{ffffff}%s \n",atext);
		strcat(sctring,str);
		format(str,sizeof(str),"\t{ffffff}Статус в штате: \t\t\t{ffffff}%s \n\n",prank);
		strcat(sctring,str);
		format(str,sizeof(str),"\t{ffffff}Статус {FFFF00}VIP{ffffff}: \t\t\t\t%s \n\n",drank);
		strcat(sctring,str);
		if(PlayerInfo[targetid][pAdmin] >= 1)
		{
			format(str,sizeof(str),"\t{FF6347}Ранг администратора: \t\t{ffffff}%d \n",PlayerInfo[targetid][pAdmin]);
			strcat(sctring,str);
		}
		if(PlayerInfo[targetid][pHelper] >= 1)
		{
			format(str,sizeof(str),"\t{FF6347}Ранг Тех.Поддержки: \t\t{ffffff}%d \n",PlayerInfo[targetid][pHelper]);
			strcat(sctring,str);
		}
		format(str,sizeof(str),"{9ACD32}_______________________________________________________________\n\n");
		strcat(sctring,str);
		format(str,sizeof(str),"\t{ffffff}Законопослушность: \t\t\t{ffffff}%d \n",PlayerInfo[targetid][pZakonp]);
		strcat(sctring,str);
		format(str,sizeof(str),"\t{ffffff}Предупреждений: \t\t\t{ffffff}%d/{FF6347}3 \n",PlayerInfo[targetid][pWarns]);
		strcat(sctring,str);
		format(str,sizeof(str),"\t{ffffff}Уровень Преступлений: \t\t{ffffff}%d/{FF6347}6 \n",wanted);
		strcat(sctring,str);
		format(str,sizeof(str),"\t{ffffff}Наркозависимость: \t\t\t{ffffff}%s (%d) \n",zavisimostitext,PlayerInfo[targetid][pNarcoLomka]);
		strcat(sctring,str);
		format(str,sizeof(str),"\t{ffffff}Наркотики при себе: \t\t\t{ffffff}%d \n",PlayerInfo[targetid][pDrugs]);
		strcat(sctring,str);
		format(str,sizeof(str),"\t{ffffff}Материалы при себе: \t\t{ffffff}%d \n",PlayerInfo[targetid][pMats]);
		strcat(sctring,str);
		format(str,sizeof(str),"\t{ffffff}Отмычек при себе: \t\t\t{ffffff}%d \n",otmi);
		strcat(sctring,str);
		format(str,sizeof(str),"\t{ffffff}Веревок при себе: \t\t\t{ffffff}%d \n",tiee);
		strcat(sctring,str);
		format(str,sizeof(str),"{9ACD32}_______________________________________________________________\n\n");
		strcat(sctring,str);
		format(str,sizeof(str),"\t{ffffff}Часов в игре: \t\t\t\t{ffffff}%d \n",PayDayHad);
		strcat(sctring,str);
		format(str,sizeof(str),"\t{ffffff}Работа: \t\t\t\t{ffffff}%s \n",jtext);
		strcat(sctring,str);
		format(str,sizeof(str),"\t{ffffff}Организация: \t\t\t\t{ffffff}%s \n",GetPlayerFracName(targetid));
		strcat(sctring,str);
		format(str,sizeof(str),"\t{ffffff}Ранг: \t\t\t\t\t{ffffff}%s \n\n",GetPlayerRank(targetid)); ///
		strcat(sctring,str);
		format(str,sizeof(str),"\t{ffffff}Денег: \t\t\t\t{ffffff}%d{FFFF00}$ \n",PlayerInfo[targetid][pCash]);
		strcat(sctring,str);
		format(str,sizeof(str),"\t{ffffff}В банке: \t\t\t\t{ffffff}%d{FFFF00}$ \n",PlayerInfo[targetid][pBank]);
		strcat(sctring,str);
		format(str,sizeof(str),"\t{ffffff}Donate Coin: \t\t\t\t{ffffff}%d{FFFF00} \n\n",PlayerInfo[targetid][pDonatemoney2]);
		strcat(sctring,str);
		format(str,sizeof(str),"\t{ffffff}Телефон: \t\t\t\t{ffffff}%d \n",PlayerInfo[targetid][pPnumber]);
		strcat(sctring,str);
		format(str,sizeof(str),"\t{ffffff}На счету телефона: \t\t\t{ffffff}%d \n", PlayerInfo[playerid][pMobile]); strcat(sctring,str);
		format(str,sizeof(str),"\n\n\t\t\t{FF0000}WHISPER - ROLE PLAY    \n");
		strcat(sctring,str);
		format(str,sizeof(str),"{9ACD32}_______________________________________________________________\n");
		strcat(sctring,str);
		new lol[256];
		format(lol,sizeof(lol),"{33AA33}Статистика игрового аккаунта:{ffffff} %s ",PlayerInfo[targetid][pName]);
		ShowPlayerDialog(playerid,1932,0,lol,sctring,"Ок","");
	}
}
stock SetPlayerToTeamColor(playerid)//ЦВЕТА Фракциям
{
	switch(PlayerInfo[playerid][pMember])
	{
	case 0:	SetPlayerColor(playerid, 0xFFFFFF20);
	case 1: SetPlayerColor(playerid, COLOR_DBLUE);
	case 2: SetPlayerColor(playerid, 0x313131AA);
	case 3: SetPlayerColor(playerid, COLOR_GREEN);
	case 4: SetPlayerColor(playerid, 0xA52A2AFF);
	case 5: SetPlayerColor(playerid, 0xDDA701FF);
	case 6: SetPlayerColor(playerid, COLOR_REDD);
	case 7: SetPlayerColor(playerid, 0x114D71FF);
	case 8: SetPlayerColor(playerid, 0xB313E7FF);
	case 10: SetPlayerColor(playerid, COLOR_DBLUE);
	case 11: SetPlayerColor(playerid, 0x139BECFF);
	case 12: SetPlayerColor(playerid, 0x8813E7FF);
	case 13: SetPlayerColor(playerid, 0xDBD604AA);
	case 14: SetPlayerColor(playerid, COLOR_GRAD1);
	case 15: SetPlayerColor(playerid, 0x009F00AA);
	case 16: SetPlayerColor(playerid, 0x40848BAA);
	case 17: SetPlayerColor(playerid, TEAM_AZTECAS_COLOR);
	case 18: SetPlayerColor(playerid, 0x83BFBFAA);
	case 19: SetPlayerColor(playerid, COLOR_GREEN);
	case 21: SetPlayerColor(playerid, COLOR_DBLUE);
	case 23: SetPlayerColor(playerid, 0x708090FF);
	case 24: SetPlayerColor(playerid, 0xF45000FF);
	case 25: SetPlayerColor(playerid, 0x2E8B57FF);
	case 26: SetPlayerColor(playerid, 0x708090AA);
	case 27: SetPlayerColor(playerid, 0xFF0000AA);
	}
	return true;
}
public OnGameModeExit()
{
	mysql_format(dbHandle, QUERY, sizeof(QUERY), "UPDATE `"TABLE_ACCOUNT"` SET `pOnline` = '1001'");
	mysql_function_query(dbHandle, QUERY, false, "", "");
	PlayerForeach(i)
	{
		if(IsPlayerConnected(i)) OnPlayerUpdateRL(i),IsConnected{i} = 0;
	}
	TextDrawDestroy(RedTeam);
	TextDrawDestroy(BlueTeam);
	mysql_close();
	return true;
}
publics: LoadProperty()
{
	static rows, fields;
	cache_get_data(rows, fields);
	new temp[64],i=0;
	if(rows)
	{
		for(new he = 0;he < rows; he++)
		{
			cache_get_row(he, 0, temp), HomeInfo[he][hID] = strval(temp);
			cache_get_row(he, 1, temp), HomeInfo[he][hEntrancex] = floatstr(temp);
