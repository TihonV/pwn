	}
	else printf("[ERROR] Дома не загружены.");
	return true;
}
publics: LoadBizz()
{
	static rows, fields;
	cache_get_data(rows, fields);
	new temp[64],string2[300],i=0;
	if(rows)
	{
		for(new he = 0;he < rows; he++)
		{
			cache_get_row(he, 0, temp), Business[he][bID] = strval(temp);
			cache_get_row(he, 1, temp), Business[he][bOwned] = strval(temp);
			cache_get_row(he, 2, temp), strmid(Business[he][bOwner], temp, 0, strlen(temp), 255);
			cache_get_row(he, 3, temp), strmid(Business[he][bMessage], temp, 0, strlen(temp), 255);
			cache_get_row(he, 4, temp), strmid(Business[he][bExtortion], temp, 0, strlen(temp), 255);
			cache_get_row(he, 5, temp), Business[he][bEntranceX] = floatstr(temp);
			cache_get_row(he, 6, temp), Business[he][bEntranceY] = floatstr(temp);
			cache_get_row(he, 7, temp), Business[he][bEntranceZ] = floatstr(temp);
			cache_get_row(he, 8, temp), Business[he][bExitX] = floatstr(temp);
			cache_get_row(he, 9, temp), Business[he][bExitY] = floatstr(temp);
			cache_get_row(he, 10, temp), Business[he][bExitZ] = floatstr(temp);
			cache_get_row(he, 11, temp), Business[he][bBuyPrice] = strval(temp);
			cache_get_row(he, 12, temp), Business[he][bEntranceCost] = strval(temp);
			cache_get_row(he, 13, temp), Business[he][bTill] = strval(temp);
			cache_get_row(he, 14, temp), Business[he][bLocked] = strval(temp);
			cache_get_row(he, 15, temp), Business[he][bInterior] = strval(temp);
			cache_get_row(he, 16, temp), Business[he][bProducts] = strval(temp);
			cache_get_row(he, 17, temp), Business[he][bMaxProducts] = strval(temp);
			cache_get_row(he, 18, temp), Business[he][bPriceProd] = strval(temp);
			cache_get_row(he, 19, temp), Business[he][b2Till] = strval(temp);
			cache_get_row(he, 20, temp), Business[he][bCena] = strval(temp);
			cache_get_row(he, 21, temp), Business[he][bBarX] = floatstr(temp);
			cache_get_row(he, 22, temp), Business[he][bBarY] = floatstr(temp);
			cache_get_row(he, 23, temp), Business[he][bBarZ] = floatstr(temp);
			cache_get_row(he, 24, temp), Business[he][bMafia] = strval(temp);
			cache_get_row(he, 25, temp), Business[he][bVirtual] = strval(temp);
			i++;
			if(Business[he][bOwned] == 0)
			{
				format(string2, sizeof(string2), "{00FF32}Цена:{FEFEFE} %d\n{F5FF00}Бизнес продаётся\nДля покупки нажмите клавишу 'L.ALT'",Business[he][bBuyPrice]);
				Business[he][bLocked] = 1;
				Business[he][bLabel] = Create3DTextLabel(string2,COLOR_YELLOW,Business[he][bEntranceX], Business[he][bEntranceY], Business[he][bEntranceZ],20.0,0,1);
				Business[he][bPickupV] = AddStaticPickup(19132, 23, Business[he][bEntranceX], Business[he][bEntranceY], Business[he][bEntranceZ]);
				Business[he][bPickupE] = AddStaticPickup(1318, 23, Business[he][bExitX], Business[he][bExitY], Business[he][bExitZ], Business[he][bVirtual]);
			}
			else if(Business[he][bOwned] == 1)
			{
				format(string2,sizeof(string2), "%s\nВладелец:\n %s\nДля входа нажмите клавишу\nL.ALT", Business[he][bMessage], Business[he][bOwner]);
				Business[he][bLabel] = Create3DTextLabel(string2,TEAM_GROVE_COLOR,Business[he][bEntranceX], Business[he][bEntranceY], Business[he][bEntranceZ],20.0,0,1);
				Business[he][bPickupV] = AddStaticPickup(19132, 23, Business[he][bEntranceX], Business[he][bEntranceY], Business[he][bEntranceZ]);
				Business[he][bPickupE] = AddStaticPickup(1318, 23, Business[he][bExitX], Business[he][bExitY], Business[he][bExitZ], Business[he][bVirtual]);
			}
			else
			{
				Business[he][bOwned] = 1;
				format(string2,sizeof(string2), "%s\nВладелец:\n %s\nДля входа нажмите клавишу\nL.ALT", Business[he][bMessage], Business[he][bOwner]);
				Business[he][bLabel] = Create3DTextLabel(string2,TEAM_GROVE_COLOR,Business[he][bEntranceX], Business[he][bEntranceY], Business[he][bEntranceZ],20.0,0,1);
				Business[he][bPickupV] = AddStaticPickup(19132, 23, Business[he][bEntranceX], Business[he][bEntranceY], Business[he][bEntranceZ]);
				Business[he][bPickupE] = AddStaticPickup(1318, 23, Business[he][bExitX], Business[he][bExitY], Business[he][bExitZ], Business[he][bVirtual]);
			}
		}
		for(new h = 0; h < sizeof(Business); h++) Create3DTextLabel("24/7\nДля приобретения продуктов\nИспользуйте клавишу 'L.ALT'", COLOR_YELLOW,Business[h][bBarX],Business[h][bBarY],Business[h][bBarZ],18.0, 0), Create3DTextLabel("Для выхода используйте клавишу\nL.ALT", COLOR_YELLOW, Business[h][bExitX], Business[h][bExitY], Business[h][bExitZ], 18.0, 0);
		printf("[ %d ] Бизнесы успешно загружены.",i);
	}
	else printf("[ERROR] Бизнесов не загружены.");
	return true;
}
